# FUNGSI MENAMPILKAN MENU PILIHAN VOICE GEMINI DENGAN PAGINATION (30 VOICE VALID + GENDER)
show_gemini_voice_menu() {
    local chat_id="$1"
    local message_id="$2"
    local page="${3:-1}"  # Halaman saat ini, default 1
    
    load_uci_config
    local current_voice="$SOUND_GEMINI_VOICE"
    
    # ============ VOICE GEMINI VALID (30 VOICE - BERDASARKAN DOKUMENTASI) ============
    # Format: "value" "display_name" "deskripsi_singkat" "gender"
    local all_voices=(
        # Voice Pria (16)
        "Puck" "Puck" "Upbeat - Bersemangat" "♂️ Pria"
        "Charon" "Charon" "Informative - Informatif" "♂️ Pria"
        "Fenrir" "Fenrir" "Excitable - Bersemangat" "♂️ Pria"
        "Achird" "Achird" "Friendly - Ramah" "♂️ Pria"
        "Zubenelgenubi" "Zubenelgenubi" "Casual - Santai" "♂️ Pria"
        "Algieba" "Algieba" "Smooth - Halus" "♂️ Pria"
        "Alnilam" "Alnilam" "Firm - Tegas" "♂️ Pria"
        "Orus" "Orus" "Firm - Tegas" "♂️ Pria"
        "Enceladus" "Enceladus" "Breathy - Berhembus" "♂️ Pria"
        "Iapetus" "Iapetus" "Clear - Jelas" "♂️ Pria"
        "Umbriel" "Umbriel" "Easy-going - Santai" "♂️ Pria"
        "Algenib" "Algenib" "Gravelly - Berat" "♂️ Pria"
        "Rasalgethi" "Rasalgethi" "Informative - Informatif" "♂️ Pria"
        "Schedar" "Schedar" "Even - Tenang/Stabil" "♂️ Pria"
        "Sadachbia" "Sadachbia" "Lively - Ceria" "♂️ Pria"
        "Sadaltager" "Sadaltager" "Knowledgeable - Berpengetahuan" "♂️ Pria"
        
        # Voice Wanita (14)
        "Zephyr" "Zephyr" "Bright - Cerah" "♀️ Wanita"
        "Kore" "Kore" "Firm - Tegas" "♀️ Wanita"
        "Leda" "Leda" "Youthful - Muda" "♀️ Wanita"
        "Aoede" "Aoede" "Breezy - Ringan" "♀️ Wanita"
        "Callirrhoe" "Callirrhoe" "Easy-going - Santai" "♀️ Wanita"
        "Autonoe" "Autonoe" "Bright - Cerah" "♀️ Wanita"
        "Despina" "Despina" "Smooth - Halus" "♀️ Wanita"
        "Erinome" "Erinome" "Clear - Jelas" "♀️ Wanita"
        "Gacrux" "Gacrux" "Mature - Dewasa/Berwibawa" "♀️ Wanita"
        "Laomedeia" "Laomedeia" "Upbeat - Bersemangat" "♀️ Wanita"
        "Achernar" "Achernar" "Soft - Lembut" "♀️ Wanita"
        "Pulcherrima" "Pulcherrima" "Forward - Tegas/Maju" "♀️ Wanita"
        "Vindemiatrix" "Vindemiatrix" "Gentle - Lembut" "♀️ Wanita"
        "Sulafat" "Sulafat" "Warm - Hangat" "♀️ Wanita"
    )
    
    local total_voices=$((${#all_voices[@]} / 4))  # 4 elemen per voice (value, name, desc, gender)
    local total_pages=$(( (total_voices + VOICES_PER_PAGE - 1) / VOICES_PER_PAGE ))
    
    # Validasi halaman
    if [ "$page" -gt "$total_pages" ]; then
        page=$total_pages
    fi
    if [ "$page" -lt 1 ]; then
        page=1
    fi
    
    # Hitung indeks awal dan akhir (setiap voice 4 elemen)
    local start_idx=$(( (page - 1) * VOICES_PER_PAGE * 4 ))
    local end_idx=$(( start_idx + (VOICES_PER_PAGE * 4) - 1 ))
    [ "$end_idx" -ge "$((total_voices * 4 - 1))" ] && end_idx=$((total_voices * 4 - 1))
    
    log "📄 Menampilkan voice Gemini halaman $page/$total_pages (total $total_voices voice valid)"
    
    # ============ MEMBANGUN KEYBOARD ============
    local keyboard='['
    local row_items=""
    local item_count=0
    
    for ((i=start_idx; i<=end_idx; i+=4)); do
        local voice_value="${all_voices[$i]}"
        local voice_name="${all_voices[$((i+1))]}"
        local voice_desc="${all_voices[$((i+2))]}"
        local voice_gender="${all_voices[$((i+3))]}"
        
        # Tentukan emoji berdasarkan gender dan karakter
        local voice_emoji="🎤"
        if [[ "$voice_gender" == *"Pria"* ]]; then
            case "$voice_value" in
                Puck|Fenrir|Laomedeia|Sadachbia) voice_emoji="👨‍🎤" ;;  # Pria bersemangat
                Charon|Rasalgethi|Sadaltager) voice_emoji="👨‍🏫" ;;     # Pria informatif
                Alnilam|Orus) voice_emoji="👨‍💼" ;;                     # Pria tegas
                Algieba|Despina) voice_emoji="👨‍🎨" ;;                   # Pria halus
                Enceladus) voice_emoji="👨‍🌪️" ;;                        # Pria berhembus
                Iapetus|Schedar) voice_emoji="👨‍⚖️" ;;                   # Pria jelas/tenang
                Algenib) voice_emoji="👨‍🏋️" ;;                          # Pria berat
                Achird) voice_emoji="👨‍👧" ;;                           # Pria ramah
                Zubenelgenubi|Umbriel) voice_emoji="👨‍🕶️" ;;            # Pria santai
                *) voice_emoji="👨" ;;
            esac
        else
            case "$voice_value" in
                Zephyr|Autonoe) voice_emoji="👩‍✨" ;;                    # Wanita cerah
                Leda|Aoede) voice_emoji="👩‍🌸" ;;                        # Wanita muda
                Kore|Gacrux) voice_emoji="👩‍💼" ;;                       # Wanita tegas/dewasa
                Sulafat) voice_emoji="👩‍🌞" ;;                           # Wanita hangat
                Achernar|Vindemiatrix) voice_emoji="👩‍🍃" ;;             # Wanita lembut
                Callirrhoe) voice_emoji="👩‍😊" ;;                        # Wanita santai
                Despina) voice_emoji="👩‍🎨" ;;                           # Wanita halus
                Erinome) voice_emoji="👩‍⚖️" ;;                           # Wanita jelas
                Laomedeia) voice_emoji="👩‍🎤" ;;                         # Wanita bersemangat
                Pulcherrima) voice_emoji="👩‍🌟" ;;                       # Wanita tegas
                *) voice_emoji="👩" ;;
            esac
        fi
        
        # Tentukan teks tombol
        local display_text="${voice_emoji} ${voice_name}"
        [ "$current_voice" = "$voice_value" ] && display_text="${display_text} ✅"
        
        # Callback data
        local callback_data="gemini_voice_${voice_value}"
        
        # Tambahkan ke row (2 tombol per baris)
        if [ $((item_count % 2)) -eq 0 ]; then
            if [ -n "$row_items" ]; then
                keyboard="${keyboard}[${row_items}],"
            fi
            row_items="{\"text\":\"${display_text}\",\"callback_data\":\"${callback_data}\"}"
        else
            row_items="${row_items},{\"text\":\"${display_text}\",\"callback_data\":\"${callback_data}\"}"
        fi
        item_count=$((item_count + 1))
    done
    
    # Tambahkan baris terakhir jika ada
    if [ -n "$row_items" ]; then
        keyboard="${keyboard}[${row_items}],"
    fi
    
    # ============ BARIS PAGINATION ============
    keyboard="${keyboard}["
    local pagination_items=""
    
    # Tombol Previous
    if [ "$page" -gt 1 ]; then
        pagination_items="{\"text\":\"◀️ Sebelumnya\",\"callback_data\":\"gemini_voice_page_$((page - 1))\"}"
    fi
    
    # Informasi halaman
    local page_info="{\"text\":\"📄 $page/$total_pages\",\"callback_data\":\"gemini_voice_page_info\"}"
    if [ -n "$pagination_items" ]; then
        pagination_items="${pagination_items},${page_info}"
    else
        pagination_items="$page_info"
    fi
    
    # Tombol Next
    if [ "$page" -lt "$total_pages" ]; then
        if [ -n "$pagination_items" ]; then
            pagination_items="${pagination_items},{\"text\":\"▶️ Selanjutnya\",\"callback_data\":\"gemini_voice_page_$((page + 1))\"}"
        else
            pagination_items="{\"text\":\"▶️ Selanjutnya\",\"callback_data\":\"gemini_voice_page_$((page + 1))\"}"
        fi
    fi
    
    keyboard="${keyboard}${pagination_items}],"
    
    # ============ BARIS TOMBOL KEMBALI ============
    keyboard="${keyboard}[{\"text\":\"⬅️ Kembali ke Menu Gemini\",\"callback_data\":\"gemini_config_menu\"}]"
    keyboard="${keyboard}]"
    
    # ============ MEMBANGUN PESAN (TANPA MASALAH PARSING) ============
    
    # Header pesan
    local message="🎤 PILIH VOICE GEMINI (Halaman $page dari $total_pages)

Voice Saat Ini: $current_voice
Total Voice Tersedia: $total_voices voice (30 voice resmi)
Menampilkan voice ke-$(((page-1)*VOICES_PER_PAGE+1)) s/d $(((page-1)*VOICES_PER_PAGE+item_count))

📋 Daftar Voice:
"
    
    # Bangun daftar voice dengan newline yang benar (bukan literal \n)
    for ((i=start_idx; i<=end_idx; i+=4)); do
        local voice_value="${all_voices[$i]}"
        local voice_name="${all_voices[$((i+1))]}"
        local voice_desc="${all_voices[$((i+2))]}"
        local voice_gender="${all_voices[$((i+3))]}"
        local checkmark=""
        [ "$current_voice" = "$voice_value" ] && checkmark=" ✅"
        
        # Tambahkan ke pesan dengan newline yang benar
        message="${message}• ${voice_name}: ${voice_desc} (${voice_gender})${checkmark}
"
    done
    
    # Footer pesan
    message="${message}
📊 Statistik Gender:
• 👨 Pria: 16 voice
• 👩 Wanita: 14 voice

💡 Tips:
• Pilih voice yang sesuai dengan karakter suara yang diinginkan
• Ikon 👨 menandakan voice pria, 👩 menandakan voice wanita
• Gunakan tombol navigasi untuk melihat voice lainnya
• Tanda ✅ menunjukkan voice yang sedang dipilih"
    
    # Kirim atau edit pesan
    if [ -z "$message_id" ]; then
        curl -s -X POST \
            "https://api.telegram.org/bot${TELEGRAM_TOKEN}/sendMessage" \
            -d chat_id="${chat_id}" \
            --data-urlencode "text=${message}" \
            -d reply_markup="{\"inline_keyboard\":${keyboard}}" \
            > /dev/null 2>&1
    else
        curl -s -X POST \
            "https://api.telegram.org/bot${TELEGRAM_TOKEN}/editMessageText" \
            -d chat_id="${chat_id}" \
            -d message_id="${message_id}" \
            --data-urlencode "text=${message}" \
            -d reply_markup="{\"inline_keyboard\":${keyboard}}" \
            > /dev/null 2>&1
    fi
    
    log "✅ Menampilkan voice Gemini halaman $page/$total_pages (voice $(((page-1)*VOICES_PER_PAGE+1))-$(((page-1)*VOICES_PER_PAGE+item_count)) dari $total_voices)"
}

# FUNGSI MENGATUR VOICE GEMINI
set_gemini_voice() {
    local chat_id="$1"
    local message_id="$2"
    local voice="$3"
    
    uci set jsholat.sound.gemini_voice="$voice"
    uci commit jsholat
    
    # Update variabel config
    SOUND_GEMINI_VOICE="$voice"
    
    # Kembali ke menu voice
    show_gemini_voice_menu "$chat_id" "$message_id"
    
    log "🎤 Voice Gemini diatur ke $voice untuk chat_id=$chat_id"
}

# FUNGSI MEMINTA API KEY GEMINI
gemini_set_api_key_prompt() {
    local chat_id="$1"
    local message_id="$2"
    
    local message="🔑 *SET API KEY GEMINI*

Masukkan API key Gemini Anda.

*Cara mendapatkannya:*
1. Buka https://aistudio.google.com/app/apikey
2. Login dengan akun Google
3. Klik \"Create API Key\"
4. Salin API key yang diberikan

*Contoh:* AIzaSyB7Xp8...

⚠️ *Catatan:* API key bersifat rahasia. Jangan bagikan ke orang lain.

❌ Ketik / untuk membatalkan."
    
    mkdir -p "/tmp/jsholat_bot_setup"
    echo "waiting_gemini_api_key" > "/tmp/jsholat_bot_setup/${chat_id}.flag"
    
    if [ -n "$message_id" ]; then
        curl -s -X POST \
            "https://api.telegram.org/bot${TELEGRAM_TOKEN}/editMessageText" \
            -d chat_id="${chat_id}" \
            -d message_id="${message_id}" \
            --data-urlencode "text=${message}" \
            -d parse_mode="Markdown" \
            > /dev/null 2>&1
    else
        send_message "$chat_id" "%s" "Markdown" "$message"
    fi
    
    log "🔑 Meminta API key Gemini dari chat_id=$chat_id"
}

# FUNGSI MEMPROSES API KEY GEMINI
gemini_set_api_key_process() {
    local chat_id="$1"
    local api_key="$2"
    
    # Validasi sederhana (API key Google biasanya dimulai dengan AIza)
    if [[ ! "$api_key" =~ ^AIza[0-9A-Za-z_-]{35,}$ ]]; then
        send_message "$chat_id" "❌ *API Key tidak valid!*\n\nAPI key Google biasanya dimulai dengan 'AIza' dan panjang sekitar 39 karakter.\n\nSilakan cek kembali API key Anda." "Markdown"
        rm -f "/tmp/jsholat_bot_setup/${chat_id}.flag"
        return 1
    fi
    
    uci set jsholat.sound.gemini_api_key="$api_key"
    uci commit jsholat
    
    # Update variabel config
    SOUND_GEMINI_API_KEY="$api_key"
    
    send_message "$chat_id" "✅ *API Key Gemini berhasil disimpan!*

Sekarang Anda dapat menggunakan metode TTS Gemini.

Gunakan /settts untuk memilih metode Gemini." "Markdown"
    
    rm -f "/tmp/jsholat_bot_setup/${chat_id}.flag"
    log "✅ API Key Gemini disimpan untuk chat_id=$chat_id"
}

# FUNGSI TEST GEMINI TTS
test_gemini_tts() {
    local chat_id="$1"
    local message_id="$2"
    
    # Edit pesan untuk menunjukkan sedang mempersiapkan
    curl -s -X POST \
        "https://api.telegram.org/bot${TELEGRAM_TOKEN}/editMessageText" \
        -d chat_id="${chat_id}" \
        -d message_id="${message_id}" \
        -d text="🤖 *Mempersiapkan test Gemini TTS...*" \
        -d parse_mode="Markdown" \
        > /dev/null 2>&1
    
    # Ambil konfigurasi
    load_uci_config
    
    local api_key="$SOUND_GEMINI_API_KEY"
    local model="$SOUND_GEMINI_MODEL"
    local voice="$SOUND_GEMINI_VOICE"
    local tts_enabled="$SOUND_REMINDER_SOUND_ENABLED"
    
    if [ "$tts_enabled" = "0" ]; then
        send_message "$chat_id" "❌ Suara TTS dinonaktifkan. Aktifkan terlebih dahulu di menu pengaturan TTS."
        return 1
    fi
    
    if [ -z "$api_key" ]; then
        curl -s -X POST \
            "https://api.telegram.org/bot${TELEGRAM_TOKEN}/editMessageText" \
            -d chat_id="${chat_id}" \
            -d message_id="${message_id}" \
            -d text="❌ *API Key Gemini belum dikonfigurasi!*\n\nSilakan atur API key terlebih dahulu di menu konfigurasi Gemini." \
            -d parse_mode="Markdown" \
            > /dev/null 2>&1
        return 1
    fi
    
    # Update pesan
    curl -s -X POST \
        "https://api.telegram.org/bot${TELEGRAM_TOKEN}/editMessageText" \
        -d chat_id="${chat_id}" \
        -d message_id="${message_id}" \
        -d text="🔊 *Memutar test Gemini TTS dengan voice $voice...*\n\n⏳ Mohon tunggu sekitar 5-10 detik." \
        -d parse_mode="Markdown" \
        > /dev/null 2>&1
    
    # Buat teks test
    local test_text="Ini adalah uji coba suara Teks ke Suara menggunakan Gemini AI TTS dengan voice $voice. Suara ini akan digunakan untuk pengingat waktu sholat."
    
    # Mainkan suara test menggunakan fungsi dari jsholat
    /usr/bin/jsholat tts-test "$test_text" &
    
    # Tunggu sebentar lalu update status
    sleep 5
    
    curl -s -X POST \
        "https://api.telegram.org/bot${TELEGRAM_TOKEN}/editMessageText" \
        -d chat_id="${chat_id}" \
        -d message_id="${message_id}" \
        -d text="✅ *Test Gemini TTS selesai!*

*Voice:* $voice
*Model:* $model

Jika suara tidak terdengar, periksa:
1. 🔊 Volume speaker
2. 🌐 Koneksi internet
3. 🔑 API key yang digunakan
4. 📦 Dependensi sox/ffmpeg untuk konversi audio" \
        -d parse_mode="Markdown" \
        > /dev/null 2>&1
    
    log "🤖 Test Gemini TTS dilakukan dengan voice $voice untuk chat_id=$chat_id"
}

# FUNGSI INFORMASI MODEL GEMINI
show_gemini_model_info() {
    local chat_id="$1"
    local message_id="$2"
    
    load_uci_config
    local current_model="$SOUND_GEMINI_MODEL"
    
    # Tentukan keterangan berdasarkan model saat ini
    local model_desc=""
    case "$current_model" in
        "gemini-2.5-flash-preview-tts")
            model_desc="Model **Flash** dioptimalkan untuk **latensi rendah**, cocok untuk aplikasi sehari-hari yang responsif dengan kualitas suara baik."
            ;;
        "gemini-2.5-pro-preview-tts")
            model_desc="Model **Pro** dioptimalkan untuk **kualitas tertinggi**, ideal untuk konten premium seperti podcast, audiobook, dan narasi profesional."
            ;;
        *)
            model_desc="Model tidak dikenal. Silakan pilih model yang tersedia."
            ;;
    esac
    
    local keyboard='[[
        {"text": "📋 Pilih Model", "callback_data": "gemini_model_menu"}
    ],[
        {"text": "⬅️ Kembali", "callback_data": "gemini_config_menu"}
    ]]'
    
    local message=$(printf '📋 *INFORMASI MODEL GEMINI TTS*

*Model Saat Ini:* `%s`

📝 *Keterangan:* %s

🎤 *Fitur TTS:*
• 30 pilihan voice dengan karakter unik
• Kontrol gaya bicara dengan bahasa alami
• Multi-speaker hingga 2 pembicara
• Deteksi bahasa otomatis (24+ bahasa)
• Ekspresi emosional dan aksen

🔧 *Persyaratan Teknis:*
• Koneksi internet stabil
• API key dari Google AI Studio
• sox atau ffmpeg untuk konversi audio

🌐 *Dokumentasi:*
https://ai.google.dev/gemini-api/docs/speech-generation

💡 *Catatan:* Model dapat diubah melalui menu di bawah.' "$current_model" "$model_desc")
    
    if [ -z "$message_id" ]; then
        send_inline_keyboard "$chat_id" "$message" "$keyboard"
    else
        edit_inline_keyboard "$chat_id" "$message_id" "$message" "$keyboard"
    fi
}

# FUNGSI MENU PEMILIHAN MODEL GEMINI
show_gemini_model_menu() {
    local chat_id="$1"
    local message_id="$2"
    
    load_uci_config
    local current_model="$SOUND_GEMINI_MODEL"
    
    local keyboard='[[
        {"text": "⚡ gemini-2.5-flash-preview-tts (LATENSI RENDAH) '"$( [ "$current_model" = "gemini-2.5-flash-preview-tts" ] && echo "✅" )"'", "callback_data": "set_gemini_model_flash"}
    ],[
        {"text": "✨ gemini-2.5-pro-preview-tts (KUALITAS TERTINGGI) '"$( [ "$current_model" = "gemini-2.5-pro-preview-tts" ] && echo "✅" )"'", "callback_data": "set_gemini_model_pro"}
    ],[
        {"text": "⬅️ Kembali", "callback_data": "gemini_model_info"}
    ]]'
    
    local message=$(printf '🧠 *PILIH MODEL GEMINI TTS*

*Model Saat Ini:* `%s`

📊 *Perbandingan Model:*

⚡ **gemini-2.5-flash-preview-tts**
• Dioptimalkan untuk **latensi rendah**
• Respons cepat (< 3 detik)
• Cocok untuk aplikasi real-time
• Kualitas suara baik
• Ideal untuk penggunaan sehari-hari

✨ **gemini-2.5-pro-preview-tts**
• Dioptimalkan untuk **kualitas tertinggi**
• Output audio premium
• Kontrol gaya lebih presisi
• Cocok untuk podcast, audiobook, konten profesional
• Kualitas suara superior

💡 *Pilih model sesuai kebutuhan:* Flash untuk kecepatan, Pro untuk kualitas terbaik.' "$current_model")
    
    edit_inline_keyboard "$chat_id" "$message_id" "$message" "$keyboard"
}

# FUNGSI SET MODEL GEMINI
set_gemini_model() {
    local chat_id="$1"
    local message_id="$2"
    local model="$3"
    local callback_id="$4"
    
    # Validasi model
    case "$model" in
        "gemini-2.5-flash-preview-tts"|"gemini-2.5-pro-preview-tts")
            # Model valid
            ;;
        *)
            log "ERROR: Model Gemini tidak valid: $model"
            send_message "$chat_id" "❌ *Model tidak valid!*\n\nPilih model yang tersedia." "Markdown"
            return 1
            ;;
    esac
    
    uci set jsholat.sound.gemini_model="$model"
    uci commit jsholat
    
    # Update variabel config
    SOUND_GEMINI_MODEL="$model"
    
    # Konversi ke nama display
    local model_name=""
    case "$model" in
        "gemini-2.5-flash-preview-tts") model_name="Gemini 2.5 Flash Preview" ;;
        "gemini-2.5-pro-preview-tts") model_name="Gemini 2.5 Pro Preview" ;;
    esac
    
    # Kembali ke menu model
    show_gemini_model_menu "$chat_id" "$message_id"
    
    # Kirim notifikasi sukses
    if [ -n "$callback_id" ]; then
        curl -s -X POST \
            "https://api.telegram.org/bot${TELEGRAM_TOKEN}/answerCallbackQuery" \
            -d callback_query_id="${callback_id}" \
            -d text="✅ Model diubah ke ${model_name}" \
            -d show_alert="false" \
            > /dev/null 2>&1
    fi
    
    log "🧠 Model Gemini diatur ke $model untuk chat_id=$chat_id"
}

# Fungsi untuk test TTS
test_tts() {
    local chat_id="$1"
    local message_id="$2"
    
    # Edit pesan untuk menunjukkan sedang mempersiapkan
    curl -s -X POST \
        "https://api.telegram.org/bot${TELEGRAM_TOKEN}/editMessageText" \
        -d chat_id="${chat_id}" \
        -d message_id="${message_id}" \
        -d text="🔊 *Mempersiapkan test TTS...*" \
        -d parse_mode="Markdown" \
        > /dev/null 2>&1
    
    # Ambil konfigurasi
    load_uci_config
    local tts_method="$SOUND_TTS_METHOD"
    local tts_enabled="$SOUND_REMINDER_SOUND_ENABLED"
    
    if [ "$tts_enabled" = "0" ]; then
        send_message "$chat_id" "❌ Suara TTS dinonaktifkan. Aktifkan terlebih dahulu di menu pengaturan TTS."
        return 1
    fi
    
    # Buat teks test berdasarkan metode
    local test_text=""
    local test_method_name=""
    local voice_info=""
    
    case "$tts_method" in
        "google")
            test_text="Ini adalah uji coba suara Teks ke Suara menggunakan Google Translate. Suara ini akan digunakan untuk pengingat waktu sholat."
            test_method_name="Google Translate"
            ;;
		"edge")
			local edge_voice=$(uci -q get jsholat.sound.edge_voice || echo "id-ID-ArdiNeural")
			local voice_name=""
			local voice_emoji=""
			
			case "$edge_voice" in
				"id-ID-ArdiNeural")
					voice_name="Ardi (Indonesia-Pria)"
					voice_emoji="🗣️"
					;;
				"id-ID-GadisNeural")
					voice_name="Gadis (Indonesia-Wanita)"
					voice_emoji="👩"
					;;
				"jv-ID-DimasNeural")
					voice_name="Dimas (Jawa-Pria)"
					voice_emoji="👨‍🦰"
					;;
				"jv-ID-SitiNeural")
					voice_name="Siti (Jawa-Wanita)"
					voice_emoji="👩‍🦰"
					;;
			esac
			
			test_text="Ini adalah uji coba suara Teks ke Suara menggunakan Edge-TTS dengan voice $voice_name. Suara ini akan digunakan untuk pengingat waktu sholat."
			test_method_name="Edge-TTS"
			voice_info="$voice_emoji Voice: $voice_name"
			;;
        "espeak")
            test_text="Ini adalah uji coba suara Teks ke Suara menggunakan eSpeak. Suara ini akan digunakan untuk pengingat waktu sholat."
            test_method_name="eSpeak"
            ;;
        "murf")
            test_text="Ini adalah uji coba suara Teks ke Suara menggunakan Murf.ai. Suara ini akan digunakan untuk pengingat waktu sholat."
            test_method_name="Murf.ai"
            ;;
        "gemini")
            # Ambil konfigurasi Gemini
            local gemini_voice=$(uci -q get jsholat.sound.gemini_voice || echo "Leda")
            local gemini_model=$(uci -q get jsholat.sound.gemini_model || echo "gemini-2.5-flash-preview-tts")
            
            test_text="Ini adalah uji coba suara Teks ke Suara menggunakan Gemini AI TTS dengan voice $gemini_voice. Suara ini akan digunakan untuk pengingat waktu sholat."
            test_method_name="Gemini AI"
            voice_info=" (Voice: $gemini_voice, Model: $gemini_model)"
            ;;
        *)
            test_text="Ini adalah uji coba suara Teks ke Suara. Suara ini akan digunakan untuk pengingat waktu sholat."
            test_method_name="$tts_method"
            ;;
    esac
    
    # Edit pesan untuk menunjukkan sedang memainkan
    curl -s -X POST \
        "https://api.telegram.org/bot${TELEGRAM_TOKEN}/editMessageText" \
        -d chat_id="${chat_id}" \
        -d message_id="${message_id}" \
        -d text="🔊 *Memutar test TTS dengan metode $test_method_name${voice_info}...*" \
        -d parse_mode="Markdown" \
        > /dev/null 2>&1
    
    # Panggil fungsi play_tts_reminder dengan parameter yang sesuai
    # Parameter: salat_name, prayer_time, reminder_mins, timezone, lokasi, custom_text
    play_tts_reminder "Test" "12:00" "5" "WIB" "Test Location" "$test_text" &
    
    # Tunggu sebentar (3 detik) untuk memberi kesempatan audio mulai diputar
    sleep 3
    
    # Siapkan pesan hasil
    local result_message="✅ *Test TTS selesai dengan metode $test_method_name*${voice_info}

Jika suara tidak terdengar, periksa:"

    # Tambahkan catatan khusus berdasarkan metode
    case "$tts_method" in
        "google")
            result_message="${result_message}
1. 🔊 Volume speaker
2. 🌐 Koneksi internet (diperlukan untuk Google TTS)
3. 📦 Dependensi: wget, madplay/mpg123"
            ;;
        "edge")
            result_message="${result_message}
1. 🔊 Volume speaker
2. 🌐 Koneksi internet (diperlukan untuk Edge-TTS)
3. 📦 Dependensi: edge-tts (pip install edge-tts)"
            ;;
        "espeak")
            result_message="${result_message}
1. 🔊 Volume speaker
2. 📦 Dependensi: espeak, aplay (opkg install espeak alsa-utils)"
            ;;
        "murf")
            result_message="${result_message}
1. 🔊 Volume speaker
2. 🌐 Koneksi internet (diperlukan untuk Murf.ai)
3. 🔑 API key Murf.ai (periksa konfigurasi)
4. 💳 Pastikan saldo/kredit mencukupi"
            ;;
        "gemini")
            result_message="${result_message}
1. 🔊 Volume speaker
2. 🌐 Koneksi internet (diperlukan untuk Gemini API)
3. 🔑 API key Gemini (periksa konfigurasi di Google AI Studio)
4. 🎤 Voice yang digunakan: $(uci -q get jsholat.sound.gemini_voice || echo "Leda")
5. 📦 Dependensi: sox atau ffmpeg untuk konversi audio"
            ;;
        *)
            result_message="${result_message}
1. 🔊 Volume speaker
2. 🌐 Koneksi internet (jika diperlukan)
3. 📦 Dependensi yang sesuai"
            ;;
    esac
    
    curl -s -X POST \
        "https://api.telegram.org/bot${TELEGRAM_TOKEN}/editMessageText" \
        -d chat_id="${chat_id}" \
        -d message_id="${message_id}" \
        -d text="$result_message" \
        -d parse_mode="Markdown" \
        > /dev/null 2>&1
    
    log "✅ Test TTS dilakukan dengan metode $tts_method untuk chat_id=$chat_id${voice_info}"
}

# Fungsi untuk memutar suara reminder dari berbagai sumber TTS
play_tts_reminder() {
    local salat_name="$1"
    local prayer_time="$2"
    local reminder_mins="$3"
    local timezone="$4"
    local lokasi="$5"
	local custom_text="${6:-}"
    
    # Buat teks untuk TTS
    local tts_text=""
    if [ "$salat_name" = "Test" ]; then
		if [ -n "$custom_text" ]; then
			tts_text="$custom_text"  
		else
			tts_text="Ini adalah test suara TTS. Suara ini akan digunakan untuk pengingat waktu sholat."
		fi
    elif [ "$salat_name" = "Imsyak" ]; then
        tts_text="Pengumuman. Sebentar lagi pada pukul $prayer_time $timezone akan memasuki waktu imsyak untuk wilayah $lokasi dan sekitarnya. Segera persiapkan diri."
    else
        tts_text="Pengumuman. Sebentar lagi pada pukul $prayer_time $timezone akan memasuki waktu sholat $salat_name untuk wilayah $lokasi dan sekitarnya. Segera persiapkan diri untuk sholat."
    fi
    
    # Panggil script jsholat untuk memutar TTS
    /usr/bin/jsholat tts-test "$tts_text" &
}

# FUNGSI UNTUK HUMANIZE METODE TTS
humanize_tts_method() {
    local method="$1"
    
    case "$method" in
        "google") echo "Google Translate" ;;
        "edge") echo "Edge-TTS (Microsoft)" ;;
        "espeak") echo "eSpeak (Offline)" ;;
        "murf") echo "Murf.ai" ;;
        "gemini") echo "Gemini AI (Google)" ;;
        *) echo "$method" ;;
    esac
}

# FUNGSI ALARM SAHUR UNTUK BOT
handle_sahur_alarm() {
    local chat_id="$1"
    local message_id="$2"
    local action="$3"  # "test" atau "status"
    
    load_uci_config
    
    local sahur_enabled="$SOUND_SAHUR_ENABLED"
    local sahur_time="$SOUND_SAHUR_TIME"
    local timezone="$SCHEDULE_TIMEZONE"
    local lokasi="$SCHEDULE_CITY_LABEL"
    local province="$SCHEDULE_PROVINCE"
    
    local tts_method="$SOUND_TTS_METHOD"
    local volume_level="$SOUND_VOLUME_LEVEL"
    local repeat_count="$SOUND_REMINDER_REPEAT_COUNT"
    local repeat_interval="$SOUND_REMINDER_REPEAT_INTERVAL"
    
    local tts_method_name=$(humanize_tts_method "$tts_method")
    
    # Format lokasi lengkap
    local lokasi_text="$lokasi"
    [ -n "$province" ] && lokasi_text="$lokasi, $province"
    
    # Format waktu untuk humanize
    local hour=$(echo $sahur_time | cut -d':' -f1 | sed 's/^0//')
    local minute=$(echo $sahur_time | cut -d':' -f2 | sed 's/^0//')
    
    local humanized_time=""
    if [ "$minute" = "0" ] || [ "$minute" = "00" ]; then
        humanized_time="jam $hour tepat"
    else
        minute=${minute#0}
        humanized_time="jam $hour lewat $minute menit"
    fi
    
    local humanized_timezone="$timezone"
    case "$timezone" in
        "WIB") humanized_timezone="Waktu Indonesia Barat" ;;
        "WITA") humanized_timezone="Waktu Indonesia Tengah" ;;
        "WIT") humanized_timezone="Waktu Indonesia Timur" ;;
    esac
    
    if [ "$action" = "test" ]; then
        # ✅ BACA TEKS CUSTOM
        local template_text=$(get_sahur_reminder_text)
        
        # Format teks dengan placeholder
        local formatted_text=$(format_sahur_reminder \
            "$template_text" \
            "$humanized_time" \
            "$humanized_timezone" \
            "$lokasi_text")
        
        # Teks untuk preview di bot
        local preview_text="🔊 *TEST ALARM SAHUR*

⏰ Waktu Sahur: $sahur_time $timezone
📍 Wilayah: $lokasi, $province

🌙 *Pesan yang akan diucapkan:* 
\"$formatted_text\"

🎵 *Catatan:* 
• Suara akan diputar menggunakan metode TTS: *$tts_method_name*
• Pengulangan suara: *${repeat_count}x* (interval ${repeat_interval} detik)
• Alarm hanya aktif saat Ramadhan
• Volume: ${volume_level}%"
        
        if [ -n "$message_id" ]; then
            edit_inline_keyboard "$chat_id" "$message_id" "$preview_text" '[[{"text":"⬅️ Kembali","callback_data":"sahur_menu"}]]'
        else
            send_inline_keyboard "$chat_id" "$preview_text" '[[{"text":"⬅️ Kembali","callback_data":"sahur_menu"}]]'
        fi
        
        # Kirim teks yang sudah diformat ke service
        /usr/bin/jsholat tts-test "$formatted_text" &
        
        log "🔊 Test alarm sahur untuk chat_id=$chat_id dengan teks custom"
        
    elif [ "$action" = "status" ]; then
        # ✅ BACA TEKS CUSTOM UNTUK PREVIEW DI STATUS
        local template_text=$(get_sahur_reminder_text)
        local preview_example=$(format_sahur_reminder \
            "$template_text" \
            "$humanized_time" \
            "$humanized_timezone" \
            "$lokasi_text")
        
        local status_text=$(printf '🌙 *PENGATURAN ALARM SAHUR*

*Status:* %s
*Waktu Sahur:* %s %s
*Lokasi:* %s

📝 *Keterangan:*
• Alarm hanya aktif saat BULAN RAMADHAN
• Metode TTS: *%s*
• Volume suara: *%s%%*
• Pengulangan: *%sx* (interval %s detik)
• Teks Custom: %s

💡 *Fitur:*
• Pengingat untuk bangun sahur
• Pesan nuansa Ramadhan
• Notifikasi Telegram otomatis

🔊 *Contoh ucapan dengan teks custom:* 
\"%s\"' \
"$([ "$sahur_enabled" = "1" ] && echo "🟢 AKTIF" || echo "🔴 NONAKTIF")" \
"$sahur_time" "$timezone" "$lokasi_text" \
"$tts_method_name" "$volume_level" "$repeat_count" "$repeat_interval" \
"$([ -f "$SAHUR_REMINDER_FILE" ] && echo "✅ Aktif" || echo "❌ Default")" \
"$preview_example")
        
        if [ -n "$message_id" ]; then
            edit_inline_keyboard "$chat_id" "$message_id" "$status_text" '[[{"text":"⬅️ Kembali","callback_data":"sahur_menu"}]]'
        else
            send_inline_keyboard "$chat_id" "$status_text" '[[{"text":"⬅️ Kembali","callback_data":"sahur_menu"}]]'
        fi
        
        log "📊 Status alarm sahur ditampilkan untuk chat_id=$chat_id"
    fi
}

# FUNGSI MENU PENGATURAN SAHUR
show_sahur_menu() {
    local chat_id="$1"
    local message_id="$2"
    
    load_uci_config
    
    local sahur_enabled="$SOUND_SAHUR_ENABLED"
    local sahur_time="$SOUND_SAHUR_TIME"
    local timezone="$SCHEDULE_TIMEZONE"
    
    local tts_method="$SOUND_TTS_METHOD"
    local volume_level="$SOUND_VOLUME_LEVEL"
    local repeat_count="$SOUND_REMINDER_REPEAT_COUNT"
    local repeat_interval="$SOUND_REMINDER_REPEAT_INTERVAL"
    
    local tts_method_name=$(humanize_tts_method "$tts_method")
    
    # Cek status Ramadhan
    local ramadhan_status=""
    if is_ramadhan; then
        ramadhan_status="🌙 *SEDANG RAMADHAN* - Alarm akan aktif"
    else
        ramadhan_status="📅 *BUKAN RAMADHAN* - Alarm tidak aktif (otomatis)"
    fi
    
    # ✅ TAMBAHKAN TOMBOL UNTUK PENGATURAN TEKS
    local keyboard='[[
        {"text": "'"$( [ "$sahur_enabled" = "1" ] && echo "🔴 Nonaktifkan" || echo "🟢 Aktifkan")"' Alarm", "callback_data": "toggle_sahur"}
    ],[
        {"text": "⏰ Atur Waktu: '"$sahur_time"'", "callback_data": "sahur_set_time"}
    ],[
        {"text": "📝 Atur Teks Pengingat", "callback_data": "sahur_text_menu"}
    ],[
        {"text": "🎧 Test Suara", "callback_data": "sahur_test"},
        {"text": "📊 Status", "callback_data": "sahur_status"}
    ],[
        {"text": "⬅️ Kembali", "callback_data": "back_to_reminder_menu"}
    ]]'
    
    local message=$(printf '🌙 *PENGATURAN ALARM SAHUR*

*Status:* %s
*Waktu:* %s %s

%s

📝 *Konfigurasi Saat Ini:*
• Metode TTS: *%s*
• Volume: *%s%%*
• Pengulangan: *%sx* (interval %s detik)
• Notifikasi Telegram: Otomatis

💡 *Tips:* 
• Gunakan menu "Atur Teks Pengingat" untuk menyesuaikan pesan
• Test suara untuk mendengar hasilnya' \
"$([ "$sahur_enabled" = "1" ] && echo "🟢 AKTIF" || echo "🔴 NONAKTIF")" \
"$sahur_time" "$timezone" \
"$ramadhan_status" \
"$tts_method_name" "$volume_level" "$repeat_count" "$repeat_interval")
    
    if [ -z "$message_id" ]; then
        send_inline_keyboard "$chat_id" "$message" "$keyboard"
    else
        edit_inline_keyboard "$chat_id" "$message_id" "$message" "$keyboard"
    fi
}

# FUNGSI TOGGLE SAHUR
toggle_sahur() {
    local chat_id="$1"
    local message_id="$2"
    
    local current_status="$SOUND_SAHUR_ENABLED"
    local new_status=$([ "$current_status" = "1" ] && echo "0" || echo "1")
    
    uci set jsholat.sound.sahur_enabled="$new_status"
    uci commit jsholat
    
    # Update variabel config
    SOUND_SAHUR_ENABLED="$new_status"
    
    # Kembali ke menu sahur
    show_sahur_menu "$chat_id" "$message_id"
    
    local status_text=$([ "$new_status" = "1" ] && echo "diaktifkan" || echo "dinonaktifkan")
    log "🌙 Alarm sahur telah $status_text untuk chat_id=$chat_id"
}

# FUNGSI MEMINTA INPUT WAKTU SAHUR
sahur_set_time_prompt() {
    local chat_id="$1"
    local message_id="$2"

    # Hapus flag lama jika ada
    rm -f "/tmp/jsholat_bot_setup/${chat_id}.flag"	
    
    local message="⏰ *ATUR WAKTU SAHUR*

Masukkan waktu sahur dalam format HH:MM

*Contoh:* 
• 02:30 (jam 2:30 pagi)
• 03:00 (jam 3 pagi)
• 02:00 (jam 2 pagi)

⚠️ *Catatan:*
• Gunakan format 24 jam
• Alarm hanya aktif saat Ramadhan
• Waktu dalam zona $SCHEDULE_TIMEZONE

❌ Ketik / untuk membatalkan."
    
    mkdir -p "/tmp/jsholat_bot_setup"
    echo "waiting_sahur_time" > "/tmp/jsholat_bot_setup/${chat_id}.flag"
    
    if [ -n "$message_id" ]; then
        edit_inline_keyboard "$chat_id" "$message_id" "$message" '[[{"text":"❌ Batal","callback_data":"sahur_menu"}]]'
    else
        send_inline_keyboard "$chat_id" "$message" '[[{"text":"❌ Batal","callback_data":"sahur_menu"}]]'
    fi
    
    log "⏰ Meminta input waktu sahur dari chat_id=$chat_id"
}

# FUNGSI PROSES SET WAKTU SAHUR
sahur_set_time_process() {
    local chat_id="$1"
    local time_input="$2"
    
    # Validasi format waktu HH:MM
    if ! echo "$time_input" | grep -qE '^([0-1]?[0-9]|2[0-3]):[0-5][0-9]$'; then
        # PERBAIKAN: Gunakan printf dengan cara yang lebih aman
        local error_msg=""
        printf -v error_msg '❌ *Format waktu tidak valid!*

*Input Anda:* `%s`

*Format yang benar:* `HH:MM`
*Contoh:* 02:30 atau 03:00

ℹ️ *Catatan:*
• Gunakan angka 0-23 untuk jam
• Gunakan angka 00-59 untuk menit
• Pisahkan dengan tanda titik dua (:)' \
        "$time_input"
        
        send_message "$chat_id" "$error_msg" "Markdown"
        rm -f "/tmp/jsholat_bot_setup/${chat_id}.flag"
        return 1
    fi
    
    # Simpan ke UCI
    uci set jsholat.sound.sahur_time="$time_input"
    uci commit jsholat
    
    # Update variabel config
    SOUND_SAHUR_TIME="$time_input"
    
    # PERBAIKAN: Gunakan printf dengan -v untuk assignment
    local success_msg=""
    printf -v success_msg '✅ *Waktu sahur berhasil diubah!*

⏰ *Waktu baru:* %s %s
📍 *Zona waktu:* %s
🌙 *Status:* Alarm akan aktif saat bulan Ramadhan

💡 *Tips:* Gunakan menu Test Suara untuk mencoba.' \
        "$time_input" "$SCHEDULE_TIMEZONE" "$SCHEDULE_TIMEZONE"
        
    send_message "$chat_id" "$success_msg" "Markdown"
    
    rm -f "/tmp/jsholat_bot_setup/${chat_id}.flag"
    log "⏰ Waktu sahur diubah ke $time_input untuk chat_id=$chat_id"
}

# FUNGSI MENAMPILKAN MENU PENGATURAN TEKS SAHUR
show_sahur_text_menu() {
    local chat_id="$1"
    local message_id="$2"
    
    local current_text=$(get_sahur_reminder_text)
    local preview_text=""
    
    # Buat preview dengan placeholder
    local lokasi="$SCHEDULE_CITY_LABEL"
    local province="$SCHEDULE_PROVINCE"
    local lokasi_text="$lokasi"
    [ -n "$province" ] && lokasi_text="$lokasi, $province"
    
    # Format preview
    preview_text=$(format_sahur_reminder "$current_text" "03:00" "WIB" "$lokasi_text")
    
    local keyboard='[[
        {"text": "📝 Lihat Teks Saat Ini", "callback_data": "sahur_view_text"}
    ],[
        {"text": "✏️ Ubah Teks", "callback_data": "sahur_edit_text"}
    ],[
        {"text": "🔄 Reset ke Default", "callback_data": "sahur_reset_text"}
    ],[
        {"text": "⬅️ Kembali", "callback_data": "sahur_menu"}
    ]]'
    
    local message=$(printf '📝 *PENGATURAN TEKS PENGINGAT SAHUR*

Anda dapat mengubah teks yang akan diucapkan saat alarm sahur.

*Placeholder yang tersedia:*
• `{time}` : Waktu sahur (contoh: 03:00)
• `{timezone}` : Zona waktu (contoh: WIB)
• `{location}` : Lokasi lengkap (contoh: Brebes, Jawa Tengah)

*Contoh preview dengan waktu 03:00 WIB:*
%s

💡 *Tips:* 
• Gunakan placeholder sesuai kebutuhan
• Maksimal 500 karakter
• Teks akan tersimpan permanen' \
"$preview_text")
    
    if [ -z "$message_id" ]; then
        send_inline_keyboard "$chat_id" "$message" "$keyboard"
    else
        edit_inline_keyboard "$chat_id" "$message_id" "$message" "$keyboard"
    fi
}

# FUNGSI MELIHAT TEKS SAAT INI
sahur_view_text() {
    local chat_id="$1"
    local message_id="$2"
    
    local current_text=$(get_sahur_reminder_text)
    
    local message=$(printf '📝 *TEKS PENGINGAT SAHUR SAAT INI*

%s

*Placeholder:*
• `{time}` → Waktu sahur
• `{timezone}` → Zona waktu
• `{location}` → Lokasi lengkap

Gunakan tombol di bawah untuk mengubah.' \
"$current_text")
    
    local keyboard='[[
        {"text": "✏️ Ubah Teks", "callback_data": "sahur_edit_text"}
    ],[
        {"text": "🔄 Reset ke Default", "callback_data": "sahur_reset_text"}
    ],[
        {"text": "⬅️ Kembali", "callback_data": "sahur_text_menu"}
    ]]'
    
    edit_inline_keyboard "$chat_id" "$message_id" "$message" "$keyboard"
}

# FUNGSI MEMINTA INPUT TEKS BARU
sahur_edit_text_prompt() {
    local chat_id="$1"
    local message_id="$2"
    
    # ✅ PERBAIKAN: Gunakan HEREDOC atau escape dengan benar
    local message="✏️ *UBAH TEKS PENGINGAT SAHUR*

Kirimkan teks baru yang ingin digunakan.

*Placeholder yang tersedia:*
• {time} → Waktu sahur (contoh: 03:00)
• {timezone} → Zona waktu (contoh: WIB)
• {location} → Lokasi lengkap (contoh: Brebes, Jawa Tengah)

*Contoh:*
\"Bangunlah wahai kaum muslimin, waktu sahur telah tiba pukul {time} {timezone} untuk wilayah {location}. Mari kita siapkan sahur.\"

⚠️ Maksimal 500 karakter.
❌ Ketik / untuk membatalkan."
    
    mkdir -p "/tmp/jsholat_bot_setup"
    echo "waiting_sahur_text" > "/tmp/jsholat_bot_setup/${chat_id}.flag"
    
    if [ -n "$message_id" ]; then
        edit_inline_keyboard "$chat_id" "$message_id" "$message" '[[{"text":"❌ Batal","callback_data":"sahur_text_menu"}]]'
    else
        send_inline_keyboard "$chat_id" "$message" '[[{"text":"❌ Batal","callback_data":"sahur_text_menu"}]]'		
    fi
    
    log "✏️ Meminta input teks sahur baru dari chat_id=$chat_id"
}

# FUNGSI MEMPROSES INPUT TEKS BARU
sahur_edit_text_process() {
    local chat_id="$1"
    local new_text="$2"
    
    # Validasi panjang teks
    if [ ${#new_text} -gt 500 ]; then
        send_message "$chat_id" "❌ *Teks terlalu panjang!*\n\nMaksimal 500 karakter.\nAnda menggunakan: ${#new_text} karakter." "Markdown"
        rm -f "/tmp/jsholat_bot_setup/${chat_id}.flag"
        return 1
    fi
    
    # Cek apakah mengandung placeholder yang valid
    if [[ "$new_text" != *"{time}"* ]] || [[ "$new_text" != *"{timezone}"* ]] || [[ "$new_text" != *"{location}"* ]]; then
        local warning="⚠️ *Peringatan:* Teks Anda tidak mengandung semua placeholder.\n\n"
        warning+="Disarankan menggunakan:\n"
        warning+="• `{time}` - Waktu sahur\n"
        warning+="• `{timezone}` - Zona waktu\n"
        warning+="• `{location}` - Lokasi lengkap\n\n"
        warning+="Tetap simpan teks ini?"
        
        local keyboard='[[
            {"text": "✅ Ya, Simpan", "callback_data": "sahur_force_save_'$(echo "$new_text" | sed 's/ /_/g' | sed 's/[^a-zA-Z0-9_]/_/g' | cut -c1-50)'"},
            {"text": "❌ Batal", "callback_data": "sahur_text_menu"}
        ]]'
        
        send_inline_keyboard "$chat_id" "$warning" "$keyboard"
        rm -f "/tmp/jsholat_bot_setup/${chat_id}.flag"
        return 0
    fi
    
    # Simpan teks
    save_sahur_reminder_text "$new_text" "$chat_id"
    
    send_message "$chat_id" "✅ *Teks pengingat sahur berhasil disimpan!*

Teks baru: %s" "Markdown" "$new_text"
    
    rm -f "/tmp/jsholat_bot_setup/${chat_id}.flag"
    log "✅ Teks sahur baru disimpan untuk chat_id=$chat_id"
}

# FUNGSI FORCE SAVE (untuk teks tanpa placeholder lengkap)
sahur_force_save() {
    local chat_id="$1"
    local message_id="$2"
    local text="$3"
    
    save_sahur_reminder_text "$text" "$chat_id"
    
    remove_keyboard "$chat_id" "$message_id" "✅ *Teks pengingat sahur berhasil disimpan!*\n\nTeks: $text"
    log "✅ Teks sahur (force save) disimpan untuk chat_id=$chat_id"
}

# FUNGSI RESET KE DEFAULT
sahur_reset_text() {
    local chat_id="$1"
    local message_id="$2"
    
    # Hapus file custom
    rm -f "$SAHUR_REMINDER_FILE"
    
    local default_text="$SAHUR_REMINDER_DEFAULT"
    
    # ✅ PERBAIKAN: Gunakan printf dengan argumen yang benar
    local message=$(printf '🔄 *Teks pengingat sahur telah direset ke default*\n\n%s\n\nGunakan preview untuk melihat hasilnya.' "$default_text")
    
    remove_keyboard "$chat_id" "$message_id" "$message"
    log "🔄 Teks sahur direset ke default untuk chat_id=$chat_id"
}

# Fungsi untuk menampilkan menu pengulangan reminder
show_reminder_repeat_menu() {
    local chat_id="$1"
    local message_id="$2"
    
    # Reload config untuk memastikan nilai terbaru
    load_uci_config
	
    local repeat_count="$SOUND_REMINDER_REPEAT_COUNT"
    local repeat_interval="$SOUND_REMINDER_REPEAT_INTERVAL"
    
    local keyboard='[[
        {"text": "1x '$( [ "$repeat_count" = "1" ] && echo "✅" )'", "callback_data": "set_reminder_repeat_1"},
        {"text": "2x '$( [ "$repeat_count" = "2" ] && echo "✅" )'", "callback_data": "set_reminder_repeat_2"},
        {"text": "3x '$( [ "$repeat_count" = "3" ] && echo "✅" )'", "callback_data": "set_reminder_repeat_3"}
    ],[
        {"text": "4x '$( [ "$repeat_count" = "4" ] && echo "✅" )'", "callback_data": "set_reminder_repeat_4"},
        {"text": "5x '$( [ "$repeat_count" = "5" ] && echo "✅" )'", "callback_data": "set_reminder_repeat_5"}
    ],[
        {"text": "⏱️ Interval: '"${repeat_interval}"'s", "callback_data": "reminder_interval_menu"}
    ],[
        {"text": "⬅️ Kembali", "callback_data": "reminder_menu"}
    ]]'
    
    local message=$(printf '🔄 *PENGATURAN PENGULANGAN PENGINGAT*

*Status Saat Ini:*
• Pengulangan: %s kali
• Interval: %s detik

📝 *Catatan Penting:*
• Imsyak: SELALU 1x (tidak terpengaruh pengaturan ini)
• Sholat lain (Subuh, Dzuhur, Ashar, Maghrib, Isya): Mengikuti pengaturan di atas
• Interval hanya berlaku jika pengulangan > 1x

💡 *Rekomendasi:*
• Area kecil (rumah): 1-2x
• Area sedang (kantor/musholla): 2-3x  
• Area luas/ramai (masjid): 3-5x' \
"$repeat_count" "$repeat_interval")
    
    if [ -z "$message_id" ]; then
        send_inline_keyboard "$chat_id" "$message" "$keyboard"
    else
        edit_inline_keyboard "$chat_id" "$message_id" "$message" "$keyboard"
    fi
}

# Fungsi untuk menampilkan menu interval reminder
show_reminder_interval_menu() {
    local chat_id="$1"
    local message_id="$2"
    
    # Reload config
    load_uci_config
	
    local repeat_interval="$SOUND_REMINDER_REPEAT_INTERVAL"
    
    local keyboard='[[
        {"text": "3s '$( [ "$repeat_interval" = "3" ] && echo "✅" )'", "callback_data": "set_reminder_interval_3"},
        {"text": "5s '$( [ "$repeat_interval" = "5" ] && echo "✅" )'", "callback_data": "set_reminder_interval_5"},
        {"text": "7s '$( [ "$repeat_interval" = "7" ] && echo "✅" )'", "callback_data": "set_reminder_interval_7"}
    ],[
        {"text": "10s '$( [ "$repeat_interval" = "10" ] && echo "✅" )'", "callback_data": "set_reminder_interval_10"},
        {"text": "15s '$( [ "$repeat_interval" = "15" ] && echo "✅" )'", "callback_data": "set_reminder_interval_15"}
    ],[
        {"text": "⬅️ Kembali", "callback_data": "reminder_repeat_menu"}
    ]]'
    
    local message=$(printf '⏱️ *PENGATURAN INTERVAL PENGINGAT*

*Status Saat Ini:* %s detik

📝 *Keterangan:*
• Interval adalah waktu jeda antara pengulangan suara pengingat
• Setelah suara pertama selesai, sistem akan menunggu sebelum memutar ulang

💡 *Rekomendasi:*
• 3-5 detik: Cepat, untuk pengingat singkat
• 7-10 detik: Normal, memberikan waktu respons
• 15 detik: Longgar, untuk area yang sangat luas' \
"$repeat_interval")
    
    if [ -z "$message_id" ]; then
        send_inline_keyboard "$chat_id" "$message" "$keyboard"
    else
        edit_inline_keyboard "$chat_id" "$message_id" "$message" "$keyboard"
    fi
}

# Fungsi untuk menyimpan pengulangan reminder
set_reminder_repeat_count() {
    local chat_id="$1"
    local message_id="$2"
    local repeat_value="$3"
    
    # Validasi nilai
    case "$repeat_value" in
        "1"|"2"|"3"|"4"|"5")
            # Nilai valid
            ;;
        *)
            log "ERROR: Nilai pengulangan tidak valid: $repeat_value"
            send_message "$chat_id" "❌ Nilai pengulangan tidak valid. Hanya 1-5 yang diperbolehkan."
            return 1
            ;;
    esac
    
    uci set jsholat.sound.reminder_repeat_count="$repeat_value"
    uci commit jsholat
    # Reload config untuk memastikan nilai terbaru
    load_uci_config
	
    # Update variabel config
    SOUND_REMINDER_REPEAT_COUNT="$repeat_value"
    
    # Kembali ke menu pengulangan
    show_reminder_repeat_menu "$chat_id" "$message_id"
    
    log "Pengulangan reminder diatur ke $repeat_value kali untuk chat_id=$chat_id"
}

# Fungsi untuk menyimpan interval reminder
set_reminder_interval() {
    local chat_id="$1"
    local message_id="$2"
    local interval_value="$3"
    
    # Validasi nilai
    case "$interval_value" in
        "3"|"5"|"7"|"10"|"15")
            # Nilai valid
            ;;
        *)
            log "ERROR: Nilai interval tidak valid: $interval_value"
            send_message "$chat_id" "❌ Nilai interval tidak valid. Pilihan: 3, 5, 7, 10, 15 detik."
            return 1
            ;;
    esac
    
    uci set jsholat.sound.reminder_repeat_interval="$interval_value"
    uci commit jsholat
    
	# PERBAIKAN: Load ulang config untuk update variabel
    load_uci_config
    
	# Update variabel config
    SOUND_REMINDER_REPEAT_INTERVAL="$interval_value"
    
    # Kembali ke menu interval
    show_reminder_interval_menu "$chat_id" "$message_id"
    
    log "Interval reminder diatur ke $interval_value detik untuk chat_id=$chat_id"
}

# Fungsi untuk toggle suara TTS
toggle_tts_sound() {
    local chat_id="$1"
    local message_id="$2"
    
    local current_status="$SOUND_REMINDER_SOUND_ENABLED"
    local new_status=$([ "$current_status" = "1" ] && echo "0" || echo "1")
    
    uci set jsholat.sound.reminder_sound_enabled="$new_status"
    uci commit jsholat
    
    # Update variabel config
    SOUND_REMINDER_SOUND_ENABLED="$new_status"
    
    # Kembali ke menu reminder untuk menunjukkan perubahan
    show_reminder_menu "$chat_id" "$message_id"
    
    local status_text=$([ "$new_status" = "1" ] && echo "diaktifkan" || echo "dinonaktifkan")
    log "Suara TTS telah $status_text untuk chat_id=$chat_id"
}

# FUNGSI MENAMPILKAN MENU PENGATURAN AYAT
show_ayat_menu() {
    local chat_id="$1"
    local message_id="$2"
    
    # Reload config
    load_uci_config
    
    local ayat_enabled="$SERVICE_AYAT_ENABLED"
    local ayat_status_text=$([ "$ayat_enabled" = "1" ] && echo "🟢 AKTIF" || echo "🔴 NONAKTIF")
    
    local keyboard='[[
        {"text": "'"$( [ "$ayat_enabled" = "1" ] && echo "🔴 Nonaktifkan" || echo "🟢 Aktifkan")"' Ayat", "callback_data": "toggle_ayat"}
    ],[
        {"text": "📖 Test Ayat Acak", "callback_data": "test_ayat"}
    ],[
        {"text": "❌ Batal", "callback_data": "cancel_update"}
    ]]'
    
    # PERBAIKAN: Escape kutip satu dengan '\'' (keluar string, tambah kutip, masuk lagi)
    local message=$(printf '📖 *PENGATURAN AYAT AL-QUR'\''AN*

*Status:* %s

📝 *Penjelasan:*
• Saat fitur ini AKTIF, sistem akan mengirimkan ayat acak 
  dari Al-Qur'\''an setiap kali notifikasi waktu sholat dikirim.

• Ayat diambil dari API MyQuran dengan terjemahan 
  bahasa Indonesia dan latin.

• Cocok untuk menambah pengetahuan dan keberkahan 
  di setiap waktu sholat.

💡 *Tips:* 
Gunakan tombol Test untuk mencoba melihat contoh ayat acak.' "$ayat_status_text")
    
    if [ -z "$message_id" ]; then
        send_inline_keyboard "$chat_id" "$message" "$keyboard"
    else
        edit_inline_keyboard "$chat_id" "$message_id" "$message" "$keyboard"
    fi
}

# FUNGSI TOGGLE AYAT ACAK
toggle_ayat() {
    local chat_id="$1"
    local message_id="$2"
    
    local current_status="$SERVICE_AYAT_ENABLED"
    local new_status=$([ "$current_status" = "1" ] && echo "0" || echo "1")
    
    uci set jsholat.service.ayat_enabled="$new_status"
    uci commit jsholat
    
    # Update variabel config
    SERVICE_AYAT_ENABLED="$new_status"
    
    # Kembali ke menu ayat
    show_ayat_menu "$chat_id" "$message_id"
    
    local status_text=$([ "$new_status" = "1" ] && echo "diaktifkan" || echo "dinonaktifkan")
    log "📖 Ayat acak telah $status_text untuk chat_id=$chat_id"
}

# FUNGSI TEST AYAT ACAK
test_ayat() {
    local chat_id="$1"
    local message_id="$2"
    
    # Pesan loading
    local loading_msg="⏳ *Mengambil ayat acak dari API MyQuran...*"
    
    if [ -n "$message_id" ]; then
        curl -s -X POST \
            "https://api.telegram.org/bot${TELEGRAM_TOKEN}/editMessageText" \
            -d chat_id="${chat_id}" \
            -d message_id="${message_id}" \
            -d text="$loading_msg" \
            -d parse_mode="Markdown" \
            > /dev/null 2>&1
    else
        local sent_msg=$(send_message "$chat_id" "$loading_msg")
        message_id=$(echo "$sent_msg" | jq -r '.result.message_id // empty')
    fi
    
    # Ambil ayat acak
    local ayat=$(get_random_ayat)
    
    if [ -n "$ayat" ] && [ "$ayat" != "null" ] && [ "$ayat" != "" ]; then
        # Format pesan
        local ayat_message="📖 *CONTOH AYAT ACAK*

${ayat}

💡 *Fitur ini akan aktif secara otomatis*
   pada setiap notifikasi waktu sholat."
        
        # Tampilkan hasil
        if [ -n "$message_id" ]; then
            curl -s -X POST \
                "https://api.telegram.org/bot${TELEGRAM_TOKEN}/editMessageText" \
                -d chat_id="${chat_id}" \
                -d message_id="${message_id}" \
                -d text="$ayat_message" \
                -d parse_mode="Markdown" \
                > /dev/null 2>&1
        fi
        
        log "✅ Test ayat berhasil untuk chat_id=$chat_id"
    else
        # Error
        local error_msg="❌ *Gagal mengambil ayat acak*

Kemungkinan penyebab:
• Koneksi internet terputus
• API MyQuran sedang bermasalah
• Format response tidak sesuai

Silakan coba beberapa saat lagi."
        
        if [ -n "$message_id" ]; then
            curl -s -X POST \
                "https://api.telegram.org/bot${TELEGRAM_TOKEN}/editMessageText" \
                -d chat_id="${chat_id}" \
                -d message_id="${message_id}" \
                -d text="$error_msg" \
                -d parse_mode="Markdown" \
                > /dev/null 2>&1
        fi
        
        log "❌ Test ayat gagal untuk chat_id=$chat_id"
    fi
}

# FUNGSI MENGAMBIL AYAT ACAK DARI API MYQURAN
get_random_ayat() {
    local api_url="https://api.myquran.com/v2/quran/ayat/acak"
    local response=$(curl -s --max-time 10 "$api_url")

    [ -z "$response" ] && { log "ERROR: Gagal mengambil ayat acak"; echo ""; return 1; }

    local surah_name=$(echo "$response" | jq -r '.data.info.surat.nama.id')
    local ayat_number=$(echo "$response" | jq -r '.data.ayat.ayah')
    local ayat_text=$(echo "$response" | jq -r '.data.ayat.text')
    local ayat_arab=$(echo "$response" | jq -r '.data.ayat.arab')
    local ayat_latin=$(echo "$response" | jq -r '.data.ayat.latin')
    local ayat_notes=$(echo "$response" | jq -r '.data.ayat.notes')

    # Format pesan dengan Markdown
    local formatted_ayat="
*📖 QS ${surah_name}:${ayat_number}*

\`${ayat_arab}\`

*${ayat_latin}*

*Artinya:* \"${ayat_text}\""

    # Tambahkan catatan jika ada
    if [ -n "$ayat_notes" ] && [ "$ayat_notes" != "null" ]; then
        formatted_ayat+="

📝 _${ayat_notes}_"
    fi

    echo "${formatted_ayat}"
    return 0
}

# FUNGSI HANDLER UNTUK COMMAND /start
handle_start_command() {
    local chat_id="$1"
    
    log "🚀 Menjalankan handler /start untuk chat_id=$chat_id"
    
    local setup_flag="/tmp/jsholat_bot_setup_done"
    local setup_version_file="/tmp/jsholat_bot_setup_version"
    local current_version="2.8"  # Naikkan versi karena ada command baru
    local need_setup=0
    
    local registered_commands=$(curl -s "https://api.telegram.org/bot${TELEGRAM_TOKEN}/getMyCommands")
    local cmd_count=$(echo "$registered_commands" | jq '.result | length')
    
    log "📊 Command terdaftar saat ini: $cmd_count/21"
    
    if [ "$cmd_count" -lt 21 ]; then
        need_setup=1
        log "📋 Need setup: Command tidak lengkap ($cmd_count/21)"
    fi
    
    if [ ! -f "$setup_flag" ]; then
        need_setup=1
        log "📋 Need setup: Belum pernah setup"
    fi
    
    if [ -f "$setup_version_file" ]; then
        local last_version=$(cat "$setup_version_file")
        if [ "$last_version" != "$current_version" ]; then
            need_setup=1
            log "📋 Need setup: Versi berubah ($last_version -> $current_version)"
        fi
    fi
    
    if [ "$need_setup" -eq 1 ]; then
        log "🔄 Menjalankan setup command menu..."
        
        local processing_msg=$(send_message "$chat_id" "⏳ *Mengaktifkan command menu...*" "Markdown")
        local processing_msg_id=$(echo "$processing_msg" | jq -r '.result.message_id // empty')
        
        local register_result=$(register_bot_commands_silent)
        
        if [ "$register_result" = "success" ]; then
            echo "$(date '+%Y-%m-%d %H:%M:%S')" > "$setup_flag"
            echo "$current_version" > "$setup_version_file"
            
            local success_msg="✅ *Command menu berhasil diaktifkan!*

Sekarang ketik / di kolom pesan untuk melihat semua perintah.

📍 *Mulai sekarang:*
/setlokasi - Atur lokasi Anda
/jadwal - Lihat jadwal hari ini
/setupbot - Atur profil bot
/status - Cek semua pengaturan

🌙 *Semoga ibadah makin khusyuk!*"
            
            if [ -n "$processing_msg_id" ]; then
                curl -s -X POST \
                    "https://api.telegram.org/bot${TELEGRAM_TOKEN}/editMessageText" \
                    -d chat_id="${chat_id}" \
                    -d message_id="${processing_msg_id}" \
                    -d text="$success_msg" \
                    -d parse_mode="Markdown" \
                    > /dev/null 2>&1
            else
                send_message "$chat_id" "$success_msg" "Markdown"
            fi
        else
            local failed_msg="❌ *Gagal mengaktifkan command menu*

Silakan coba dengan perintah:
/setup

Atau gunakan perintah manual:
/help - Lihat semua perintah

🌙 *Terima kasih*"
            
            if [ -n "$processing_msg_id" ]; then
                curl -s -X POST \
                    "https://api.telegram.org/bot${TELEGRAM_TOKEN}/editMessageText" \
                    -d chat_id="${chat_id}" \
                    -d message_id="${processing_msg_id}" \
                    -d text="$failed_msg" \
                    -d parse_mode="Markdown" \
                    > /dev/null 2>&1
            else
                send_message "$chat_id" "$failed_msg" "Markdown"
            fi
        fi
    else
        local last_setup="Tidak diketahui"
        [ -f "$setup_flag" ] && last_setup=$(cat "$setup_flag")
        
        local normal_msg="Assalamu'alaikum! 

🤖 *Jsholat Bot*

✅ Command menu siap digunakan (*${cmd_count} perintah*)
🕒 Terakhir setup: ${last_setup}

📌 *Perintah cepat:*
/jadwal - Jadwal hari ini
/status - Status pengaturan
/setupbot - Atur profil bot
/help - Semua perintah

🌙 *Selamat beribadah!*"
        
        send_message "$chat_id" "$normal_msg" "Markdown"
    fi
}

# FUNGSI KIRIM PESAN SELAMAT DATANG
send_welcome_message() {
    local chat_id="$1"
    local message_type="$2"  # setup_success, setup_failed, normal
    
    case "$message_type" in
        "setup_success")
            # PESAN UNTUK FIRST TIME SETUP - SUKSES
            local message=$(cat <<'EOF'
Assalamu'alaikum! 

🤖 *Jsholat Bot siap digunakan!*

✅ *Command menu sudah aktif!*
Ketik / di kolom pesan untuk melihat semua perintah.

📍 *Mulai sekarang:*
/setlokasi - Atur lokasi Anda
/jadwal - Lihat jadwal hari ini
/status - Cek semua pengaturan

🌙 *Semoga ibadah makin khusyuk!*
EOF
)
            send_message "$chat_id" "$message" "Markdown"
            ;;
            
        "setup_failed")
            # PESAN UNTUK FIRST TIME SETUP - GAGAL
            local message=$(cat <<'EOF'
Assalamu'alaikum! 

🤖 *Jsholat Bot*

⚠️ *Maaf, terjadi kesalahan saat mengaktifkan command menu.*

Silakan coba lagi dengan perintah:
/setup

Atau gunakan perintah manual:
/help - Lihat semua perintah

🌙 *Terima kasih*
EOF
)
            send_message "$chat_id" "$message" "Markdown"
            ;;
            
        "normal")
            # PESAN UNTUK USER YANG SUDAH SETUP
            # Ambil tanggal setup terakhir
            local last_setup="Tidak diketahui"
            if [ -f "/tmp/jsholat_bot_setup_done" ]; then
                last_setup=$(cat "/tmp/jsholat_bot_setup_done")
            fi
            
            # Ambil jumlah command terdaftar
            local cmd_count=$(curl -s "https://api.telegram.org/bot${TELEGRAM_TOKEN}/getMyCommands" | jq '.result | length')
            
            local message=$(cat <<EOF
Assalamu'alaikum! 

🤖 *Jsholat Bot*

✅ Command menu siap digunakan (*${cmd_count} perintah*)
🕒 Terakhir setup: ${last_setup}

📌 *Perintah cepat:*
/jadwal - Jadwal hari ini
/status - Status pengaturan
/help - Semua perintah

🌙 *Selamat beribadah!*
EOF
)
            send_message "$chat_id" "$message" "Markdown"
            ;;
            
        *)
            # DEFAULT MESSAGE
            local message=$(cat <<'EOF'
Assalamu'alaikum! 

🤖 *Jsholat Bot*

Gunakan /help untuk melihat semua perintah.

🌙 *Semoga bermanfaat*
EOF
)
            send_message "$chat_id" "$message" "Markdown"
            ;;
    esac
    
    log "💬 Welcome message sent: type=$message_type"
}

# FUNGSI HANDLER UNTUK COMMAND /setup
handle_setup_command() {
    local chat_id="$1"
    
    log "🔄 Menjalankan force setup untuk chat_id=$chat_id"
    
    local loading_msg=$(send_message "$chat_id" "⏳ *Mengaktifkan command menu...*" "Markdown")
    local loading_msg_id=$(echo "$loading_msg" | jq -r '.result.message_id // empty')
    
    local register_result=$(register_bot_commands_silent)
    
    if [ "$register_result" = "success" ]; then
        echo "$(date '+%Y-%m-%d %H:%M:%S')" > "/tmp/jsholat_bot_setup_done"
        echo "2.8" > "/tmp/jsholat_bot_setup_version"
        
        local success_msg="✅ *Command menu berhasil diaktifkan!*

Sekarang ketik / di kolom pesan untuk melihat semua perintah.

📋 *Total:* 21 perintah tersedia
✨ Termasuk perintah /setupbot untuk atur profil bot"
        
        if [ -n "$loading_msg_id" ]; then
            curl -s -X POST \
                "https://api.telegram.org/bot${TELEGRAM_TOKEN}/editMessageText" \
                -d chat_id="${chat_id}" \
                -d message_id="${loading_msg_id}" \
                -d text="$success_msg" \
                -d parse_mode="Markdown" \
                > /dev/null 2>&1
        else
            send_message "$chat_id" "$success_msg" "Markdown"
        fi
    else
        local failed_msg="❌ *Gagal mengaktifkan command menu*

Error: Command menu tidak dapat didaftarkan.

Silakan coba lagi beberapa saat."
        
        if [ -n "$loading_msg_id" ]; then
            curl -s -X POST \
                "https://api.telegram.org/bot${TELEGRAM_TOKEN}/editMessageText" \
                -d chat_id="${chat_id}" \
                -d message_id="${loading_msg_id}" \
                -d text="$failed_msg" \
                -d parse_mode="Markdown" \
                > /dev/null 2>&1
        else
            send_message "$chat_id" "$failed_msg" "Markdown"
        fi
    fi
}

# FUNGSI SETUP BOT
# Fungsi untuk mengecek rate limit sebelum mencoba
check_rate_limit() {
    local action="$1"  # name, description, bio, photo
    local chat_id="$2"
    
    local rate_file="/tmp/jsholat_rate_limit_${action}"
    local current_time=$(date +%s)
    
    if [ -f "$rate_file" ]; then
        local retry_after=$(cat "$rate_file")
        if [ "$current_time" -lt "$retry_after" ]; then
            local wait_seconds=$((retry_after - current_time))
            local hours=$((wait_seconds / 3600))
            local minutes=$(( (wait_seconds % 3600) / 60 ))
            local seconds=$((wait_seconds % 60))
            
            local wait_time=$(date -d "@$retry_after" "+%H:%M:%S %d/%m/%Y" 2>/dev/null || echo "Tidak dapat menentukan")
            
            send_message "$chat_id" "⏳ *Mohon tunggu*\n\nAnda sudah mencapai batas pengubahan *%s*.\n\n• Harap tunggu: *%d jam %d menit %d detik*\n• Dapat diubah setelah: %s\n\n💡 *Saran:* Gunakan fitur lain sambil menunggu." "Markdown" \
                "$action" "$hours" "$minutes" "$seconds" "$wait_time"
            return 1
        else
            rm -f "$rate_file"
        fi
    fi
    return 0
}

# Fungsi untuk menyimpan rate limit
save_rate_limit() {
    local action="$1"
    local retry_after="$2"
    
    if [ -n "$retry_after" ] && [ "$retry_after" -gt 0 ]; then
        local retry_time=$(( $(date +%s) + retry_after ))
        echo "$retry_time" > "/tmp/jsholat_rate_limit_${action}"
        log "⚠️ Rate limit disimpan untuk $action: $retry_after detik (sampai $(date -d "@$retry_time" '+%H:%M:%S %d/%m/%Y'))"
    fi
}

# FUNGSI MENAMPILKAN MENU SETUP PROFIL BOT
show_bot_profile_menu() {
    local chat_id="$1"
    local message_id="$2"
    
    load_uci_config
    
    local bot_info=$(curl -s "https://api.telegram.org/bot${TELEGRAM_TOKEN}/getMe")
    local bot_name=$(echo "$bot_info" | jq -r '.result.first_name // "Tidak diketahui"')
    local bot_username=$(echo "$bot_info" | jq -r '.result.username // "Tidak diketahui"')
    
    # HAPUS menu "Kelola Deskripsi Foto"
    local keyboard='[[
        {"text": "📝 Ganti Nama Bot", "callback_data": "bot_set_name"}
    ],[
        {"text": "🖼️ Ganti Foto Profil", "callback_data": "bot_set_photo"}
    ],[
        {"text": "📋 Ganti Deskripsi", "callback_data": "bot_set_description"}
    ],[
        {"text": "📌 Ganti Bio", "callback_data": "bot_set_bio"}
    ],[
        {"text": "👁️ Lihat Profil", "callback_data": "bot_view_profile"}
    ],[
        {"text": "❌ Batal", "callback_data": "cancel_update"}
    ]]'
    
    local message="🤖 SETUP PROFIL BOT TELEGRAM

Nama: $bot_name
Username: @$bot_username

📌 Pilih opsi yang ingin diubah:
• 📝 Ganti nama bot
• 🖼️ Ganti foto profil
• 📋 Ganti deskripsi/tentang bot
• 📌 Ganti bio (maks 70 karakter)

⚠️ Catatan: 
Perubahan akan langsung diterapkan di Telegram."
    
    if [ -z "$message_id" ]; then
        curl -s -X POST \
            "https://api.telegram.org/bot${TELEGRAM_TOKEN}/sendMessage" \
            -d chat_id="${chat_id}" \
            --data-urlencode "text=${message}" \
            -d reply_markup="{\"inline_keyboard\":${keyboard}}" \
            > /dev/null 2>&1
    else
        curl -s -X POST \
            "https://api.telegram.org/bot${TELEGRAM_TOKEN}/editMessageText" \
            -d chat_id="${chat_id}" \
            -d message_id="${message_id}" \
            --data-urlencode "text=${message}" \
            -d reply_markup="{\"inline_keyboard\":${keyboard}}" \
            > /dev/null 2>&1
    fi
    
    log "📋 Menu setup profil bot ditampilkan"
}

# FUNGSI MELIHAT PROFIL BOT
view_bot_profile() {
    local chat_id="$1"
    local message_id="$2"
    
    log "👁️ Mengambil informasi profil bot..."
    
    local bot_info=$(curl -s "https://api.telegram.org/bot${TELEGRAM_TOKEN}/getMe")
    local bot_id=$(echo "$bot_info" | jq -r '.result.id')
    local bot_name=$(echo "$bot_info" | jq -r '.result.first_name')
    local bot_username=$(echo "$bot_info" | jq -r '.result.username')
    
    local desc_info=$(curl -s "https://api.telegram.org/bot${TELEGRAM_TOKEN}/getMyDescription")
    local description=$(echo "$desc_info" | jq -r '.result.description // "Tidak ada deskripsi"')
    
    local bio_info=$(curl -s "https://api.telegram.org/bot${TELEGRAM_TOKEN}/getMyShortDescription")
    local bio=$(echo "$bio_info" | jq -r '.result.short_description // "Tidak ada bio"')
    
    local photos=$(curl -s "https://api.telegram.org/bot${TELEGRAM_TOKEN}/getUserProfilePhotos?user_id=${bot_id}&limit=1")
    local total_photos=$(echo "$photos" | jq -r '.result.total_count // 0')
    local has_photo="❌ Tidak ada"
    [ "$total_photos" -gt 0 ] && has_photo="✅ Ada ($total_photos foto)"
    
    # HTML FORMAT - AMAN DARI MARKDOWN
    local message="<b>👁️ INFORMASI PROFIL BOT</b>

<b>ID:</b> $bot_id
<b>Username:</b> @$bot_username
<b>Nama:</b> $bot_name
<b>Foto Profil:</b> $has_photo

<b>📋 Deskripsi:</b>
$description

<b>📌 Bio:</b>
$bio"
    
    local keyboard='[[
        {"text": "🔄 Refresh", "callback_data": "bot_view_profile"}
    ],[
        {"text": "⬅️ Kembali", "callback_data": "bot_profile_menu"}
    ]]'
    
    local payload=$(jq -n \
        --arg chat_id "$chat_id" \
        --arg text "$message" \
        --argjson keyboard "$keyboard" \
        '{
            chat_id: $chat_id,
            text: $text,
            parse_mode: "HTML",
            reply_markup: {inline_keyboard: $keyboard}
        }')
    
    if [ -n "$message_id" ]; then
        payload=$(echo "$payload" | jq --arg msg_id "$message_id" '. + {message_id: $msg_id}')
        curl -s -X POST \
            "https://api.telegram.org/bot${TELEGRAM_TOKEN}/editMessageText" \
            -H "Content-Type: application/json" \
            -d "$payload" > /dev/null 2>&1
    else
        curl -s -X POST \
            "https://api.telegram.org/bot${TELEGRAM_TOKEN}/sendMessage" \
            -H "Content-Type: application/json" \
            -d "$payload" > /dev/null 2>&1
    fi
    
    log "✅ Informasi profil bot ditampilkan (HTML)"
}

# FUNGSI GANTI NAMA BOT
bot_set_name_prompt() {
    local chat_id="$1"
    local message_id="$2"
    
    # ✅ CEK RATE LIMIT DULU!
    if ! check_rate_limit "name" "$chat_id"; then
        return 1
    fi
    
    local message="📝 *GANTI NAMA BOT*

Masukkan nama baru untuk bot Anda.

*Contoh:* Jadwal Sholat Bot

⚠️ *Batasan Telegram:*
• Maksimal 64 karakter
• Bisa menggunakan emoji
• Maksimal 20x perubahan per menit
• Jika kena limit, tunggu ~23 jam

❌ Ketik / untuk membatalkan."
    
    mkdir -p "/tmp/jsholat_bot_setup"
    echo "waiting_bot_name" > "/tmp/jsholat_bot_setup/${chat_id}.flag"
    
    if [ -n "$message_id" ]; then
        curl -s -X POST \
            "https://api.telegram.org/bot${TELEGRAM_TOKEN}/editMessageText" \
            -d chat_id="${chat_id}" \
            -d message_id="${message_id}" \
            --data-urlencode "text=${message}" \
            -d parse_mode="Markdown" \
            > /dev/null 2>&1
    else
        send_message "$chat_id" "%s" "Markdown" "$message"
    fi
    
    log "📋 Meminta nama baru dari chat_id=$chat_id"
}

bot_set_name_process() {
    local chat_id="$1"
    local new_name="$2"
    local start_time=$(date +%s)
    
    log "📝 Mengganti nama bot menjadi: $new_name"
    
    # ✅ CEK LAGI SEBELUM EKSEKUSI (antisipasi jika prompt sudah lama)
    if ! check_rate_limit "name" "$chat_id"; then
        rm -f "/tmp/jsholat_bot_setup/${chat_id}.flag"
        return 1
    fi
    
    local escaped_name=$(echo "$new_name" | sed 's/"/\\"/g')
    
    local response=$(curl -s -X POST \
        "https://api.telegram.org/bot${TELEGRAM_TOKEN}/setMyName" \
        -H "Content-Type: application/json" \
        -d "{\"name\": \"$escaped_name\"}")
    
    local ok=$(echo "$response" | jq -r '.ok // false')
    local error_code=$(echo "$response" | jq -r '.error_code // empty')
    local description=$(echo "$response" | jq -r '.description // "Unknown error"')
    local retry_after=$(echo "$response" | jq -r '.parameters.retry_after // empty')
    local end_time=$(date +%s)
    local elapsed=$((end_time - start_time))
    
    # ✅ SIMPAN RATE LIMIT JIKA ADA
    if [ "$error_code" = "429" ] && [ -n "$retry_after" ]; then
        save_rate_limit "name" "$retry_after"
    fi
    
    if [ "$ok" = "true" ]; then
        send_message "$chat_id" "✅ *Nama bot berhasil diubah!*\n\n*Nama baru:* %s\n⏱️ *Waktu proses:* %d detik" "Markdown" "$new_name" "$elapsed"
        log "✅ Nama bot berhasil diubah dalam $elapsed detik"
        rm -f "/tmp/jsholat_bot_setup/${chat_id}.flag"
        return 0
    else
        local error_msg="❌ *Gagal mengubah nama bot*\n\n"
        error_msg+="📋 *Detail Error:*\n"
        error_msg+="• Kode: %s\n"
        error_msg+="• Pesan: %s\n"
        error_msg+="⏱️ *Waktu respon:* %d detik\n"
        
        if [ "$error_code" = "429" ] && [ -n "$retry_after" ]; then
            local hours=$((retry_after / 3600))
            local minutes=$(( (retry_after % 3600) / 60 ))
            local seconds=$((retry_after % 60))
            
            error_msg+="\n⚠️ *RATE LIMIT TERDETEKSI!*\n"
            error_msg+="• Harap tunggu: *%d jam %d menit %d detik*\n"
            error_msg+="• Coba lagi setelah: %s\n"
            error_msg+="\n📌 *Penyebab:* Terlalu sering mengubah nama dalam waktu singkat.\n"
            error_msg+="💡 *Saran:* Gunakan fitur lain atau istirahat dulu."
            
            local retry_time=$(date -d "@$(( $(date +%s) + retry_after ))" "+%H:%M:%S %d/%m/%Y" 2>/dev/null || echo "Tidak dapat menentukan")
            
            send_message "$chat_id" "$error_msg" "Markdown" \
                "$error_code" "$description" "$elapsed" \
                "$hours" "$minutes" "$seconds" "$retry_time"
        else
            error_msg+="\n📌 *Saran:* Periksa koneksi internet dan coba lagi."
            send_message "$chat_id" "$error_msg" "Markdown" \
                "$error_code" "$description" "$elapsed"
        fi
        
        log "❌ Gagal mengubah nama bot: Kode=$error_code, Pesan=$description, Waktu=$elapsed detik, RetryAfter=$retry_after"
        # FLAG TIDAK DIHAPUS - user bisa coba lagi nanti
        return 1
    fi
}

# FUNGSI GANTI FOTO PROFIL BOT
bot_set_photo_prompt() {
    local chat_id="$1"
    local message_id="$2"
    
    # ✅ CEK RATE LIMIT UNTUK FOTO
    if ! check_rate_limit "photo" "$chat_id"; then
        return 1
    fi
    
    # Hapus flag lama jika ada
    rm -f "/tmp/jsholat_bot_setup/${chat_id}.flag"
    
    mkdir -p "/tmp/jsholat_bot_setup"
    echo "waiting_bot_photo" > "/tmp/jsholat_bot_setup/${chat_id}.flag"
    
    local message="🖼️ *GANTI FOTO PROFIL BOT*

📸 Kirim foto yang akan dijadikan profil bot.

*Ketentuan:*
• Format: JPG, JPEG, PNG
• Ukuran maksimal: 5 MB
• Resolusi minimal: 320x320 pixel
• Rasio persegi direkomendasikan

⚠️ *Batasan Telegram:*
• Maksimal 3 foto profil
• Maksimal 20x perubahan per menit
• Jika kena limit, tunggu ~23 jam

⏳ *Tunggu* hingga muncul notifikasi sukses/gagal.
❌ Ketik / untuk membatalkan."

    if [ -n "$message_id" ]; then
        curl -s -X POST \
            "https://api.telegram.org/bot${TELEGRAM_TOKEN}/editMessageText" \
            -d chat_id="${chat_id}" \
            -d message_id="${message_id}" \
            --data-urlencode "text=${message}" \
            -d parse_mode="Markdown" \
            > /dev/null 2>&1
    else
        send_message "$chat_id" "%s" "Markdown" "$message"
    fi
    
    log "📸 Meminta foto profil baru dari chat_id=$chat_id"
}

bot_handle_photo() {
    local chat_id="$1"
    local photo_array="$2"
    
    log "📸 Memproses upload foto profil untuk chat_id=$chat_id"
	
	# ✅ CEK RATE LIMIT UNTUK FOTO
    if ! check_rate_limit "photo" "$chat_id"; then
        rm -f "/tmp/jsholat_bot_setup/${chat_id}.flag"
        return 1
    fi
    
    # Validasi input
    if [ -z "$photo_array" ] || [ "$photo_array" = "null" ] || [ "$photo_array" = "[]" ]; then
        send_message "$chat_id" "❌ *Tidak ada foto yang diterima.* Silakan kirim file gambar." "Markdown"
        rm -f "/tmp/jsholat_bot_setup/${chat_id}.flag"
        return 1
    fi
    
    # Ambil file_id dari resolusi tertinggi (last element)
    local file_id=$(echo "$photo_array" | jq -r '.[-1].file_id // empty')
    
    if [ -z "$file_id" ] || [ "$file_id" = "null" ]; then
        send_message "$chat_id" "❌ *Gagal mendapatkan file_id dari foto.*" "Markdown"
        rm -f "/tmp/jsholat_bot_setup/${chat_id}.flag"
        return 1
    fi
    
    log "📸 File ID: $file_id"
    
    # Kirim pesan "sedang memproses"
    local processing_msg=$(send_message "$chat_id" "⏳ *Mengupload foto profil...*" "Markdown")
    local processing_msg_id=$(echo "$processing_msg" | jq -r '.result.message_id // empty')
    
    # Dapatkan bot ID
    local bot_info=$(curl -s "https://api.telegram.org/bot${TELEGRAM_TOKEN}/getMe")
    local bot_id=$(echo "$bot_info" | jq -r '.result.id')
    
    if [ -z "$bot_id" ] || [ "$bot_id" = "null" ]; then
        send_message "$chat_id" "❌ *Gagal mendapatkan informasi bot.*" "Markdown"
        rm -f "/tmp/jsholat_bot_setup/${chat_id}.flag"
        return 1
    fi
    
    # Download foto
    local file_info=$(curl -s "https://api.telegram.org/bot${TELEGRAM_TOKEN}/getFile?file_id=${file_id}")
    local file_path=$(echo "$file_info" | jq -r '.result.file_path // empty')
    
    if [ -z "$file_path" ] || [ "$file_path" = "null" ]; then
        # Update pesan error
        curl -s -X POST \
            "https://api.telegram.org/bot${TELEGRAM_TOKEN}/editMessageText" \
            -d chat_id="${chat_id}" \
            -d message_id="${processing_msg_id}" \
            -d text="❌ *Gagal mengunduh foto.*\n\nFile tidak dapat diakses." \
            -d parse_mode="Markdown" \
            > /dev/null 2>&1
        
        rm -f "/tmp/jsholat_bot_setup/${chat_id}.flag"
        return 1
    fi
    
    local temp_file="/tmp/bot_photo_${chat_id}_${RANDOM}.jpg"
    curl -s -o "$temp_file" "https://api.telegram.org/file/bot${TELEGRAM_TOKEN}/${file_path}"
    
    # Cek hasil download
    if [ ! -s "$temp_file" ]; then
        curl -s -X POST \
            "https://api.telegram.org/bot${TELEGRAM_TOKEN}/editMessageText" \
            -d chat_id="${chat_id}" \
            -d message_id="${processing_msg_id}" \
            -d text="❌ *Gagal mengunduh foto.*\n\nFile kosong atau corrupt." \
            -d parse_mode="Markdown" \
            > /dev/null 2>&1
        
        rm -f "$temp_file" "/tmp/jsholat_bot_setup/${chat_id}.flag"
        return 1
    fi
    
    # Upload sebagai foto profil
    local response=$(curl -s -X POST \
        "https://api.telegram.org/bot${TELEGRAM_TOKEN}/setUserProfilePhotos" \
        -F "user_id=${bot_id}" \
        -F "photo=@${temp_file}")
    
    local ok=$(echo "$response" | jq -r '.ok')
    local error_code=$(echo "$response" | jq -r '.error_code // empty')
    local description=$(echo "$response" | jq -r '.description // "Unknown error"')
    local retry_after=$(echo "$response" | jq -r '.parameters.retry_after // empty')
    local end_time=$(date +%s)
    local elapsed=$((end_time - start_time))
    
    # ✅ SIMPAN RATE LIMIT
    if [ "$error_code" = "429" ] && [ -n "$retry_after" ]; then
        save_rate_limit "photo" "$retry_after"
    fi
    
    # Hapus file temporary
    rm -f "$temp_file"
    
    # Update pesan berdasarkan hasil
    if [ "$ok" = "true" ]; then
        curl -s -X POST \
            "https://api.telegram.org/bot${TELEGRAM_TOKEN}/editMessageText" \
            -d chat_id="${chat_id}" \
            -d message_id="${processing_msg_id}" \
            -d text="✅ *Foto profil berhasil diupload!*\n\nFoto baru sekarang menjadi profil bot Anda." \
            -d parse_mode="Markdown" \
            > /dev/null 2>&1
        
        log "✅ Foto profil bot berhasil diubah untuk chat_id=$chat_id"
    else
        curl -s -X POST \
            "https://api.telegram.org/bot${TELEGRAM_TOKEN}/editMessageText" \
            -d chat_id="${chat_id}" \
            -d message_id="${processing_msg_id}" \
            -d text="❌ *Gagal mengupload foto profil*\n\nError: $error" \
            -d parse_mode="Markdown" \
            > /dev/null 2>&1
        
        log "❌ Gagal mengubah foto profil: $error"
    fi
    
    # Hapus flag
    rm -f "/tmp/jsholat_bot_setup/${chat_id}.flag"
}

