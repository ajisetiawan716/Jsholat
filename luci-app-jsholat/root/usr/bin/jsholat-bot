            -d message_id="${message_id}" \
            -d text="🌐 *Pilih Sumber Jadwal Sholat*" \
            -d parse_mode="Markdown" \
            -d reply_markup="{\"inline_keyboard\":${keyboard}}" \
            > /dev/null 2>&1
    fi
}

# Fungsi untuk mengubah sumber jadwal
set_jadwal_source() {
    local chat_id="$1"
    local message_id="$2"
    local source="$3"
    
    uci set jsholat.schedule.source="$source"
    # Jika sumber adalah aladhan, set method ke 20 (default untuk Indonesia)
    if [ "$source" = "aladhan" ]; then
        uci set jsholat.schedule.method="20"
        log "Mengatur method ke 20 untuk AlAdhan API"
    fi
    
    uci commit jsholat    
	
	# Update variabel config
    SCHEDULE_SOURCE="$source"
    
    local source_name=""
    case "$source" in
        "jadwalsholat") source_name="JadwalSholat.org" ;;
        "aladhan") source_name="AlAdhan API" ;;
        "arina") source_name="Arina.Id" ;;
        "equranid") source_name="Equran.Id" ;;
        "myquran") source_name="MyQuran API" ;;
        "apiajimedia") source_name="AjiMedia API" ;;
    esac
    
    remove_keyboard "$chat_id" "$message_id" "✅ Sumber jadwal sholat diubah ke *$source_name*
    
    Silahkan lakukan /update jadwal."
    log " ✅ Sumber jadwal sholat diubah ke $source_name"
}

# Fungsi untuk menampilkan status audio lengkap
audio_status() {
    local chat_id="$1"
    local message_id="$2"
    
    log "Menampilkan status audio detail untuk chat_id=$chat_id"
    
    # Kirim pesan loading
    local loading_text="📊 *Mengumpulkan informasi audio...*"
    
    if [ -n "$message_id" ] && [ "$message_id" != "null" ]; then
        curl -s -X POST \
            "https://api.telegram.org/bot${TELEGRAM_TOKEN}/editMessageText" \
            -d chat_id="${chat_id}" \
            -d message_id="${message_id}" \
            --data-urlencode "text=${loading_text}" \
            -d parse_mode="Markdown" \
            > /dev/null 2>&1
    else
        local loading_msg=$(send_message "$chat_id" "$loading_text")
        message_id=$(echo "$loading_msg" | jq -r '.result.message_id // empty' 2>/dev/null)
    fi
    
    # Load config
    load_uci_config
    
    # 1. Informasi dari config
    local config_section=$(printf '*📁 CONFIG UCI:*\n• Volume Level: *%s%%*\n• Mixer Device: `%s`\n• Control Type: *%s*\n• Sound Enabled: *%s*' \
        "$SOUND_VOLUME_LEVEL" \
        "$SOUND_MIXER_DEVICE" \
        "$SOUND_VOLUME_CONTROL" \
        "$([ "$SOUND_ENABLED" = "1" ] && echo "YA" || echo "TIDAK")")
    
    # 2. Informasi system audio
    local system_info=""
    if command -v amixer >/dev/null 2>&1; then
        # Current mixer status
        local mixer_status=$(amixer get "$SOUND_MIXER_DEVICE" 2>/dev/null | head -5)
        
        # Available mixers
        local available_count=$(amixer scontrols 2>/dev/null | wc -l)
        local sample_mixers=$(amixer scontrols 2>/dev/null | head -3 | sed "s/Simple mixer control '\([^']*\)',0/\1/" | tr '\n' ', ')
        
        system_info=$(printf '*🎛️ SYSTEM AUDIO:*\n• Mixer Status:\n```\n%s\n```\n• Total Mixers: *%s*\n• Sample: %s' \
            "${mixer_status:-Tidak ada output}" \
            "$available_count" \
            "${sample_mixers%, }")
    else
        system_info="*❌ SYSTEM AUDIO:*\n`amixer` tidak tersedia di sistem"
    fi
    
    # 3. Test sederhana
    local test_result=""
    if timeout 1 amixer get "$SOUND_MIXER_DEVICE" >/dev/null 2>&1; then
        test_result="✅ Mixer device dapat diakses"
    else
        test_result="❌ Mixer device tidak dapat diakses"
    fi
    
    # 4. Deteksi hardware
    local hardware_info=""
    if [ -f "/proc/asound/cards" ]; then
        local sound_cards=$(grep -c "^[0-9]" /proc/asound/cards)
        hardware_info=$(printf '*💽 HARDWARE:*\n• Sound Cards: *%s*\n• Cards Info:\n```\n%s\n```' \
            "$sound_cards" \
            "$(head -10 /proc/asound/cards)")
    fi
    
    # Gabungkan semua informasi
    local status_message=$(printf '%s\n\n%s\n\n%s\n\n%s' \
        "$config_section" \
        "$system_info" \
        "$test_result" \
        "$hardware_info")
    
    # Keyboard
    local keyboard='[[
        {"text": "🔧 Test Cepat", "callback_data": "test_volume"},
        {"text": "🔄 Deteksi Ulang", "callback_data": "detect_audio"}
    ],[
        {"text": "📈 Volume Chart", "callback_data": "volume_chart"}
    ],[
        {"text": "⚙️ Kembali", "callback_data": "volume_menu"},
        {"text": "❌ Tutup", "callback_data": "cancel_update"}
    ]]'
    
    # Tampilkan hasil
    if [ -n "$message_id" ]; then
        edit_inline_keyboard "$chat_id" "$message_id" "$status_message" "$keyboard"
    fi
    
    log "Status audio detail ditampilkan"
}

# Fungsi sederhana untuk volume chart (opsional)
volume_chart() {
    local chat_id="$1"
    local message_id="$2"
    
    load_uci_config
    local volume="$SOUND_VOLUME_LEVEL"
    
    # Buat chart sederhana
    local bars=$((volume / 10))
    local chart=""
    for ((i=0; i<10; i++)); do
        if [ $i -lt $bars ]; then
            chart="${chart}█"
        else
            chart="${chart}░"
        fi
    done
    
    local chart_text=$(printf '📈 *Volume Chart*\n\n%s *%s%%*\n\nSetiap █ = 10%%' \
        "$chart" "$volume")
    
    local keyboard='[[
        {"text": "⚙️ Kembali ke Status", "callback_data": "audio_status"}
    ]]'
    
    edit_inline_keyboard "$chat_id" "$message_id" "$chart_text" "$keyboard"
}

# Fungsi untuk menampilkan menu volume
show_volume_menu() {
    local chat_id="$1"
    local message_id="$2"
    
    load_uci_config
    local current_volume="$SOUND_VOLUME_LEVEL"
    local mixer_device="$SOUND_MIXER_DEVICE"
    local control_type="$SOUND_VOLUME_CONTROL"
    
    # Format teks dengan printf untuk multi-line
    local menu_text
    menu_text=$(printf '🔊 *Pengaturan Volume*\n\n📊 Status:\n• Volume: *%s%%*\n• Mixer: *%s*\n• Tipe: *%s*' \
        "$current_volume" "$mixer_device" "$control_type")
    
    # Keyboard dengan layout 3 tombol per baris
    local keyboard='[[
        {"text": "🔇 0%", "callback_data": "set_volume_0"},
        {"text": "🔈 25%", "callback_data": "set_volume_25"},
        {"text": "🔉 30%", "callback_data": "set_volume_30"}
    ],[
        {"text": "🔊 45%", "callback_data": "set_volume_45"},
        {"text": "🔊 50%", "callback_data": "set_volume_50"},
        {"text": "🔊 60%", "callback_data": "set_volume_60"}
    ],[
        {"text": "🔊 75%", "callback_data": "set_volume_75"},
        {"text": "🔊 80%", "callback_data": "set_volume_80"},
        {"text": "🔊 85%", "callback_data": "set_volume_85"}
    ],[
        {"text": "🔊 90%", "callback_data": "set_volume_90"},
        {"text": "🔊 95%", "callback_data": "set_volume_95"},
        {"text": "📢 100%", "callback_data": "set_volume_100"}
    ],[
        {"text": "🎧 Tes Suara", "callback_data": "test_volume"},
        {"text": "🔄 Deteksi Audio", "callback_data": "detect_audio"},
        {"text": "📊 Status Audio", "callback_data": "audio_status"}
