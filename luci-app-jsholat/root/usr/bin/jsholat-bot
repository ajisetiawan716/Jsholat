# Fungsi untuk mendeteksi mixer device otomatis
detect_mixer_device() {
    local preferred_mixer="$1"
    
    # Jika mixer yang dipilih berfungsi, gunakan itu
    if [ -n "$preferred_mixer" ] && amixer get "$preferred_mixer" >/dev/null 2>&1; then
        log "Menggunakan mixer device dari config: $preferred_mixer"
        echo "$preferred_mixer"
        return 0
    fi
    
    # List mixer devices yang umum
    local common_mixers=("Master" "Speaker" "PCM" "Digital" "Headphone" "Playback" "DAC" "Audio")
    
    log "Mencari mixer device yang tersedia..."
    
    for mixer in "${common_mixers[@]}"; do
        if amixer get "$mixer" >/dev/null 2>&1; then
            log "✓ Ditemukan mixer device: $mixer"
            
            # Test volume control pada mixer ini
            local current_vol=$(amixer get "$mixer" 2>/dev/null | grep -oE '[0-9]+%' | head -1 | tr -d '%')
            
            if [ -n "$current_vol" ]; then
                # Coba set dan reset volume untuk test
                amixer -q set "$mixer" $((current_vol > 50 ? current_vol - 10 : current_vol + 10))% >/dev/null 2>&1
                sleep 0.1
                amixer -q set "$mixer" ${current_vol}% >/dev/null 2>&1
                
                log "Mixer $mixer berfungsi (current: ${current_vol}%)"
                echo "$mixer"
                return 0
            fi
        fi
    done
    
    # Fallback: coba semua mixer controls yang ada
    log "Mencoba semua mixer controls..."
    local all_mixers=$(amixer scontrols 2>/dev/null | sed "s/Simple mixer control '\([^']*\)',0/\1/" | head -5)
    
    for mixer in $all_mixers; do
        if [ -n "$mixer" ] && amixer get "$mixer" >/dev/null 2>&1; then
            log "✓ Fallback ditemukan: $mixer"
            echo "$mixer"
            return 0
        fi
    done
    
    log "❌ Tidak ditemukan mixer device yang valid"
    echo "Master"  # Fallback ke Master
    return 1
}

# Fungsi untuk menentukan jenis volume control
detect_volume_control_type() {
    local mixer_device="$1"
    
    # Mixer tertentu biasanya hardware control
    case "$mixer_device" in
        "Master"|"Speaker"|"Headphone"|"Playback")
            echo "hardware"
            ;;
        "PCM"|"Digital"|"DAC")
            echo "software"
            ;;
        *)
            # Coba tentukan berdasarkan kemampuan
            if amixer get "$mixer_device" 2>/dev/null | grep -q "Playback channels"; then
                echo "hardware"
            else
                echo "software"
            fi
            ;;
    esac
}

# Fungsi bantu untuk mengirim pesan dengan format printf
send_formatted_message() {
    local chat_id="$1"
    local message_id="$2"
    local format="$3"
    shift 3
    
    # Format pesan dengan printf
    local formatted_text
    formatted_text=$(printf "$format" "$@")
    
    if [ -n "$message_id" ] && [ "$message_id" != "null" ]; then
        # Edit pesan yang ada
        curl -s -X POST \
            "https://api.telegram.org/bot${TELEGRAM_TOKEN}/editMessageText" \
            -d chat_id="${chat_id}" \
            -d message_id="${message_id}" \
            --data-urlencode "text=${formatted_text}" \
            -d parse_mode="Markdown" \
            > /dev/null 2>&1
    else
        # Kirim pesan baru
        send_message "$chat_id" "$formatted_text"
    fi
}

# Fungsi untuk menyimpan volume dengan fallback detection otomatis
set_volume() {
    local chat_id="$1"
    local message_id="$2"
    local volume_level="$3"
    
    # Validasi volume level
    if ! [[ "$volume_level" =~ ^[0-9]+$ ]] || [ "$volume_level" -lt 0 ] || [ "$volume_level" -gt 100 ]; then
        log "ERROR: Volume level tidak valid: $volume_level"
        send_formatted_message "$chat_id" "" "❌ Volume level tidak valid. Harus antara 0-100."
        return 1
    fi
    
    # Simpan ke config
    uci set jsholat.sound.volume_level="$volume_level"
    uci commit jsholat
    
    load_uci_config
    
    log "Mengatur volume ke ${volume_level}%"
    
    # Deteksi dan terapkan volume
    local mixer_device="$SOUND_MIXER_DEVICE"
    local detected_mixer=$(detect_mixer_device "$mixer_device")
    local success=0
    
    # Coba set volume
    if amixer -q set "$detected_mixer" "${volume_level}%" >/dev/null 2>&1; then
        success=1
        log "✓ Volume diatur ke ${volume_level}% pada $detected_mixer"
        
        # Update config jika berbeda
        if [ "$mixer_device" != "$detected_mixer" ]; then
            uci set jsholat.sound.mixer_device="$detected_mixer"
            uci commit jsholat
            mixer_device="$detected_mixer"
        fi
    else
        log "❌ Gagal set volume pada $detected_mixer"
    fi
    
    # Bangun keyboard
    local keyboard='[[
        {"text": "🎧 Tes Suara", "callback_data": "test_volume"},
        {"text": "🔄 Deteksi Ulang", "callback_data": "detect_audio"}
    ],[
        {"text": "⬅️ Kembali", "callback_data": "volume_menu"}
    ]]'
    
    # Kirim pesan berdasarkan hasil
    if [ "$success" -eq 1 ]; then
        send_formatted_message "$chat_id" "$message_id" \
            '✅ Volume berhasil diatur ke *%s%%*\n\n📊 *Detail:*\n• Mixer Device: *%s*\n• Control Type: *%s*' \
            "$volume_level" "$mixer_device" "$SOUND_VOLUME_CONTROL"
    else
        send_formatted_message "$chat_id" "$message_id" \
            '⚠️ Volume mungkin tidak berhasil diatur\n\nGunakan tombol 🔄 Deteksi Ulang untuk mencari pengaturan audio yang tepat.'
    fi
    
    # Jika berhasil, tambahkan keyboard
    if [ "$success" -eq 1 ] && [ -n "$message_id" ]; then
        curl -s -X POST \
            "https://api.telegram.org/bot${TELEGRAM_TOKEN}/editMessageReplyMarkup" \
            -d chat_id="${chat_id}" \
            -d message_id="${message_id}" \
            -d reply_markup="{\"inline_keyboard\":${keyboard}}" \
            > /dev/null 2>&1
    fi
    
    return $success
}

# Fungsi baru untuk deteksi audio
detect_audio() {
    local chat_id="$1"
    local message_id="$2"
    
    log "Memulai deteksi audio untuk chat_id=$chat_id"
    
    # Kirim pesan status baru
    local status_msg=$(send_message "$chat_id" "🔍 *Mendeteksi pengaturan audio...*")
    local new_msg_id=$(echo "$status_msg" | jq -r '.result.message_id // empty' 2>/dev/null)
    
    # Hapus pesan lama jika ada (dari callback query)
    if [ -n "$message_id" ]; then
        delete_message "$chat_id" "$message_id"
    fi
    
    # Deteksi mixer device
    local detected_mixer=$(detect_mixer_device "")
    local control_type=$(detect_volume_control_type "$detected_mixer")
    
    # Simpan ke config
    uci set jsholat.sound.mixer_device="$detected_mixer"
    uci set jsholat.sound.volume_control="$control_type"
    uci commit jsholat
    load_uci_config
    
    # Cek mixer yang tersedia
    local available_mixers=$(amixer scontrols 2>/dev/null | sed "s/Simple mixer control '\([^']*\)',0/\1/" | tr '\n' ', ' | sed 's/, $//')
    
    # Tampilkan hasil
    local result_message=$(printf '✅ *Deteksi Audio Selesai*

📊 *Hasil Deteksi:*
• Mixer Device: *%s*
• Control Type: *%s*

🎛️ *Mixer yang tersedia:*
%s

💡 *Tips:* 
Gunakan tombol 🎧 Tes Suara untuk memverifikasi pengaturan.' \
"$detected_mixer" "$control_type" "${available_mixers:-Tidak terdeteksi}")
    
    # Keyboard dengan opsi test dan kembali ke volume menu
    local keyboard='[[
        {"text": "🎧 Tes Suara", "callback_data": "test_volume"},
        {"text": "🔙 Kembali ke Volume", "callback_data": "volume_menu"}
    ]]'
    
    # Edit pesan status dengan hasil
    if [ -n "$new_msg_id" ]; then
        edit_inline_keyboard "$chat_id" "$new_msg_id" "$result_message" "$keyboard"
    else
        # Fallback
        send_inline_keyboard "$chat_id" "$result_message" "$keyboard"
    fi
    
    log "Deteksi audio selesai: mixer=$detected_mixer, type=$control_type"
}

# Fungsi untuk menguji suara
test_volume() {
    local chat_id="$1"
    local message_id="$2"
    
    # Load config terbaru
    load_uci_config
    
    local volume_level="$SOUND_VOLUME_LEVEL"
    local mixer_device="$SOUND_MIXER_DEVICE"
    local control_type="$SOUND_VOLUME_CONTROL"
    
    # Gunakan printf untuk teks dengan newline yang benar
    local playing_text
    playing_text=$(printf '🔊 Memainkan suara uji...\n\n• Volume: *%s%%*\n• Mixer: *%s*' \
        "$volume_level" "$mixer_device")
    
    # Edit pesan untuk menunjukkan sedang memainkan suara
    curl -s -X POST \
        "https://api.telegram.org/bot${TELEGRAM_TOKEN}/editMessageText" \
        -d chat_id="${chat_id}" \
        -d message_id="${message_id}" \
        --data-urlencode "text=${playing_text}" \
        -d parse_mode="Markdown" \
        > /dev/null 2>&1
    
    # Mainkan suara uji (2 detik)
    speaker-test -D default -t sine -f 1000 -l 1 >/dev/null 2>&1 &
    local test_pid=$!
    
    # Tunggu selesai atau timeout
    wait $test_pid 2>/dev/null
    
    # Gunakan printf untuk pesan selesai
    local completed_text
    completed_text=$(printf '✅ Tes suara selesai\n\n• Volume: *%s%%*\n• Mixer: *%s*\n• Control: *%s*' \
        "$volume_level" "$mixer_device" "$control_type")
    
    # Edit pesan lagi setelah selesai
    curl -s -X POST \
        "https://api.telegram.org/bot${TELEGRAM_TOKEN}/editMessageText" \
        -d chat_id="${chat_id}" \
        -d message_id="${message_id}" \
        --data-urlencode "text=${completed_text}" \
        -d parse_mode="Markdown" \
        > /dev/null 2>&1
    
    log "Tes suara dilakukan: level=${volume_level}%, mixer=${mixer_device}, control=${control_type}"
}

# FUNGSI PENGATURAN TTS
# Fungsi untuk menampilkan menu pengaturan TTS method
show_tts_method_menu() {
    local chat_id="$1"
    local message_id="$2"
    
    # Reload config untuk memastikan nilai terbaru
    load_uci_config
    
    local current_method="$SOUND_TTS_METHOD"
    local tts_enabled="$SOUND_REMINDER_SOUND_ENABLED"
    
    # Konversi kode metode ke nama yang lebih deskriptif
    local method_display_name=""
    case "$current_method" in
        "google")
            method_display_name="Google Translate"
            ;;
        "edge")
            method_display_name="Edge-TTS"
            ;;
        "espeak")
            method_display_name="eSpeak"
            ;;
        "murf")
            method_display_name="Murf.ai"
            ;;
        "gemini")
            method_display_name="Gemini AI"
            ;;
        *)
            method_display_name="$current_method (Tidak Dikenal)"
            ;;
    esac
    
    # Status API Murf.ai
    local murf_status=""
    if [ "$current_method" = "murf" ]; then
        if [ -n "$SOUND_MURF_API_KEY" ]; then
            murf_status="✅ TERKONFIGURASI"
        else
            murf_status="🔴 BELUM DIKONFIGURASI"
        fi
    else
        murf_status="⚪ Tidak diperlukan"
    fi
    
    # Status API Gemini
    local gemini_api_key=$(uci -q get jsholat.sound.gemini_api_key || echo "")
    local gemini_voice=$(uci -q get jsholat.sound.gemini_voice || echo "Leda")
    local gemini_model=$(uci -q get jsholat.sound.gemini_model || echo "gemini-2.5-flash-preview-tts")
    
    local gemini_status=""
    if [ "$current_method" = "gemini" ]; then
        if [ -n "$gemini_api_key" ]; then
            gemini_status="✅ TERKONFIGURASI (Voice: $gemini_voice, Model: $gemini_model)"
        else
            gemini_status="🔴 BELUM DIKONFIGURASI"
        fi
    else
        gemini_status="⚪ Tidak diperlukan"
    fi
    
    # Status dependensi
    local deps_status=""
    case "$current_method" in
        "edge")
            if command -v edge-tts >/dev/null 2>&1; then
                deps_status="✅ Terinstal"
            else
                deps_status="🔴 Belum terinstal (pip install edge-tts)"
            fi
            ;;
        "espeak")
            if command -v espeak >/dev/null 2>&1 && command -v aplay >/dev/null 2>&1; then
                deps_status="✅ Terinstal"
            else
                deps_status="🔴 Belum terinstal (opkg install espeak alsa-utils)"
            fi
            ;;
        "murf")
            if [ -n "$SOUND_MURF_API_KEY" ]; then
                deps_status="✅ Siap digunakan"
            else
                deps_status="⚪ Perlu API key"
            fi
            ;;
        "gemini")
            # Cek dependensi konversi audio
            if [ -n "$gemini_api_key" ]; then
                if command -v sox >/dev/null 2>&1 || command -v ffmpeg >/dev/null 2>&1; then
                    deps_status="✅ Siap digunakan"
                else
                    deps_status="⚠️ API key OK, tapi sox/ffmpeg tidak ada"
                fi
            else
                deps_status="⚪ Perlu API key"
            fi
            ;;
        *)
            deps_status="✅ Siap digunakan"
            ;;
    esac
    
    # Tombol keyboard
	local keyboard='[[
		{"text": "🌐 Google '$( [ "$current_method" = "google" ] && echo "✅" )'", "callback_data": "set_tts_google"}
	],[
		{"text": "📘 Edge-TTS '$( [ "$current_method" = "edge" ] && echo "✅" )'", "callback_data": "set_tts_edge"}
	],[
		{"text": "🗣 eSpeak '$( [ "$current_method" = "espeak" ] && echo "✅" )'", "callback_data": "set_tts_espeak"}
	],[
		{"text": "🎙️ Murf.ai '$( [ "$current_method" = "murf" ] && echo "✅" )'", "callback_data": "set_tts_murf"}
	],[
		{"text": "🤖 Gemini AI '$( [ "$current_method" = "gemini" ] && echo "✅" )'", "callback_data": "set_tts_gemini"}
	],[
		{"text": "🎤 Atur Voice Edge", "callback_data": "edge_voice_settings"}
	],[
        {"text": "🗣️ Atur Voice Gemini", "callback_data": "gemini_voice_menu"}
    ],[
		{"text": "🎧 Test TTS", "callback_data": "test_tts"}
	],[
		{"text": "❌ Batal", "callback_data": "cancel_update"}
	]]'
    
    # Pesan dengan informasi lengkap - DESKRIPSI DALAM BENTUK PARAGRAF
    local message=$(printf '🔊 *Pengaturan TTS (Text-to-Speech)*

*📊 Status Saat Ini:*
• *Metode*: %s
• *Suara*: %s
• *API Murf.ai*: %s
• *API Gemini*: %s
• *Dependensi*: %s

📝 *Penjelasan Metode:*

🌐 *Google Translate* — Suaranya standar seperti asisten virtual di ponsel pada umumnya. Metode ini langsung bisa digunakan tanpa perlu install apapun, cocok untuk penggunaan sehari-hari di rumah.

📘 *Edge-TTS (Microsoft)* — Menghasilkan suara yang lebih halus dan natural, hampir mirip dengan manusia asli berbicara. Kualitasnya lebih enak didengar untuk waktu yang lama. Hanya perlu proses install satu kali, setelah itu bisa langsung dinikmati.

🗣️ *eSpeak (Offline)* — Solusi tepat jika perangkat Anda tidak selalu terhubung internet. Suaranya unik seperti robot, ringan dan tidak membebani perangkat. Cocok untuk pengguna yang mengutamakan kestabilan tanpa tergantung koneksi.

🎙️ *Murf.ai* — Menawarkan kualitas suara profesional seperti penyiar radio atau voice over. Sangat cocok untuk masjid, pengajian, atau acara resmi yang menginginkan kesan eksklusif. Layanan ini memerlukan kunci khusus (mungkin berbayar).

🤖 *Gemini AI* — Teknologi AI terbaru dari Google dengan kualitas suara premium yang sangat natural. Tersedia berbagai pilihan voice dengan karakter berbeda (Zephyr, Puck, Charon, Fenrir, dll). Membutuhkan API key dari Google AI Studio (gratis/berbayar).

⚡ *Tips:* Gunakan tombol 🎧 Test TTS untuk mencoba dan membandingkan langsung suara dari masing-masing metode.

💡 *Pengaturan pengulangan suara ada di menu /reminder*' \
"$method_display_name" \
"$([ "$tts_enabled" = "1" ] && echo "🟢 AKTIF" || echo "🔴 NONAKTIF")" \
"$murf_status" \
"$gemini_status" \
"$deps_status")
    
    if [ -z "$message_id" ]; then
        send_inline_keyboard "$chat_id" "$message" "$keyboard"
    else
        edit_inline_keyboard "$chat_id" "$message_id" "$message" "$keyboard"
    fi
}

# Fungsi untuk mengubah metode TTS
set_tts_method() {
    local chat_id="$1"
    local message_id="$2"
    local method="$3"
    
    # Validasi metode
    case "$method" in
        "google"|"edge"|"espeak"|"murf"|"gemini")
            # Metode valid
            ;;
        *)
            log "ERROR: Metode TTS tidak valid: $method"
            send_message "$chat_id" "❌ Metode TTS tidak valid. Pilih: google, edge, espeak, murf, atau gemini"
            return 1
            ;;
    esac
    
    # Jika memilih murf tapi tidak ada API key, minta konfigurasi
    if [ "$method" = "murf" ] && [ -z "$SOUND_MURF_API_KEY" ]; then
        send_message "$chat_id" "🔑 *Konfigurasi Murf.ai API Key*

Anda memilih metode Murf.ai yang membutuhkan API key.

Silakan atur API key dengan perintah:
\`uci set jsholat.sound.murf_api_key='API_KEY_ANDA'\`
\`uci commit jsholat\`

Atau kembali ke menu dan pilih metode lain."
        return 0
    fi
    
    # Jika memilih gemini tapi tidak ada API key, arahkan ke konfigurasi
    if [ "$method" = "gemini" ] && [ -z "$SOUND_GEMINI_API_KEY" ]; then
        send_message "$chat_id" "🔑 *Konfigurasi Gemini API Key*

Anda memilih metode Gemini yang membutuhkan API key.

Silakan atur API key melalui menu:
1. Pilih Gemini di menu TTS
2. Klik "Set API Key"
3. Masukkan API key Anda

Atau dengan perintah manual:
\`uci set jsholat.sound.gemini_api_key='API_KEY_ANDA'\`
\`uci commit jsholat\`"
        return 0
    fi
    
    uci set jsholat.sound.tts_method="$method"
    uci commit jsholat
    
    # Update variabel config
    SOUND_TTS_METHOD="$method"
    
    local method_name=""
    case "$method" in
        "google") method_name="Google Translate" ;;
        "edge") method_name="Edge-TTS" ;;
        "espeak") method_name="eSpeak" ;;
        "murf") method_name="Murf.ai" ;;
        "gemini") method_name="Gemini AI" ;;
    esac
    
    # Kembali ke menu TTS untuk menunjukkan perubahan
    show_tts_method_menu "$chat_id" "$message_id"
    log "Metode TTS diatur ke $method_name untuk chat_id=$chat_id"
}

# Fungsi untuk menampilkan menu pemilihan voice Edge-TTS
show_edge_voice_menu() {
    local chat_id="$1"
    local message_id="$2"
    
    # Baca voice yang sedang dipilih
    local current_voice=$(uci -q get jsholat.sound.edge_voice || echo "id-ID-ArdiNeural")
    
    # Fungsi helper untuk menampilkan emoji berdasarkan voice
    local ardi_emoji="🗣️"
    local gadis_emoji="👩"
    local dimas_emoji="👨‍🦰"
    local siti_emoji="👩‍🦰"
    
    # Tombol keyboard untuk pilihan voice (4 pilihan)
    local keyboard='[[
        {"text": "'$ardi_emoji' Ardi (Indonesia-Pria) '"$( [ "$current_voice" = "id-ID-ArdiNeural" ] && echo "✅" )"'", "callback_data": "set_edge_voice_ardi"}
    ],[
        {"text": "'$gadis_emoji' Gadis (Indonesia-Wanita) '"$( [ "$current_voice" = "id-ID-GadisNeural" ] && echo "✅" )"'", "callback_data": "set_edge_voice_gadis"}
    ],[
        {"text": "'$dimas_emoji' Dimas (Jawa-Pria) '"$( [ "$current_voice" = "jv-ID-DimasNeural" ] && echo "✅" )"'", "callback_data": "set_edge_voice_dimas"}
    ],[
        {"text": "'$siti_emoji' Siti (Jawa-Wanita) '"$( [ "$current_voice" = "jv-ID-SitiNeural" ] && echo "✅" )"'", "callback_data": "set_edge_voice_siti"}
    ],[
        {"text": "🔙 Kembali ke Menu TTS", "callback_data": "tts_menu"}
    ]]'
    
    # Tentukan nama voice yang sedang dipilih
    local current_voice_name=""
    case "$current_voice" in
        "id-ID-ArdiNeural")
            current_voice_name="Ardi (Indonesia-Pria)"
            ;;
        "id-ID-GadisNeural")
            current_voice_name="Gadis (Indonesia-Wanita)"
            ;;
        "jv-ID-DimasNeural")
            current_voice_name="Dimas (Jawa-Pria)"
            ;;
        "jv-ID-SitiNeural")
            current_voice_name="Siti (Jawa-Wanita)"
            ;;
        *)
            current_voice_name="$current_voice"
            ;;
    esac
    
    # Informasi voice
    local message=$(printf '🎤 *Pilih Voice untuk Edge-TTS*

*Voice Saat Ini:* %s

📝 *Deskripsi Voice:*

🗣️ *Ardi (id-ID-ArdiNeural)* — Suara pria dewasa bahasa Indonesia dengan intonasi yang tegas dan jelas. Cocok untuk pengumuman yang membutuhkan kesan formal dan berwibawa.

👩 *Gadis (id-ID-GadisNeural)* — Suara wanita muda bahasa Indonesia dengan artikulasi yang lembut dan natural. Cocok untuk pengingat yang bersahabat dan ramah.

👨‍🦰 *Dimas (jv-ID-DimasNeural)* — Suara pria bahasa Jawa dengan logat khas yang hangat. Cocok untuk daerah dengan budaya Jawa yang kental, memberikan nuansa lokal yang akrab.

👩‍🦰 *Siti (jv-ID-SitiNeural)* — Suara wanita bahasa Jawa dengan intonasi yang lembut dan santun. Sangat cocok untuk pengajian atau acara keagamaan di lingkungan Jawa.

⚡ Pilih voice yang paling sesuai dengan preferensi Anda. Perubahan akan langsung diterapkan setelah restart service.

💡 *Tips:* Gunakan tombol 🎧 Test TTS untuk mencoba suara setelah memilih voice.' \
"$current_voice_name")
    
    if [ -z "$message_id" ]; then
        send_inline_keyboard "$chat_id" "$message" "$keyboard"
    else
        edit_inline_keyboard "$chat_id" "$message_id" "$message" "$keyboard"
    fi
}

# Fungsi untuk mengatur voice Edge-TTS
set_edge_voice() {
    local chat_id="$1"
    local message_id="$2"
    local voice_type="$3"  # "ardi", "gadis", "dimas", atau "siti"
    
    local voice_value=""
    local voice_name=""
    local voice_emoji=""
    
    case "$voice_type" in
        "ardi")
            voice_value="id-ID-ArdiNeural"
            voice_name="Ardi (Indonesia-Pria)"
            voice_emoji="🗣️"
            ;;
        "gadis")
            voice_value="id-ID-GadisNeural"
            voice_name="Gadis (Indonesia-Wanita)"
            voice_emoji="👩"
            ;;
        "dimas")
            voice_value="jv-ID-DimasNeural"
            voice_name="Dimas (Jawa-Pria)"
            voice_emoji="👨‍🦰"
            ;;
        "siti")
            voice_value="jv-ID-SitiNeural"
            voice_name="Siti (Jawa-Wanita)"
            voice_emoji="👩‍🦰"
            ;;
        *)
            send_message "$chat_id" "❌ Pilihan voice tidak valid"
            return 1
            ;;
    esac
    
    # Simpan ke UCI
    uci set jsholat.sound.edge_voice="$voice_value"
    uci commit jsholat
    
    # Konfirmasi
    local message="✅ *Voice Edge-TTS diubah ke $voice_name*

Perubahan akan langsung diaktifkan.


🎧 *Ingin mencoba?* Gunakan tombol Test TTS di menu pengaturan."
    
    # Tampilkan menu voice dengan konfirmasi
    show_edge_voice_menu "$chat_id" "$message_id"
    
    # Kirim pesan terpisah untuk konfirmasi
    send_message "$chat_id" "$message"
    
    log "Voice Edge-TTS diubah ke $voice_name oleh chat_id=$chat_id"
}

