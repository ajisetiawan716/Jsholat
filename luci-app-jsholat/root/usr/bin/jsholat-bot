# Tambahkan fungsi delete_message
delete_message() {
    local chat_id="$1"
    local message_id="$2"
    
    curl -s -X POST \
        "https://api.telegram.org/bot${TELEGRAM_TOKEN}/deleteMessage" \
        -d chat_id="${chat_id}" \
        -d message_id="${message_id}" \
        > /dev/null 2>&1
}

# Fungsi untuk konversi waktu dengan detik ke total detik
time_to_seconds_with_sec() {
    local time_str=$1
    
    # Pastikan input tidak kosong
    if [ -z "$time_str" ]; then
        echo "0"
        return 1
    fi
    
    # Hapus semua karakter non-digit dan non-titik dua
    local clean_time=$(echo "$time_str" | tr -cd '0-9:')
    
    # Handle format HH:MM:SS atau HH:MM
    if echo "$clean_time" | grep -qE '^[0-9]{1,2}:[0-9]{2}:[0-9]{2}$'; then
        # Format HH:MM:SS
        local hours=${clean_time%%:*}
        local temp=${clean_time#*:}
        local minutes=${temp%%:*}
        local seconds=${temp#*:}
    elif echo "$clean_time" | grep -qE '^[0-9]{1,2}:[0-9]{2}$'; then
        # Format HH:MM
        local hours=${clean_time%:*}
        local minutes=${clean_time#*:}
        local seconds="00"
    else
        echo "0"
        return 1
    fi
    
    # Hilangkan leading zero
    hours=${hours#0}
    minutes=${minutes#0}
    seconds=${seconds#0}
    
    # Default ke 0 jika kosong
    [ -z "$hours" ] && hours=0
    [ -z "$minutes" ] && minutes=0
    [ -z "$seconds" ] && seconds=0
    
    # Validasi range
    if [ "$hours" -lt 0 ] || [ "$hours" -gt 23 ] || 
       [ "$minutes" -lt 0 ] || [ "$minutes" -gt 59 ] ||
       [ "$seconds" -lt 0 ] || [ "$seconds" -gt 59 ]; then
        echo "0"
        return 1
    fi
    
    echo $(( hours * 3600 + minutes * 60 + seconds ))
    return 0
}

# Fungsi untuk mendapatkan info sholat berikutnya dengan format jam, menit, detik
get_next_prayer_info() {
    local current_time="$1"
    local imsyak="$2"
    local subuh="$3"
    local dzuhur="$4"
    local ashar="$5"
    local magrib="$6"
    local isya="$7"
    
    # Konversi waktu sekarang ke detik
    local current_sec=$(time_to_seconds_with_sec "$current_time")
    local next_prayer=""
    local next_prayer_time=""
    local next_prayer_sec=""

    # Fungsi helper untuk cek waktu sholat berikutnya
    check_next_prayer() {
        local prayer_name="$1"
        local prayer_time="$2"
        # Konversi waktu sholat ke detik (format HH:MM tanpa detik)
        local prayer_sec=$(time_to_seconds_with_sec "$prayer_time")
        
        if [ "$prayer_sec" -gt "$current_sec" ]; then
            if [ -z "$next_prayer_time" ] || [ "$prayer_sec" -lt "$next_prayer_sec" ]; then
                next_prayer="$prayer_name"
                next_prayer_time="$prayer_time"
                next_prayer_sec="$prayer_sec"
            fi
        fi
    }
    
    # Cek semua waktu sholat
    check_next_prayer "Imsyak" "$imsyak"
    check_next_prayer "Subuh" "$subuh"
    check_next_prayer "Dzuhur" "$dzuhur"
    check_next_prayer "Ashar" "$ashar"
    check_next_prayer "Maghrib" "$magrib"
    check_next_prayer "Isya" "$isya"
    
    # Format info waktu berikutnya
    if [ -n "$next_prayer" ]; then
        local time_diff_sec=$(( next_prayer_sec - current_sec ))
        
        # Hitung jam, menit, detik
        local hours=$(( time_diff_sec / 3600 ))
        local minutes=$(( (time_diff_sec % 3600) / 60 ))
        local seconds=$(( time_diff_sec % 60 ))
        
        local next_info="⏳ *Sholat berikutnya*: $next_prayer pukul $next_prayer_time"
        
        # Format countdown berdasarkan durasi
        if [ "$hours" -gt 0 ]; then
            # Lebih dari 1 jam: 6j 25m 17d
            next_info+=" (${hours}j ${minutes}m ${seconds}d lagi)"
        elif [ "$minutes" -gt 0 ]; then
            # Kurang dari 1 jam: 25m 17d
            next_info+=" (${minutes}m ${seconds}d lagi)"
        else
            # Kurang dari 1 menit: 17d
            next_info+=" (${seconds}d lagi)"
        fi
        
        echo "$next_info"
    else
        # Jika sudah melewati semua sholat hari ini
        echo "⏳ *Sholat berikutnya*: Imsyak (besok pukul $imsyak)"
    fi
}

# Fungsi untuk menampilkan jadwal sholat hari ini dengan format JSON
show_daily_schedule() {
    local chat_id="$1"
    
    log "📅 Menampilkan jadwal harian untuk chat_id=$chat_id"
    
    # ============ INISIALISASI VARIABEL ============
    local day_name=$(date +"%A")
    local day_num=$(date +"%d")
    local month_num=$(date +"%m")
    local month_name=$(date +"%B")
    local year=$(date +"%Y")
    local today=$(date +"%d-%m-%Y")
    local timezone="$SCHEDULE_TIMEZONE"
    local jadwal_file="$SCHEDULE_FILE_JADWAL"
    
    # Waktu saat ini
    local current_time=$(date +"%H:%M:%S")
    local current_time_12h=$(date +"%I:%M:%S %p")
    
    # ============ VALIDASI FILE JADWAL ============
    if [ -z "$jadwal_file" ]; then
        log "ERROR: SCHEDULE_FILE_JADWAL kosong"
        send_message "$chat_id" "❌ Konfigurasi file jadwal tidak ditemukan."
        return 0
    fi
    
    if [ ! -f "$jadwal_file" ]; then
        log "ERROR: File jadwal tidak ditemukan: $jadwal_file"
        send_message "$chat_id" "❌ File jadwal tidak ditemukan. Silakan lakukan /update terlebih dahulu."
        return 0
    fi
    
    # Cek apakah file bisa dibaca
    if [ ! -r "$jadwal_file" ]; then
        log "ERROR: File jadwal tidak bisa dibaca: $jadwal_file"
        send_message "$chat_id" "❌ File jadwal tidak dapat diakses (izin baca)."
        return 0
    fi
    
    # Cek ukuran file
    local file_size=$(stat -c %s "$jadwal_file" 2>/dev/null || echo "0")
    if [ "$file_size" -eq 0 ]; then
        log "ERROR: File jadwal kosong: $jadwal_file"
        send_message "$chat_id" "❌ File jadwal kosong. Silakan lakukan /update."
        return 0
    fi
    
    # ============ CEK VALIDITAS JSON ============
    if ! jq empty "$jadwal_file" 2>/dev/null; then
        log "ERROR: File bukan JSON valid: $jadwal_file"
        
        # Baca 5 baris pertama untuk debugging
        if [ "$DEBUG_MODE" = "1" ]; then
            local first_lines=$(head -5 "$jadwal_file" 2>/dev/null | tr '\n' ' ' | sed 's/"/\\"/g')
            log "DEBUG: 5 baris pertama file: $first_lines"
        fi
        
        send_message "$chat_id" "❌ File jadwal rusak (bukan format JSON). Silakan lakukan /update."
        return 0
    fi
    
    # ============ AMBIL DATA UNTUK HARI INI ============
    local imsyak=""
    local subuh=""
    local dzuhur=""
    local ashar=""
    local magrib=""
    local isya=""
    local lokasi="${SCHEDULE_CITY_LABEL:-Tidak diketahui}"
    local provinsi="${SCHEDULE_PROVINCE:-Tidak diketahui}"
    
    # Cek struktur JSON (apakah array atau object)
    local json_type=$(jq -r 'type' "$jadwal_file" 2>/dev/null)
    
	if [ "$json_type" = "array" ]; then
		# Format array of objects
		local JSON_DATA=$(jq -c --arg t "$today" \
			'.[] | select(.gregorian_date == $t)' \
			"$jadwal_file" 2>/dev/null | head -1)
		
		# Jika tidak ditemukan, coba format tanggal lain
		if [ -z "$JSON_DATA" ] || [ "$JSON_DATA" = "null" ] || [ "$JSON_DATA" = "{" ]; then
			# Coba format dd/mm/yyyy
			local today_slash=$(date +"%d/%m/%Y")
			JSON_DATA=$(jq -c --arg t "$today_slash" \
				'.[] | select(.gregorian_date == $t)' \
				"$jadwal_file" 2>/dev/null | head -1)
		fi
		
		# Jika masih tidak ditemukan, ambil data pertama sebagai sample
		if [ -z "$JSON_DATA" ] || [ "$JSON_DATA" = "null" ] || [ "$JSON_DATA" = "{" ]; then
			JSON_DATA=$(jq -c '.[0]' "$jadwal_file" 2>/dev/null)
			log "⚠️ Menggunakan data pertama sebagai sample"
		fi
	fi

	# Validasi JSON_DATA
	if [ -z "$JSON_DATA" ] || [ "$JSON_DATA" = "null" ] || [ "$JSON_DATA" = "{" ] || [ ${#JSON_DATA} -lt 10 ]; then
		log "ERROR: Gagal mendapatkan data jadwal"
		send_message "$chat_id" "❌ Gagal membaca data jadwal. Silakan lakukan /update."
		return 0
	fi
    
    # ============ EKSTRAK DATA ============
    if [ -n "$JSON_DATA" ] && [ "$JSON_DATA" != "null" ]; then
        # Coba berbagai kemungkinan nama field
        imsyak=$(echo "$JSON_DATA" | jq -r '.imsyak // .Imsyak // .imsak // .Imsak // empty' 2>/dev/null)
        subuh=$(echo "$JSON_DATA" | jq -r '.subuh // .Subuh // .shubuh // .Shubuh // empty' 2>/dev/null)
        dzuhur=$(echo "$JSON_DATA" | jq -r '.dzuhur // .Dzuhur // .dhuhur // .Dhuhur // .zuhur // .Zuhur // empty' 2>/dev/null)
        ashar=$(echo "$JSON_DATA" | jq -r '.ashar // .Ashar // .asr // .Asr // empty' 2>/dev/null)
        magrib=$(echo "$JSON_DATA" | jq -r '.maghrib // .Maghrib // .magrib // .Magrib // empty' 2>/dev/null)
        isya=$(echo "$JSON_DATA" | jq -r '.isya // .Isya // .isha // .Isha // empty' 2>/dev/null)
        
        # Debug log
        if [ "$DEBUG_MODE" = "1" ]; then
            log "DEBUG: Data diekstrak - imsyak='$imsyak', subuh='$subuh', dzuhur='$dzuhur', ashar='$ashar', magrib='$magrib', isya='$isya'"
        fi
    else
        log "ERROR: Tidak ada data untuk tanggal $today dalam file jadwal"
        send_message "$chat_id" "❌ Jadwal sholat untuk hari ini ($today) tidak ditemukan. Silakan lakukan /update."
        return 0
    fi
    
    # ============ VALIDASI DATA ============
    local invalid_data=0
    local empty_fields=""
    local invalid_format_fields=""
    
    # Cek field kosong
    [ -z "$imsyak" ] && { invalid_data=1; empty_fields="${empty_fields} imsyak"; }
    [ -z "$subuh" ] && { invalid_data=1; empty_fields="${empty_fields} subuh"; }
    [ -z "$dzuhur" ] && { invalid_data=1; empty_fields="${empty_fields} dzuhur"; }
    [ -z "$ashar" ] && { invalid_data=1; empty_fields="${empty_fields} ashar"; }
    [ -z "$magrib" ] && { invalid_data=1; empty_fields="${empty_fields} maghrib"; }
    [ -z "$isya" ] && { invalid_data=1; empty_fields="${empty_fields} isya"; }
    
    # Jika ada field kosong, kirim pesan error dan return
    if [ $invalid_data -eq 1 ]; then
        log "ERROR: Field kosong:$empty_fields untuk tanggal $today"
        
        # Pesan error yang lebih informatif
        local error_msg="❌ *Data jadwal tidak lengkap*

Field yang kosong: \`$empty_fields\`

Kemungkinan penyebab:
• Sumber data mengalami masalah
• Proses update belum selesai
• Format data dari sumber berubah

Silakan lakukan /update untuk memperbaiki."

        send_message "$chat_id" "$error_msg"
        return 0
    fi
    
    # Validasi format waktu (HH:MM)
    for time_var in "imsyak:$imsyak" "subuh:$subuh" "dzuhur:$dzuhur" "ashar:$ashar" "magrib:$magrib" "isya:$isya"; do
        field_name="${time_var%%:*}"
        field_value="${time_var#*:}"
        
        if ! echo "$field_value" | grep -qE '^([0-1]?[0-9]|2[0-3]):[0-5][0-9]$'; then
            invalid_data=1
            invalid_format_fields="${invalid_format_fields} $field_name($field_value)"
        fi
    done
    
    # Jika ada format waktu tidak valid
    if [ $invalid_data -eq 1 ] && [ -n "$invalid_format_fields" ]; then
        log "ERROR: Format waktu tidak valid:$invalid_format_fields"
        
        local error_msg="❌ *Format waktu tidak valid*

Field bermasalah: \`$invalid_format_fields\`

Kemungkinan data dari sumber mengalami perubahan format.
Silakan lakukan /update untuk memperbaiki."

        send_message "$chat_id" "$error_msg"
        return 0
    fi
    
    # ============ AMBIL TANGGAL HIJRIYAH ============
    local hijri_date hijri_status
    hijri_date=$(get_hijri_date)
    hijri_status=$?
    
    local hijri_display=""
    if [ -n "$hijri_date" ]; then
        hijri_display="📅 *Hijriyah*: $hijri_date"
        if [ $hijri_status -ne 0 ]; then
            hijri_display+=" _(informasi tanggal mungkin tidak terupdate)_"
        fi
    else
        hijri_display="📅 *Hijriyah*: (tidak tersedia)"
    fi
    
    # ============ AMBIL INFO PEMBARUAN ============
    local last_updated="Tidak diketahui"
    local data_source="Tidak diketahui"
    local last_updated_file="/usr/share/jsholat/last_updated.txt"
    
    if [ -f "$last_updated_file" ] && [ -r "$last_updated_file" ]; then
        if command -v jq >/dev/null 2>&1; then
            last_updated=$(jq -r '.last_updated // "Tidak diketahui"' "$last_updated_file" 2>/dev/null)
            data_source=$(jq -r '.data_source // "Tidak diketahui"' "$last_updated_file" 2>/dev/null)
        else
            # Fallback sederhana
            last_updated=$(head -1 "$last_updated_file" 2>/dev/null | cut -d' ' -f1-2)
            data_source="Unknown"
        fi
    fi
    
    local update_info="🔄 Terakhir diperbarui: $last_updated"
    local source_info="🌐 Sumber: $data_source"
    
    # ============ TRANSLATE HARI DAN BULAN ============
    case "$day_name" in
        "Monday") day_name="Senin" ;;
        "Tuesday") day_name="Selasa" ;;
        "Wednesday") day_name="Rabu" ;;
        "Thursday") day_name="Kamis" ;;
        "Friday") day_name="Jumat" ;;
        "Saturday") day_name="Sabtu" ;;
        "Sunday") day_name="Ahad" ;;
    esac
    
    case "$month_name" in
        "January") month_name="Januari" ;;
        "February") month_name="Februari" ;;
        "March") month_name="Maret" ;;
        "April") month_name="April" ;;
        "May") month_name="Mei" ;;
        "June") month_name="Juni" ;;
        "July") month_name="Juli" ;;
        "August") month_name="Agustus" ;;
        "September") month_name="September" ;;
        "October") month_name="Oktober" ;;
        "November") month_name="November" ;;
        "December") month_name="Desember" ;;
    esac
    
    # ============ FORMAT TANGGAL ============
    local formatted_date="$day_name, $day_num $month_name $year"
    local timezone_display=""
    [ -n "$timezone" ] && timezone_display="($timezone)"
    
    # ============ HITUNG SHOLAT BERIKUTNYA ============
    local next_prayer_info=$(get_next_prayer_info "$current_time" "$imsyak" "$subuh" "$dzuhur" "$ashar" "$magrib" "$isya")
    
    # ============ KIRIM PESAN ============
    local message="🕌 *Jadwal Sholat Hari Ini*

📆 *Hari/Tanggal*: $formatted_date
🕒 *Waktu Sekarang*: $current_time / $current_time_12h
${hijri_display}
📍 *Wilayah*: $lokasi, $provinsi
🌐 *Zona Waktu*: $timezone

${next_prayer_info}

🌄 Imsyak: $imsyak $timezone_display
🌅 Subuh: $subuh $timezone_display
☀️ Dzuhur: $dzuhur $timezone_display
🌇 Ashar: $ashar $timezone_display
🌆 Maghrib: $magrib $timezone_display
🌃 Isya: $isya $timezone_display

$update_info
$source_info"

    send_message "$chat_id" "$message"
    
    if [ $? -eq 0 ]; then
        log "✅ Jadwal harian berhasil dikirim ke chat_id=$chat_id"
        return 0
    else
        log "❌ Gagal mengirim jadwal ke chat_id=$chat_id"
        return 0
    fi
}

