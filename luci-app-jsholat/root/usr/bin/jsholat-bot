    DEBUG_MODE=$(uci -q get jsholat.service.debug_mode || echo "0")
    SERVICE_AYAT_ENABLED=$(uci -q get jsholat.service.ayat_enabled || echo "0")

    # Section: sound - TTS settings
    SOUND_TTS_METHOD=$(uci -q get jsholat.sound.tts_method || echo "google")
    SOUND_REMINDER_SOUND_ENABLED=$(uci -q get jsholat.sound.reminder_sound_enabled || echo "0")
    SOUND_MURF_API_KEY=$(uci -q get jsholat.sound.murf_api_key || echo "")
    SOUND_REMINDER_REPEAT_COUNT=$(uci -q get jsholat.sound.reminder_repeat_count || echo "3")
    SOUND_REMINDER_REPEAT_INTERVAL=$(uci -q get jsholat.sound.reminder_repeat_interval || echo "5")

    # Section: sound - Gemini TTS settings 
    SOUND_GEMINI_API_KEY=$(uci -q get jsholat.sound.gemini_api_key || echo "")
    SOUND_GEMINI_MODEL=$(uci -q get jsholat.sound.gemini_model || echo "gemini-2.5-flash-preview-tts")
    SOUND_GEMINI_VOICE=$(uci -q get jsholat.sound.gemini_voice || echo "Zephyr")
	
	# Section: sound - Tarhim settings 
	SOUND_TARHIM_ENABLED=$(uci -q get jsholat.sound.tarhim_enabled || echo "0")
	SOUND_TARHIM_MODE=$(uci -q get jsholat.sound.tarhim_mode || echo "always")
	SOUND_TARHIM_FILE=$(uci -q get jsholat.sound.sound_adzan_imsy || echo "/usr/share/jsholat/tarhim.mp3")
	
	# Section: sound - Sahur settings 
	SOUND_SAHUR_ENABLED=$(uci -q get jsholat.sound.sahur_enabled || echo "0")
	SOUND_SAHUR_TIME=$(uci -q get jsholat.sound.sahur_time || echo "02:30")
}

# Panggil fungsi untuk load config
load_uci_config

# Validasi token (setelah load config)
[ -z "$TELEGRAM_TOKEN" ] && {
    log "ERROR: ❌ Token bot Telegram tidak ditemukan!"
    exit 1
}

# REGISTER COMMAND MENU 
register_bot_commands_silent() {
    log "🤖 Mendaftarkan 21 command menu (silent mode)..."
    
    # Hapus semua command dulu
    curl -s -X POST \
        "https://api.telegram.org/bot${TELEGRAM_TOKEN}/deleteMyCommands" \
        -H "Content-Type: application/json" \
        -d '{"scope": {"type": "default"}}' > /dev/null
    
    sleep 2
    
	local commands_json='{
		"commands": [
			{"command": "start", "description": "🚀 Mulai bot dan menu utama"},
			{"command": "jadwal", "description": "🕌 Jadwal sholat hari ini"},
			{"command": "jdwlbulan", "description": "📅 Jadwal sholat bulan ini"},
			{"command": "statusbot", "description": "🤖 Status detail bot"},
			{"command": "status", "description": "📊 Status singkat pengaturan"},
			{"command": "lokasi", "description": "📍 Lihat lokasi saat ini"},
			{"command": "setlokasi", "description": "🔍 Cari dan ubah lokasi"},
			{"command": "setjadwal", "description": "🌐 Ganti sumber jadwal"},
			{"command": "sethijri", "description": "📆 Koreksi tanggal Hijriyah"},
			{"command": "update", "description": "🔄 Update jadwal sholat"},
			{"command": "setvolume", "description": "🔊 Atur volume suara"},
			{"command": "detectaudio", "description": "🎛️ Deteksi mixer audio"},
			{"command": "reminder", "description": "🔔 Atur pengingat sholat"},
			{"command": "sahur", "description": "🌙 Atur alarm sahur Ramadhan"},   
			{"command": "settts", "description": "🗣️ Pilih metode TTS"},
			{"command": "gemini", "description": "🤖 Konfigurasi Gemini TTS"},
			{"command": "tarhim", "description": "🎵 Atur tarhim imsyak"},
			{"command": "ayat", "description": "📖 Atur ayat acak"},
			{"command": "control", "description": "🎮 Kontrol service"},
			{"command": "setupbot", "description": "🤖 Atur profil bot (nama, foto, bio)"},
			{"command": "help", "description": "❓ Bantuan daftar perintah"}
		]
	}'
    
    local response=$(curl -s -X POST \
        "https://api.telegram.org/bot${TELEGRAM_TOKEN}/setMyCommands" \
        -H "Content-Type: application/json" \
        -d "$commands_json")
    
    local ok=$(echo "$response" | jq -r '.ok')
    local result_var="failed"
    
    if [ "$ok" = "true" ]; then
        log "✅ Berhasil mendaftarkan 21 command menu"
        result_var="success"
        
        sleep 1
        local verify=$(curl -s "https://api.telegram.org/bot${TELEGRAM_TOKEN}/getMyCommands")
        local cmd_count=$(echo "$verify" | jq '.result | length')
        log "📊 Verifikasi: $cmd_count command terdaftar"
        
        if [ "$cmd_count" -lt 21 ]; then
            log "⚠️ Verifikasi gagal - hanya $cmd_count command"
            result_var="failed"
        fi
    else
        local error=$(echo "$response" | jq -r '.description')
        log "❌ Gagal mendaftarkan command menu: $error"
    fi
    
    echo "$result_var"
}

# FUNGSI VERIFIKASI COMMAND MENU
verify_bot_commands() {
    log "🔍 Memverifikasi command menu..."
    
    local response=$(curl -s "https://api.telegram.org/bot${TELEGRAM_TOKEN}/getMyCommands")
    local cmd_count=$(echo "$response" | jq '.result | length')
    local cmd_list=$(echo "$response" | jq -r '.result[].command' | tr '\n' ' ')
    
    log "📊 Command terdaftar: $cmd_count/21 - [$cmd_list]"
    
    if [ "$cmd_count" -ge 21 ]; then
        echo "success"
    else
        echo "failed"
    fi
}

