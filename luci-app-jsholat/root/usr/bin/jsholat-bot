# Fungsi untuk mendapatkan informasi memori sistem dengan format yang mudah dibaca
get_system_memory_info() {
    if [ -f "/proc/meminfo" ]; then
        local total_kb=$(grep -E '^MemTotal:' /proc/meminfo | awk '{print $2}')
        local available_kb=$(grep -E '^MemAvailable:' /proc/meminfo | awk '{print $2}')
        
        if [ -n "$total_kb" ] && [ -n "$available_kb" ]; then
            # Hitung memori terpakai
            local used_kb=$((total_kb - available_kb))
            
            # Fungsi untuk format human readable (tanpa bc)
            format_bytes_simple() {
                local bytes_kb=$1
                if [ $bytes_kb -ge 1048576 ]; then # 1024*1024 = 1GB in KB
                    local gb_int=$((bytes_kb / 1048576))
                    local gb_frac=$(( (bytes_kb % 1048576) / 10485 )) # approx 0.xx
                    echo "${gb_int}.${gb_frac} GB"
                elif [ $bytes_kb -ge 1024 ]; then # 1MB in KB
                    local mb_int=$((bytes_kb / 1024))
                    local mb_frac=$(( (bytes_kb % 1024) / 10 )) # approx 0.xx
                    echo "${mb_int}.${mb_frac} MB"
                else
                    echo "${bytes_kb} KB"
                fi
            }
            
            # Format total dan used dalam GB/MB
            local total_human=""
            local used_human=""
            
            if [ $total_kb -ge 1048576 ]; then # > 1GB
                total_human="$((total_kb / 1048576)).$(( (total_kb % 1048576) / 10485 )) GB"
                used_human="$((used_kb / 1048576)).$(( (used_kb % 1048576) / 10485 )) GB"
            elif [ $total_kb -ge 1024 ]; then # > 1MB
                total_human="$((total_kb / 1024)).$(( (total_kb % 1024) / 10 )) MB"
                used_human="$((used_kb / 1024)).$(( (used_kb % 1024) / 10 )) MB"
            else
                total_human="${total_kb} KB"
                used_human="${used_kb} KB"
            fi
            
            # Hitung persentase
            local used_percent=0
            if [ "$total_kb" -gt 0 ]; then
                used_percent=$(( (used_kb * 100) / total_kb ))
            fi
            
            echo "💽 *Memori Sistem*: ${used_human} / ${total_human} (${used_percent}%)"
        else
            echo "💽 *Memori Sistem*: Informasi tidak tersedia"
        fi
    else
        echo "💽 *Memori Sistem*: Informasi tidak tersedia"
    fi
}

# Fungsi untuk menampilkan status detail bot di Telegram
show_bot_status() {
    local chat_id="$1"
    local message_id="$2"
    
    # Dapatkan status dari fungsi get_bot_status
    local status_json=$(get_bot_status)
    local status=$(echo "$status_json" | jq -r '.status // empty' 2>/dev/null)
    
    # Jika tidak ada jq, gunakan parsing sederhana
    if [ -z "$status" ]; then
        status=$(echo "$status_json" | grep -o '"status":"[^"]*"' | cut -d'"' -f4)
    fi
    
    if [ "$status" = "running" ]; then
        # Extract data dari JSON dengan default values
        local pid=$(echo "$status_json" | jq -r '.pid // ""' 2>/dev/null || echo "")
        local uptime=$(echo "$status_json" | jq -r '.uptime // ""' 2>/dev/null || echo "")
        local start_time=$(echo "$status_json" | jq -r '.start_time // ""' 2>/dev/null || echo "")
        local memory_usage=$(echo "$status_json" | jq -r '.memory_usage // ""' 2>/dev/null || echo "")
        local memory_percent=$(echo "$status_json" | jq -r '.memory_percent // ""' 2>/dev/null || echo "")
        local location=$(echo "$status_json" | jq -r '.location // ""' 2>/dev/null || echo "")
        local timezone=$(echo "$status_json" | jq -r '.timezone // ""' 2>/dev/null || echo "")
        local source=$(echo "$status_json" | jq -r '.source // ""' 2>/dev/null || echo "")
        local hijri_adjust=$(echo "$status_json" | jq -r '.hijri_adjust // ""' 2>/dev/null || echo "")
        
        # Ambil nilai dari variabel config yang sudah di-load
        local gemini_api_key="$SOUND_GEMINI_API_KEY"
        local gemini_voice="$SOUND_GEMINI_VOICE"
        local gemini_model="$SOUND_GEMINI_MODEL"
        
        # Jika gagal parse dengan jq, coba manual parsing
        if [ -z "$hijri_adjust" ]; then
            hijri_adjust=$(echo "$status_json" | grep -o '"hijri_adjust":"[^"]*"' | cut -d'"' -f4)
        fi
        
        # Jika masih kosong, ambil dari variabel config langsung
        if [ -z "$hijri_adjust" ]; then
            hijri_adjust="$SCHEDULE_HIJRI_ADJUST"
        fi
        
        # Konversi sumber
        local source_name=""
        case "$source" in
            "jadwalsholat") source_name="JadwalSholat.org" ;;
            "aladhan") source_name="AlAdhan API" ;;
            "arina") source_name="Arina.Id" ;;
            "equranid") source_name="Equran.Id" ;;
            "myquran") source_name="MyQuran API" ;;
            "apiajimedia") source_name="AjiMedia API" ;;
            *) source_name="$source" ;;
        esac
        
        # ============ STATUS SERVICE ============
        local service_status=$([ "$SERVICE_ENABLED" = "1" ] && echo "🟢 AKTIF" || echo "🔴 NONAKTIF")
        local sound_status=$([ "$SOUND_ENABLED" = "1" ] && echo "🟢 AKTIF" || echo "🔴 NONAKTIF")
        
        # ============ STATUS NOTIFIKASI TELEGRAM (INFO UMUM) ============
        local telegram_status=$([ "$SERVICE_TELEGRAM_ENABLED" = "1" ] && echo "🟢 AKTIF" || echo "🔴 NONAKTIF")
        
        # Info pengiriman pesan (umum)
        local notifikasi_umum=""
        if [ "$SERVICE_TELEGRAM_ENABLED" = "1" ]; then
            notifikasi_umum="✅ Semua notifikasi waktu sholat"
        else
            notifikasi_umum="❌ Tidak ada notifikasi yang dikirim"
        fi
        
        # ============ STATUS REMINDER ============
        local reminder_status="🔴 NONAKTIF"
        if [ "$SOUND_REMINDER_BEFORE" != "0" ]; then
            reminder_status="🟢 AKTIF (${SOUND_REMINDER_BEFORE}m)"
        fi
        
        # ============ STATUS TTS ============
        local tts_status_display="🔴 NONAKTIF"
        local tts_method_display=""
        
        if [ "$SOUND_REMINDER_SOUND_ENABLED" = "1" ]; then
            case "$SOUND_TTS_METHOD" in
                "google") 
                    tts_method_display="Google"
                    ;;
                "edge") 
                    tts_method_display="Edge-TTS"
                    ;;
                "espeak") 
                    tts_method_display="eSpeak"
                    ;;
                "murf") 
                    tts_method_display="Murf.ai"
                    if [ -n "$SOUND_MURF_API_KEY" ]; then
                        tts_method_display="Murf.ai (✅ API key)"
                    else
                        tts_method_display="Murf.ai (❌ no API key)"
                    fi
                    ;;
                "gemini") 
                    if [ -n "$gemini_api_key" ]; then
                        tts_method_display="Gemini AI (${gemini_voice})"
                    else
                        tts_method_display="Gemini AI (❌ no API key)"
                    fi
                    ;;
                *) 
                    tts_method_display="$SOUND_TTS_METHOD"
                    ;;
            esac
            tts_status_display="🟢 AKTIF ($tts_method_display)"
        fi
        
        # ============ STATUS TARHIM DENGAN PERILAKU TTS ============
        local tarhim_status="🔴 NONAKTIF"
        local tarhim_mode_display=""
        local tts_imsyak_info=""
        
        if [ "$SOUND_TARHIM_ENABLED" = "1" ]; then
            case "$SOUND_TARHIM_MODE" in
                "always")
                    tarhim_mode_display="Setiap Hari"
                    tts_imsyak_info="🔊 TTS Imsyak: AKTIF setiap hari"
                    ;;
                "ramadhan_only")
                    tarhim_mode_display="Hanya Ramadhan"
                    # Cek status Ramadhan untuk info TTS
                    if is_ramadhan; then
                        tts_imsyak_info="🔊 TTS Imsyak: AKTIF (sedang Ramadhan)"
                    else
                        tts_imsyak_info="🔊 TTS Imsyak: NONAKTIF (bukan Ramadhan, tarhim tetap diputar)"
                    fi
                    ;;
                *)
                    tarhim_mode_display="$SOUND_TARHIM_MODE"
                    tts_imsyak_info="⚠️ Mode tidak dikenal"
                    ;;
            esac
            tarhim_status="🟢 AKTIF"
        else
            tarhim_mode_display="-"
            tts_imsyak_info="🔊 TTS Imsyak: NONAKTIF (tarhim dimatikan)"
        fi
        
        # ============ STATUS AYAT ============
        local ayat_status=$([ "$SERVICE_AYAT_ENABLED" = "1" ] && echo "🟢 AKTIF" || echo "🔴 NONAKTIF")
        
        # ============ STATUS PENGULANGAN REMINDER ============
        local repeat_count="$SOUND_REMINDER_REPEAT_COUNT"
        local repeat_interval="$SOUND_REMINDER_REPEAT_INTERVAL"
        local repeat_status="⚙️ ${repeat_count}x Ulang (Interval ${repeat_interval}s)"
        [ "$SOUND_REMINDER_BEFORE" = "0" ] && repeat_status="⚙️ - (reminder off)"
        
        # ============ STATUS VOLUME DETAIL ============
        local volume_detail="🔊 ${SOUND_VOLUME_LEVEL}% (${SOUND_VOLUME_CONTROL})"
        
        # ============ STATUS FILE AUDIO ============
        local adzan_file_status=""
        if [ -f "$SOUND_ADZAN" ]; then
            adzan_file_status="✅"
        else
            adzan_file_status="❌"
        fi
        
        local adzan_subuh_file_status=""
        if [ -f "$SOUND_ADZAN_SHUBUH" ]; then
            adzan_subuh_file_status="✅"
        else
            adzan_subuh_file_status="❌"
        fi
        
        local tarhim_file_status=""
        if [ -f "$SOUND_TARHIM_FILE" ]; then
            tarhim_file_status="✅"
        else
            tarhim_file_status="❌"
        fi
        
        # ============ STATUS SUMBER JADWAL & INTERVAL ============
        local schedule_interval="$SCHEDULE_INTERVAL"
        local interval_display=""
        case "$schedule_interval" in
            "0") interval_display="Tidak Otomatis" ;;
            "3600") interval_display="Setiap Jam" ;;
            "86400") interval_display="Setiap Hari" ;;
            "604800") interval_display="Setiap Minggu" ;;
            "monthly_special") interval_display="Setiap Bulan" ;;
            *) interval_display="$schedule_interval" ;;
        esac
        
        # ============ STATUS LAST UPDATE JADWAL ============
        local last_updated="Tidak diketahui"
        local last_updated_file="/usr/share/jsholat/last_updated.txt"
        if [ -f "$last_updated_file" ]; then
            if command -v jq >/dev/null 2>&1; then
                last_updated=$(jq -r '.last_updated // ""' "$last_updated_file" 2>/dev/null)
                [ -z "$last_updated" ] && last_updated="Tidak diketahui"
            fi
        fi
        
        # ============ STATUS API KEY MURF ============
        local murf_status="❌ Belum Dikonfigurasi"
        if [ -n "$SOUND_MURF_API_KEY" ]; then
            murf_status="✅ Terkonfigurasi"
        fi
        
        # ============ STATUS API KEY GEMINI ============
        local gemini_status="❌ Belum Dikonfigurasi"
        if [ -n "$gemini_api_key" ]; then
            # Tampilkan hanya 4 karakter pertama dan terakhir
            local masked_key="${gemini_api_key:0:4}...${gemini_api_key: -4}"
            gemini_status="✅ Terkonfigurasi (${masked_key})"
        fi
        
        # ============ STATUS CACHE HIJRIYAH ============
        local hijri_cache_status="❌ Tidak ada"
        local hijri_cache_file="/tmp/jsholat_cache/hijri_date_cache.json"
        if [ -f "$hijri_cache_file" ]; then
            local cache_time=$(jq -r '.cache_time' "$hijri_cache_file" 2>/dev/null)
            if [ -n "$cache_time" ]; then
                local now=$(date +%s)
                local cache_age=$((now - cache_time))
                local cache_age_min=$((cache_age / 60))
                hijri_cache_status="✅ ${cache_age_min} menit lalu"
            fi
        fi
        
        # ============ STATUS RAMADHAN SAAT INI ============
        local ramadhan_status="📅 Bukan Ramadhan"
        if is_ramadhan; then
            local hijri_date=$(get_hijri_date)
            ramadhan_status="🌙 *RAMADHAN* - $hijri_date"
        fi
        
        # Format info memori bot
        local memory_info="💾 *Memori Bot*: ${memory_usage}"
        if [ -n "$memory_percent" ] && [ "$memory_percent" != "0" ]; then
            memory_info+=" (${memory_percent}%)"
        fi
        
        # Dapatkan info memori sistem
        local system_memory_info=$(get_system_memory_info)
        
        # Log info
        local log_info=""
        if [ -f "$LOG_FILE" ]; then
            local log_lines=$(wc -l < "$LOG_FILE" 2>/dev/null || echo "0")
            local log_size=$(du -h "$LOG_FILE" 2>/dev/null | cut -f1 || echo "0B")
            log_info="📊 *Log File*: ${log_lines} baris (${log_size})"
        fi
        
        # Waktu server
        local server_time=$(date +"%Y-%m-%d %H:%M:%S %Z")
        
        # ============ FORMAT PESAN STATUS LENGKAP (DENGAN NOTIFIKASI UMUM) ============
        local status_message=$(printf '🤖 *STATUS BOT JSHOLAT - DETAIL LENGKAP*

🟢 *STATUS PROSES*
┌──────────────────────
│⏱  *Uptime*: %s
│🔢  *PID*: %s
│⏰  *Start Time*: %s
│%s
│%s
└──────────────────────

📍 *LOKASI & JADWAL*
┌──────────────────────
│🏙️  *Wilayah*: %s
│🌐  *Zona Waktu*: %s
│📡  *Sumber Jadwal*: %s
│🔄  *Interval Update*: %s
│📅  *Update Terakhir*: %s
│📆  *Adjust Hijriyah*: %s
│🗂️  *Cache Hijriyah*: %s
└──────────────────────

🌙 *STATUS RAMADHAN*
┌──────────────────────
│%s
└──────────────────────

⚙️ *KONFIGURASI SERVICE*
┌──────────────────────
│🛠️  *Service Utama*: %s
│🔊  *Suara Adzan*: %s
│📖  *Ayat Acak*: %s
└──────────────────────

📢 *NOTIFIKASI TELEGRAM* (INFO UMUM)
┌──────────────────────
│🤖  *Status Fitur*: %s
│📨  *Pengiriman Pesan*: %s
└──────────────────────

🔔 *PENGATURAN REMINDER*
┌──────────────────────
│⏰  *Durasi*: %s
│🔄  *Pengulangan*: %s
│🗣️  *Suara TTS*: %s
│🔑  *Murf.ai API*: %s
│🤖  *Gemini AI API*: %s
└──────────────────────

🎵 *PENGATURAN TARHIM & IMSYAK*
┌──────────────────────
│🔊  *Status Tarhim*: %s
│📅  *Mode Tarhim*: %s
│🔔  *Perilaku TTS Imsyak*: %s
│📁  *File Suara*: %s
└──────────────────────

🔊 *PENGATURAN AUDIO*
┌──────────────────────
│📊  *Volume*: %s
│🎛️  *Mixer Device*: %s
│📀  *File Adzan*: %s
│🌅  *File Adzan Subuh*: %s
└──────────────────────

%s
🕒 *Waktu Server*: %s
🆔 *Last Update ID*: %s' \
"$uptime" "$pid" "$start_time" "$memory_info" "$system_memory_info" \
"$location" "$timezone" "$source_name" "$interval_display" "$last_updated" \
"$hijri_adjust" "$hijri_cache_status" \
"$ramadhan_status" \
"$service_status" "$sound_status" "$ayat_status" \
"$telegram_status" \
"$notifikasi_umum" \
"$reminder_status" "$repeat_status" "$tts_status_display" "$murf_status" "$gemini_status" \
"$tarhim_status" "$tarhim_mode_display" "$tts_imsyak_info" "$tarhim_file_status" \
"$volume_detail" "$SOUND_MIXER_DEVICE" "$adzan_file_status" "$adzan_subuh_file_status" \
"$log_info" "$server_time" "$LAST_UPDATE_ID")
        
    else
        # Bot stopped
        local status_message="🔴 *STATUS BOT JSHOLAT*

❌ *STATUS*: BERHENTI

ℹ️ Bot saat ini tidak berjalan.
Gunakan /control untuk mengaktifkannya kembali.

🕒 *Waktu Server*: $(date +"%Y-%m-%d %H:%M:%S %Z")"
    fi
    
    # Kirim atau edit pesan
    if [ -z "$message_id" ]; then
        send_message "$chat_id" "$status_message"
    else
        curl -s -X POST \
            "https://api.telegram.org/bot${TELEGRAM_TOKEN}/editMessageText" \
            -d chat_id="${chat_id}" \
            -d message_id="${message_id}" \
            -d text="${status_message}" \
            -d parse_mode="Markdown" \
            > /dev/null 2>&1
    fi
}

# FUNGSI MENAMPILKAN STATUS SINGKAT (/status)
show_short_status() {
    local chat_id="$1"
    local message_id="$2"
    
    # Load config terbaru
    load_uci_config
    
    # ============ AMBIL SEMUA VARIABEL STATUS ============
    
    # Lokasi & Wilayah
    local city_label="$SCHEDULE_CITY_LABEL"
    local province="$SCHEDULE_PROVINCE"
    local timezone="$SCHEDULE_TIMEZONE"
    
    # Jadwal & Sumber
    local source="$SCHEDULE_SOURCE"
    local interval="$SCHEDULE_INTERVAL"
    local hijri_adj="$SCHEDULE_HIJRI_ADJUST"
    
    # Service & Notifikasi
    local service_status="$SERVICE_ENABLED"
    local sound_status="$SOUND_ENABLED"
    local telegram_status="$SERVICE_TELEGRAM_ENABLED"
    local ayat_status="$SERVICE_AYAT_ENABLED"
    
    # Reminder Durasi
    local reminder_before="$SOUND_REMINDER_BEFORE"
    
    # TTS Settings
    local tts_enabled="$SOUND_REMINDER_SOUND_ENABLED"
    local tts_method="$SOUND_TTS_METHOD"
    local repeat_count="$SOUND_REMINDER_REPEAT_COUNT"
    local repeat_interval="$SOUND_REMINDER_REPEAT_INTERVAL"
    local gemini_api_key="$SOUND_GEMINI_API_KEY"  
    local gemini_voice="$SOUND_GEMINI_VOICE"      	
    
    # Tarhim Settings
    local tarhim_enabled="$SOUND_TARHIM_ENABLED"
    local tarhim_mode="$SOUND_TARHIM_MODE"
    
    # Audio Settings
    local volume_level="$SOUND_VOLUME_LEVEL"
    local volume_control="$SOUND_VOLUME_CONTROL"
    local mixer_device="$SOUND_MIXER_DEVICE"
    
    # ============ KONVERSI STATUS KE HUMAN READABLE ============
    
    # Service status
    local service_text=$([ "$service_status" = "1" ] && echo "🟢 AKTIF" || echo "🔴 NONAKTIF")
    local sound_text=$([ "$sound_status" = "1" ] && echo "🟢 AKTIF" || echo "🔴 NONAKTIF")
    local telegram_text=$([ "$telegram_status" = "1" ] && echo "🟢 AKTIF" || echo "🔴 NONAKTIF")
    local ayat_text=$([ "$ayat_status" = "1" ] && echo "🟢 AKTIF" || echo "🔴 NONAKTIF")
    local tts_text=$([ "$tts_enabled" = "1" ] && echo "🟢 AKTIF" || echo "🔴 NONAKTIF")
    local tarhim_text=$([ "$tarhim_enabled" = "1" ] && echo "🟢 AKTIF" || echo "🔴 NONAKTIF")
    
    # Status notifikasi umum (berdasarkan telegram_status)
    local notifikasi_umum=""
    if [ "$telegram_status" = "1" ]; then
        notifikasi_umum="✅ Semua notifikasi waktu sholat terkirim"
    else
        notifikasi_umum="❌ Tidak ada notifikasi yang dikirim"
    fi
    
    # Reminder status
    local reminder_text=""
    if [ "$reminder_before" = "0" ]; then
        reminder_text="🔴 NONAKTIF"
    else
        reminder_text="🟢 AKTIF (${reminder_before} menit)"
    fi
    
    # Convert sumber jadwal
    local source_name=""
    case "$source" in
        "jadwalsholat") source_name="JadwalSholat.org" ;;
        "aladhan") source_name="AlAdhan API" ;;
        "arina") source_name="Arina.Id" ;;
        "equranid") source_name="Equran.Id" ;;
        "myquran") source_name="MyQuran API" ;;
        "apiajimedia") source_name="AjiMedia API" ;;
        *) source_name="$source" ;;
    esac
    
    # Convert interval update
    local interval_name=""
    case "$interval" in
        "0") interval_name="❌ Tidak Otomatis" ;;
        "3600") interval_name="🕐 Setiap Jam" ;;
        "86400") interval_name="📆 Setiap Hari" ;;
        "604800") interval_name="📅 Setiap Minggu" ;;
        "monthly_special") interval_name="🗓️ Setiap Bulan" ;;
        *) interval_name="❓ Tidak diketahui" ;;
    esac
    
    # Convert metode TTS
    local tts_method_name=""
    local gemini_info=""
    case "$tts_method" in
        "google") tts_method_name="Google" ;;
        "edge") tts_method_name="Edge-TTS" ;;
        "espeak") tts_method_name="eSpeak" ;;
        "murf") tts_method_name="Murf.ai" ;;
        "gemini") 
            tts_method_name="Gemini AI"
            if [ -n "$gemini_api_key" ]; then
                gemini_info=" (${gemini_voice})"
            else
                gemini_info=" (no API key)"
            fi
            ;;
        *) tts_method_name="$tts_method" ;;
    esac
    tts_method_name="${tts_method_name}${gemini_info}"
    
    # ============ STATUS TARHIM DENGAN PERILAKU TTS IMSYAK ============
    
    # Mode tarhim display name
    local tarhim_mode_name=""
    case "$tarhim_mode" in
        "always") tarhim_mode_name="Setiap Hari" ;;
        "ramadhan_only") tarhim_mode_name="Hanya Ramadhan" ;;
        *) tarhim_mode_name="$tarhim_mode" ;;
    esac
    
    # Perilaku TTS Imsyak berdasarkan mode dan status Ramadhan
    local tts_imsyak_info=""
    if [ "$tarhim_enabled" = "1" ]; then
        case "$tarhim_mode" in
            "always")
                tts_imsyak_info="🔊 TTS Imsyak: AKTIF setiap hari"
                ;;
            "ramadhan_only")
                if is_ramadhan; then
                    tts_imsyak_info="🔊 TTS Imsyak: AKTIF (sedang Ramadhan)"
                else
                    tts_imsyak_info="🔊 TTS Imsyak: NONAKTIF (bukan Ramadhan, tarhim tetap diputar)"
                fi
                ;;
            *)
                tts_imsyak_info="⚠️ Perilaku TTS tidak dikenal"
                ;;
        esac
    else
        tts_imsyak_info="🔊 TTS Imsyak: NONAKTIF (tarhim dimatikan)"
    fi
    
    # Format pengulangan reminder
    local repeat_text=""
    if [ "$reminder_before" = "0" ]; then
        repeat_text="⚙️ - (reminder off)"
    else
        repeat_text="⚙️ ${repeat_count}x (${repeat_interval}s)"
        [ "$repeat_count" = "1" ] && repeat_text="⚙️ 1x (tanpa interval)"
    fi
    
    # Format volume
    local volume_text="🔊 ${volume_level}%"
    case "$volume_control" in
        "hardware") volume_text="${volume_text} (🔧 Hardware)" ;;
        "software") volume_text="${volume_text} (💻 Software)" ;;
        *) volume_text="${volume_text} (${volume_control})" ;;
    esac
    
    # ============ CEK STATUS FILE AUDIO ============
    local adzan_file_status="✅"
    local adzan_subuh_file_status="✅"
    local tarhim_file_status="✅"
    
    [ ! -f "$SOUND_ADZAN" ] && adzan_file_status="❌"
    [ ! -f "$SOUND_ADZAN_SHUBUH" ] && adzan_subuh_file_status="❌"
    [ ! -f "$SOUND_TARHIM_FILE" ] && tarhim_file_status="❌"
    
    # ============ CEK STATUS RAMADHAN ============
    local ramadhan_icon=""
    if is_ramadhan; then
        ramadhan_icon="🌙 *Ramadhan* • "
    else
        ramadhan_icon=""
    fi
    
    # ============ FORMAT PESAN STATUS SINGKAT ============
    local status_message
    status_message=$(printf '%s📊 *STATUS PENGATURAN JSHOLAT*

📍 *LOKASI & WAKTU*
┌──────────────────────
│🏙️ Wilayah: *%s, %s*
│🕒 Zona: *%s*
│🔄 Update: %s
│🌐 Sumber: *%s*
│📆 Adjust Hijri: *%s*
└──────────────────────

⚙️ *SERVICE & NOTIFIKASI*
┌──────────────────────
│🛠️ Service: %s
│🔊 Adzan: %s
│🤖 Telegram: %s
│📨 Notifikasi: %s
│📖 Ayat Acak: %s
└──────────────────────

🔔 *REMINDER SHOLAT*
┌──────────────────────
│⏰ Durasi: %s
│🗣️ Suara TTS: %s
│🎤 Metode: *%s*
│🔄 Pengulangan: %s
└──────────────────────

🎵 *TARHIM IMSYAK*
┌──────────────────────
│🔊 Status Tarhim: %s
│📅 Mode Tarhim: %s
│🔔 Perilaku TTS Imsyak: %s
│📁 File Suara: %s
└──────────────────────

🔊 *AUDIO*
┌──────────────────────
│📊 Volume: %s
│🎛️ Mixer: *%s*
│📀 Adzan: %s
│🌅 Adzan Subuh: %s
└──────────────────────

💡 *Info*: Gunakan /statusbot untuk detail lebih lengkap
🕒 *Update*: %s' \
"$ramadhan_icon" \
"$city_label" "$province" \
"$timezone" \
"$interval_name" \
"$source_name" \
"$hijri_adj" \
"$service_text" \
"$sound_text" \
"$telegram_text" \
"$notifikasi_umum" \
"$ayat_text" \
"$reminder_text" \
"$tts_text" \
"$tts_method_name" \
"$repeat_text" \
"$tarhim_text" \
"$tarhim_mode_name" \
"$tts_imsyak_info" \
"$tarhim_file_status" \
"$volume_text" \
"$mixer_device" \
"$adzan_file_status" \
"$adzan_subuh_file_status" \
"$(date +'%H:%M:%S %Z')")
    
    # ============ KIRIM PESAN ============
    if [ -z "$message_id" ]; then
        # Kirim pesan baru
        send_message "$chat_id" "$status_message"
    else
        # Edit pesan yang sudah ada
        curl -s -X POST \
            "https://api.telegram.org/bot${TELEGRAM_TOKEN}/editMessageText" \
            -d chat_id="${chat_id}" \
            -d message_id="${message_id}" \
            -d text="${status_message}" \
            -d parse_mode="Markdown" \
            > /dev/null 2>&1
    fi
    
    log "📊 Status singkat ditampilkan untuk chat_id=$chat_id"
}

# Fungsi update jadwal manual - Versi dengan log terpisah
run_update_background() {
    local chat_id="$1"
    local msg_id="$2"
    local token="$3"
    
    # Fungsi untuk update progress
    update_progress() {
        local text="$1"
        curl -s -X POST \
            "https://api.telegram.org/bot${token}/editMessageText" \
            -d chat_id="${chat_id}" \
            -d message_id="${msg_id}" \
            -d text="$text" \
            -d parse_mode="Markdown" \
            > /dev/null 2>&1
    }
    
    # Update progress pertama
    update_progress "🔄 *Memulai update jadwal...*"
    
    # Buat file log sementara dengan nama UNIK (pakai PID dan timestamp)
    local log_file="/tmp/jsholat_update_${chat_id}_$$_$(date +%s).log"
    local line_count=0
    
    # Jalankan update dan proses output secara REAL-TIME
    /usr/bin/jadwal-update.sh 2>&1 | while IFS= read -r line; do
        if [ -n "$line" ]; then
            # Simpan ke log
            echo "$line" >> "$log_file"
            line_count=$((line_count + 1))
            
            # Tampilkan di Telegram (real-time)
            if [ $((line_count % 2)) -eq 0 ] || \
               echo "$line" | grep -qi "error\|gagal\|berhasil\|selesai\|update"; then
                if ! echo "$line" | grep -q "Ping gagal"; then
                    update_progress "$(printf '🔄 *Memperbarui jadwal...*\n\n%s' "$line")"
                fi
            fi
        fi
    done
    
    # Tentukan pesan akhir berdasarkan output di file log INI (bukan file lama)
    if grep -q "✅ Jadwal sholat berhasil diperbarui" "$log_file"; then
        # UPDATE BERHASIL
        local important_lines=$(grep -E "Memulai update dari sumber|Mengambil jadwal|✅ Jadwal sholat berhasil diperbarui|Update berhasil|Service berhasil" "$log_file" | tail -10)
        update_progress "$(printf '✅ *Jadwal Sholat Berhasil Diperbarui*\n\n📋 *Ringkasan:*\n```\n%s\n```' "$important_lines")"
        
    elif grep -q "Jadwal masih valid" "$log_file"; then
        # JADWAL MASIH VALID
        local last_check=$(grep "Jadwal masih valid" "$log_file" | tail -1)
        update_progress "$(printf 'ℹ️ *Jadwal Masih Valid*\n\n%s' "$last_check")"
        
    elif grep -q "ERROR\|Gagal" "$log_file" | grep -v "Ping gagal"; then
        # ERROR
        local error_lines=$(grep -E "ERROR|Gagal" "$log_file" | grep -v "Ping gagal" | tail -5)
        if [ -n "$error_lines" ]; then
            update_progress "$(printf '❌ *Gagal Memperbarui Jadwal*\n\n*Error:*\n```\n%s\n```' "$error_lines")"
        else
            update_progress "❌ *Gagal Memperbarui Jadwal*\n\nCek log untuk detail."
        fi
        
    else
        # KONDISI LAIN
        local last_lines=$(tail -5 "$log_file")
        if [ -n "$last_lines" ]; then
            update_progress "$(printf 'ℹ️ *Hasil Update*\n\n```\n%s\n```' "$last_lines")"
        else
            update_progress "✅ *Proses selesai*"
        fi
    fi
    
    # Hapus keyboard
    curl -s -X POST \
        "https://api.telegram.org/bot${token}/editMessageReplyMarkup" \
        -d chat_id="${chat_id}" \
        -d message_id="${msg_id}" \
        -d reply_markup='{"inline_keyboard":[]}' \
        > /dev/null 2>&1
    
    # Bersihkan log setelah 5 menit
    (
        sleep 300
        rm -f "$log_file"
    ) &
}

# Fungsi proses pesan
process_message() {
    local chat_id="$1"
    local text="$2"
    local message_data="$3"
    local success=0
    
    # Cek authorization
    if ! check_authorization "$chat_id"; then
        send_message "$chat_id" "⛔ This is a private bot. If you want to implement one for you, check this out https://www.ajisetiawan.com/projects/jsholat"
        log "⛔ Percobaan akses dari chat ID tidak terdaftar: $chat_id"
        return 1
    fi
	
    # HANDLER KHUSUS UNTUK FOTO - PRIORITAS UTAMA!
    if [ -f "/tmp/jsholat_bot_setup/${chat_id}.flag" ]; then
        local flag=$(cat "/tmp/jsholat_bot_setup/${chat_id}.flag" 2>/dev/null)
		
        # Handler untuk Gemini API key
        if [ "$flag" = "waiting_gemini_api_key" ]; then
            if [ -n "$text" ]; then
                gemini_set_api_key_process "$chat_id" "$text"
                log "Gemini API key diproses untuk chat_id=$chat_id"
                return 0
            fi
        fi
        
        # Handler untuk input waktu sahur
        if [ "$flag" = "waiting_sahur_time" ]; then
            if [ "$text" = "/" ] || [ "$text" = "/cancel" ] || [ "$text" = "batal" ] || [ "$text" = "Batal" ]; then
                rm -f "/tmp/jsholat_bot_setup/${chat_id}.flag"
                send_message "$chat_id" "❌ *Pengaturan waktu sahur dibatalkan.*" "Markdown"
                log "❌ Pengaturan waktu sahur dibatalkan oleh user $chat_id"
                return 0
            fi
            
            if [ -n "$text" ]; then
                sahur_set_time_process "$chat_id" "$text"
                log "Waktu sahur diproses untuk chat_id=$chat_id"
                return 0
            fi
        fi
        
        # Handler untuk foto
        local photo_array=$(echo "$message_data" | jq -r '.photo // empty' 2>/dev/null)
        local document=$(echo "$message_data" | jq -r '.document // empty' 2>/dev/null)
        
        if [ "$flag" = "waiting_bot_photo" ]; then
            # CEK APAKAH INI FOTO
            if [ -n "$photo_array" ] && [ "$photo_array" != "null" ] && [ "$photo_array" != "[]" ]; then
                log "📸 Mendeteksi foto array: $(echo "$photo_array" | jq -r 'length') item"
                bot_handle_photo "$chat_id" "$photo_array"
                return 0
            fi
            
            # CEK APAKAH INI DOKUMEN GAMBAR
            if [ -n "$document" ] && [ "$document" != "null" ]; then
                local mime_type=$(echo "$document" | jq -r '.mime_type // empty')
                if [[ "$mime_type" == image/* ]]; then
                    log "📸 Mendeteksi dokumen gambar: $mime_type"
                    local file_id=$(echo "$document" | jq -r '.file_id // empty')
                    if [ -n "$file_id" ]; then
                        # Buat photo array palsu
                        local fake_photo_array="[{\"file_id\": \"$file_id\"}]"
                        bot_handle_photo "$chat_id" "$fake_photo_array"
                        return 0
                    fi
                fi
            fi
            
            # BUKAN FOTO - CEK APAKAH PERINTAH BATAL
            if [ "$text" = "/" ] || [ "$text" = "/cancel" ] || [ "$text" = "batal" ] || [ "$text" = "Batal" ]; then
                rm -f "/tmp/jsholat_bot_setup/${chat_id}.flag"
                send_message "$chat_id" "❌ *Proses ganti foto dibatalkan.*" "Markdown"
                log "❌ Proses ganti foto dibatalkan oleh user $chat_id"
                return 0
            else
                # KIRIM PESAN ERROR
                send_message "$chat_id" "❌ *Bukan foto!* Silakan kirim file gambar (JPG/PNG).\n\nKetik / untuk membatalkan." "Markdown"
                log "❌ User $chat_id mengirim bukan foto saat mode waiting_bot_photo"
                return 0
            fi
        fi
        
        # Handler untuk mode setup lainnya (nama, deskripsi, bio)
        case "$flag" in
            "waiting_bot_name")
                if [ -n "$text" ]; then
                    bot_set_name_process "$chat_id" "$text"
                    log "Nama bot diproses untuk chat_id=$chat_id"
                    return 0
                fi
                ;;
            "waiting_bot_description")
                if [ -n "$text" ]; then
                    bot_set_description_process "$chat_id" "$text"
                    log "Deskripsi bot diproses untuk chat_id=$chat_id"
                    return 0
                fi
                ;;
            "waiting_bot_bio")
                if [ -n "$text" ]; then
                    bot_set_bio_process "$chat_id" "$text"
                    log "Bio bot diproses untuk chat_id=$chat_id"
                    return 0
                fi
                ;;
        esac
    fi

    log "Menerima pesan dari chat_id=$chat_id: $text"

	# Pengecekan umur flag lokasi
    if [ -f "$LOCATION_SEARCH_FLAG_DIR/${chat_id}.flag" ]; then
        local flag_time=$(stat -c %Y "$LOCATION_SEARCH_FLAG_DIR/${chat_id}.flag" 2>/dev/null)
        local now=$(date +%s)
        
        if [ $((now - flag_time)) -gt 300 ]; then  # 5 menit
            rm -f "$LOCATION_SEARCH_FLAG_DIR/${chat_id}.flag"
            log "⏰ Flag pencarian lokasi expired untuk chat_id=$chat_id"
            # Kirim notifikasi optional
            send_message "$chat_id" "⏰ Sesi pencarian lokasi telah expired. Silakan kirim /setlokasi lagi." "Markdown"
        fi
    fi
	
    case "$text" in
		"/start")
			handle_start_command "$chat_id"
			success=$?
			log "✅ Command /start diproses untuk chat_id=$chat_id (status: $success)"
			;;			
		"/jadwal")
			show_daily_schedule "$chat_id"
			success=$?
			if [ $success -ne 0 ]; then
				log "❌ Command /jadwal gagal untuk chat_id=$chat_id"
				# JANGAN pakai continue di sini!
				# Cukup return dengan status error
				return 1
			fi
			log "✅ Command /jadwal diproses untuk chat_id=$chat_id (status: $success)"
			;;
        "/jdwlbulan")
            send_monthly_schedule "$chat_id"
            success=$?
            log "✅ Command /jdwlbulan diproses untuk chat_id=$chat_id (status: $success)"
            ;;
        "/lokasi")
            local lokasi="$SCHEDULE_CITY_LABEL"
            local provinsi="$SCHEDULE_PROVINCE"
            send_message "$chat_id" "📍 Lokasi jadwal saat ini: *$lokasi, $provinsi*"
            success=$?
            log "✅ Command /lokasi diproses untuk chat_id=$chat_id (status: $success)"
            ;;
        "/control")
            show_control_menu "$chat_id"
            success=$?
            log "✅ Command /control diproses untuk chat_id=$chat_id (status: $success)"
            ;;
        "/setvolume")
            show_volume_menu "$chat_id"
            success=$?
            log "✅ Command /setvolume diproses untuk chat_id=$chat_id (status: $success)"
            ;;
		"/detectaudio")
			detect_audio "$chat_id" ""
			success=$?
			log "✅ Command /detectaudio diproses untuk chat_id=$chat_id (status: $success)"
			;;	
		"/statusbot")
			show_bot_status "$chat_id"
			success=$?
			log "✅ Command /statusbot diproses untuk chat_id=$chat_id (status: $success)"
        	;;	
		"/status")
			show_short_status "$chat_id"
			success=$?
			log "✅ Command /status diproses untuk chat_id=$chat_id (status: $success)"
			;;
        "/update")
            # Create confirmation keyboard
            local keyboard='[[
                {"text": "✅ Ya, Update Jadwal", "callback_data": "confirm_update"},
                {"text": "❌ Batal", "callback_data": "cancel_update"}
            ]]'
            
            local update_message=$(printf '⚠️ *Update Jadwal Sholat*\n\nAnda yakin ingin mengupdate jadwal sholat?\n\nProses ini akan menjalankan update dan mungkin memakan waktu beberapa detik.')
			send_inline_keyboard "$chat_id" "$update_message" "$keyboard"
			success=$?
			log "✅ Command /update diproses untuk chat_id=$chat_id (status: $success)"
            ;;
        "/setjadwal")
            show_source_menu "$chat_id"
            success=$?
            log "✅ Command /setjadwal diproses untuk chat_id=$chat_id (status: $success)"
            ;;
		"/reminder")
			show_reminder_menu "$chat_id"
			success=$?
			log "✅ Command /reminder diproses untuk chat_id=$chat_id (status: $success)"
			;;	
        "/setlokasi")
			# HAPUS FLAG LAMA
            rm -f "$LOCATION_SEARCH_FLAG_DIR/${chat_id}.flag"
            mkdir -p "$LOCATION_SEARCH_FLAG_DIR"
            touch "$LOCATION_SEARCH_FLAG_DIR/${chat_id}.flag"
            send_message "$chat_id" "$(printf '🔍 *CARI LOKASI*\n\nMasukkan nama kota/kabupaten yang ingin dicari:\nContoh: *%s* atau *%s*\n\n❌ Ketik *batal* untuk membatalkan.' "Bandung" "Aceh Barat")"
            success=$?
            log "📍 Command /setlokasi diproses untuk chat_id=$chat_id (status: $success)"
            ;;
        "/help")
            send_help_message "$chat_id"
            success=$?
            log "✅ Command /help diproses untuk chat_id=$chat_id (status: $success)"
            ;;
        "/sethijri")
            show_hijri_adjust_menu "$chat_id"
            success=$?
            log "✅ Command /sethijri diproses untuk chat_id=$chat_id (status: $success)"
            ;;
		"/settts")
			show_tts_method_menu "$chat_id"
			success=$?
			log "✅ Command /settts diproses untuk chat_id=$chat_id (status: $success)"
			;;
		"/tarhim")
			show_tarhim_menu "$chat_id"
			success=$?
			log "✅ Command /tarhim diproses untuk chat_id=$chat_id (status: $success)"
			;;
		"/ayat")
			show_ayat_menu "$chat_id"
			success=$?
			log "✅ Command /ayat diproses untuk chat_id=$chat_id (status: $success)"
			;;
		"/setup")
			register_bot_commands "$chat_id"
			success=$?
			log "✅ Command /setup diproses untuk chat_id=$chat_id (status: $success)"
			;;
		"/setupbot")
			handle_setupbot_command "$chat_id"
			success=$?
			log "✅ Command /setupbot diproses untuk chat_id=$chat_id (status: $success)"
			;;
        "/gemini")
            show_gemini_config_menu "$chat_id"
            success=$?
            log "✅ Command /gemini diproses untuk chat_id=$chat_id (status: $success)"
            ;;
		"/sahur")
			show_sahur_menu "$chat_id"
			success=$?
			log "✅ Command /sahur diproses untuk chat_id=$chat_id (status: $success)"
			;;			
		"/"|"/cancel"|"batal"|"Batal"|"/batal")
			# Perintah pembatalan universal
			# Cek flag pencarian lokasi (prioritas setelah flag setup)
			if [ -f "$LOCATION_SEARCH_FLAG_DIR/${chat_id}.flag" ]; then
				rm -f "$LOCATION_SEARCH_FLAG_DIR/${chat_id}.flag"
				send_message "$chat_id" "❌ *Pencarian lokasi dibatalkan.*"
				log "❌ User $chat_id membatalkan pencarian lokasi dengan $text"
			elif [ -f "/tmp/jsholat_bot_setup/${chat_id}.flag" ]; then
				rm -f "/tmp/jsholat_bot_setup/${chat_id}.flag"
				send_message "$chat_id" "❌ *Proses setup dibatalkan.*" "Markdown"
				log "❌ User $chat_id membatalkan proses setup"
			else
				send_message "$chat_id" "❌ Tidak ada proses aktif yang bisa dibatalkan."
			fi
			success=0
			;;
		
		*)
			# Cek flag pencarian lokasi
			if [ -f "$LOCATION_SEARCH_FLAG_DIR/${chat_id}.flag" ]; then
				# Hapus flag
				rm -f "$LOCATION_SEARCH_FLAG_DIR/${chat_id}.flag"
				
				# Tampilkan hasil dengan pagination
				show_location_results_paginated "$chat_id" "" "$text" "1"
				success=$?
				log "📍 Hasil pencarian lokasi ditampilkan untuk chat_id=$chat_id (status: $success)"
			else
				# Kirim pesan error untuk perintah tidak dikenal
				send_message "$chat_id" "❌ Perintah tidak dikenali. Gunakan /start untuk melihat menu"
				send_help_message "$chat_id"
				log "⚠️ Perintah tidak dikenal dari chat_id=$chat_id: $text"
				success=0
			fi
			;;
    esac
    
    return $success
}

# Fungsi proses callback query (tanpa logging response)
process_callback() {
    local callback_id="$1"
    local chat_id="$2"
    local message_id="$3"
    local data="$4"
    
    # Cek authorization
    if ! check_authorization "$chat_id"; then
        curl -s -X POST \
            "https://api.telegram.org/bot${TELEGRAM_TOKEN}/answerCallbackQuery" \
            -d callback_query_id="${callback_id}" \
            -d text="⛔ This is a private bot" \
            -d show_alert="true" \
            > /dev/null 2>&1
        log "Percobaan akses callback dari chat ID tidak terdaftar: $chat_id"    
        return
    fi

    [ "$DEBUG_MODE" = "1" ] && log "Memproses callback: $data dari chat_id=$chat_id"

    # Jawab callback query
    curl -s -X POST \
        "https://api.telegram.org/bot${TELEGRAM_TOKEN}/answerCallbackQuery" \
        -d callback_query_id="${callback_id}" \
        > /dev/null 2>&1
	
	# HANDLER CALLBACK SETUP BOT (PHOTO DESC)    
    if [[ "$data" == bot_set_photo_desc_* ]]; then
        local photo_index=$(echo "$data" | sed 's/bot_set_photo_desc_//')
        bot_set_photo_desc_for_index "$chat_id" "$message_id" "$photo_index"
        return
    fi

    case "$data" in
        "on")
            update_service_status "$chat_id" "$message_id" "1"
            ;;
        "off")
            update_service_status "$chat_id" "$message_id" "0"
            ;;
        "done")
            remove_keyboard "$chat_id" "$message_id" "🛠 Kontrol service selesai"
            ;;
		"bot_status")
        show_bot_status "$chat_id" "$message_id"
        ;;	
        "status")
            local current_status="$SERVICE_ENABLED"
            local status_text=$([ "$current_status" = "1" ] && echo "AKTIF" || echo "NONAKTIF")
            
            curl -s -X POST \
                "https://api.telegram.org/bot${TELEGRAM_TOKEN}/answerCallbackQuery" \
                -d callback_query_id="${callback_id}" \
                -d text="Status saat ini: $status_text" \
                -d show_alert="false" \
                > /dev/null 2>&1
            ;;
        "settings")
            show_settings_menu "$chat_id" "$message_id"
            ;;
        set_volume_*)
            local volume_level=$(echo "$data" | cut -d'_' -f3)
            set_volume "$chat_id" "$message_id" "$volume_level"
            ;;
        "test_volume")
            test_volume "$chat_id" "$message_id"
            ;;
		"detect_audio")
			detect_audio "$chat_id" "$message_id"
			;;
		"audio_status")
			audio_status "$chat_id" "$message_id"
			;;
		"volume_chart")
			volume_chart "$chat_id" "$message_id"
			;;			
        "volume_menu")
            show_volume_menu "$chat_id" "$message_id"
            ;;    
        "toggle_sound")
            toggle_sound_setting "$chat_id" "$message_id"
            ;;
        "toggle_telegram")
            toggle_telegram_setting "$chat_id" "$message_id"
            ;;
        "back_to_control")
            show_control_menu "$chat_id" "$message_id"
            ;;
		"back_to_volume")
			show_volume_menu "$chat_id" "$message_id"
			;;	
        "set_source_jadwalsholat")
            set_jadwal_source "$chat_id" "$message_id" "jadwalsholat"
            ;;
        "set_source_aladhan")
            set_jadwal_source "$chat_id" "$message_id" "aladhan"
            ;;
        "set_source_arina")
            set_jadwal_source "$chat_id" "$message_id" "arina"
            ;;
        "set_source_equranid")
            set_jadwal_source "$chat_id" "$message_id" "equranid"
            ;;
        "set_source_myquran")
            set_jadwal_source "$chat_id" "$message_id" "myquran"
            ;;
        "set_source_apiajimedia")
            set_jadwal_source "$chat_id" "$message_id" "apiajimedia"
            ;;
		"confirm_update")
			# Hapus pesan konfirmasi
			curl -s -X POST \
				"https://api.telegram.org/bot${TELEGRAM_TOKEN}/deleteMessage" \
				-d chat_id="${chat_id}" \
				-d message_id="${message_id}" \
				> /dev/null 2>&1

			# Buat pesan progress BARU
			local progress_msg=$(curl -s -X POST \
				"https://api.telegram.org/bot${TELEGRAM_TOKEN}/sendMessage" \
				-d chat_id="${chat_id}" \
				-d text="🔄 *Memulai update jadwal sholat...*" \
				-d parse_mode="Markdown")
			
			local progress_msg_id=$(echo "$progress_msg" | jq -r '.result.message_id')
			
			# Ekspor fungsi
			export -f run_update_background
			export TELEGRAM_TOKEN
			
			# Jalankan di background
			(
				run_update_background "$chat_id" "$progress_msg_id" "$TELEGRAM_TOKEN"
			) &
			
			log "✅ Update jadwal berjalan di background (PID: $!)"
			;;
        "cancel_update")
            remove_keyboard "$chat_id" "$message_id" "❌ Update dibatalkan"
            log "❌  Update dibatalkan.."
            ;;
        set_location_*)
            # Handle location selection
            local city_value=$(echo "$data" | cut -d'_' -f3)
            local timezone=$(echo "$data" | cut -d'_' -f4)
            set_location "$chat_id" "$message_id" "$city_value" "$timezone"
            ;;
		"reminder_menu")
			show_reminder_menu "$chat_id" "$message_id"
			;;
		"hijri_menu")
            show_hijri_adjust_menu "$chat_id" "$message_id"
            ;;
        set_hijri_adj_*)
            # Parse nilai dengan benar
            local adj_value=$(echo "$data" | sed 's/set_hijri_adj_//')
            set_hijri_adjust "$chat_id" "$message_id" "$adj_value"
            ;;
		"tts_menu")
			show_tts_method_menu "$chat_id" "$message_id"
			;;		
		set_tts_*)
			local method=$(echo "$data" | sed 's/set_tts_//')
			set_tts_method "$chat_id" "$message_id" "$method"
			;;
			
		"toggle_tts_sound")
			toggle_tts_sound "$chat_id" "$message_id"
			;;
			
		"test_tts")
			test_tts "$chat_id" "$message_id"
			;;
		"reminder_repeat_menu")
			show_reminder_repeat_menu "$chat_id" "$message_id"
			;;
			
		"reminder_interval_menu")
			show_reminder_interval_menu "$chat_id" "$message_id"
			;;
			
		set_reminder_repeat_*)
			local repeat_value=$(echo "$data" | sed 's/set_reminder_repeat_//')
			set_reminder_repeat_count "$chat_id" "$message_id" "$repeat_value"
			;;
			
		set_reminder_interval_*)
			local interval_value=$(echo "$data" | sed 's/set_reminder_interval_//')
			set_reminder_interval "$chat_id" "$message_id" "$interval_value"
			;;
        set_reminder_*)
            # HANYA untuk durasi reminder (0, 5, 10, 15)
            # Validasi dulu bahwa ini benar-benar durasi
            local duration=$(echo "$data" | sed 's/set_reminder_//')
            
            # Cek apakah duration adalah angka yang valid
            if [[ "$duration" =~ ^[0-9]+$ ]] && [[ "$duration" =~ ^(0|5|10|15)$ ]]; then
                set_reminder_duration "$chat_id" "$message_id" "$duration"
            else
                log "ERROR: Callback data tidak valid: $data"
            fi
            ;;
		"tarhim_menu")
			show_tarhim_menu "$chat_id" "$message_id"
			;;
			
		"toggle_tarhim")
			toggle_tarhim "$chat_id" "$message_id"
			;;
			
		"tarhim_mode_menu")
			show_tarhim_mode_menu "$chat_id" "$message_id"
			;;
			
		"back_to_tarhim_menu")
			show_tarhim_menu "$chat_id" "$message_id"
			;;
			
		"back_to_reminder_menu")
			# Hapuf flag set waktu sahur
			rm -f "/tmp/jsholat_bot_setup/${chat_id}.flag"
			rm -f "/tmp/jsholat_bot_setup/${chat_id}_sahur_text.flag" 2>/dev/null		
			show_reminder_menu "$chat_id" "$message_id"
			;;
			
		"test_tarhim")
			test_tarhim "$chat_id" "$message_id"
			;;
			
		set_tarhim_mode_*)
			local mode=$(echo "$data" | sed 's/set_tarhim_mode_//')
			set_tarhim_mode "$chat_id" "$message_id" "$mode"
			;;
			
		"ayat_menu")
			show_ayat_menu "$chat_id" "$message_id"
			;;
			
		"toggle_ayat")
			toggle_ayat "$chat_id" "$message_id"
			;;
			
		"test_ayat")
			test_ayat "$chat_id" "$message_id"
			;;

		"back_to_settings")
			show_settings_menu "$chat_id" "$message_id"
			;;
		"force_setup")
			handle_setup_command "$chat_id"
			remove_keyboard "$chat_id" "$message_id" "✅ Perintah setup sedang dijalankan..."
			;;
		"bot_profile_menu")
			show_bot_profile_menu "$chat_id" "$message_id"
			;;
		"bot_view_profile")
			view_bot_profile "$chat_id" "$message_id"
			;;
		"bot_set_name")
			bot_set_name_prompt "$chat_id" "$message_id"
			;;
		"bot_set_photo")
			bot_set_photo_prompt "$chat_id" "$message_id"
			;;
		"bot_set_description")
			bot_set_description_prompt "$chat_id" "$message_id"
			;;
		"bot_set_bio")
			bot_set_bio_prompt "$chat_id" "$message_id"
			;;
		"bot_set_photo_description")
			bot_set_photo_description_prompt "$chat_id" "$message_id"
			;;
		"bot_view_photo_descriptions")
			bot_view_photo_descriptions "$chat_id" "$message_id"
			;;
		"back_to_settings")
			show_settings_menu "$chat_id" "$message_id"
			;;
        # HANDLER GEMINI
        "gemini_config_menu")
            show_gemini_config_menu "$chat_id" "$message_id"
            ;;
        "gemini_set_api_key")
            gemini_set_api_key_prompt "$chat_id" "$message_id"
            ;;
        "gemini_voice_menu")
            show_gemini_voice_menu "$chat_id" "$message_id" "1"
            ;;
        "gemini_model_info")
            show_gemini_model_info "$chat_id" "$message_id"
            ;;
        "test_gemini")
            test_gemini_tts "$chat_id" "$message_id"
            ;;
        gemini_voice_page_info)
            curl -s -X POST \
                "https://api.telegram.org/bot${TELEGRAM_TOKEN}/answerCallbackQuery" \
                -d callback_query_id="${callback_id}" \
                -d text="📄 Halaman $page dari $total_pages" \
                -d show_alert="false" \
                > /dev/null 2>&1
            ;;
        gemini_voice_page_*)
            local page=$(echo "$data" | sed 's/gemini_voice_page_//')
            show_gemini_voice_menu "$chat_id" "$message_id" "$page"
            ;;
        # HANDLER PEMILIHAN VOICE GEMINI
        gemini_voice_*)
            local voice=$(echo "$data" | sed 's/^gemini_voice_//')
            set_gemini_voice "$chat_id" "$message_id" "$voice"
            ;;
        # HANDLER MODEL GEMINI
        "gemini_model_info")
            show_gemini_model_info "$chat_id" "$message_id"
            ;;
        "gemini_model_menu")
            show_gemini_model_menu "$chat_id" "$message_id"
            ;;
        "set_gemini_model_flash")
            set_gemini_model "$chat_id" "$message_id" "gemini-2.5-flash-preview-tts" "$callback_id"
            ;;
        "set_gemini_model_pro")
            set_gemini_model "$chat_id" "$message_id" "gemini-2.5-pro-preview-tts" "$callback_id"
            ;;			
		# Handler untuk menu voice Edge
		"edge_voice_settings")
			show_edge_voice_menu "$chat_id" "$message_id"
			;;

		# Handler untuk memilih voice Ardi
		"set_edge_voice_ardi")
			set_edge_voice "$chat_id" "$message_id" "ardi"
			;;

		# Handler untuk memilih voice Gadis
		"set_edge_voice_gadis")
			set_edge_voice "$chat_id" "$message_id" "gadis"
			;;
		# Handler untuk memilih voice Dimas (Jawa-Pria)
		"set_edge_voice_dimas")
			set_edge_voice "$chat_id" "$message_id" "dimas"
			;;

		# Handler untuk memilih voice Siti (Jawa-Wanita)
		"set_edge_voice_siti")
			set_edge_voice "$chat_id" "$message_id" "siti"
			;;
        "cancel_location_search")
            # Hapus flag pencarian
            rm -f "$LOCATION_SEARCH_FLAG_DIR/${chat_id}.flag"
            # Hapus keyboard dan tampilkan pesan
            remove_keyboard "$chat_id" "$message_id" "❌ *Pencarian lokasi dibatalkan.*"
            log "❌ Pencarian lokasi dibatalkan oleh user $chat_id"
            ;;
            
        loc_page_*)
            # Format: loc_page_query_page
            local rest=$(echo "$data" | sed 's/^loc_page_//')
            
            # Cek apakah ini info page
            if [ "$rest" = "info" ]; then
                curl -s -X POST \
                    "https://api.telegram.org/bot${TELEGRAM_TOKEN}/answerCallbackQuery" \
                    -d callback_query_id="${callback_id}" \
                    -d text="📄 Ini adalah halaman saat ini" \
                    -d show_alert="false" \
                    > /dev/null 2>&1
                return
            fi
            
            # Ambil page (angka terakhir)
            local page=$(echo "$rest" | grep -o '[0-9]*$')
            # Ambil query (semua sebelum angka terakhir)
            local query=$(echo "$rest" | sed 's/_[0-9]*$//')
            
            # URL decode query (ganti underscore dengan spasi)
            query=$(echo "$query" | sed 's/_/ /g')
            
            log "📄 Beralih ke halaman $page untuk query '$query'"
            show_location_results_paginated "$chat_id" "$message_id" "$query" "$page"
            ;;
            
        "loc_page_info")
            # Hanya tampilkan informasi, tidak melakukan apa-apa
            curl -s -X POST \
                "https://api.telegram.org/bot${TELEGRAM_TOKEN}/answerCallbackQuery" \
                -d callback_query_id="${callback_id}" \
                -d text="📄 Halaman informasi - Gunakan tombol navigasi" \
                -d show_alert="false" \
                > /dev/null 2>&1
            ;;
		"sahur_menu")
        # HAPUS FLAG SEBELUM MENAMPILKAN MENU
			rm -f "/tmp/jsholat_bot_setup/${chat_id}.flag"
			rm -f "/tmp/jsholat_bot_setup/${chat_id}_sahur_text.flag" 2>/dev/null		
			show_sahur_menu "$chat_id" "$message_id"
			;;
			
		"toggle_sahur")
			toggle_sahur "$chat_id" "$message_id"
			;;
			
		"sahur_set_time")
			# HAPUS FLAG LAMA sebelum membuat yang baru
			rm -f "/tmp/jsholat_bot_setup/${chat_id}.flag"			
			sahur_set_time_prompt "$chat_id" "$message_id"
			;;
			
		"sahur_test")
			handle_sahur_alarm "$chat_id" "$message_id" "test"
			;;
			
		"sahur_status")
			handle_sahur_alarm "$chat_id" "$message_id" "status"
			;;
		"sahur_text_menu")
			show_sahur_text_menu "$chat_id" "$message_id"
			;;

		"sahur_view_text")
			sahur_view_text "$chat_id" "$message_id"
			;;

		"sahur_edit_text")
			sahur_edit_text_prompt "$chat_id" "$message_id"
			;;

		"sahur_reset_text")
			sahur_reset_text "$chat_id" "$message_id"
			;;

		sahur_force_save_*)
			# Ekstrak teks dari callback data
			local encoded_text=$(echo "$data" | sed 's/^sahur_force_save_//')
			# Decode (ganti underscore kembali ke spasi)
			local saved_text=$(echo "$encoded_text" | sed 's/_/ /g')
			sahur_force_save "$chat_id" "$message_id" "$saved_text"
			;;			
        *)
            log "WARNING: Callback tidak dikenal: $data"
            ;;
    esac
}

# ============ MAIN LOOP DENGAN ERROR HANDLING YANG BENAR ============

# Inisialisasi LAST_UPDATE_ID dari file state jika ada
if [ -f "$STATE_FILE" ]; then
    LAST_UPDATE_ID=$(cat "$STATE_FILE" 2>/dev/null || echo "0")
else
    LAST_UPDATE_ID=0
fi

log "🚀 Memulai main loop dengan LAST_UPDATE_ID=$LAST_UPDATE_ID"

while true; do
    # Validasi LAST_UPDATE_ID
    if [ -z "$LAST_UPDATE_ID" ] || [ "$LAST_UPDATE_ID" -lt 0 ]; then
        LAST_UPDATE_ID=0
        log "⚠️ LAST_UPDATE_ID tidak valid, reset ke 0"
    fi

    # Ambil updates dengan timeout proteksi
    response=$(curl -s \
        --connect-timeout 5 \
        --max-time 20 \
        -w "\n%{http_code}" \
        "https://api.telegram.org/bot${TELEGRAM_TOKEN}/getUpdates?offset=$((LAST_UPDATE_ID + 1))&timeout=10")

    curl_exit=$?

    # Cek error curl
    if [ $curl_exit -ne 0 ]; then
        log "ERROR: curl gagal dengan kode $curl_exit"
        sleep 3
        continue
    fi

    # Pisahkan HTTP code dan response body
    http_code=$(echo "$response" | tail -n1)
    updates=$(echo "$response" | sed '$d')

    # Validasi HTTP code
    if [ "$http_code" != "200" ]; then
        log "ERROR: HTTP code dari Telegram: $http_code"
        sleep 3
        continue
    fi

    # Validasi JSON sebelum diparse jq
    if ! echo "$updates" | jq empty >/dev/null 2>&1; then
        log "ERROR: JSON tidak valid dari Telegram"
        log "DEBUG: Response: $(echo "$updates" | head -c 200)"
        sleep 2
        continue
    fi

    # Cek status OK dari Telegram
    ok=$(echo "$updates" | jq -r '.ok // false')
    if [ "$ok" != "true" ]; then
        error_desc=$(echo "$updates" | jq -r '.description // "Unknown error"')
        log "ERROR: Telegram API error: $error_desc"
        sleep 2
        continue
    fi

    # Ambil update IDs
    update_ids=$(echo "$updates" | jq -r '.result[].update_id')

    if [ -z "$update_ids" ]; then
        # Tidak ada update, jeda sebentar
        sleep 0.5
        continue
    fi

    # Proses setiap update SATU PER SATU
    for current_update_id in $update_ids; do
        # Skip update yang sudah diproses
        if [ "$current_update_id" -le "$LAST_UPDATE_ID" ]; then
            continue
        fi

        log "📨 Memproses update ID: $current_update_id"

        # Ambil update lengkap untuk ID ini
        update=$(echo "$updates" | jq -c --argjson id "$current_update_id" \
            '.result[] | select(.update_id == $id)')

        if [ -z "$update" ] || [ "$update" = "null" ]; then
            log "WARNING: Update kosong untuk ID $current_update_id"
            continue
        fi

        processing_ok=0
        processing_type=""

        # ============ HANDLE MESSAGE ============
        message=$(echo "$update" | jq -c '.message // empty')
        
        if [ -n "$message" ] && [ "$message" != "null" ]; then
            processing_type="message"
            chat_id=$(echo "$message" | jq -r '.chat.id // empty')
            text=$(echo "$message" | jq -r '.text // empty')
            message_data="$message"

            if [ -n "$chat_id" ]; then
                log "📩 Message dari chat_id=$chat_id: ${text:0:50}"
                
                # Panggil process_message dan simpan return value
                process_message "$chat_id" "$text" "$message_data"
                process_result=$?
                
                if [ $process_result -eq 0 ]; then
                    processing_ok=1
                    log "✅ Message berhasil diproses untuk chat_id=$chat_id"
                else
                    log "❌ Message gagal diproses untuk chat_id=$chat_id (kode: $process_result)"
                    # JANGAN set processing_ok=1
                fi
            else
                log "WARNING: Message tanpa chat_id"
            fi
        fi

        # ============ HANDLE CALLBACK QUERY ============
        callback_query=$(echo "$update" | jq -c '.callback_query // empty')
        
        if [ -n "$callback_query" ] && [ "$callback_query" != "null" ]; then
            processing_type="callback"
            callback_id=$(echo "$callback_query" | jq -r '.id // empty')
            callback_chat_id=$(echo "$callback_query" | jq -r '.message.chat.id // empty')
            callback_message_id=$(echo "$callback_query" | jq -r '.message.message_id // empty')
            callback_data=$(echo "$callback_query" | jq -r '.data // empty')

            if [ -n "$callback_id" ] && [ -n "$callback_chat_id" ] && \
               [ -n "$callback_message_id" ] && [ -n "$callback_data" ]; then
                
                log "🔄 Callback dari chat_id=$callback_chat_id: $callback_data"
                
                # Panggil process_callback
                process_callback "$callback_id" "$callback_chat_id" "$callback_message_id" "$callback_data"
                process_result=$?
                
                if [ $process_result -eq 0 ]; then
                    processing_ok=1
                    log "✅ Callback berhasil diproses"
                else
                    log "❌ Callback gagal diproses (kode: $process_result)"
                fi
            else
                log "WARNING: Callback query tidak lengkap"
            fi
        fi

        # ============ HANDLE EDITED MESSAGE ============
        edited_message=$(echo "$update" | jq -c '.edited_message // empty')
        if [ -n "$edited_message" ] && [ "$edited_message" != "null" ]; then
            processing_type="edited_message"
            # Abaikan edited message untuk sekarang, tapi tetap anggap sukses agar offset naik
            log "ℹ️ Edited message diabaikan (update ID: $current_update_id)"
            processing_ok=1  # Anggap sukses agar offset naik
        fi

        # ============ HANDLE CHANNEL POST ============
        channel_post=$(echo "$update" | jq -c '.channel_post // empty')
        if [ -n "$channel_post" ] && [ "$channel_post" != "null" ]; then
            processing_type="channel_post"
            # Abaikan channel post untuk sekarang, tapi tetap anggap sukses
            log "ℹ️ Channel post diabaikan (update ID: $current_update_id)"
            processing_ok=1  # Anggap sukses agar offset naik
        fi

        # ============ HANDLE INLINE QUERY ============
        inline_query=$(echo "$update" | jq -c '.inline_query // empty')
        if [ -n "$inline_query" ] && [ "$inline_query" != "null" ]; then
            processing_type="inline_query"
            # Abaikan inline query untuk sekarang
            log "ℹ️ Inline query diabaikan (update ID: $current_update_id)"
            processing_ok=1  # Anggap sukses agar offset naik
        fi

        # ============ HANDLE CHOSEN INLINE RESULT ============
        chosen_inline_result=$(echo "$update" | jq -c '.chosen_inline_result // empty')
        if [ -n "$chosen_inline_result" ] && [ "$chosen_inline_result" != "null" ]; then
            processing_type="chosen_inline_result"
            # Abaikan chosen inline result
            log "ℹ️ Chosen inline result diabaikan (update ID: $current_update_id)"
            processing_ok=1  # Anggap sukses agar offset naik
        fi

        # ============ HANDLE SHIPPING QUERY ============
        shipping_query=$(echo "$update" | jq -c '.shipping_query // empty')
        if [ -n "$shipping_query" ] && [ "$shipping_query" != "null" ]; then
            processing_type="shipping_query"
            # Abaikan shipping query
            log "ℹ️ Shipping query diabaikan (update ID: $current_update_id)"
            processing_ok=1  # Anggap sukses agar offset naik
        fi

        # ============ HANDLE PRE_CHECKOUT QUERY ============
        pre_checkout_query=$(echo "$update" | jq -c '.pre_checkout_query // empty')
        if [ -n "$pre_checkout_query" ] && [ "$pre_checkout_query" != "null" ]; then
            processing_type="pre_checkout_query"
            # Abaikan pre-checkout query
            log "ℹ️ Pre-checkout query diabaikan (update ID: $current_update_id)"
            processing_ok=1  # Anggap sukses agar offset naik
        fi

        # ============ HANDLE POLL ============
        poll=$(echo "$update" | jq -c '.poll // empty')
        if [ -n "$poll" ] && [ "$poll" != "null" ]; then
            processing_type="poll"
            # Abaikan poll update
            log "ℹ️ Poll update diabaikan (update ID: $current_update_id)"
            processing_ok=1  # Anggap sukses agar offset naik
        fi

        # ============ HANDLE POLL ANSWER ============
        poll_answer=$(echo "$update" | jq -c '.poll_answer // empty')
        if [ -n "$poll_answer" ] && [ "$poll_answer" != "null" ]; then
            processing_type="poll_answer"
            # Abaikan poll answer
            log "ℹ️ Poll answer diabaikan (update ID: $current_update_id)"
            processing_ok=1  # Anggap sukses agar offset naik
        fi

        # ============ HANDLE MY_CHAT_MEMBER ============
        my_chat_member=$(echo "$update" | jq -c '.my_chat_member // empty')
        if [ -n "$my_chat_member" ] && [ "$my_chat_member" != "null" ]; then
            processing_type="my_chat_member"
            # Abaikan my chat member update
            log "ℹ️ My chat member update diabaikan (update ID: $current_update_id)"
            processing_ok=1  # Anggap sukses agar offset naik
        fi

        # ============ HANDLE CHAT_MEMBER ============
        chat_member=$(echo "$update" | jq -c '.chat_member // empty')
        if [ -n "$chat_member" ] && [ "$chat_member" != "null" ]; then
            processing_type="chat_member"
            # Abaikan chat member update
            log "ℹ️ Chat member update diabaikan (update ID: $current_update_id)"
            processing_ok=1  # Anggap sukses agar offset naik
        fi

        # ============ HANDLE CHAT_JOIN_REQUEST ============
        chat_join_request=$(echo "$update" | jq -c '.chat_join_request // empty')
        if [ -n "$chat_join_request" ] && [ "$chat_join_request" != "null" ]; then
            processing_type="chat_join_request"
            # Abaikan chat join request
            log "ℹ️ Chat join request diabaikan (update ID: $current_update_id)"
            processing_ok=1  # Anggap sukses agar offset naik
        fi

        # ============ UPDATE OFFSET HANYA JIKA PROSES BERHASIL ============
        if [ $processing_ok -eq 1 ]; then
            LAST_UPDATE_ID=$current_update_id
            write_last_update_id "$LAST_UPDATE_ID"
            log "📌 Offset dinaikkan ke $LAST_UPDATE_ID (tipe: $processing_type)"
        else
            # Jika tidak ada tipe yang terdeteksi sama sekali
            if [ -z "$processing_type" ]; then
                log "⚠️ WARNING: Update $current_update_id tidak memiliki tipe yang dikenal"
                # Coba debug dengan melihat struktur update
                if [ "$DEBUG_MODE" = "1" ]; then
                    log "DEBUG: Struktur update: $(echo "$update" | jq -c 'keys')"
                fi
                # Tetap naikkan offset untuk menghindari loop
                LAST_UPDATE_ID=$current_update_id
                write_last_update_id "$LAST_UPDATE_ID"
                log "📌 Offset tetap dinaikkan untuk menghindari loop"
            else
                log "⚠️ WARNING: Update $current_update_id ($processing_type) gagal diproses, offset TIDAK dinaikkan"
                
                # KIRIM NOTIFIKASI KE ADMIN (opsional)
                #if [ -n "$AUTHORIZED_CHAT_ID" ] && [ "$AUTHORIZED_CHAT_ID" != "null" ]; then
                    # Kirim notifikasi hanya untuk error penting, jangan spam
                #    if [ "$processing_type" = "message" ] || [ "$processing_type" = "callback" ]; then
                #        send_message "$AUTHORIZED_CHAT_ID" "⚠️ Update $current_update_id ($processing_type) gagal diproses. Cek log." > /dev/null 2>&1
                #    fi
                #fi
            fi
        fi

        # Jeda antar update dalam batch yang sama
        sleep 0.1

    done  # END for current_update_id

    # Jeda antar polling untuk mengurangi beban CPU
    sleep 0.3

    # Bersihkan proses zombie (jika ada)
    wait 2>/dev/null

done  # END while true