    if [ "$verify_result" = "failed" ]; then
        log "🔄 Boot: Command tidak lengkap, mencoba register ulang..."
        register_bot_commands_silent > /dev/null
    else
        log "✅ Boot: Command menu sudah lengkap (21 perintah)"
    fi
fi

