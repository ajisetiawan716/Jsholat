# Inisiasi log
LOG_FILE="/var/log/jsholat/bot.log"
MAX_LOG_SIZE=1048576  # 1MB
log() {
    local log_message="$1"

    # Persingkat pesan panjang dengan mengambil baris pertama saja
    if [[ "$log_message" == *$'\n'* ]]; then
        log_message=$(echo "$log_message" | head -n 1 | sed 's/ - .*//')
        log_message="$log_message..."
    fi

    # Potong pesan yang terlalu panjang (lebih dari 100 karakter)
    if [ ${#log_message} -gt 100 ]; then
        log_message="${log_message:0:100}..."
    fi
	
	# Rotasi log jika melebihi ukuran maksimal
    if [ -f "$LOG_FILE" ] && [ $(wc -c < "$LOG_FILE") -gt $MAX_LOG_SIZE ]; then
        mv "$LOG_FILE" "$LOG_FILE.old"
        touch "$LOG_FILE"
        chmod 644 "$LOG_FILE"
    fi

    echo "[$(date +"%Y-%m-%d %H:%M:%S")] - $log_message" >> "$LOG_FILE"
}

# PID file untuk monitoring
PID_FILE="/var/run/jsholat-bot.pid"
LOCK_FILE="/var/run/jsholat-bot.lock"

# ============ FUNGSI CEK DAN MATIKAN INSTANCE LAMA ============
kill_old_instances() {
    log "🔍 Memeriksa instance jsholat-bot yang sudah berjalan..."
    
    # Cari semua proses jsholat-bot kecuali diri sendiri
    local current_pid=$$
    local old_pids=$(pgrep -f "jsholat-bot" | grep -v "$current_pid" || true)
    
    if [ -n "$old_pids" ]; then
        log "⚠️ Ditemukan instance lain dengan PID: $(echo $old_pids | tr '\n' ' ')"
        
        for pid in $old_pids; do
            log "🔄 Mematikan instance PID $pid dengan SIGTERM..."
            kill -15 "$pid" 2>/dev/null
        done
        
        sleep 2
        
        # Cek apakah masih ada yang hidup
        local still_alive=""
        for pid in $old_pids; do
            if kill -0 "$pid" 2>/dev/null; then
                still_alive="$still_alive $pid"
            fi
        done
        
        if [ -n "$still_alive" ]; then
            log "⚠️ Instance masih hidup: $still_alive, menggunakan SIGKILL..."
            for pid in $still_alive; do
                kill -9 "$pid" 2>/dev/null
            done
            sleep 1
        fi
        
        # Verifikasi final
        local final_check=$(pgrep -f "jsholat-bot" | grep -v "$current_pid" || true)
        if [ -z "$final_check" ]; then
            log "✅ Semua instance lama berhasil dimatikan"
        else
            log "❌ Gagal mematikan instance: $final_check"
        fi
    else
        log "✅ Tidak ada instance jsholat-bot lain yang ditemukan"
    fi
    
    # Hapus file PID lama jika ada
    if [ -f "$PID_FILE" ]; then
        local old_pid=$(cat "$PID_FILE" 2>/dev/null)
        if [ -n "$old_pid" ] && ! kill -0 "$old_pid" 2>/dev/null; then
            rm -f "$PID_FILE"
            log "🗑️ File PID stale dihapus"
        fi
    fi
    
    # Hapus lock file lama
    rm -f "$LOCK_FILE" 2>/dev/null
}

# ============ FUNGSI WRITE PID ============
write_pid() {
    echo $$ > "$PID_FILE"
    log "📝 Menulis PID $$ ke $PID_FILE"
}

# ============ FUNGSI CLEANUP ============
cleanup_pid() {
    if [ -f "$PID_FILE" ]; then
        local pid_in_file=$(cat "$PID_FILE" 2>/dev/null)
        if [ "$pid_in_file" = "$$" ]; then
            rm -f "$PID_FILE"
            log "🗑️ File PID $PID_FILE dihapus"
        fi
    fi
    rm -f "$LOCK_FILE" 2>/dev/null
}

# ============ FUNGSI ACQUIRE LOCK ============
acquire_lock() {
    # Coba buat lock file dengan flock
    exec 200>"$LOCK_FILE"
    if ! flock -n 200; then
        local locked_pid=$(cat "$LOCK_FILE" 2>/dev/null)
        log "❌ Gagal mendapatkan lock. Instance dengan PID $locked_pid mungkin masih berjalan"
        
        # Tanya user apakah ingin mematikan paksa
        echo "Instance lain terdeteksi. Matikan? (y/n): "
        read -t 5 answer
        if [ "$answer" = "y" ] || [ "$answer" = "Y" ]; then
            kill_old_instances
            # Coba lagi
            if ! flock -n 200; then
                log "❌ Masih tidak bisa mendapatkan lock setelah mematikan instance"
                exit 1
            fi
        else
            exit 1
        fi
    fi
    
    # Tulis PID ke lock file
    echo $$ > "$LOCK_FILE"
    log "🔒 Lock acquired untuk PID $$"
}

# ============ MAIN EKSEKUSI ============

# Panggil fungsi kill old instances SEBELUM melakukan apapun
kill_old_instances

# Acquire lock untuk mencegah multiple instance
 acquire_lock  # Opsional, bisa diaktifkan jika perlu

# Trap untuk cleanup
trap cleanup_pid EXIT INT TERM

# Tulis PID (HANYA SEKALI!)
write_pid

# Inisialisasi LAST_UPDATE_ID dari file state
STATE_FILE="${1:-/tmp/last_update}"
if [ -f "$STATE_FILE" ]; then
    LAST_UPDATE_ID=$(cat "$STATE_FILE" 2>/dev/null)
    # Validasi isi file
    if ! [[ "$LAST_UPDATE_ID" =~ ^[0-9]+$ ]]; then
        LAST_UPDATE_ID=0
    fi
else
    LAST_UPDATE_ID=0
fi

log "🚀 Memulai bot dengan LAST_UPDATE_ID=$LAST_UPDATE_ID"

# Pagination settings
RESULTS_PER_PAGE=5
PAGINATION_CACHE_DIR="/tmp/jsholat_cache/pagination"
mkdir -p "$PAGINATION_CACHE_DIR"

# Gemini voices pagination
VOICES_PER_PAGE=8  # Jumlah voice per halaman (lebih banyak karena hanya teks)
GEMINI_VOICE_CACHE_DIR="/tmp/jsholat_cache/gemini_voices"
mkdir -p "$GEMINI_VOICE_CACHE_DIR"

