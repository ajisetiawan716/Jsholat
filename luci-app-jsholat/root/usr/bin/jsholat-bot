# Fungsi untuk info Hijriyah
HIJRI_CACHE_FILE="/tmp/jsholat_cache/hijri_date_cache.json"
HIJRI_CACHE_EXPIRE=3600 # Cache berlaku selama 1 jam (3600 detik)

# Fungsi untuk mendapatkan tanggal Hijriyah dengan cache
get_hijri_date() {
    local gregorian_date=$(date +"%Y-%m-%d")
    local now=$(date +%s)
    
    # Baca nilai adjustment dari config UCI, default -1
    local hijri_adj=$(uci -q get jsholat.schedule.hijri_adjust || echo "-1")
    
    # Cek cache terlebih dahulu
    if [ -f "$HIJRI_CACHE_FILE" ]; then
        local cache_time=$(jq -r '.cache_time' "$HIJRI_CACHE_FILE" 2>/dev/null)
        
        if [ -n "$cache_time" ] && [ $((now - cache_time)) -lt $HIJRI_CACHE_EXPIRE ]; then
            # Ambil format tanggal dari cache (day monthName year)
            local hijri_day=$(jq -r '.hijri_date.day' "$HIJRI_CACHE_FILE" 2>/dev/null)
            local hijri_month=$(jq -r '.hijri_date.monthName' "$HIJRI_CACHE_FILE" 2>/dev/null)
            local hijri_year=$(jq -r '.hijri_date.year' "$HIJRI_CACHE_FILE" 2>/dev/null)
            
            if [ -n "$hijri_day" ] && [ "$hijri_day" != "null" ] && \
               [ -n "$hijri_month" ] && [ "$hijri_month" != "null" ] && \
               [ -n "$hijri_year" ] && [ "$hijri_year" != "null" ]; then
                echo "$hijri_day $hijri_month $hijri_year"
                return 0
            fi
        fi
    fi
    
    # Jika cache tidak ada atau sudah expired, ambil dari API baru
    local api_url="https://api.myquran.com/v3/cal/hijr/$gregorian_date?adj=$hijri_adj"
    local response=$(curl -s --max-time 5 "$api_url") # Timeout 5 detik
    local status=$(echo "$response" | jq -r '.status' 2>/dev/null)
    
    if [ "$status" = "true" ]; then
        # Format dan simpan ke cache dengan struktur baru
        mkdir -p "$(dirname "$HIJRI_CACHE_FILE")"
        echo "$response" | jq "{
            cache_time: $now,
            hijri_date: (.data.hijr | .year = (.year|tostring + \" H\"))
        }" > "$HIJRI_CACHE_FILE"
        
        # Ambil format tanggal (day monthName year)
        local hijri_day=$(echo "$response" | jq -r '.data.hijr.day' 2>/dev/null)
        local hijri_month=$(echo "$response" | jq -r '.data.hijr.monthName' 2>/dev/null)
        local hijri_year=$(echo "$response" | jq -r '.data.hijr.year' 2>/dev/null)
        
        # Tambahkan " H" ke tahun jika belum ada
        if [[ ! "$hijri_year" =~ " H$" ]]; then
            hijri_year="$hijri_year H"
        fi
        
        echo "$hijri_day $hijri_month $hijri_year"
        return 0
    else
        log "ERROR" "❌ Gagal mendapatkan tanggal Hijriyah dari API"
        # Coba gunakan cache yang expired jika ada
        if [ -f "$HIJRI_CACHE_FILE" ]; then
            local hijri_day=$(jq -r '.hijri_date.day' "$HIJRI_CACHE_FILE" 2>/dev/null)
            local hijri_month=$(jq -r '.hijri_date.monthName' "$HIJRI_CACHE_FILE" 2>/dev/null)
            local hijri_year=$(jq -r '.hijri_date.year' "$HIJRI_CACHE_FILE" 2>/dev/null)
            
            if [ -n "$hijri_day" ] && [ "$hijri_day" != "null" ] && \
               [ -n "$hijri_month" ] && [ "$hijri_month" != "null" ] && \
               [ -n "$hijri_year" ] && [ "$hijri_year" != "null" ]; then
                echo "$hijri_day $hijri_month $hijri_year"
                return 1
            fi
        fi
        echo ""
        return 1
    fi
}

# File untuk menyimpan teks custom sahur
SAHUR_REMINDER_FILE="/usr/share/jsholat/sahur-reminder.txt"
SAHUR_REMINDER_DEFAULT="Assalamu'alaikum. Bangunlah untuk sahur di bulan Ramadhan yang penuh berkah. Waktu sekarang menunjukkan {time} {timezone}. Untuk wilayah {location} dan sekitarnya. Segera bangun dan persiapkan sahur. Jangan lewatkan keberkahan sahur. Marhaban ya Ramadhan."

# Fungsi untuk membaca teks custom sahur
get_sahur_reminder_text() {
    if [ -f "$SAHUR_REMINDER_FILE" ] && [ -s "$SAHUR_REMINDER_FILE" ]; then
        cat "$SAHUR_REMINDER_FILE" 2>/dev/null | head -c 500  # Batasi 500 karakter
    else
        echo "$SAHUR_REMINDER_DEFAULT"
    fi
}

# Fungsi untuk menyimpan teks custom sahur
save_sahur_reminder_text() {
    local text="$1"
    local chat_id="$2"
    
    # Buat direktori jika belum ada
    mkdir -p "$(dirname "$SAHUR_REMINDER_FILE")"
    
    # Simpan teks ke file
    echo "$text" > "$SAHUR_REMINDER_FILE"
    
    log "📝 Teks custom sahur disimpan oleh chat_id=$chat_id"
    return 0
}

# Fungsi untuk memformat teks sahur dengan placeholder
format_sahur_reminder() {
    local template="$1"
    local time="$2"
    local timezone="$3"
    local location="$4"
    
    # Ganti placeholder dengan nilai sebenarnya
    local formatted_text="$template"
    formatted_text="${formatted_text//\{time\}/$time}"
    formatted_text="${formatted_text//\{timezone\}/$timezone}"
    formatted_text="${formatted_text//\{location\}/$location}"
    
    echo "$formatted_text"
}

# Fungsi untuk mengecek apakah bulan saat ini adalah Ramadhan
is_ramadhan() {
    # Cek apakah cache file ada
    if [ ! -f "$HIJRI_CACHE_FILE" ]; then
        # Coba generate cache dulu dengan memanggil get_hijri_date
        get_hijri_date > /dev/null 2>&1
    fi
    
    # Baca bulan dari cache file
    if [ -f "$HIJRI_CACHE_FILE" ]; then
        local hijri_month=$(jq -r '.hijri_date.month // ""' "$HIJRI_CACHE_FILE" 2>/dev/null)
        
        # Validasi data
        if [ -n "$hijri_month" ] && [ "$hijri_month" != "null" ]; then
            # Cek apakah bulan ke-9 (Ramadhan)
            if [ "$hijri_month" -eq 9 ] 2>/dev/null; then
                return 0
            fi
        fi
    fi
    
    return 1
}


# Fungsi untuk mendapatkan status bot (untuk init script)
get_bot_status() {
    local pid_file="/var/run/jsholat-bot.pid"
    
    if [ -f "$pid_file" ]; then
        local pid=$(cat "$pid_file" 2>/dev/null)
        if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
            # Get uptime dan waktu start
            local uptime_str=""
            local start_time_str="Unknown"
            local memory_usage="Unknown"
            local memory_percent="0"
            
            if [ -d "/proc/$pid" ]; then
                local start_time=$(stat -c %Y /proc/$pid 2>/dev/null || echo 0)
                local now=$(date +%s)
                local uptime=$((now - start_time))
                
                # Hitung uptime
                local days=$((uptime / 86400))
                local hours=$(( (uptime % 86400) / 3600 ))
                local minutes=$(( (uptime % 3600) / 60 ))
                local seconds=$((uptime % 60))
                
                uptime_str="${days}h ${hours}j ${minutes}m ${seconds}d"
                
                # Format waktu start
                if [ "$start_time" -gt 0 ]; then
                    start_time_str=$(date -d "@$start_time" "+%Y-%m-%d %H:%M:%S" 2>/dev/null || \
                                   date -r "$start_time" "+%Y-%m-%d %H:%M:%S" 2>/dev/null || \
                                   echo "Unknown")
                fi
                
                # Ambil informasi memori dari /proc/$pid/status
                if [ -f "/proc/$pid/status" ]; then
                    # Ambil RSS (Resident Set Size) dalam KB
                    local rss_kb=$(grep -E '^VmRSS:' /proc/$pid/status | awk '{print $2}')
                    if [ -n "$rss_kb" ]; then
                        # Konversi ke MB
                        local rss_mb=$((rss_kb / 1024))
                        memory_usage="${rss_mb} MB"
                        
                        # Hitung persentase memori jika total memori tersedia
                        if [ -f "/proc/meminfo" ]; then
                            local total_mem_kb=$(grep -E '^MemTotal:' /proc/meminfo | awk '{print $2}')
                            if [ -n "$total_mem_kb" ] && [ "$total_mem_kb" -gt 0 ]; then
                                memory_percent=$(( (rss_kb * 100) / total_mem_kb ))
                            fi
                        fi
                    fi
                fi
            fi
            
            # Return JSON format for easy parsing
            echo '{
                "status": "running",
                "pid": "'"$pid"'",
                "uptime": "'"$uptime_str"'",
                "start_time": "'"$start_time_str"'",
                "memory_usage": "'"$memory_usage"'",
                "memory_percent": "'"$memory_percent"'",
                "location": "'"${SCHEDULE_CITY_LABEL}, ${SCHEDULE_PROVINCE}"'",
                "timezone": "'"${SCHEDULE_TIMEZONE}"'",
                "source": "'"${SCHEDULE_SOURCE}"'",
                "service": "'"${SERVICE_ENABLED}"'",
                "hijri_adjust": "'"${SCHEDULE_HIJRI_ADJUST}"'",
                "sound": "'"${SOUND_ENABLED}"'",
                "telegram": "'"${SERVICE_TELEGRAM_ENABLED}"'",
                "reminder": "'"${SOUND_REMINDER_BEFORE}"'"
            }'
            return 0
        else
            rm -f "$pid_file"
            echo '{"status": "stopped"}'
            return 1
        fi
    else
        echo '{"status": "stopped"}'
        return 1
    fi
}

# Fungsi untuk mencari lokasi
search_location() {
    local query="$1"
    
    if [ ! -f "$CITIES_FILE" ]; then
        log "❌ ERROR: File cities.json tidak ditemukan di $CITIES_FILE"
        return 1
    fi

    # Normalisasi query yang lebih komprehensif
    local norm_query=$(echo "$query" | perl -ne 'print lc' | perl -pe 's/[^a-z0-9 ]//g')
    log "🔍 Mencari lokasi dengan query: '$query' (normalized: '$norm_query')"

    # Pencarian utama dengan optimasi
    jq -c --arg q "$norm_query" '
        to_entries[] | 
        .key as $province | 
        .value[] | 
        select(
            (.label | ascii_downcase | index($q)) or
            (.value | index($q))
        ) | {
            province: $province,
            label: .label,
            value: .value,
            timezone: .timezone
        }
    ' "$CITIES_FILE" > "$LOCATION_SEARCH_CACHE"

    # Fallback jika tidak ditemukan
    if [ ! -s "$LOCATION_SEARCH_CACHE" ]; then
        log "🔄 Mencoba pencarian alternatif..."
        jq -c --arg q "$norm_query" '
            to_entries[] | 
            .key as $province | 
            .value[] | 
            select(
                (.label | ascii_downcase | test(".*"+$q+".*")) or
                (.value | test(".*"+$q+".*"))
            ) | {
                province: $province,
                label: .label,
                value: .value,
                timezone: .timezone
            }
        ' "$CITIES_FILE" > "$LOCATION_SEARCH_CACHE"
    fi

    if [ -s "$LOCATION_SEARCH_CACHE" ]; then
        local result_count=$(wc -l < "$LOCATION_SEARCH_CACHE")
        log "✅ Ditemukan $result_count hasil"
        [ "$DEBUG_MODE" = "1" ] && log "📋 Contoh hasil: $(head -n 1 "$LOCATION_SEARCH_CACHE")"
        return 0
    else
        log "❌ Tidak ditemukan hasil untuk: $norm_query"
        log "📋 Daftar kota tersedia:"
        jq -r 'to_entries[] | .key + ": " + (.value[] | .label)' "$CITIES_FILE" | head -n 10 >> "$LOG_FILE"
        return 1
    fi
}

# Fungsi untuk menampilkan hasil pencarian lokasi dengan pagination
show_location_results_paginated() {
    local chat_id="$1"
    local message_id="$2"
    local query="$3"
    local page="${4:-1}"
    
    log "📄 Memproses hasil pencarian (halaman $page) untuk chat $chat_id, query: '$query'"
    
    # Force reset cache file jika halaman 1
    if [ "$page" -eq 1 ]; then
        > "$LOCATION_SEARCH_CACHE"
        if ! search_location "$query"; then
            log "❌ Pencarian gagal untuk: $query"
            
            # Ambil contoh kota yang valid
            local example_cities=$(jq -r '.[][0:2].label' "$CITIES_FILE" 2>/dev/null | head -n 3 | grep -v null | tr '\n' ', ' | sed 's/,$//')
            if [ -z "$example_cities" ]; then
                example_cities="Jakarta, Bandung, Surabaya"
            fi
            
            if [ -z "$message_id" ]; then
                send_message "$chat_id" "$(printf '❌ Tidak ditemukan lokasi dengan kata kunci '\''%s'\''\n\nContoh pencarian yang valid: %s\n\nPastikan mengetik nama kota/kabupaten dengan benar.' "$query" "$example_cities")"
            else
                remove_keyboard "$chat_id" "$message_id" "$(printf '❌ Tidak ditemukan lokasi dengan kata kunci '\''%s'\''\n\nContoh pencarian yang valid: %s\n\nPastikan mengetik nama kota/kabupaten dengan benar.' "$query" "$example_cities")"
            fi
            return 1
        fi
    fi

    # Baca semua hasil pencarian
    local all_results=()
    while IFS= read -r result; do
        [ -z "$result" ] && continue
        all_results+=("$result")
    done < "$LOCATION_SEARCH_CACHE"
    
    local total_results=${#all_results[@]}
    local total_pages=$(( (total_results + RESULTS_PER_PAGE - 1) / RESULTS_PER_PAGE ))
    
    # Validasi halaman
    if [ "$page" -gt "$total_pages" ]; then
        page=$total_pages
    fi
    
    # Hitung indeks awal dan akhir
    local start_idx=$(( (page - 1) * RESULTS_PER_PAGE ))
    local end_idx=$(( start_idx + RESULTS_PER_PAGE - 1 ))
    [ "$end_idx" -ge "$total_results" ] && end_idx=$((total_results - 1))
    
    log "📊 Menampilkan hasil $((start_idx + 1))-$((end_idx + 1)) dari $total_results (halaman $page/$total_pages)"

    # Mulai membangun keyboard sebagai array of arrays
    local keyboard='{"inline_keyboard":['
    
    # Tampilkan hasil untuk halaman ini (setiap hasil dalam baris sendiri)
    for ((i=start_idx; i<=end_idx; i++)); do
        local result="${all_results[$i]}"
        
        # Ekstrak data dari JSON
        local province=$(echo "$result" | jq -r '.province')
        local label=$(echo "$result" | jq -r '.label')
        local value=$(echo "$result" | jq -r '.value')
        local timezone=$(echo "$result" | jq -r '.timezone')

        # Bangun teks tombol dan callback data
        local button_text="${label}, ${province} (${timezone})"
        local callback_data="set_location_${value}_${timezone}"
        
        # Tambahkan baris dengan satu tombol (PASTIKAN DALAM ARRAY)
        keyboard="${keyboard}[{\"text\":\"${button_text}\",\"callback_data\":\"${callback_data}\"}],"
    done
    
    # Buat baris pagination (SELALU DALAM BENTUK ARRAY)
    keyboard="${keyboard}["
    local first_pagination=true
    
    # Tombol Previous
    if [ "$page" -gt 1 ]; then
        if [ "$first_pagination" = true ]; then
            first_pagination=false
        else
            keyboard="${keyboard},"
        fi
        keyboard="${keyboard}{\"text\":\"◀️ Sebelumnya\",\"callback_data\":\"loc_page_${query}_$((page - 1))\"}"
    fi
    
    # Informasi halaman
    if [ "$first_pagination" = true ]; then
        first_pagination=false
    else
        keyboard="${keyboard},"
    fi
    keyboard="${keyboard}{\"text\":\"📄 $page/$total_pages\",\"callback_data\":\"loc_page_info\"}"
    
    # Tombol Next
    if [ "$page" -lt "$total_pages" ]; then
        keyboard="${keyboard},{\"text\":\"▶️ Selanjutnya\",\"callback_data\":\"loc_page_${query}_$((page + 1))\"}"
    fi
    
    # Tutup baris pagination
    keyboard="${keyboard}],"
    
    # Baris tombol Batal (DALAM ARRAY)
    keyboard="${keyboard}[{\"text\":\"❌ Batal\",\"callback_data\":\"cancel_location_search\"}]"
    
    # Tutup array inline_keyboard
    keyboard="${keyboard}]}"
    
    [ "$DEBUG_MODE" = "1" ] && log "⌨️ Keyboard JSON: $keyboard"

    # Validasi keyboard dengan jq
    if ! echo "$keyboard" | jq empty 2>/dev/null; then
        log "❌ ERROR: Struktur keyboard tidak valid"
        # Kirim keyboard sederhana tanpa pagination sebagai fallback
        local fallback_keyboard='{"inline_keyboard":[[{"text":"❌ Batal","callback_data":"cancel_location_search"}]]}'
        local result_text="🔍 *Hasil pencarian untuk:* ${query}
📌 *Ditemukan*: $total_results lokasi

⚠️ Terjadi kesalahan tampilan. Gunakan tombol di bawah untuk membatalkan."
        
        if [ -z "$message_id" ]; then
            # Kirim pesan baru dengan keyboard
            curl -s -X POST \
                "https://api.telegram.org/bot${TELEGRAM_TOKEN}/sendMessage" \
                -d chat_id="${chat_id}" \
                --data-urlencode "text=${result_text}" \
                -d parse_mode="Markdown" \
                -d reply_markup="$fallback_keyboard" \
                > /dev/null 2>&1
        else
            # Edit pesan yang ada
            curl -s -X POST \
                "https://api.telegram.org/bot${TELEGRAM_TOKEN}/editMessageText" \
                -d chat_id="${chat_id}" \
                -d message_id="${message_id}" \
                --data-urlencode "text=${result_text}" \
                -d parse_mode="Markdown" \
                -d reply_markup="$fallback_keyboard" \
                > /dev/null 2>&1
        fi
        return 1
    fi

    # Kirim hasil
    local result_text="🔍 *Hasil pencarian untuk:* ${query}
📌 *Ditemukan*: $total_results lokasi
📄 *Halaman*: $page dari $total_pages

👇 Pilih lokasi yang diinginkan:"
    
    if [ -z "$message_id" ]; then
        # Kirim pesan baru dengan keyboard
        curl -s -X POST \
            "https://api.telegram.org/bot${TELEGRAM_TOKEN}/sendMessage" \
            -d chat_id="${chat_id}" \
            --data-urlencode "text=${result_text}" \
            -d parse_mode="Markdown" \
            -d reply_markup="$keyboard" \
            > /dev/null 2>&1
    else
        # Edit pesan yang ada
        curl -s -X POST \
            "https://api.telegram.org/bot${TELEGRAM_TOKEN}/editMessageText" \
            -d chat_id="${chat_id}" \
            -d message_id="${message_id}" \
            --data-urlencode "text=${result_text}" \
            -d parse_mode="Markdown" \
            -d reply_markup="$keyboard" \
            > /dev/null 2>&1
    fi
}

# Fungsi untuk menampilkan hasil pencarian lokasi
show_location_results() {
    local chat_id="$1"
    local message_id="$2"
    local query="$3"
    
    log "Memproses hasil pencarian untuk chat $chat_id, query: '$query'"
    
    # Force reset cache file
    > "$LOCATION_SEARCH_CACHE"

    if ! search_location "$query"; then
        log "Pencarian gagal untuk: $query"
        
        # Ambil contoh kota yang valid
        local example_cities=$(jq -r '.[][0:2].label' "$CITIES_FILE" 2>/dev/null | head -n 3 | grep -v null | tr '\n' ', ' | sed 's/,$//')
        if [ -z "$example_cities" ]; then
            example_cities="Jakarta, Bandung, Surabaya"
        fi
        
        # Langsung gunakan printf dalam send_message
        if [ -z "$message_id" ]; then
            send_message "$chat_id" "$(printf '❌ Tidak ditemukan lokasi dengan kata kunci '\''%s'\''\n\nContoh pencarian yang valid: %s\n\nPastikan mengetik nama kota/kabupaten dengan benar.' "$query" "$example_cities")"
        else
            remove_keyboard

 "$chat_id" "$message_id" "$(printf '❌ Tidak ditemukan lokasi dengan kata kunci '\''%s'\''\n\nContoh pencarian yang valid: %s\n\nPastikan mengetik nama kota/kabupaten dengan benar.' "$query" "$example_cities")"
        fi
        return 1
    fi

    # Baca hasil pencarian
    local results=$(cat "$LOCATION_SEARCH_CACHE")
    if [ -z "$results" ]; then
        log "ERROR: Hasil pencarian kosong"
        send_message "$chat_id" "❌ Data lokasi tidak valid"
        return 1
    fi

    # Bangun keyboard inline
    local keyboard_rows=""
    local first_row=true

    while IFS= read -r result; do
        [ -z "$result" ] && continue

        # Ekstrak data dari JSON
        local province=$(echo "$result" | jq -r '.province')
        local label=$(echo "$result" | jq -r '.label')
        local value=$(echo "$result" | jq -r '.value')
        local timezone=$(echo "$result" | jq -r '.timezone')

        # Bangun teks tombol dan callback data
        local button_text="${label}, ${province} (${timezone})"
        local callback_data="set_location_${value}_${timezone}"

        # Tambahkan ke keyboard
        if [ "$first_row" = false ]; then
            keyboard_rows="${keyboard_rows},"
        else
            first_row=false
        fi

        keyboard_rows="${keyboard_rows}[{\"text\":\"${button_text}\",\"callback_data\":\"${callback_data}\"}]"
    done < "$LOCATION_SEARCH_CACHE"

    # Tambahan tombol Batal
    if [ -n "$keyboard_rows" ]; then
        keyboard_rows="${keyboard_rows},"
    fi
    keyboard_rows="${keyboard_rows}[{\"text\":\"❌ Batal\",\"callback_data\":\"cancel_update\"}]"

    local keyboard="[${keyboard_rows}]"
    [ "$DEBUG_MODE" = "1" ] && log "Keyboard yang dibentuk: $keyboard"

    # Validasi keyboard
    if ! echo "$keyboard" | jq empty 2>/dev/null; then
        log "ERROR: Struktur keyboard tidak valid"
        send_message "$chat_id" "❌ Terjadi kesalahan saat memproses lokasi"
        return 1
    fi

    # Kirim hasil
    local result_text="🔍 Hasil pencarian untuk: *${query}*
Ditemukan $(wc -l < "$LOCATION_SEARCH_CACHE") hasil"
    if [ -z "$message_id" ]; then
        send_inline_keyboard "$chat_id" "$result_text" "$keyboard"
    else
        edit_inline_keyboard "$chat_id" "$message_id" "$result_text" "$keyboard"
    fi
}

# Fungsi untuk membersihkan city_value SAJA (untuk jadwalsholat.org)
clean_city_value() {
    local city_value="$1"
    local source="$2"
    
	if [ "$source" != "jadwalsholat" ] && [ "$source" != "arina" ]; then
		echo "$city_value"
		return 0
	fi
    
    local original_value="$city_value"
    
    # Step 1: Normalisasi string
    # - Ubah ke lowercase
    # - Hapus titik, spasi ganda, trim
    # - Ubah spasi ke strip
    city_value=$(echo "$city_value" | \
        tr '[:upper:]' '[:lower:]' | \
        tr -d '.' | \
        sed 's/[[:space:]]\+/ /g; s/^[[:space:]]*//; s/[[:space:]]*$//' | \
        sed 's/[[:space:]]/-/g')
    
    # Step 2: Hapus prefix (case insensitive dengan berbagai format)
    city_value=$(echo "$city_value" | sed -E '
        # Hapus kabupaten dengan berbagai variasi
        s/^kabupaten-//
        s/^kab-//
        s/^kabupaten//
        s/^kab//
        
        # Hapus kota dengan berbagai variasi
        s/^kota-//
        s/^kota//
        
        # Hapus singkatan
        s/^k-//
    ')
    
    # Step 3: Gabungkan arah mata angin
    city_value=$(echo "$city_value" | sed -E '
        s/-(barat|utara|timur|selatan|tengah)$/\1/i
        s/-(timur)[-_]?(laut)$/timur\2/i
        s/-(barat)[-_]?(daya|laut)$/barat\2/i
        s/-(selatan)[-_]?(timur)$/selatan\2/i
    ')
    
    # Step 4: Hapus angka dan karakter khusus
    city_value=$(echo "$city_value" | sed -E '
        s/-[0-9]+$//
        s/[^a-z0-9]//g  # Hapus semua karakter non-alphanumeric
    ')
    
    # Log perubahan
    if [ "$original_value" != "$city_value" ]; then
        log "Membersihkan city_value: '$original_value' -> '$city_value'"
    else
        log "Tidak ada perubahan untuk city_value: '$original_value'"
    fi
    
    echo "$city_value"
}

# Fungsi baru untuk update jadwal di background dengan progress
run_update_background_for_location() {
    local chat_id="$1"
    local msg_id="$2"
    local token="$3"
    local city_label="$4"
    local province="$5"
    
    # Fungsi untuk update progress
    update_progress() {
        local text="$1"
        curl -s -X POST \
            "https://api.telegram.org/bot${token}/editMessageText" \
            -d chat_id="${chat_id}" \
            -d message_id="${msg_id}" \
            -d text="$text" \
            -d parse_mode="Markdown" \
            > /dev/null 2>&1
    }
    
    # Update progress pertama
    update_progress "🔄 *Memperbarui jadwal sholat untuk ${city_label}, ${province}...*"
    
    # Buat file log sementara
    local log_file="/tmp/jsholat_update_loc_${chat_id}_$$_$(date +%s).log"
    local line_count=0
    local last_update_time=$(date +%s)
    
    # Jalankan update dan proses output secara REAL-TIME
    /usr/bin/jadwal-update.sh 2>&1 | while IFS= read -r line; do
        if [ -n "$line" ]; then
            # Simpan ke log
            echo "$line" >> "$log_file"
            line_count=$((line_count + 1))
            
            # Update progress setiap 2 baris atau untuk baris penting
            local current_time=$(date +%s)
            if [ $((line_count % 2)) -eq 0 ] || \
               [ $((current_time - last_update_time)) -ge 2 ] || \
               echo "$line" | grep -qi "error\|gagal\|berhasil\|selesai\|update\|mengambil\|jadwal"; then
                
                if ! echo "$line" | grep -q "Ping gagal"; then
                    update_progress "$(printf '🔄 *Memperbarui jadwal...*\n📍 Lokasi: %s, %s\n\n%s' "$city_label" "$province" "$line")"
                    last_update_time=$current_time
                fi
            fi
        fi
    done
    
    # Tentukan pesan akhir
    local final_message=""
    if grep -q "✅ Jadwal sholat berhasil diperbarui" "$log_file"; then
        # UPDATE BERHASIL
        local important_lines=$(grep -E "Memulai update dari sumber|Mengambil jadwal|✅ Jadwal sholat berhasil diperbarui|Update berhasil|Service berhasil" "$log_file" | tail -10)
        final_message="✅ *Jadwal Sholat Berhasil Diperbarui*

📍 *Lokasi Baru*: ${city_label}, ${province}

📋 *Ringkasan*:
\`\`\`
${important_lines}
\`\`\`"
        
    elif grep -q "Jadwal masih valid" "$log_file"; then
        # JADWAL MASIH VALID
        local last_check=$(grep "Jadwal masih valid" "$log_file" | tail -1)
        final_message="ℹ️ *Jadwal Masih Valid*

📍 *Lokasi Baru*: ${city_label}, ${province}

${last_check}

Jadwal untuk lokasi baru sudah tersedia."
        
    elif grep -q "ERROR\|Gagal" "$log_file" | grep -v "Ping gagal"; then
        # ERROR
        local error_lines=$(grep -E "ERROR|Gagal" "$log_file" | grep -v "Ping gagal" | tail -5)
        final_message="❌ *Gagal Memperbarui Jadwal*

📍 *Lokasi*: ${city_label}, ${province}

*Error*:
\`\`\`
${error_lines}
\`\`\`

Silakan coba /update manual."
        
    else
        # KONDISI LAIN
        local last_lines=$(tail -5 "$log_file")
        final_message="ℹ️ *Hasil Update Jadwal*

📍 *Lokasi Baru*: ${city_label}, ${province}

\`\`\`
${last_lines}
\`\`\`"
    fi
    
    # Update pesan final
    update_progress "$final_message"
    
    # Hapus keyboard jika ada
    curl -s -X POST \
        "https://api.telegram.org/bot${token}/editMessageReplyMarkup" \
        -d chat_id="${chat_id}" \
        -d message_id="${msg_id}" \
        -d reply_markup='{"inline_keyboard":[]}' \
        > /dev/null 2>&1
    
    # Bersihkan log setelah 5 menit
    (
        sleep 300
        rm -f "$log_file"
    ) &
}

# Fungsi untuk menyimpan lokasi yang dipilih
set_location() {
    local chat_id="$1"
    local message_id="$2"
    local city_value="$3"
    local timezone="$4"
    
    log "Menyimpan lokasi: $city_value, $timezone untuk chat $chat_id"

    # Cari detail lokasi dari cache
    local location_info=$(jq -r --arg val "$city_value" '
        select(.value == $val)' "$LOCATION_SEARCH_CACHE")

    if [ -z "$location_info" ]; then
        log "ERROR: Data lokasi tidak ditemukan di cache"
        remove_keyboard "$chat_id" "$message_id" "❌ Gagal menyimpan lokasi. Silakan coba lagi."
        return 1
    fi

    local province=$(echo "$location_info" | jq -r '.province')
    local city_label=$(echo "$location_info" | jq -r '.label')
    local original_city_value="$city_value"
    
    # Bersihkan city_value jika sumber jadwal adalah jadwalsholat atau arina
    local cleaned_city_value="$city_value"

    if [ "$SCHEDULE_SOURCE" = "jadwalsholat" ] || [ "$SCHEDULE_SOURCE" = "arina" ]; then
        cleaned_city_value=$(clean_city_value "$city_value" "$SCHEDULE_SOURCE")
        log "Membersihkan city_value: '$original_city_value' -> '$cleaned_city_value'"
    fi

    # Simpan ke config
    uci set jsholat.schedule.city_label="$city_label"
    uci set jsholat.schedule.province="$province"
    uci set jsholat.schedule.city_value="$cleaned_city_value"
    uci set jsholat.schedule.timezone_value="$timezone"
    uci commit jsholat
    
    # Update variabel config
    SCHEDULE_CITY_LABEL="$city_label"
    SCHEDULE_PROVINCE="$province"
    SCHEDULE_CITY_VALUE="$cleaned_city_value"
    SCHEDULE_TIMEZONE="$timezone"
    
    log "Lokasi disimpan: $city_label, $province ($timezone)"

    # Kirim konfirmasi dan hapus keyboard
    remove_keyboard "$chat_id" "$message_id" "✅ Lokasi berhasil diubah ke: *${city_label}, ${province} (${timezone})*"

    # Buat pesan progress BARU untuk update jadwal
    local progress_msg=$(curl -s -X POST \
        "https://api.telegram.org/bot${TELEGRAM_TOKEN}/sendMessage" \
        -d chat_id="${chat_id}" \
        -d text="🔄 *Mempersiapkan update jadwal untuk lokasi baru...*" \
        -d parse_mode="Markdown")
    
    local progress_msg_id=$(echo "$progress_msg" | jq -r '.result.message_id')
    
    # Ekspor fungsi jika perlu
    export -f run_update_background_for_location
    export TELEGRAM_TOKEN
    
    # Jalankan update di background
    (
        run_update_background_for_location "$chat_id" "$progress_msg_id" "$TELEGRAM_TOKEN" "$city_label" "$province"
    ) &
    
    local bg_pid=$!
    log "🔄 Update jadwal untuk lokasi baru berjalan di background (PID: $bg_pid) untuk chat_id=$chat_id"
    
    return 0
}

# Fungsi untuk menampilkan menu adjustment Hijriyah
show_hijri_adjust_menu() {
    local chat_id="$1"
    local message_id="$2"
    
    # Reload config untuk memastikan nilai terbaru
    load_uci_config
    
    local current_adj="$SCHEDULE_HIJRI_ADJUST"
    
    # Validasi nilai
    if [[ ! "$current_adj" =~ ^[-+][0-9]$|^[0-9]$ ]]; then
        log "Nilai current_adj tidak valid, reset ke -1: $current_adj"
        current_adj="-1"
        uci set jsholat.schedule.hijri_adjust="-1"
        uci commit jsholat
        SCHEDULE_HIJRI_ADJUST="-1"
    fi
    
    local keyboard='[[
        {"text": "-2 '$( [ "$current_adj" = "-2" ] && echo "✅" )'", "callback_data": "set_hijri_adj_-2"},
        {"text": "-1 '$( [ "$current_adj" = "-1" ] && echo "✅" )'", "callback_data": "set_hijri_adj_-1"},
        {"text": "0 '$( [ "$current_adj" = "0" ] && echo "✅" )'", "callback_data": "set_hijri_adj_0"}
    ],[
        {"text": "+1 '$( [ "$current_adj" = "1" ] && echo "✅" )'", "callback_data": "set_hijri_adj_1"},
        {"text": "+2 '$( [ "$current_adj" = "2" ] && echo "✅" )'", "callback_data": "set_hijri_adj_2"}
    ],[
        {"text": "❌ Batal", "callback_data": "cancel_update"}
    ]]'
    
    local message=$(printf '📅 *Pengaturan Adjust Hijriyah*

*Nilai saat ini:* %s

📝 *Penjelasan:*
• -2/-1 : Koreksi mundur 1-2 hari
• 0 : Tanpa koreksi
• +1/+2 : Koreksi maju 1-2 hari

Contoh: Jika tanggal Hijriyah tampil lebih awal/lambat 1 hari, pilih -1 atau +1 sesuai kebutuhan.' "$current_adj")
    
    if [ -z "$message_id" ]; then
        send_inline_keyboard "$chat_id" "$message" "$keyboard"
    else
        edit_inline_keyboard "$chat_id" "$message_id" "$message" "$keyboard"
    fi
}

# Fungsi untuk menyimpan adjustment Hijriyah
set_hijri_adjust() {
    local chat_id="$1"
    local message_id="$2"
    local adj_value="$3"
    
    # Validasi nilai
    case "$adj_value" in
        "-2"|"-1"|"0"|"1"|"2")
            # Nilai valid
            ;;
        *)
            log "ERROR: Nilai adjustment tidak valid: $adj_value"
            send_message "$chat_id" "❌ Nilai adjustment tidak valid. Hanya -2, -1, 0, +1, +2 yang diperbolehkan."
            return 1
            ;;
    esac
    
    uci set jsholat.schedule.hijri_adjust="$adj_value"
    uci commit jsholat
    
    # Update variabel config
    SCHEDULE_HIJRI_ADJUST="$adj_value"
    
    # Hapus cache
    rm -f "$HIJRI_CACHE_FILE"
    
    # Kirim konfirmasi
    remove_keyboard "$chat_id" "$message_id" "✅ Adjustment Hijriyah berhasil diatur ke $adj_value"
    
    log "Adjustment Hijriyah diatur ke $adj_value untuk chat_id=$chat_id"
}

# Fungsi untuk mengirim pesan
send_message() {
    local chat_id="$1"
    local text="$2"
    local parse_mode="${3:-Markdown}"
    
    # Escape karakter khusus JSON dan Markdown
    # 1. Escape backslash
    text=$(echo "$text" | sed 's/\\/\\\\/g')
    # 2. Escape double quote
    text=$(echo "$text" | sed 's/"/\\"/g')
    # 3. Escape karakter kontrol
    text=$(echo "$text" | sed 's/\r/\\r/g' | sed 's/\t/\\t/g')
    
    # Untuk Markdown, pastikan tidak ada karakter yang bermasalah
    if [ "$parse_mode" = "Markdown" ]; then
        # Escape karakter khusus Markdown jika diperlukan
        # Tapi jangan escape yang sudah benar
        text=$(echo "$text" | sed 's/\([_[\]()~>#+=|{}.!-]\)/\\\1/g')
    fi
    
    # Generate JSON payload dengan jq (lebih aman)
    local json_payload=$(jq -n \
        --arg chat_id "$chat_id" \
        --arg text "$text" \
        --arg parse_mode "$parse_mode" \
        '{
            chat_id: $chat_id,
            text: $text,
            parse_mode: $parse_mode
        }')
    
    log "📤 Mengirim pesan ke chat_id=$chat_id"
    
    # PERBAIKAN: Pindahkan opsi timeout ke tempat yang benar
    local response=$(curl -s -X POST \
        --connect-timeout 5 \
        --max-time 15 \
        "https://api.telegram.org/bot${TELEGRAM_TOKEN}/sendMessage" \
        -H "Content-Type: application/json" \
        -d "$json_payload")
    
    # Cek response
    local ok=$(echo "$response" | jq -r '.ok // false')
    
    if [ "$ok" = "true" ]; then
        log "✅ Pesan berhasil dikirim"
        echo "$response"
        return 0
    else
        local error_code=$(echo "$response" | jq -r '.error_code // empty')
        local description=$(echo "$response" | jq -r '.description // "Unknown error"')
        
        log "❌ Gagal mengirim pesan: $error_code - $description"
        
        # Coba kirim tanpa parse_mode jika error parsing
        if [[ "$description" == *"can't parse entities"* ]] || [[ "$description" == *"Bad Request"* ]]; then
            log "🔄 Mencoba mengirim tanpa parse_mode..."
            
            json_payload=$(jq -n \
                --arg chat_id "$chat_id" \
                --arg text "$text" \
                '{
                    chat_id: $chat_id,
                    text: $text
                }')
            
            response=$(curl -s -X POST \
                --connect-timeout 5 \
                --max-time 15 \
                "https://api.telegram.org/bot${TELEGRAM_TOKEN}/sendMessage" \
                -H "Content-Type: application/json" \
                -d "$json_payload")
            
            ok=$(echo "$response" | jq -r '.ok // false')
            
            if [ "$ok" = "true" ]; then
                log "✅ Pesan berhasil dikirim tanpa parse_mode"
                echo "$response"
                return 0
            else
                log "❌ Masih gagal meski tanpa parse_mode"
                echo "$response"
                return 1
            fi
        fi
        
        echo "$response"
        return 1
    fi
}

# Fungsi untuk mengirim jadwal bulanan dengan cache fallback dan pengecekan konfigurasi
send_monthly_schedule() {
    local chat_id="$1"
    local cache_dir="/tmp/jsholat_cache"
    local current_month=$(date +%Y%m)
    local cache_file="$cache_dir/jadwal_bulanan_${current_month}.png"
    local temp_file="/tmp/jadwal_bulanan.png"
    local current_date=$(date +%s)
    local cache_expired=0
    local use_cache=0
    local config_changed=0
    local progress_msg_id=""

    log "📤 Mengirim jadwal bulanan ke chat_id=$chat_id"

    # Buat direktori cache jika belum ada
    mkdir -p "$cache_dir"
    [ "$DEBUG_MODE" = "1" ] && log "🔧 DEBUG: Direktori cache: $cache_dir"

    # File untuk menyimpan hash konfigurasi terakhir
    local config_hash_file="$cache_dir/last_config.hash"

    # Ambil hash konfigurasi saat ini
    local current_config_hash=$(uci export jsholat | md5sum | cut -d' ' -f1)
    [ "$DEBUG_MODE" = "1" ] && log "🔧 DEBUG: Config hash saat ini: $current_config_hash"

    # Cek apakah file cache ada dan valid
    if [ -f "$cache_file" ]; then
        local file_date=$(stat -c %Y "$cache_file" 2>/dev/null)
        local file_size=$(stat -c %s "$cache_file" 2>/dev/null)
        local file_age=$(( (current_date - file_date) / 86400 ))  # umur dalam hari
        
        [ "$DEBUG_MODE" = "1" ] && log "🔧 DEBUG: Cache ditemukan - ukuran: $file_size bytes, umur: $file_age hari"
        
        # Cek apakah konfigurasi berubah
        if [ -f "$config_hash_file" ]; then
            local last_config_hash=$(cat "$config_hash_file")
            [ "$DEBUG_MODE" = "1" ] && log "🔧 DEBUG: Last config hash: $last_config_hash"
            
            if [ "$current_config_hash" != "$last_config_hash" ]; then
                config_changed=1
                log "📝 Konfigurasi UCI berubah, perlu generate ulang"
                [ "$DEBUG_MODE" = "1" ] && log "🔧 DEBUG: Hash berbeda: '$current_config_hash' vs '$last_config_hash'"
            fi
        else
            [ "$DEBUG_MODE" = "1" ] && log "🔧 DEBUG: File hash config tidak ditemukan"
        fi

        if [ "$file_age" -lt 1 ] && [ "$config_changed" -eq 0 ] && [ "$file_size" -gt 1000 ]; then
            log "✅ Menggunakan gambar dari cache (umur: $file_age hari, ukuran: $file_size bytes)"
            use_cache=1
        else
            cache_expired=1
            if [ "$file_age" -ge 1 ]; then
                log "⏰ Cache expired (umur: $file_age hari)"
            fi
            if [ "$config_changed" -eq 1 ]; then
                log "⚙️ Konfigurasi berubah, cache perlu diperbarui"
            fi
            if [ "$file_size" -le 1000 ]; then
                log "⚠️ File cache korup/terlalu kecil ($file_size bytes)"
            fi
        fi
    else
        log "❌ Cache tidak ditemukan, akan generate baru"
        [ "$DEBUG_MODE" = "1" ] && log "🔧 DEBUG: Mencari file: $cache_file"
    fi

    # Jika tidak menggunakan cache, kirim pesan bahwa proses dimulai
    if [ "$use_cache" -eq 0 ]; then
        # Kirim pesan bahwa proses dimulai dengan printf format
        local progress_text=$(printf '⏳ *Membuat jadwal bulanan...*\n\nProses ini akan berjalan di background.\nAnda akan menerima gambar setelah selesai.')
        local progress_msg=$(send_message "$chat_id" "$progress_text" "Markdown")
        progress_msg_id=$(echo "$progress_msg" | jq -r '.result.message_id // empty')
        
        log "⏳ Memulai generate jadwal bulanan di background untuk chat_id=$chat_id (progress_msg_id: $progress_msg_id)"
        
        # Jalankan generator di BACKGROUND
        (
            local start_time=$(date +%s)
            log "🔄 Menjalankan generator jadwal bulanan di background (PID: $$)"
            
            if [ "$DEBUG_MODE" = "1" ]; then
                log "🔧 DEBUG: Memanggil: python3 /usr/bin/jadwal-monthly"
                # Simpan output untuk debugging
                python3 /usr/bin/jadwal-monthly > "/tmp/jadwal-monthly-debug-$$.log" 2>&1
                local py_exit=$?
                log "🔧 DEBUG: Python exit code: $py_exit"
                log "🔧 DEBUG: Output tersimpan di: /tmp/jadwal-monthly-debug-$$.log"
            else
                python3 /usr/bin/jadwal-monthly > /dev/null 2>&1
                local py_exit=$?
            fi
            
            # Hapus pesan progress jika ada
            if [ -n "$progress_msg_id" ]; then
                curl -s -X POST \
                    "https://api.telegram.org/bot${TELEGRAM_TOKEN}/deleteMessage" \
                    -d chat_id="${chat_id}" \
                    -d message_id="${progress_msg_id}" \
                    > /dev/null 2>&1
                log "🗑️ Pesan progress dihapus (message_id: $progress_msg_id)"
            fi
            
            if [ $py_exit -ne 0 ]; then
                log "❌ Gagal generate jadwal bulanan (exit code: $py_exit)"
                
                # Jika gagal generate, coba gunakan cache yang ada jika tersedia
                if [ -f "$cache_file" ]; then
                    local file_size=$(stat -c %s "$cache_file" 2>/dev/null)
                    log "⚠️ Fallback ke cache yang tersedia (ukuran: $file_size bytes)"
                    
                    curl -s -X POST \
                        "https://api.telegram.org/bot${TELEGRAM_TOKEN}/sendPhoto" \
                        -F chat_id="${chat_id}" \
                        -F photo="@$cache_file" \
                        -F caption="📅 Jadwal Sholat Bulan $(date +"%B %Y") (from cache - fallback)"
                    
                    if [ $? -eq 0 ]; then
                        log "✅ Gambar cache berhasil dikirim (fallback)"
                    else
                        log "❌ Gagal mengirim gambar cache (fallback)"
                    fi
                else
                    log "❌ Tidak ada cache tersedia untuk fallback"
                    local error_text=$(printf '❌ *Gagal membuat jadwal bulanan*\n\nTidak ada cache tersedia.')
                    send_message "$chat_id" "$error_text" "Markdown"
                fi
                
                local end_time=$(date +%s)
                local elapsed=$((end_time - start_time))
                log "⏱️ Proses selesai dalam $elapsed detik (GAGAL)"
                return 1
            fi

            # Verifikasi file output
            if [ ! -f "$temp_file" ]; then
                log "❌ File output tidak ditemukan: $temp_file"
                
                # Cari file dengan nama mirip untuk debugging
                if [ "$DEBUG_MODE" = "1" ]; then
                    log "🔧 DEBUG: Mencari file di /tmp:"
                    ls -la /tmp/jadwal* 2>/dev/null | while read line; do
                        log "🔧 DEBUG: $line"
                    done
                fi
                
                # Coba lagi dengan cache jika ada
                if [ -f "$cache_file" ]; then
                    log "⚠️ Fallback ke cache yang tersedia"
                    curl -s -X POST \
                        "https://api.telegram.org/bot${TELEGRAM_TOKEN}/sendPhoto" \
                        -F chat_id="${chat_id}" \
                        -F photo="@$cache_file" \
                        -F caption="📅 Jadwal Sholat Bulan $(date +"%B %Y") (from cache - fallback)"
                    
                    if [ $? -eq 0 ]; then
                        log "✅ Gambar cache berhasil dikirim (fallback)"
                    else
                        log "❌ Gagal mengirim gambar cache (fallback)"
                    fi
                else
                    local error_text=$(printf '❌ *Gagal membuat jadwal bulanan*\n\nFile output tidak ditemukan.')
                    send_message "$chat_id" "$error_text" "Markdown"
                fi
                
                local end_time=$(date +%s)
                local elapsed=$((end_time - start_time))
                log "⏱️ Proses selesai dalam $elapsed detik (GAGAL)"
                return 1
            fi

            # Dapatkan ukuran file baru
            local new_file_size=$(stat -c %s "$temp_file" 2>/dev/null)
            log "📊 File baru: $temp_file (ukuran: $new_file_size bytes)"

            # Update cache dengan file baru
            mv "$temp_file" "$cache_file"
            log "💾 Cache diperbarui: $cache_file"
            
            # Simpan hash konfigurasi terbaru
            echo "$current_config_hash" > "$config_hash_file"
            log "💾 Hash config disimpan: $current_config_hash"
            
            # Kirim gambar hasil generate
            local caption="📅 Jadwal Sholat Bulan $(date +"%B %Y")"
            if [ "$cache_expired" -eq 1 ]; then
                caption="$caption (updated)"
                log "🔄 Label: updated (cache expired)"
            fi
            if [ "$config_changed" -eq 1 ]; then
                caption="$caption (config updated)"
                log "⚙️ Label: config updated"
            fi

            log "📤 Mengirim gambar ke chat_id=$chat_id"
            local send_result=$(curl -s -X POST \
                "https://api.telegram.org/bot${TELEGRAM_TOKEN}/sendPhoto" \
                -F chat_id="${chat_id}" \
                -F photo="@$cache_file" \
                -F caption="$caption")
            
            if echo "$send_result" | jq -e '.ok' >/dev/null 2>&1; then
                log "✅ Gambar berhasil dikirim ke chat_id=$chat_id"
            else
                local error_msg=$(echo "$send_result" | jq -r '.description' 2>/dev/null || echo "Unknown error")
                log "❌ Gagal mengirim gambar: $error_msg"
                
                if [ "$DEBUG_MODE" = "1" ]; then
                    log "🔧 DEBUG: Response lengkap: $send_result"
                fi
                
                # Kirim pesan error jika gambar gagal dikirim
                local error_text=$(printf '❌ *Gagal mengirim gambar*\n\nError: %s' "$error_msg")
                send_message "$chat_id" "$error_text" "Markdown"
            fi
            
            local end_time=$(date +%s)
            local elapsed=$((end_time - start_time))
            log "⏱️ Proses selesai dalam $elapsed detik (SUKSES)"
        ) &
        
        local bg_pid=$!
        log "🔄 Generator jadwal bulanan berjalan di background (PID: $bg_pid)"
        [ "$DEBUG_MODE" = "1" ] && log "🔧 DEBUG: Background job PID: $bg_pid, PPID: $$"
        
        return 0
    fi

    # Kirim gambar dari cache (langsung)
    local caption="📅 Jadwal Sholat Bulan $(date +"%B %Y")"
    if [ "$use_cache" -eq 1 ]; then
        caption="$caption (from cache)"
        log "📤 Mengirim gambar dari cache ke chat_id=$chat_id"
    fi

    local file_size=$(stat -c %s "$cache_file" 2>/dev/null)
    log "📊 File cache: $cache_file (ukuran: $file_size bytes)"

    local send_result=$(curl -s --connect-timeout 5 --max-time 10 -X POST \
        "https://api.telegram.org/bot${TELEGRAM_TOKEN}/sendPhoto" \
        -F chat_id="${chat_id}" \
        -F photo="@$cache_file" \
        -F caption="$caption")
    
    if echo "$send_result" | jq -e '.ok' >/dev/null 2>&1; then
        log "✅ Gambar cache berhasil dikirim ke chat_id=$chat_id"
        return 0
    else
        local error_msg=$(echo "$send_result" | jq -r '.description' 2>/dev/null || echo "Unknown error")
        log "❌ Gagal mengirim gambar cache: $error_msg"
        
        if [ "$DEBUG_MODE" = "1" ]; then
            log "🔧 DEBUG: Response lengkap: $send_result"
        fi
        
        # Kirim pesan error jika gambar gagal dikirim
        local error_text=$(printf '❌ *Gagal mengirim gambar cache*\n\nError: %s' "$error_msg")
        send_message "$chat_id" "$error_text" "Markdown"
        return 1
    fi
}

# Fungsi untuk mengirim inline keyboard
send_inline_keyboard() {
    local chat_id="$1"
    local text="$2"
    local keyboard="$3"
    
    log "Mengirim inline keyboard ke $chat_id"
    log "Teks: $text"
    [ "$DEBUG_MODE" = "1" ] && log "Keyboard: $keyboard"

    # Bangun payload JSON yang benar
    local payload=$(printf '{
        "chat_id": "%s",
        "text": "%s",
        "parse_mode": "Markdown",
        "reply_markup": {"inline_keyboard": %s}
    }' "$chat_id" "$(echo "$text" | sed 's/"/\\"/g')" "$keyboard")

    [ "$DEBUG_MODE" = "1" ] && log "Payload yang dikirim: $payload"

    local response=$(curl -s -X POST \
        "https://api.telegram.org/bot${TELEGRAM_TOKEN}/sendMessage" \
        -H "Content-Type: application/json" \
        -d "$payload")

    [ "$DEBUG_MODE" = "1" ] && log "Response dari Telegram API: $response"

    if ! echo "$response" | jq -e '.ok' >/dev/null; then
        local error_msg=$(echo "$response" | jq -r '.description' 2>/dev/null || echo "Unknown error")
        log "ERROR: Gagal mengirim keyboard - $error_msg"
        return 1
    fi

    return 0
}

# Fungsi untuk mengedit pesan dengan inline keyboard
edit_inline_keyboard() {
    local chat_id="$1"
    local message_id="$2"
    local text="$3"
    local keyboard="$4"
    
    [ "$DEBUG_MODE" = "1" ] && log "Mengedit pesan dengan inline keyboard (message_id=$message_id)"
    
    # Escape text untuk JSON
    local escaped_text=$(echo "$text" | sed 's/\\/\\\\/g; s/"/\\"/g')
    
    # Coba dengan parse_mode=Markdown terlebih dahulu
    local response=$(curl -s -X POST \
        "https://api.telegram.org/bot${TELEGRAM_TOKEN}/editMessageText" \
        -d chat_id="${chat_id}" \
        -d message_id="${message_id}" \
        --data-urlencode "text=${text}" \
        -d parse_mode="Markdown" \
        -d reply_markup="{\"inline_keyboard\":${keyboard}}")
    
    if [ "$DEBUG_MODE" = "1" ]; then
        log "Response editInlineKeyboard: $response"
    fi
    
    # Cek apakah berhasil
    if ! echo "$response" | jq -e '.ok' >/dev/null; then
        local error_desc=$(echo "$response" | jq -r '.description' 2>/dev/null || echo "Unknown error")
        log "ERROR: Gagal mengedit keyboard dengan Markdown - $error_desc"
        
        # Jika error parsing, coba tanpa parse_mode
        if [[ "$error_desc" == *"parse entities"* ]]; then
            log "🔄 Mencoba edit tanpa parse_mode..."
            
            response=$(curl -s -X POST \
                "https://api.telegram.org/bot${TELEGRAM_TOKEN}/editMessageText" \
                -d chat_id="${chat_id}" \
                -d message_id="${message_id}" \
                --data-urlencode "text=${text}" \
                -d reply_markup="{\"inline_keyboard\":${keyboard}}")
            
            if echo "$response" | jq -e '.ok' >/dev/null; then
                log "✅ Berhasil mengedit tanpa parse_mode"
                return 0
            else
                error_desc=$(echo "$response" | jq -r '.description' 2>/dev/null || echo "Unknown error")
                log "ERROR: Gagal mengedit keyboard tanpa parse_mode - $error_desc"
                send_message "$chat_id" "❌ Terjadi kesalahan saat memperbarui pesan"
                return 1
            fi
        else
            send_message "$chat_id" "❌ Terjadi kesalahan saat memperbarui pesan"
            return 1
        fi
    fi
    
    return 0
}

# Fungsi untuk mengedit pesan (tanpa keyboard)
remove_keyboard() {
    local chat_id="$1"
    local message_id="$2"
    local text="$3"

    [ "$DEBUG_MODE" = "1" ] && log "Menghapus keyboard untuk message_id=$message_id"
    
    curl -s -X POST \
        "https://api.telegram.org/bot${TELEGRAM_TOKEN}/editMessageText" \
        -d chat_id="${chat_id}" \
        -d message_id="${message_id}" \
        -d text="${text}" \
        -d parse_mode="Markdown" \
        > /dev/null 2>&1
}

# Fungsi untuk update status service
update_service_status() {
    local chat_id="$1"
    local message_id="$2"
    local status="$3"
    
    uci set jsholat.service.service="$status"
    uci commit jsholat
    /etc/init.d/jsholat restart
	
	# Update variabel config
    SERVICE_ENABLED="$status"
    
    local status_text=$([ "$status" = "1" ] && echo "diaktifkan" || echo "dinonaktifkan")
    remove_keyboard "$chat_id" "$message_id" "✅ Service jsholat telah $status_text"
}

# Fungsi untuk toggle pengaturan suara
toggle_sound_setting() {
    local chat_id="$1"
    local message_id="$2"
    
    local current_status="$SOUND_ENABLED"
    local new_status=$([ "$current_status" = "1" ] && echo "0" || echo "1")
    
    uci set jsholat.sound.sound_enabled="$new_status"
    uci commit jsholat
	
	# Update variabel config
    SOUND_ENABLED="$new_status"
    
    local status_text=$([ "$new_status" = "1" ] && echo "diaktifkan" || echo "dinonaktifkan")
    remove_keyboard "$chat_id" "$message_id" "🔊 Suara adzan telah $status_text"
}

# Fungsi untuk toggle notifikasi Telegram
toggle_telegram_setting() {
    local chat_id="$1"
    local message_id="$2"
    
    local current_status="$SERVICE_TELEGRAM_ENABLED"
    local new_status=$([ "$current_status" = "1" ] && echo "0" || echo "1")
    
    uci set jsholat.service.telegram_enabled="$new_status"
    uci commit jsholat    
	
	# Update variabel config
    SERVICE_TELEGRAM_ENABLED="$new_status"
    
    local status_text=$([ "$new_status" = "1" ] && echo "diaktifkan" || echo "dinonaktifkan")
    remove_keyboard "$chat_id" "$message_id" "📱 Notifikasi Telegram telah $status_text"
}

# Fungsi untuk menampilkan menu pengaturan tarhim
# Fungsi untuk menampilkan menu pengaturan tarhim - VERSI AMAN UNTUK EDIT
show_tarhim_menu() {
    local chat_id="$1"
    local message_id="$2"
    
    # Reload config untuk memastikan nilai terbaru
    load_uci_config
    
    local tarhim_enabled="$SOUND_TARHIM_ENABLED"
    local tarhim_mode="$SOUND_TARHIM_MODE"
    local tarhim_file="$SOUND_TARHIM_FILE"
    local reminder_sound_enabled="$SOUND_REMINDER_SOUND_ENABLED"
    local reminder_before="$SOUND_REMINDER_BEFORE"
    
    # Cek status Ramadhan
    local is_ramadhan_now=0
    if is_ramadhan; then
        is_ramadhan_now=1
    fi
    
    # Status enabled/disabled
    local enabled_text=$([ "$tarhim_enabled" = "1" ] && echo "🟢 AKTIF" || echo "🔴 NONAKTIF")
    
    # Status mode dengan deskripsi perilaku TTS
    local mode_text=""
    local tts_behavior_text=""
    
    if [ "$tarhim_enabled" = "1" ]; then
        case "$tarhim_mode" in
            "always")
                mode_text="📆 Setiap Hari (dengan TTS)"
                tts_behavior_text="🔊 TTS reminder: AKTIF setiap hari"
                ;;
            "ramadhan_only")
                mode_text="🌙 Ramadhan Only"
                if [ "$is_ramadhan_now" = "1" ]; then
                    tts_behavior_text="🔊 TTS reminder: AKTIF (sedang Ramadhan)"
                else
                    tts_behavior_text="🔇 TTS reminder: NONAKTIF (bukan Ramadhan, tarhim tetap diputar)"
                fi
                ;;
            *)
                mode_text="$tarhim_mode"
                tts_behavior_text="⚠️ Mode tidak dikenal"
                ;;
        esac
    else
        mode_text="Tarhim Nonaktif"
        tts_behavior_text="📢 Notifikasi Telegram Imsyak tetap dikirim"
    fi
    
    # Status suara reminder secara umum
    local reminder_status=$([ "$reminder_sound_enabled" = "1" ] && echo "🟢 AKTIF" || echo "🔴 NONAKTIF")
    
    # Escape path file untuk Markdown (underscore)
    local safe_tarhim_file=$(echo "$tarhim_file" | sed 's/_/\\_/g')
    
    local keyboard='[[
        {"text": "'"$( [ "$tarhim_enabled" = "1" ] && echo "🔴 Nonaktifkan" || echo "🟢 Aktifkan")"' Tarhim", "callback_data": "toggle_tarhim"}
    ],[
        {"text": "📅 Mode: '"$( [ "$tarhim_mode" = "always" ] && echo "Setiap Hari" || echo "Hanya Ramadhan")"'", "callback_data": "tarhim_mode_menu"}
    ],[
        {"text": "🎧 Test Tarhim", "callback_data": "test_tarhim"}
    ],[
        {"text": "⬅️ Kembali", "callback_data": "back_to_reminder_menu"}
    ]]'
    
    # Gunakan teks biasa untuk path file (tanpa backtick)
    local message=$(printf '🎵 *PENGATURAN TARHIM/IMSYAK*

*Status Tarhim:* %s
*Mode Tarhim:* %s
*Status TTS Reminder:* %s
*Waktu Reminder:* %s menit sebelum Imsyak
*File Suara:* %s

📝 *PERILAKU TARHIM & TTS:*
%s

🔊 *Status Suara Reminder Umum:* %s

💡 *Penjelasan Mode:*
• *Setiap Hari*: Tarhim diputar SETIAP HARI, TTS reminder juga AKTIF setiap hari
• *Hanya Ramadhan*: Tarhim SELALU diputar setiap hari, namun TTS reminder HANYA AKTIF SAAT RAMADHAN

📢 *Notifikasi Telegram Imsyak* tetap dikirim TERLEPAS DARI STATUS TARHIM' \
"$enabled_text" "$mode_text" "$reminder_status" "$reminder_before" "$safe_tarhim_file" \
"$tts_behavior_text" "$reminder_status")
    
    if [ -z "$message_id" ]; then
        send_inline_keyboard "$chat_id" "$message" "$keyboard"
    else
        edit_inline_keyboard "$chat_id" "$message_id" "$message" "$keyboard"
    fi
}

# Fungsi untuk menampilkan menu pilihan mode tarhim
show_tarhim_mode_menu() {
    local chat_id="$1"
    local message_id="$2"
    
    # Reload config
    load_uci_config
    
    local current_mode="$SOUND_TARHIM_MODE"
    local reminder_sound_enabled="$SOUND_REMINDER_SOUND_ENABLED"
    
    # Cek status Ramadhan
    local is_ramadhan_now=0
    if is_ramadhan; then
        is_ramadhan_now=1
    fi
    
    # Status saat ini untuk Ramadhan
    local ramadhan_status=""
    if [ "$is_ramadhan_now" = "1" ]; then
        ramadhan_status="🌙 *SEDANG RAMADHAN* - TTS reminder akan AKTIF"
    else
        ramadhan_status="📅 *BUKAN RAMADHAN* - TTS reminder akan NONAKTIF"
    fi
    
    local keyboard='[[
        {"text": "📆 Setiap Hari '"$( [ "$current_mode" = "always" ] && echo "✅" )"'", "callback_data": "set_tarhim_mode_always"}
    ],[
        {"text": "🌙 Hanya Ramadhan '"$( [ "$current_mode" = "ramadhan_only" ] && echo "✅" )"'", "callback_data": "set_tarhim_mode_ramadhan_only"}
    ],[
        {"text": "⬅️ Kembali", "callback_data": "back_to_tarhim_menu"}
    ]]'
    
    local message=$(printf '📅 *PILIH MODE TARHIM*

*Mode Saat Ini:* %s

%s

🔊 *TTS Reminder Umum:* %s

📋 *DETAIL MODE:*
• *Setiap Hari*: Tarhim diputar SETIAP HARI + TTS reminder AKTIF setiap hari
• *Hanya Ramadhan*: Tarhim SELALU diputar SETIAP HARI, namun TTS reminder HANYA AKTIF saat Ramadhan

⚠️ *Catatan:* Notifikasi Telegram Imsyak tetap dikirim TERLEPAS dari mode yang dipilih' \
"$([ "$current_mode" = "always" ] && echo "Setiap Hari" || echo "Hanya Ramadhan")" \
"$ramadhan_status" \
"$([ "$reminder_sound_enabled" = "1" ] && echo "🟢 AKTIF" || echo "🔴 NONAKTIF")")
    
    if [ -z "$message_id" ]; then
        send_inline_keyboard "$chat_id" "$message" "$keyboard"
    else
        edit_inline_keyboard "$chat_id" "$message_id" "$message" "$keyboard"
    fi
}

# Fungsi untuk toggle tarhim enabled/disabled
toggle_tarhim() {
    local chat_id="$1"
    local message_id="$2"
    
    local current_status="$SOUND_TARHIM_ENABLED"
    local new_status=$([ "$current_status" = "1" ] && echo "0" || echo "1")
    
    uci set jsholat.sound.tarhim_enabled="$new_status"
    uci commit jsholat
    
    # Restart service
    /etc/init.d/jsholat restart
    
    # Update variabel config
    SOUND_TARHIM_ENABLED="$new_status"
    
    # Kirim pesan konfirmasi sebelum kembali ke menu
    local status_text=$([ "$new_status" = "1" ] && echo "diaktifkan" || echo "dinonaktifkan")
    local additional_info=""
    
    if [ "$new_status" = "1" ]; then
        additional_info="%0A%0A📢 *Catatan:* Tarhim akan diputar sesuai mode yang dipilih. Notifikasi Telegram tetap berjalan."
    else
        additional_info="%0A%0A📢 *Catatan:* Notifikasi Telegram Imsyak TETAP dikirim meskipun tarhim nonaktif."
    fi
    
    # Kirim pesan sementara
    curl -s -X POST \
        "https://api.telegram.org/bot${TELEGRAM_TOKEN}/editMessageText" \
        -d chat_id="${chat_id}" \
        -d message_id="${message_id}" \
        -d text="✅ *Tarhim telah ${status_text}*${additional_info}" \
        -d parse_mode="Markdown" \
        > /dev/null 2>&1
    
    sleep 2
    
    # Kembali ke menu tarhim
    show_tarhim_menu "$chat_id" "$message_id"
    
    log "Tarhim telah $status_text untuk chat_id=$chat_id"
}

# Fungsi untuk mengatur mode tarhim
set_tarhim_mode() {
    local chat_id="$1"
    local message_id="$2"
    local mode="$3"
    
    # Validasi mode
    case "$mode" in
        "always")
            # Mode valid
            local mode_name="Setiap Hari"
            local mode_desc="Tarhim diputar SETIAP HARI + TTS reminder AKTIF setiap hari"
            ;;
        "ramadhan_only")  
            # Mode valid
            local mode_name="Hanya Ramadhan"
            local mode_desc="Tarhim SELALU diputar SETIAP HARI, TTS reminder HANYA saat Ramadhan"
            ;;
        *)
            log "ERROR: Mode tarhim tidak valid: $mode"
            send_message "$chat_id" "❌ Mode tarhim tidak valid. Pilih: always atau ramadhan_only" ""
            return 1
            ;;
    esac
    
    uci set jsholat.sound.tarhim_mode="$mode"
    uci commit jsholat
    
    # Restart service
    /etc/init.d/jsholat restart
    
    # Update variabel config
    SOUND_TARHIM_MODE="$mode"
    
    # Cek status Ramadhan untuk informasi tambahan
    local ramadhan_info=""
    if is_ramadhan; then
        if [ "$mode" = "ramadhan_only" ]; then
            ramadhan_info="%0A%0A🌙 *Saat ini sedang Ramadhan*, TTS reminder akan AKTIF."
        fi
    else
        if [ "$mode" = "ramadhan_only" ]; then
            ramadhan_info="%0A%0A📅 *Saat ini bukan Ramadhan*, TTS reminder akan NONAKTIF (tarhim tetap diputar)."
        fi
    fi
    
    # Kirim pesan konfirmasi
    curl -s -X POST \
        "https://api.telegram.org/bot${TELEGRAM_TOKEN}/editMessageText" \
        -d chat_id="${chat_id}" \
        -d message_id="${message_id}" \
        -d text="✅ *Mode tarhim diubah ke: ${mode_name}*%0A%0A${mode_desc}${ramadhan_info}" \
        -d parse_mode="Markdown" \
        > /dev/null 2>&1
    
    sleep 2
    
    # Kembali ke menu tarhim
    show_tarhim_menu "$chat_id" "$message_id"
    
    log "Mode tarhim diatur ke $mode_name untuk chat_id=$chat_id"
}

# Fungsi untuk test suara tarhim
test_tarhim() {
    local chat_id="$1"
    local message_id="$2"
    
    # Edit pesan untuk menunjukkan sedang mempersiapkan
    curl -s -X POST \
        "https://api.telegram.org/bot${TELEGRAM_TOKEN}/editMessageText" \
        -d chat_id="${chat_id}" \
        -d message_id="${message_id}" \
        -d text="🎵 *Memutar suara tarhim...*" \
        -d parse_mode="Markdown" \
        > /dev/null 2>&1
    
    # Load config
    load_uci_config
    
    local tarhim_file="$SOUND_TARHIM_FILE"
    local volume_level="$SOUND_VOLUME_LEVEL"
    local tarhim_mode="$SOUND_TARHIM_MODE"
    
    # Cek status Ramadhan
    local is_ramadhan_now=0
    if is_ramadhan; then
        is_ramadhan_now=1
    fi
    
    # Cek file tarhim
    if [ ! -f "$tarhim_file" ]; then
        # Escape path untuk Markdown - HAPUS BACKTICK
        local safe_file=$(echo "$tarhim_file" | sed 's/_/\\_/g')
        curl -s -X POST \
            "https://api.telegram.org/bot${TELEGRAM_TOKEN}/editMessageText" \
            -d chat_id="${chat_id}" \
            -d message_id="${message_id}" \
            -d text="❌ *File tarhim tidak ditemukan*%0A%0APath: $safe_file%0A%0A📢 *Catatan:* Notifikasi Telegram Imsyak tetap dikirim meskipun file tidak ada." \
            -d parse_mode="Markdown" \
            > /dev/null 2>&1
        log "File tarhim tidak ditemukan: $tarhim_file"
        return 1
    fi
    
    # Set volume
    local mixer_device=$(detect_mixer_device "$SOUND_MIXER_DEVICE")
    amixer -q set "$mixer_device" "${volume_level}%" >/dev/null 2>&1
    
    # Putar tarhim (background process)
    (
        if command -v play >/dev/null 2>&1; then
            play -q "$tarhim_file" 2>/dev/null
        elif command -v mpg123 >/dev/null 2>&1; then
            mpg123 -q "$tarhim_file" 2>/dev/null
        elif command -v aplay >/dev/null 2>&1; then
            aplay -q "$tarhim_file" 2>/dev/null
        else
            log "Tidak ada pemutar audio yang tersedia"
        fi
    ) &
    
    local play_pid=$!
    
    # Tunggu sebentar
    sleep 3
    
    # Info tambahan tentang perilaku berdasarkan mode
    local behavior_info=""
    if [ "$tarhim_mode" = "ramadhan_only" ] && [ "$is_ramadhan_now" = "0" ]; then
        behavior_info="%0A%0A📅 *Informasi:* Saat ini bukan Ramadhan. Dalam mode *Hanya Ramadhan*, tarhim tetap diputar setiap hari (seperti test ini), namun TTS reminder tidak aktif."
    elif [ "$tarhim_mode" = "ramadhan_only" ] && [ "$is_ramadhan_now" = "1" ]; then
        behavior_info="%0A%0A🌙 *Informasi:* Sedang Ramadhan. Dalam mode *Hanya Ramadhan*, tarhim diputar dan TTS reminder AKTIF."
    elif [ "$tarhim_mode" = "always" ]; then
        behavior_info="%0A%0A📆 *Informasi:* Mode *Setiap Hari* aktif. Tarhim dan TTS reminder akan diputar setiap hari."
    fi
    
    # Escape filename untuk Markdown - HAPUS BACKTICK
    local filename=$(basename "$tarhim_file" | sed 's/_/\\_/g')
    
    # Update status - HAPUS BACKTICK
    curl -s -X POST \
        "https://api.telegram.org/bot${TELEGRAM_TOKEN}/editMessageText" \
        -d chat_id="${chat_id}" \
        -d message_id="${message_id}" \
        -d text="✅ *Test tarhim selesai*

File: $filename
Volume: ${volume_level}%
Mode: $( [ "$tarhim_mode" = "always" ] && echo "Setiap Hari" || echo "Hanya Ramadhan" )${behavior_info}

📢 *Notifikasi Telegram Imsyak* tetap dikirim terlepas dari status tarhim." \
        -d parse_mode="Markdown" \
        > /dev/null 2>&1
    
    log "Test tarhim dilakukan untuk chat_id=$chat_id"
}

# Fungsi tambahan untuk menampilkan informasi reminder lengkap
show_reminder_info() {
    local chat_id="$1"
    local message_id="$2"
    
    # Load config
    load_uci_config
    
    local tarhim_enabled="$SOUND_TARHIM_ENABLED"
    local tarhim_mode="$SOUND_TARHIM_MODE"
    local reminder_sound_enabled="$SOUND_REMINDER_SOUND_ENABLED"
    local reminder_before="$SOUND_REMINDER_BEFORE"
    local tts_method="$SOUND_TTS_METHOD"
    
    # Konversi nama metode TTS
    local tts_method_name=""
    case "$tts_method" in
        "google") tts_method_name="Google Translate" ;;
        "edge") tts_method_name="Edge-TTS" ;;
        "espeak") tts_method_name="eSpeak" ;;
        "murf") tts_method_name="Murf.ai" ;;
        *) tts_method_name="$tts_method" ;;
    esac
    
    # Cek status Ramadhan
    local is_ramadhan_now=0
    if is_ramadhan; then
        is_ramadhan_now=1
    fi
    
    # Tentukan perilaku TTS Imsyak
    local tts_imsyak_behavior=""
    if [ "$tarhim_enabled" = "1" ]; then
        if [ "$tarhim_mode" = "always" ]; then
            tts_imsyak_behavior="🔊 TTS Imsyak: AKTIF setiap hari"
        elif [ "$tarhim_mode" = "ramadhan_only" ]; then
            if [ "$is_ramadhan_now" = "1" ]; then
                tts_imsyak_behavior="🔊 TTS Imsyak: AKTIF (sedang Ramadhan)"
            else
                tts_imsyak_behavior="🔇 TTS Imsyak: NONAKTIF (bukan Ramadhan, tarhim tetap diputar)"
            fi
        fi
    else
        tts_imsyak_behavior="🔇 TTS Imsyak: NONAKTIF (tarhim dimatikan)"
    fi
    
    local keyboard='[[
        {"text": "🎵 Pengaturan Tarhim", "callback_data": "tarhim_menu"}
    ],[
        {"text": "⬅️ Kembali", "callback_data": "back_to_reminder_menu"}
    ]]'
    
    local message=$(printf '📊 *INFORMASI REMINDER & TARHIM*

⏰ *Reminder Sholat:*
• Durasi: %s menit sebelum
• Suara TTS: %s
• Metode TTS: %s

🌙 *Tarhim Imsyak:*
• Status: %s
• Mode: %s
• %s

📢 *Notifikasi Telegram:*
• Imsyak: SELALU dikirim
• Sholat wajib: SELALU dikirim

%s' \
"$reminder_before" \
"$([ "$reminder_sound_enabled" = "1" ] && echo "🟢 AKTIF" || echo "🔴 NONAKTIF")" \
"$tts_method_name" \
"$([ "$tarhim_enabled" = "1" ] && echo "🟢 AKTIF" || echo "🔴 NONAKTIF")" \
"$([ "$tarhim_mode" = "always" ] && echo "Setiap Hari" || echo "Hanya Ramadhan")" \
"$tts_imsyak_behavior" \
"$([ "$tarhim_enabled" = "0" ] && echo '%0A📌 *Catatan:* Meskipun tarhim nonaktif, notifikasi Telegram Imsyak TETAP dikirim.' || echo '')")
    
    if [ -z "$message_id" ]; then
        send_inline_keyboard "$chat_id" "$message" "$keyboard"
    else
        edit_inline_keyboard "$chat_id" "$message_id" "$message" "$keyboard"
    fi
}

# Fungsi untuk menampilkan menu durasi reminder
show_reminder_menu() {
    local chat_id="$1"
    local message_id="$2"
    
    # Reload config untuk memastikan nilai terbaru
    load_uci_config
    
    local current_reminder="$SOUND_REMINDER_BEFORE"
    local repeat_count="$SOUND_REMINDER_REPEAT_COUNT"
    local repeat_interval="$SOUND_REMINDER_REPEAT_INTERVAL"
    local tts_enabled="$SOUND_REMINDER_SOUND_ENABLED"
    local tts_method="$SOUND_TTS_METHOD"
    
	# Tampilkan status TTS dengan lebih jelas
    local tts_status_text=""
    if [ "$SOUND_REMINDER_SOUND_ENABLED" = "1" ]; then
        tts_status_text="🔊 SUARA TTS (AKTIF) ($SOUND_TTS_METHOD)"
    else
        tts_status_text="🔇 SUARA TTS (NONAKTIF)"
    fi
	
	local keyboard='[[
		{"text": "'"$tts_status_text"'", "callback_data": "toggle_tts_sound"}
	],[
		{"text": "🎧 Test TTS", "callback_data": "test_tts"}
	],[
		{"text": "🎵 Pengaturan Tarhim", "callback_data": "tarhim_menu"}  
	],[
		{"text": "🌙 Pengaturan Sahur", "callback_data": "sahur_menu"}  
	],[
		{"text": "🔕 OFF '$( [ "$current_reminder" = "0" ] && echo "✅" )'", "callback_data": "set_reminder_0"}
	],[
		{"text": "5 menit '$( [ "$current_reminder" = "5" ] && echo "✅" )'", "callback_data": "set_reminder_5"},
		{"text": "10 menit '$( [ "$current_reminder" = "10" ] && echo "✅" )'", "callback_data": "set_reminder_10"},
		{"text": "15 menit '$( [ "$current_reminder" = "15" ] && echo "✅" )'", "callback_data": "set_reminder_15"}
	],[
		{"text": "🔄 Pengulangan: '"${repeat_count}"'x Ulang", "callback_data": "reminder_repeat_menu"}
	],[
		{"text": "❌ Batal", "callback_data": "cancel_update"}
	]]'
    
    local message=$(printf '🔔 *PENGATURAN PENGINGAT SHOLAT*

*Status Saat Ini:*
• Durasi: %s menit sebelum waktu sholat
• Pengulangan: %s kali
• Interval: %s detik
• Suara TTS: %s

📝 *Keterangan:*
• *Durasi*: Berapa menit sebelum waktu sholat pengingat dibunyikan
• *Pengulangan*: Berapa kali suara pengingat diulang (kecuali Imsyak)
• *Interval*: Jeda waktu antar pengulangan
• *Imsyak*: SELALU 1x pengulangan' \
"$([ "$current_reminder" = "0" ] && echo "TIDAK AKTIF" || echo "$current_reminder")" \
"$repeat_count" \
"$repeat_interval" \
"$([ "$tts_enabled" = "1" ] && echo "AKTIF" || echo "NONAKTIF")")
    
    if [ -z "$message_id" ]; then
        send_inline_keyboard "$chat_id" "$message" "$keyboard"
    else
        edit_inline_keyboard "$chat_id" "$message_id" "$message" "$keyboard"
    fi
}

# Fungsi untuk menyimpan durasi reminder
set_reminder_duration() {
    local chat_id="$1"
    local message_id="$2"
    local duration="$3"
	
	# Validasi bahwa duration adalah angka (0, 5, 10, 15)
    case "$duration" in
        "0"|"5"|"10"|"15")
            # Valid
            ;;
        *)
            log "ERROR: Durasi reminder tidak valid: $duration"
            send_message "$chat_id" "❌ Durasi reminder tidak valid. Pilih: 0, 5, 10, atau 15 menit."
            return 1
            ;;
    esac
    
    uci set jsholat.sound.reminder_before="$duration"
    uci commit jsholat    
	# Update variabel config
    load_uci_config  # <-- Load ulang config
	
	# Update variabel config
    SOUND_REMINDER_BEFORE="$duration"
    
    local status_text=""
    if [ "$duration" = "0" ]; then
        status_text="dinonaktifkan"
        log "🔕 Reminder dinonaktifkan untuk chat_id=$chat_id"
    else
        status_text="diatur ke ${duration} menit"
        log "🔔 Reminder diatur ke ${duration} menit untuk chat_id=$chat_id"
    fi
    
    # Kembali ke menu reminder untuk menunjukkan perubahan
    show_reminder_menu "$chat_id" "$message_id"
}

# Fungsi untuk menampilkan menu pengaturan
show_settings_menu() {
    local chat_id="$1"
    local message_id="$2"
    
    local sound_status="$SOUND_ENABLED"
    local telegram_status="$SERVICE_TELEGRAM_ENABLED"
    local reminder_status="$SOUND_REMINDER_BEFORE"
    local tts_method="$SOUND_TTS_METHOD"
    local ayat_status="$SERVICE_AYAT_ENABLED"  
    
    # Konversi nama metode TTS
    local tts_display_name=""
    case "$tts_method" in
        "google") tts_display_name="Google" ;;
        "edge") tts_display_name="Edge-TTS" ;;
        "espeak") tts_display_name="eSpeak" ;;
        "murf") tts_display_name="Murf.ai" ;;
        *) tts_display_name="$tts_method" ;;
    esac
    
    local sound_text=$([ "$sound_status" = "1" ] && echo "🔊 ON" || echo "🔇 OFF")
    local telegram_text=$([ "$telegram_status" = "1" ] && echo "📱 ON" || echo "📵 OFF")
    local reminder_text=$([ "$reminder_status" = "0" ] && echo "🔔 OFF" || echo "🔔 ${reminder_status}m")
    local ayat_text=$([ "$ayat_status" = "1" ] && echo "📖 ON" || echo "📕 OFF")  
    
    local keyboard='[[
        {"text": "Suara Adzan: '"$sound_text"'", "callback_data": "toggle_sound"}
    ],[
        {"text": "Notifikasi Telegram: '"$telegram_text"'", "callback_data": "toggle_telegram"}
    ],[
        {"text": "Pengingat Sholat: '"$reminder_text"'", "callback_data": "reminder_menu"}
    ],[
        {"text": "🗣️ TTS: '"$tts_display_name"'", "callback_data": "tts_menu"}
    ],[
        {"text": "📖 Ayat Acak: '"$ayat_text"'", "callback_data": "ayat_menu"}  
    ],[
        {"text": "⬅️ Kembali", "callback_data": "back_to_control"}
    ]]'
    
    if [ -z "$message_id" ]; then
        send_inline_keyboard "$chat_id" "⚙️ *Pengaturan Jsholat*" "$keyboard"
    else
        curl -s -X POST \
            "https://api.telegram.org/bot${TELEGRAM_TOKEN}/editMessageText" \
            -d chat_id="${chat_id}" \
            -d message_id="${message_id}" \
            -d text="⚙️ *Pengaturan Jsholat*" \
            -d parse_mode="Markdown" \
            -d reply_markup="{\"inline_keyboard\":${keyboard}}" \
            > /dev/null 2>&1
    fi
}

# Fungsi untuk menampilkan menu kontrol
show_control_menu() {
    local chat_id="$1"
    local message_id="$2"
    
    local current_status="$SERVICE_ENABLED"
    local status_text=$([ "$current_status" = "1" ] && echo "AKTIF" || echo "NONAKTIF")
    
    local keyboard='[[
        {"text": "🔘 Status: '"$status_text"'", "callback_data": "status"},
        {"text": "✅ Aktifkan", "callback_data": "on"}
    ],[
        {"text": "❌ Nonaktifkan", "callback_data": "off"},
        {"text": "⚙️ Pengaturan", "callback_data": "settings"}
    ],[
        {"text": "🔊 Volume", "callback_data": "volume_menu"}
    ],[
        {"text": "✔️ Selesai", "callback_data": "done"}
    ]]'
    
    if [ -z "$message_id" ]; then
        send_inline_keyboard "$chat_id" "🛠 *Kontrol Service Jsholat*" "$keyboard"
    else
        curl -s -X POST \
            "https://api.telegram.org/bot${TELEGRAM_TOKEN}/editMessageText" \
            -d chat_id="${chat_id}" \
            -d message_id="${message_id}" \
            -d text="🛠 *Kontrol Service Jsholat*" \
            -d parse_mode="Markdown" \
            -d reply_markup="{\"inline_keyboard\":${keyboard}}" \
            > /dev/null 2>&1
    fi
}

