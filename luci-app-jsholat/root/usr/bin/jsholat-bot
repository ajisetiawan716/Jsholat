        local error_msg="❌ *Gagal mengubah deskripsi bot*\n\n"
        error_msg+="📋 *Detail Error:*\n"
        error_msg+="• Kode: %s\n"
        error_msg+="• Pesan: %s\n"
        error_msg+="⏱️ *Waktu respon:* %d detik\n"
        
        if [ "$error_code" = "429" ] && [ -n "$retry_after" ]; then
            local hours=$((retry_after / 3600))
