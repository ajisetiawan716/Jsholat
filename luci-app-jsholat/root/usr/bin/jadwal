#!/bin/bash
# Jadwal Update Jsholat - Multi API Source (JSON Format)
# Version: 1.2
# (C) 2025-2026 Jsholat - @ajisetiawan716
# Supports: Aladhan API, JadwalSholat.Org, myQuran API, AjiMedia API

# ===== FUNGSI PENGECEKAN PERINTAH =====
check_command_usage() {
    local command="$1"
    
    if [ "$command" != "run" ]; then
        echo "Script ini dirancang untuk dijalankan melalui web interface LuCI atau bot Telegram"
        echo "Gunakan antarmuka web atau bot untuk melakukan pembaruan jadwal sholat."
        exit 1
    fi
}

# ===== KONFIGURASI UTAMA =====
check_command_usage "${1:-}"
API_SOURCE="${2:-$(uci get jsholat.schedule.source 2>/dev/null || echo "aladhan")}"
LAST_UPDATED_FILE="/usr/share/jsholat/last_updated.txt"

# ===== FUNGSI GET HIJRI DATE =====
get_hijri_date() {
    local gregorian_date="$1"
    local hijri_adj=$(uci -q get jsholat.schedule.hijri_adjust || echo "-1")
    
    # Request API Tanggal Hijriyah
    local api_url="https://api.myquran.com/v3/cal/hijr/$gregorian_date?adj=$hijri_adj"
    local response=$(curl -s --max-time 5 "$api_url")
    local status=$(echo "$response" | jq -r '.status' 2>/dev/null)
    
    if [ "$status" = "true" ]; then
        local hijri_day=$(echo "$response" | jq -r '.data.hijr.day' 2>/dev/null)
        local hijri_month=$(echo "$response" | jq -r '.data.hijr.monthName' 2>/dev/null)
        local hijri_year=$(echo "$response" | jq -r '.data.hijr.year' 2>/dev/null)
        
        if [[ ! "$hijri_year" =~ " H$" ]]; then
            hijri_year="$hijri_year H"
        fi
        
        echo "$hijri_day $hijri_month $hijri_year"
        return 0
    fi
    
    echo ""
    return 1
}

# ===== FUNGSI UTILITAS =====
validate_source() {
  case "$API_SOURCE" in
    aladhan|jadwalsholat|myquran|apiajimedia|arina|equranid) return 0 ;;
    *) 
      echo "Error: Sumber API '$API_SOURCE' tidak valid" >&2
      return 1 ;;
  esac
}

cek_internet() {
    if ping -c 1 -W 3 google.com >/dev/null 2>&1 || \
       curl -s --head --connect-timeout 3 "https://www.google.com" >/dev/null 2>&1; then
        return 0
    fi
    echo "Error: Tidak ada koneksi internet" >&2
    exit 1
}

capitalize() {
    echo "$1" | awk '{
        for (i = 1; i <= NF; i++) {
            $i = toupper(substr($i, 1, 1)) tolower(substr($i, 2))
        }
        print
    }' OFS='+' 
}

# ===== FUNGSI SAVE LAST UPDATE (UNIFORM FORMAT) =====
save_last_update_info() {
    local source_name="$1"
    local city_label="$2"
    local city_value="$3"
    local province="$4"
    local country="$5"
    local method="$6"
    local month="$7"
    local year="$8"
    local current_time="$9"
    
    # Buat JSON dengan format seragam
    local json_output="{\"status\":\"success\",\"last_updated\":\"$current_time\",\"data_source\":\"$source_name\",\"format\":\"json\",\"hijri_included\":true"
    
    # Tambahkan lokasi jika tersedia
    if [ -n "$city_label" ] || [ -n "$city_value" ] || [ -n "$province" ] || [ -n "$country" ]; then
        json_output="$json_output,\"location\":{"
        local location_parts=()
        
        [ -n "$city_label" ] && location_parts+=("\"city\":\"$city_label\"")
        [ -n "$city_value" ] && location_parts+=("\"city_value\":\"$city_value\"")
        [ -n "$province" ] && location_parts+=("\"province\":\"$province\"")
        [ -n "$country" ] && location_parts+=("\"country\":\"$country\"")
        
        json_output="$json_output$(IFS=,; echo "${location_parts[*]}")}"
    fi
    
    # Tambahkan method (khusus untuk Aladhan)
    if [ -n "$method" ] && [ "$API_SOURCE" = "aladhan" ]; then
        json_output="$json_output,\"calculation_method\":$method"
    fi
    
    # Tambahkan bulan dan tahun
    if [ -n "$month" ] && [ -n "$year" ]; then
        json_output="$json_output,\"month\":$month,\"year\":$year"
    fi
    
    json_output="$json_output}"
    
    echo "$json_output" > "$LAST_UPDATED_FILE"
}

# MyQuran - get city id
get_city_id() {
    local search_term="$1"
    local province="$2"
    
    normalized_term=$(echo "$search_term" | sed '
        s/Kabupaten /KAB. /g;
        s/Kab./KAB. /g;
        s/Kota /KOTA /g;
        s/^KAB /KAB. /g;
        s/^Kota /KOTA /g;
    ' | awk '{print toupper($0)}')
    
    try_search() {
        local pattern="$1"
        local encoded_pattern
        
        if [ -z "$pattern" ] || [ "$pattern" = " " ]; then
            return 1
        fi
        
        encoded_pattern=$(echo "$pattern" | sed 's/ /%20/g')
        response=$(curl -s --max-time 10 "https://api.myquran.com/v2/sholat/kota/cari/$encoded_pattern")
        
        if echo "$response" | jq -e '.status == true' >/dev/null 2>&1; then
            city_id=$(echo "$response" | jq -r '.data[0].id // empty')
            if [ -n "$city_id" ] && [ "$city_id" != "null" ]; then
                echo "$city_id"
                return 0
            fi
        fi
        return 1
    }
    
    if city_id=$(try_search "$normalized_term"); then
        echo "$city_id"
        return 0
    fi
    
    without_prefix=$(echo "$normalized_term" | sed 's/^KAB\. //;s/^KOTA //')
    if [ "$without_prefix" != "$normalized_term" ]; then
        if city_id=$(try_search "$without_prefix"); then
            echo "$city_id"
            return 0
        fi
    fi
    
    directions_removed=$(echo "$normalized_term" | sed '
        s/\s*BARAT\s*//gi;
        s/\s*TIMUR\s*//gi;
        s/\s*SELATAN\s*//gi;
        s/\s*UTARA\s*//gi;
        s/\s*PUSAT\s*//gi;
        s/\s*TENGAH\s*//gi;
        s/\s*KOTA\s*//gi;
        s/\s*KAB\s*//gi;
        s/\s*KAB\.\s*//gi;
        s/\s+$//;
        s/^\s+//;
    ')
    
    directions_removed=$(echo "$directions_removed" | sed 's/\s\+/ /g')
    
    if [ -n "$directions_removed" ] && [ "$directions_removed" != "$normalized_term" ]; then
        if city_id=$(try_search "$directions_removed"); then
            echo "$city_id"
            return 0
        fi
    fi
    
    if [ -n "$province" ]; then
        province_upper=$(echo "$province" | awk '{print toupper($0)}')
        if city_id=$(try_search "$province_upper"); then
            echo "$city_id"
            return 0
        fi
    fi
    
    first_word=$(echo "$normalized_term" | awk '{print $1}')
    if [ -n "$first_word" ] && [ ${#first_word} -gt 3 ]; then
        if city_id=$(try_search "$first_word"); then
            echo "$city_id"
            return 0
        fi
    fi
    
    echo "ERROR"
    return 1
}

# AjiMediaApi - get city data
get_city_data() {
    local city_name="$1"
    local province="$2"
    
    local province_api=$(echo "$province" | awk '{print tolower($0)}' | sed 's/ /+/g')
    local KOTA_API_URL="https://api.ajimedia.my.id/api/kota?provinsi=$province_api"
    local kota_response=$(curl -s -k -X GET --connect-timeout 10 "$KOTA_API_URL")
    
    if [ -z "$kota_response" ] || echo "$kota_response" | grep -q '"status":"error"'; then
        return 1
    fi
    
    local city_lower=$(echo "$city_name" | awk '{print tolower($0)}')
    local matched_city=$(echo "$kota_response" | jq -r --arg name "$city_lower" '.data[] | select(.name == $name)')
    
    if [ -n "$matched_city" ]; then
        echo "$matched_city"
        return 0
    fi
    
    for prefix in "kota " "kab. "; do
        local prefixed_name="$prefix$city_lower"
        matched_city=$(echo "$kota_response" | jq -r --arg name "$prefixed_name" '.data[] | select(.name == $name)')
        if [ -n "$matched_city" ]; then
            echo "$matched_city"
            return 0
        fi
    done
    
    local city_no_directions=$(echo "$city_lower" | sed '
        s/\s*barat//g; s/\s*timur//g; s/\s*selatan//g;
        s/\s*utara//g; s/\s*pusat//g; s/\s*tengah//g;
        s/\s+$//; s/^\s+//;
    ')
    
    if [ "$city_no_directions" != "$city_lower" ]; then
        matched_city=$(echo "$kota_response" | jq -r --arg name "$city_no_directions" '.data[] | select(.name == $name)')
        if [ -n "$matched_city" ]; then
            echo "$matched_city"
            return 0
        fi
        
        for prefix in "kota " "kab. "; do
            local prefixed_name="$prefix$city_no_directions"
            matched_city=$(echo "$kota_response" | jq -r --arg name "$prefixed_name" '.data[] | select(.name == $name)')
            if [ -n "$matched_city" ]; then
                echo "$matched_city"
                return 0
            fi
        done
    fi
    
    matched_city=$(echo "$kota_response" | jq -r '.data[0] // empty')
    if [ -n "$matched_city" ]; then
        echo "$matched_city"
        return 0
    fi
    
    return 1
}

# ===== FUNGSI JSON HANDLER =====
create_json_schedule() {
    local jadwal_file="$1"
    echo '[]' > "$jadwal_file"
}

add_to_json_schedule() {
    local jadwal_file="$1"
    local gregorian_date="$2"
    local hijri_date="$3"
    local imsak="$4"
    local subuh="$5"
    local dzuhur="$6"
    local ashar="$7"
    local maghrib="$8"
    local isya="$9"
    
    local temp_file="${jadwal_file}.tmp"
    
    jq --arg date "$gregorian_date" \
       --arg hijri "$hijri_date" \
       --arg imsak "$imsak" \
       --arg subuh "$subuh" \
       --arg dzuhur "$dzuhur" \
       --arg ashar "$ashar" \
       --arg maghrib "$maghrib" \
       --arg isya "$isya" \
       '. + [{
            "gregorian_date": $date,
            "hijri_date": $hijri,
            "imsyak": $imsak,
            "subuh": $subuh,
            "dzuhur": $dzuhur,
            "ashar": $ashar,
            "maghrib": $maghrib,
            "isya": $isya
        }]' "$jadwal_file" > "$temp_file" && mv "$temp_file" "$jadwal_file"
}

# Fungsi Aladhan API
update_aladhan() {
    CITY_VALUE=$(uci get jsholat.schedule.city_value 2>/dev/null)
    CITY_LABEL=$(uci get jsholat.schedule.city_label 2>/dev/null)
    PROVINCE=$(uci get jsholat.schedule.province 2>/dev/null)
    COUNTRY=$(uci get jsholat.schedule.country 2>/dev/null)
    METHOD=$(uci get jsholat.schedule.method 2>/dev/null || echo "20")
    JADWAL_FILE=$(uci get jsholat.schedule.file_jadwal 2>/dev/null)
    
    # Pastikan file JSON
    if [[ "$JADWAL_FILE" != *.json ]]; then
        JADWAL_FILE="${JADWAL_FILE%.*}.json"
        uci set jsholat.schedule.file_jadwal="$JADWAL_FILE"
        uci commit jsholat
    fi

    CITY=$(capitalize "$CITY_VALUE")
    BULAN=$(date '+%m' | sed 's/^0*//')
    TAHUN=$(date '+%Y')
    CURRENT_TIME=$(date +"%d-%m-%Y %H:%M:%S")

    logger "jadwal: Mulai update jadwal sholat JSON pada $CURRENT_TIME (Aladhan API)"
    echo "Mengambil jadwal sholat bulan $BULAN tahun $TAHUN untuk $CITY_LABEL..."

    API_URL="https://api.aladhan.com/v1/calendarByCity?city=$CITY&country=$COUNTRY&method=$METHOD&month=$BULAN&year=$TAHUN"
    
    rm -f "$JADWAL_FILE"
    create_json_schedule "$JADWAL_FILE"

    TMP_JSON="/tmp/jadwal_sholat.json"
    HTTP_CODE=$(curl -s -w "%{http_code}" -o "$TMP_JSON" -L "$API_URL")

    if [ "$HTTP_CODE" -ne 200 ]; then
        echo "Error: Gagal mengambil data dari server (HTTP $HTTP_CODE)" >&2
        exit 1
    fi

    if ! jq empty "$TMP_JSON" >/dev/null 2>&1; then
        echo "Error: Data dari server bukan JSON yang valid." >&2
        rm -f "$TMP_JSON"
        exit 1
    fi

    echo "Memproses data dan menyimpan ke JSON..."
    
    # PERBAIKAN 1: Gunakan delimiter yang tepat dan bersihkan semua timezone sekaligus
    jq -r '.data[] | 
        "\(.date.gregorian.date) | \(.date.hijri.day) | \(.date.hijri.month.en) | \(.date.hijri.year) | \(.timings.Imsak) | \(.timings.Fajr) | \(.timings.Dhuhr) | \(.timings.Asr) | \(.timings.Maghrib) | \(.timings.Isha)"' "$TMP_JSON" |
    while IFS='|' read -r gregorian_date hijri_day hijri_month hijri_year imsak_raw subuh_raw dzuhur_raw ashar_raw maghrib_raw isya_raw; do
        
        # PERBAIKAN 2: Bersihkan spasi dan timezone dengan regex yang tepat
        gregorian_date=$(echo "$gregorian_date" | xargs)
        
        # Bersihkan waktu dari timezone (WIB/WITA/WIT)
        imsak=$(echo "$imsak_raw" | sed -E 's/[[:space:]]*\([A-Z]+\)//g' | xargs)
        subuh=$(echo "$subuh_raw" | sed -E 's/[[:space:]]*\([A-Z]+\)//g' | xargs)
        dzuhur=$(echo "$dzuhur_raw" | sed -E 's/[[:space:]]*\([A-Z]+\)//g' | xargs)
        ashar=$(echo "$ashar_raw" | sed -E 's/[[:space:]]*\([A-Z]+\)//g' | xargs)
        maghrib=$(echo "$maghrib_raw" | sed -E 's/[[:space:]]*\([A-Z]+\)//g' | xargs)
        isya=$(echo "$isya_raw" | sed -E 's/[[:space:]]*\([A-Z]+\)//g' | xargs)
        
        hijri_date="$(echo "$hijri_day" | xargs) $(echo "$hijri_month" | xargs) $(echo "$hijri_year" | xargs) H"
        
        # PERBAIKAN 3: Format tanggal dengan aman
        if [[ "$gregorian_date" =~ ^([0-9]{2})-([0-9]{2})-([0-9]{4})$ ]]; then
            day="${BASH_REMATCH[1]}"
            month="${BASH_REMATCH[2]}"
            year="${BASH_REMATCH[3]}"
            formatted_gregorian="${day}-${month}-${year}"
        else
            formatted_gregorian="$gregorian_date"
        fi
        
        add_to_json_schedule "$JADWAL_FILE" "$formatted_gregorian" "$hijri_date" "$imsak" "$subuh" "$dzuhur" "$ashar" "$maghrib" "$isya"
        
    done

    rm -f "$TMP_JSON"
    
	CITY_VALUE_CLEAN=$(echo "$CITY_VALUE" | sed 's/+/ /g')
	save_last_update_info "Aladhan.com" "$CITY_LABEL" "$CITY_VALUE_CLEAN" "$PROVINCE" "$COUNTRY" "$METHOD" "$BULAN" "$TAHUN" "$CURRENT_TIME"
    echo "✅ Jadwal sholat berhasil diperbarui pada $CURRENT_TIME (Aladhan.com)."
    
    logger "jadwal: Jadwal sholat JSON berhasil diperbarui (Aladhan API)"
}

# Fungsi JadwalSholat.Org API
update_jadwalsholatorg() {
    CITY=$(uci get jsholat.schedule.city_value 2>/dev/null | awk '{print tolower($0)}' | sed 's/-//g')
    CITY_LABEL=$(uci get jsholat.schedule.city_label 2>/dev/null)
    PROVINCE=$(uci get jsholat.schedule.province 2>/dev/null)
    COUNTRY=$(uci get jsholat.schedule.country 2>/dev/null)
    YEAR=$(date +"%Y")
    MONTH=$(date +"%m")
    JADWAL_FILE=$(uci get jsholat.schedule.file_jadwal 2>/dev/null)
    
    # Pastikan file JSON
    if [[ "$JADWAL_FILE" != *.json ]]; then
        JADWAL_FILE="${JADWAL_FILE%.*}.json"
        uci set jsholat.schedule.file_jadwal="$JADWAL_FILE"
        uci commit jsholat
    fi
    
	BULAN=$(date '+%m' | sed 's/^0*//')
    TAHUN=$(date '+%Y')
    CURRENT_TIME=$(date +"%d-%m-%Y %H:%M:%S")

    logger "jadwal: Memulai pembaruan jadwal sholat JSON pada $CURRENT_TIME (JadwalSholat.Org)"
    echo "Mengambil jadwal sholat bulan $MONTH tahun $YEAR untuk $CITY_LABEL..."

    try_download_jadwal() {
        local city_param="$1"
        local formatted_city=$(echo "$city_param" | sed 's/ //g')
        local API_URL="https://raw.githubusercontent.com/ajisetiawan716/jadwalsholatorg/master/adzan/$formatted_city/$YEAR/$MONTH.json"
        
        curl -s -k -X GET --max-time 15 "$API_URL"
    }

    # Coba dengan CITY terlebih dahulu
    response=$(try_download_jadwal "$CITY")
    
    # Jika gagal, coba dengan CITY_LABEL
    if [ $? -ne 0 ] || [ -z "$response" ] || echo "$response" | grep -q "404: Not Found"; then
        CITY_FALLBACK=$(echo "$CITY_LABEL" | awk '{print tolower($0)}' | sed 's/ //g')
        response=$(try_download_jadwal "$CITY_FALLBACK")
        
        if [ $? -ne 0 ] || [ -z "$response" ] || echo "$response" | grep -q "404: Not Found"; then
            echo "Error: Gagal mengambil data dari server" >&2
            logger "jadwal: Gagal mengambil data dari server JadwalSholat.Org"
            exit 1
        fi
    fi

    if ! echo "$response" | jq -e '.' >/dev/null 2>&1; then
        echo "Error: Data yang diterima bukan JSON valid" >&2
        exit 1
    fi
	
    # Hapus file lama dan buat JSON baru
    rm -f "$JADWAL_FILE"
    create_json_schedule "$JADWAL_FILE"
    
	echo "Memproses data dan menyimpan ke JSON..."
    
    echo "$response" | jq -r '.[] | "\(.tanggal) \(.imsyak) \(.shubuh) \(.dzuhur) \(.ashr) \(.magrib) \(.isya)"' | while read -r line; do
        tanggal=$(echo "$line" | awk '{print $1}')
        imsyak=$(echo "$line" | awk '{print $2}')
        shubuh=$(echo "$line" | awk '{print $3}')
        dzuhur=$(echo "$line" | awk '{print $4}')
        ashr=$(echo "$line" | awk '{print $5}')
        magrib=$(echo "$line" | awk '{print $6}')
        isya=$(echo "$line" | awk '{print $7}')

        date_formatted=$(date -d "$tanggal" +"%d-%m-%Y" 2>/dev/null || echo "$tanggal")
        hijri_date=$(get_hijri_date "$tanggal" 2>/dev/null || echo "")
        
        add_to_json_schedule "$JADWAL_FILE" "$date_formatted" "$hijri_date" "$imsyak" "$shubuh" "$dzuhur" "$ashr" "$magrib" "$isya"
    done

    # Simpan informasi update dengan format seragam
    save_last_update_info "JadwalSholat.org" "$CITY_LABEL" "$CITY" "$PROVINCE" "$COUNTRY" "" "$BULAN" "$TAHUN" "$CURRENT_TIME"
    
	echo "✅ Jadwal sholat berhasil diperbarui pada $CURRENT_TIME (JadwalSholat.Org)."
    logger "jadwal: Jadwal sholat JSON berhasil diperbarui (JadwalSholat.Org)"
}

# Fungsi MyQuran API
update_myquran() {
    CITY=$(uci get jsholat.schedule.city_value 2>/dev/null | awk '{print tolower($0)}' | sed 's/-//g')
    CITY_LABEL=$(uci get jsholat.schedule.city_label 2>/dev/null)
    PROVINCE=$(uci get jsholat.schedule.province 2>/dev/null)
    COUNTRY=$(uci get jsholat.schedule.country 2>/dev/null)
    YEAR=$(date +"%Y")
    MONTH=$(date +"%m")
    JADWAL_FILE=$(uci get jsholat.schedule.file_jadwal 2>/dev/null)
    
    # Pastikan file JSON
    if [[ "$JADWAL_FILE" != *.json ]]; then
        JADWAL_FILE="${JADWAL_FILE%.*}.json"
        uci set jsholat.schedule.file_jadwal="$JADWAL_FILE"
        uci commit jsholat
    fi
    
    BULAN=$(date '+%m' | sed 's/^0*//')
    TAHUN=$(date '+%Y')
    CURRENT_TIME=$(date +"%d-%m-%Y %H:%M:%S")

    echo "Memulai pembaruan jadwal sholat JSON pada $CURRENT_TIME (myQuran API)"
    logger "jadwal: Memulai pembaruan jadwal sholat JSON (myQuran API)"

    # Cari ID kota
    CITY_ID=$(get_city_id "$CITY_LABEL" "$PROVINCE")
    
    if [ "$CITY_ID" = "ERROR" ] || [ -z "$CITY_ID" ]; then
        CITY_ID=$(get_city_id "$CITY" "$PROVINCE")
        
        if [ "$CITY_ID" = "ERROR" ] || [ -z "$CITY_ID" ]; then
            echo "Error: Gagal mendapatkan ID kota" >&2
            exit 1
        fi
    fi

    echo "Mengambil jadwal untuk ID Kota: $CITY_ID ($CITY_LABEL)..."
    API_URL="https://api.myquran.com/v2/sholat/jadwal/$CITY_ID/$YEAR/$MONTH"
    response=$(curl -s -X GET "$API_URL")

    if ! echo "$response" | grep -q '"status":true'; then
        echo "Error: Gagal mengambil data jadwal" >&2
        exit 1
    fi

    # Hapus file lama dan buat JSON baru
    rm -f "$JADWAL_FILE"
    create_json_schedule "$JADWAL_FILE"

    echo "Memproses data dan menyimpan ke JSON..."
    
    echo "$response" | jq -r '.data.jadwal[] | "\(.date) \(.imsak) \(.subuh) \(.dzuhur) \(.ashar) \(.maghrib) \(.isya)"' | while read -r line; do
        original_date=$(echo "$line" | awk '{print $1}')
        imsak=$(echo "$line" | awk '{print $2}')
        subuh=$(echo "$line" | awk '{print $3}')
        dzuhur=$(echo "$line" | awk '{print $4}')
        ashar=$(echo "$line" | awk '{print $5}')
        maghrib=$(echo "$line" | awk '{print $6}')
        isya=$(echo "$line" | awk '{print $7}')
        
        formatted_date=$(date -d "$original_date" +"%d-%m-%Y")
        hijri_date=$(get_hijri_date "$original_date" 2>/dev/null || echo "")
        
        add_to_json_schedule "$JADWAL_FILE" "$formatted_date" "$hijri_date" "$imsak" "$subuh" "$dzuhur" "$ashar" "$maghrib" "$isya"
    done

    # Simpan informasi update dengan format seragam
    save_last_update_info "Bimas Islam Kemenag/Api.MyQuran.com" "$CITY_LABEL" "$CITY" "$PROVINCE" "$COUNTRY" "" "$BULAN" "$TAHUN" "$CURRENT_TIME"
    
    echo "✅ Jadwal sholat berhasil diperbarui pada $CURRENT_TIME (myQuran API)."
    logger "jadwal: Jadwal sholat JSON berhasil diperbarui (myQuran API)"
}

# Fungsi ApiAjiMedia API
update_apiajimedia() {
    PROVINCE=$(uci get jsholat.schedule.province 2>/dev/null)
    CITY_LABEL=$(uci get jsholat.schedule.city_label 2>/dev/null)
    CITY_VALUE=$(uci get jsholat.schedule.city_value 2>/dev/null)
    COUNTRY=$(uci get jsholat.schedule.country 2>/dev/null)
    YEAR=$(date +"%Y")
    MONTH=$(date +"%m")
    JADWAL_FILE=$(uci get jsholat.schedule.file_jadwal 2>/dev/null)
    
    # Pastikan file JSON
    if [[ "$JADWAL_FILE" != *.json ]]; then
        JADWAL_FILE="${JADWAL_FILE%.*}.json"
        uci set jsholat.schedule.file_jadwal="$JADWAL_FILE"
        uci commit jsholat
    fi
    
	BULAN=$(date '+%m' | sed 's/^0*//')
    TAHUN=$(date '+%Y')
    CURRENT_TIME=$(date +"%d-%m-%Y %H:%M:%S")

    logger "jadwal: Memulai pembaruan jadwal sholat JSON pada $CURRENT_TIME (API AjiMedia)"
    echo "Mengambil jadwal sholat bulan $MONTH tahun $YEAR untuk $CITY_LABEL..."
    
    # Dapatkan data kota
    MATCHED_CITY=$(get_city_data "$CITY_VALUE" "$PROVINCE")
    
    if [ $? -ne 0 ] || [ -z "$MATCHED_CITY" ]; then
        MATCHED_CITY=$(get_city_data "$CITY_LABEL" "$PROVINCE")
        
        if [ $? -ne 0 ] || [ -z "$MATCHED_CITY" ]; then
            echo "Error: Tidak dapat menemukan kota di API AjiMedia" >&2
            exit 1
        fi
    fi
    
    if ! echo "$MATCHED_CITY" | jq -e '.' >/dev/null 2>&1; then
        echo "Error: Format data kota tidak valid" >&2
        exit 1
    fi
    
    API_CITY_NAME=$(echo "$MATCHED_CITY" | jq -r '.name')
    API_CITY_ID=$(echo "$MATCHED_CITY" | jq -r '.id')
    
    echo "Kota ditemukan: $API_CITY_NAME (ID: $API_CITY_ID)"
    
    # Update city_value jika berbeda
    if [ "$CITY_VALUE" != "$API_CITY_NAME" ] && [[ ! "$CITY_VALUE" =~ ^[0-9a-f]{32}$ ]]; then
        uci set jsholat.schedule.city_value="$API_CITY_NAME"
        uci commit jsholat
        CITY_VALUE="$API_CITY_NAME"
    fi
    
    # URL API jadwal sholat
    local province_api=$(echo "$PROVINCE" | awk '{print tolower($0)}' | sed 's/ /+/g')
    local city_api=$(echo "$API_CITY_NAME" | awk '{print tolower($0)}' | sed 's/ /+/g')
    
    API_URL="https://api.ajimedia.my.id/api/cari?provinsi=$province_api&kota=$city_api&bulan=$MONTH&tahun=$YEAR"
    echo "Mengambil data dari server API AjiMedia..."
    
    # Hapus file lama dan buat JSON baru
    rm -f "$JADWAL_FILE"
    create_json_schedule "$JADWAL_FILE"
    
    # Ambil data jadwal sholat
    response=$(curl -s -k -X GET --connect-timeout 15 "$API_URL")
    
    if [ $? -ne 0 ] || [ -z "$response" ]; then
        echo "Error: Gagal mengambil data jadwal dari server" >&2
        exit 1
    fi
    
    if echo "$response" | grep -q '"status":"error"'; then
        error_msg=$(echo "$response" | jq -r '.message // "Unknown error"')
        echo "Error: $error_msg" >&2
        exit 1
    fi
    
    echo "Memproses data dan menyimpan ke JSON..."
    
    echo "$response" | jq -r '.data[] | "\(.key) \(.imsak) \(.subuh) \(.dzuhur) \(.ashar) \(.maghrib) \(.isya)"' | while read -r line; do
        tanggal=$(echo "$line" | awk '{print $1}')
        imsak=$(echo "$line" | awk '{print $2}')
        subuh=$(echo "$line" | awk '{print $3}')
        dzuhur=$(echo "$line" | awk '{print $4}')
        ashar=$(echo "$line" | awk '{print $5}')
        magrib=$(echo "$line" | awk '{print $6}')
        isya=$(echo "$line" | awk '{print $7}')
        
        hijri_date=$(get_hijri_date "$tanggal" 2>/dev/null || echo "")
        
        if [[ "$tanggal" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}$ ]]; then
            date_formatted=$(date -d "$tanggal" +"%d-%m-%Y" 2>/dev/null || echo "$tanggal")
        else
            date_formatted="$tanggal"
        fi
        
        add_to_json_schedule "$JADWAL_FILE" "$date_formatted" "$hijri_date" "$imsak" "$subuh" "$dzuhur" "$ashar" "$magrib" "$isya"
    done
    
    # Simpan informasi update dengan format seragam
    save_last_update_info "API AjiMedia" "$CITY_LABEL" "$CITY_VALUE" "$PROVINCE" "$COUNTRY" "" "$BULAN" "$TAHUN" "$CURRENT_TIME"
    
    echo "✅ Jadwal sholat berhasil diperbarui pada $CURRENT_TIME (API AjiMedia)."
    logger "jadwal: Jadwal sholat JSON berhasil diperbarui (API AjiMedia)"
}

# Fungsi Arina.Id API
update_arina() {
    CITY=$(uci get jsholat.schedule.city_value 2>/dev/null | awk '{print tolower($0)}' | sed 's/-//g')
    CITY_LABEL=$(uci get jsholat.schedule.city_label 2>/dev/null)
    PROVINCE=$(uci get jsholat.schedule.province 2>/dev/null)
    COUNTRY=$(uci get jsholat.schedule.country 2>/dev/null)
    YEAR=$(date +"%Y")
    MONTH=$(date +"%m")
    JADWAL_FILE=$(uci get jsholat.schedule.file_jadwal 2>/dev/null)
    
    # Pastikan file JSON
    if [[ "$JADWAL_FILE" != *.json ]]; then
        JADWAL_FILE="${JADWAL_FILE%.*}.json"
        uci set jsholat.schedule.file_jadwal="$JADWAL_FILE"
        uci commit jsholat
    fi
    
	BULAN=$(date '+%m' | sed 's/^0*//')
    TAHUN=$(date '+%Y')
    CURRENT_TIME=$(date +"%d-%m-%Y %H:%M:%S")

    logger "jadwal: Memulai pembaruan jadwal sholat JSON pada $CURRENT_TIME (Arina.Id)"
    echo "Mengambil jadwal sholat bulan $MONTH tahun $YEAR untuk $CITY_LABEL..."

    try_download_jadwal() {
        local city_param="$1"
        local formatted_city=$(echo "$city_param" | sed 's/ //g')
        local API_URL="https://raw.githubusercontent.com/ajisetiawan716/jadwalsholat-arina/master/jadwal/$formatted_city/$YEAR/$MONTH.json"
        
        curl -s -k -X GET --max-time 15 "$API_URL"
    }

    # Coba dengan CITY terlebih dahulu
    response=$(try_download_jadwal "$CITY")
    
    # Jika gagal, coba dengan CITY_LABEL
    if [ $? -ne 0 ] || [ -z "$response" ] || echo "$response" | grep -q "404: Not Found"; then
        CITY_FALLBACK=$(echo "$CITY_LABEL" | awk '{print tolower($0)}' | sed 's/ //g')
        response=$(try_download_jadwal "$CITY_FALLBACK")
        
        if [ $? -ne 0 ] || [ -z "$response" ] || echo "$response" | grep -q "404: Not Found"; then
            echo "Error: Gagal mengambil data dari server" >&2
            logger "jadwal: Gagal mengambil data dari server Arina.Id"
            exit 1
        fi
    fi

    if ! echo "$response" | jq -e '.' >/dev/null 2>&1; then
        echo "Error: Data yang diterima bukan JSON valid" >&2
        exit 1
    fi
	
    # Hapus file lama dan buat JSON baru
    rm -f "$JADWAL_FILE"
    create_json_schedule "$JADWAL_FILE"
    
	echo "Memproses data dan menyimpan ke JSON..."
    
    echo "$response" | jq -r '.[] | "\(.tanggal) \(.imsyak) \(.shubuh) \(.dzuhur) \(.ashr) \(.magrib) \(.isya)"' | while read -r line; do
        tanggal=$(echo "$line" | awk '{print $1}')
        imsyak=$(echo "$line" | awk '{print $2}')
        shubuh=$(echo "$line" | awk '{print $3}')
        dzuhur=$(echo "$line" | awk '{print $4}')
        ashr=$(echo "$line" | awk '{print $5}')
        magrib=$(echo "$line" | awk '{print $6}')
        isya=$(echo "$line" | awk '{print $7}')

        date_formatted=$(date -d "$tanggal" +"%d-%m-%Y" 2>/dev/null || echo "$tanggal")
        hijri_date=$(get_hijri_date "$tanggal" 2>/dev/null || echo "")
        
        add_to_json_schedule "$JADWAL_FILE" "$date_formatted" "$hijri_date" "$imsyak" "$shubuh" "$dzuhur" "$ashr" "$magrib" "$isya"
    done

    # Simpan informasi update dengan format seragam
    save_last_update_info "Arina.Id" "$CITY_LABEL" "$CITY" "$PROVINCE" "$COUNTRY" "" "$BULAN" "$TAHUN" "$CURRENT_TIME"
    
	echo "✅ Jadwal sholat berhasil diperbarui pada $CURRENT_TIME (Arina.Id)."
    logger "jadwal: Jadwal sholat JSON berhasil diperbarui (Arina.Id)"
}

# Fungsi Equran.id API
update_equranid() {
    PROVINCE=$(uci get jsholat.schedule.province 2>/dev/null)
    CITY_LABEL=$(uci get jsholat.schedule.city_label 2>/dev/null)
    CITY_VALUE=$(uci get jsholat.schedule.city_value 2>/dev/null)
    COUNTRY=$(uci get jsholat.schedule.country 2>/dev/null)
    YEAR=$(date +"%Y")
    MONTH=$(date +"%m")
    MONTH_NUM=$(date +"%-m") # Bulan tanpa leading zero
    JADWAL_FILE=$(uci get jsholat.schedule.file_jadwal 2>/dev/null)
    
    # Pastikan file JSON
    if [[ "$JADWAL_FILE" != *.json ]]; then
        JADWAL_FILE="${JADWAL_FILE%.*}.json"
        uci set jsholat.schedule.file_jadwal="$JADWAL_FILE"
        uci commit jsholat
    fi
    
    BULAN=$(date '+%m' | sed 's/^0*//')
    TAHUN=$(date '+%Y')
    CURRENT_TIME=$(date +"%d-%m-%Y %H:%M:%S")

    logger "jadwal: Memulai pembaruan jadwal sholat JSON pada $CURRENT_TIME (equran.id)"
    echo "Mengambil jadwal sholat bulan $MONTH tahun $YEAR untuk $CITY_LABEL, $PROVINCE..."

    # Validasi input provinsi dan kota
    if [ -z "$PROVINCE" ] || [ -z "$CITY_LABEL" ]; then
        echo "Error: Provinsi dan kota harus diisi" >&2
        exit 1
    fi

    # Format nama provinsi untuk API (sesuaikan dengan format di API)
    # API equran.id menggunakan format seperti "Jawa Tengah", "DKI Jakarta", dll
    
    # Format nama kota untuk API
    # Pastikan format sesuai dengan yang ada di API (contoh: "Kab. Brebes", "Kota Semarang")
    CITY_FOR_API="$CITY_LABEL"
    
    # Jika CITY_VALUE ada dan berbeda format, coba gunakan CITY_VALUE
    if [ -n "$CITY_VALUE" ] && [ "$CITY_VALUE" != "$CITY_LABEL" ]; then
        # Cek apakah CITY_VALUE sudah mengandung "Kab." atau "Kota"
        if [[ "$CITY_VALUE" =~ ^(Kab\.|Kota) ]]; then
            CITY_FOR_API="$CITY_VALUE"
        else
            # Coba teks apakah ini kota atau kabupaten berdasarkan nama
            # Asumsikan jika tidak ada prefix, coba dengan kedua format
            CITY_FOR_API="$CITY_LABEL"
        fi
    fi

    # Bersihkan nama kota dari tambahan "Kab." atau "Kota" untuk pencarian fleksibel
    CITY_CLEAN=$(echo "$CITY_FOR_API" | sed 's/^Kab\. //; s/^Kota //')
    
    echo "Mencari jadwal untuk Provinsi: $PROVINCE, Kota: $CITY_FOR_API"
    
    # Coba cari kota di daftar kabkota untuk provinsi ini
    # Kita perlu mendapatkan daftar kabkota dulu untuk validasi
    KABKOTA_LIST=$(curl -s -X POST "https://equran.id/api/v2/shalat/kabkota" \
        -H "Content-Type: application/json" \
        -d "{\"provinsi\": \"$PROVINCE\"}")
    
    if [ $? -ne 0 ] || [ -z "$KABKOTA_LIST" ]; then
        echo "Error: Gagal mengambil daftar kabupaten/kota" >&2
        exit 1
    fi
    
    # Cek apakah kota yang diminta ada dalam daftar
    FOUND_CITY=""
    if echo "$KABKOTA_LIST" | jq -e '.data' >/dev/null 2>&1; then
        # Coba cari dengan nama lengkap
        FOUND_CITY=$(echo "$KABKOTA_LIST" | jq -r --arg city "$CITY_FOR_API" '.data[] | select(. == $city)')
        
        # Jika tidak ditemukan, coba dengan nama tanpa prefix
        if [ -z "$FOUND_CITY" ] && [ -n "$CITY_CLEAN" ]; then
            FOUND_CITY=$(echo "$KABKOTA_LIST" | jq -r --arg city "$CITY_CLEAN" '.data[] | select(. | contains($city))')
            
            # Jika masih banyak hasil, ambil yang pertama
            if [ -n "$FOUND_CITY" ] && [ $(echo "$FOUND_CITY" | wc -l) -gt 1 ]; then
                FOUND_CITY=$(echo "$FOUND_CITY" | head -1)
            fi
        fi
        
        # Jika masih tidak ditemukan, coba dengan format "Kota" atau "Kab." bergantian
        if [ -z "$FOUND_CITY" ]; then
            if [[ ! "$CITY_FOR_API" =~ ^(Kab\.|Kota) ]]; then
                # Coba dengan prefix "Kab."
                FOUND_CITY=$(echo "$KABKOTA_LIST" | jq -r --arg city "Kab. $CITY_CLEAN" '.data[] | select(. == $city)')
                
                # Jika tidak, coba dengan prefix "Kota"
                if [ -z "$FOUND_CITY" ]; then
                    FOUND_CITY=$(echo "$KABKOTA_LIST" | jq -r --arg city "Kota $CITY_CLEAN" '.data[] | select(. == $city)')
                fi
            fi
        fi
    fi
    
    # Jika kota ditemukan, gunakan nama yang tepat dari API
    if [ -n "$FOUND_CITY" ]; then
        CITY_FOR_API="$FOUND_CITY"
        echo "Kota ditemukan: $CITY_FOR_API"
    else
        echo "Peringatan: Kota '$CITY_LABEL' tidak ditemukan dalam daftar. Mencoba menggunakan nama yang diberikan..." >&2
        # Tetap lanjutkan dengan nama yang diberikan, biarkan API yang merespon error
    fi

    # Ambil jadwal sholat
    echo "Mengambil jadwal dari server equran.id..."
    API_URL="https://equran.id/api/v2/shalat"
    response=$(curl -s -X POST "$API_URL" \
        -H "Content-Type: application/json" \
        -d "{
            \"provinsi\": \"$PROVINCE\",
            \"kabkota\": \"$CITY_FOR_API\",
            \"bulan\": $MONTH_NUM,
            \"tahun\": $YEAR
        }")
    
    if [ $? -ne 0 ] || [ -z "$response" ]; then
        echo "Error: Gagal mengambil data jadwal dari server" >&2
        exit 1
    fi
    
    # Cek response code
    RESPONSE_CODE=$(echo "$response" | jq -r '.code // 0')
    if [ "$RESPONSE_CODE" -ne 200 ]; then
        ERROR_MSG=$(echo "$response" | jq -r '.message // "Unknown error"')
        echo "Error: $ERROR_MSG (Code: $RESPONSE_CODE)" >&2
        exit 1
    fi
    
    # Validasi JSON
    if ! echo "$response" | jq -e '.data.jadwal' >/dev/null 2>&1; then
        echo "Error: Data jadwal tidak ditemukan dalam response" >&2
        exit 1
    fi
    
    # Hapus file lama dan buat JSON baru
    rm -f "$JADWAL_FILE"
    create_json_schedule "$JADWAL_FILE"
    
    echo "Memproses data dan menyimpan ke JSON..."
    
    # Ambil nama bulan dari response jika ada
    BULAN_NAMA=$(echo "$response" | jq -r '.data.bulan_nama // ""')
    if [ -n "$BULAN_NAMA" ]; then
        echo "Bulan: $BULAN_NAMA $TAHUN"
    fi
    
    # Proses setiap jadwal
    echo "$response" | jq -r '.data.jadwal[] | "\(.tanggal_lengkap) \(.imsak) \(.subuh) \(.dzuhur) \(.ashar) \(.maghrib) \(.isya)"' | while read -r line; do
        tanggal_lengkap=$(echo "$line" | awk '{print $1}')
        imsak=$(echo "$line" | awk '{print $2}')
        subuh=$(echo "$line" | awk '{print $3}')
        dzuhur=$(echo "$line" | awk '{print $4}')
        ashar=$(echo "$line" | awk '{print $5}')
        maghrib=$(echo "$line" | awk '{print $6}')
        isya=$(echo "$line" | awk '{print $7}')
        
        # Format tanggal dari YYYY-MM-DD ke DD-MM-YYYY
        if [[ "$tanggal_lengkap" =~ ^([0-9]{4})-([0-9]{2})-([0-9]{2})$ ]]; then
            year="${BASH_REMATCH[1]}"
            month="${BASH_REMATCH[2]}"
            day="${BASH_REMATCH[3]}"
            formatted_date="${day}-${month}-${year}"
        else
            formatted_date="$tanggal_lengkap"
        fi
        
        # Ambil tanggal Hijriyah
        hijri_date=$(get_hijri_date "$tanggal_lengkap" 2>/dev/null || echo "")
        
        add_to_json_schedule "$JADWAL_FILE" "$formatted_date" "$hijri_date" "$imsak" "$subuh" "$dzuhur" "$ashar" "$maghrib" "$isya"
    done
    
    # Simpan informasi update dengan format seragam
    save_last_update_info "Equran.id" "$CITY_LABEL" "$CITY_VALUE" "$PROVINCE" "$COUNTRY" "" "$BULAN" "$TAHUN" "$CURRENT_TIME"
    
    echo "✅ Jadwal sholat berhasil diperbarui pada $CURRENT_TIME (Equran.id)."
    logger "jadwal: Jadwal sholat JSON berhasil diperbarui (Equran.id)"
}

# ===== MAIN SCRIPT =====
cek_internet

if ! validate_source; then
  exit 1
fi

case "$API_SOURCE" in
    "aladhan") update_aladhan ;;
    "jadwalsholat") update_jadwalsholatorg ;;
    "myquran") update_myquran ;;
    "apiajimedia") update_apiajimedia ;;
    "arina") update_arina ;;
    "equranid") update_equranid ;;	
    *) echo "Error: Sumber API tidak valid" >&2; exit 1 ;;
esac

exit 0