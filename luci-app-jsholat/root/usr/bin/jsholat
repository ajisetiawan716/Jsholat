# Konfigurasi Logging
LOG_DIR="/var/log/jsholat"
LOG_FILE="$LOG_DIR/service.log"
MAX_LOG_SIZE=1048576  # 1MB
DEBUG_MODE=$(uci -q get jsholat.service.debug_mode || echo "0")


# Fungsi Inisialisasi Log
init_log_system() {
    [ -d "$LOG_DIR" ] || mkdir -p "$LOG_DIR"
    [ -f "$LOG_FILE" ] || touch "$LOG_FILE"
    chmod 644 "$LOG_FILE"
}

# Fungsi Logging Terstruktur
log() {
    local level=$1
    local message=$2
    local timestamp=$(date '+%Y-%m-%d %H:%M:%S')
    
    # Rotasi log jika melebihi ukuran maksimal
    if [ -f "$LOG_FILE" ] && [ $(wc -c < "$LOG_FILE") -gt $MAX_LOG_SIZE ]; then
        mv "$LOG_FILE" "$LOG_FILE.old"
        touch "$LOG_FILE"
        chmod 644 "$LOG_FILE"
    fi
    
    echo "[$timestamp] [$level] $message" >> "$LOG_FILE"
    logger -t "jsholat[$level]" "$message"
}

# Fungsi Validasi File
validate_file() {
    local file_path=$1
    local file_desc=$2
    
    if [ -z "$file_path" ]; then
        log "ERROR" "❌ Path $file_desc tidak boleh kosong"
        return 1
    fi
    
    if [ ! -f "$file_path" ]; then
        log "ERROR" "❌ File $file_desc tidak ditemukan: $file_path"
        return 1
    fi
    
    if [ ! -r "$file_path" ]; then
        log "ERROR" "❌ File $file_desc tidak bisa dibaca: $file_path"
        return 1
    fi
    
    [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "File $file_desc valid: $file_path"
    return 0
}


# Fungsi untuk info Hijriyah
HIJRI_CACHE_FILE="/tmp/jsholat_cache/hijri_date_cache.json"
HIJRI_CACHE_EXPIRE=3600 # Cache berlaku selama 1 jam (3600 detik)

# Fungsi untuk mendapatkan tanggal Hijriyah dengan cache
get_hijri_date() {
    local gregorian_date=$(date +"%Y-%m-%d")
    local now=$(date +%s)
    
    # Baca nilai adjustment dari config UCI, default -1
    local hijri_adj=$(uci -q get jsholat.schedule.hijri_adjust || echo "-1")
    
    # Cek cache terlebih dahulu
    if [ -f "$HIJRI_CACHE_FILE" ]; then
        local cache_time=$(jq -r '.cache_time' "$HIJRI_CACHE_FILE" 2>/dev/null)
        
        if [ -n "$cache_time" ] && [ $((now - cache_time)) -lt $HIJRI_CACHE_EXPIRE ]; then
            # Ambil format tanggal dari cache (day monthName year)
            local hijri_day=$(jq -r '.hijri_date.day' "$HIJRI_CACHE_FILE" 2>/dev/null)
            local hijri_month=$(jq -r '.hijri_date.monthName' "$HIJRI_CACHE_FILE" 2>/dev/null)
            local hijri_year=$(jq -r '.hijri_date.year' "$HIJRI_CACHE_FILE" 2>/dev/null)
            
            if [ -n "$hijri_day" ] && [ "$hijri_day" != "null" ] && \
               [ -n "$hijri_month" ] && [ "$hijri_month" != "null" ] && \
               [ -n "$hijri_year" ] && [ "$hijri_year" != "null" ]; then
                echo "$hijri_day $hijri_month $hijri_year"
                return 0
            fi
        fi
    fi
    
    # Jika cache tidak ada atau sudah expired, ambil dari API baru
    local api_url="https://api.myquran.com/v3/cal/hijr/$gregorian_date?adj=$hijri_adj"
    local response=$(curl -s --max-time 5 "$api_url") # Timeout 5 detik
    local status=$(echo "$response" | jq -r '.status' 2>/dev/null)
    
    if [ "$status" = "true" ]; then
        # Format dan simpan ke cache dengan struktur baru
        mkdir -p "$(dirname "$HIJRI_CACHE_FILE")"
        echo "$response" | jq "{
            cache_time: $now,
            hijri_date: (.data.hijr | .year = (.year|tostring + \" H\"))
        }" > "$HIJRI_CACHE_FILE"
        
        # Ambil format tanggal (day monthName year)
        local hijri_day=$(echo "$response" | jq -r '.data.hijr.day' 2>/dev/null)
        local hijri_month=$(echo "$response" | jq -r '.data.hijr.monthName' 2>/dev/null)
        local hijri_year=$(echo "$response" | jq -r '.data.hijr.year' 2>/dev/null)
        
        # Tambahkan " H" ke tahun jika belum ada
        if [[ ! "$hijri_year" =~ " H$" ]]; then
            hijri_year="$hijri_year H"
        fi
        
        echo "$hijri_day $hijri_month $hijri_year"
        return 0
    else
        log "ERROR" "❌ Gagal mendapatkan tanggal Hijriyah dari API"
        # Coba gunakan cache yang expired jika ada
        if [ -f "$HIJRI_CACHE_FILE" ]; then
            local hijri_day=$(jq -r '.hijri_date.day' "$HIJRI_CACHE_FILE" 2>/dev/null)
            local hijri_month=$(jq -r '.hijri_date.monthName' "$HIJRI_CACHE_FILE" 2>/dev/null)
            local hijri_year=$(jq -r '.hijri_date.year' "$HIJRI_CACHE_FILE" 2>/dev/null)
            
            if [ -n "$hijri_day" ] && [ "$hijri_day" != "null" ] && \
               [ -n "$hijri_month" ] && [ "$hijri_month" != "null" ] && \
               [ -n "$hijri_year" ] && [ "$hijri_year" != "null" ]; then
                echo "$hijri_day $hijri_month $hijri_year"
                return 1
            fi
        fi
        echo ""
        return 1
    fi
}

# Fungsi untuk mengecek apakah bulan saat ini adalah Ramadhan
# Memanfaatkan cache dari get_hijri_date()
is_ramadhan() {
    # Pastikan cache hijriyah tersedia
    if [ ! -f "$HIJRI_CACHE_FILE" ]; then
        # Coba generate cache dulu dengan memanggil get_hijri_date
        [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "📅 Cache Hijriyah tidak ditemukan, mencoba generate..."
        local hijri_date=$(get_hijri_date)
        
        # Jika masih tidak ada, return error
        if [ ! -f "$HIJRI_CACHE_FILE" ]; then
            log "WARNING" "⚠️ Tidak dapat mengakses informasi tanggal Hijriyah"
            return 1
        fi
    fi
    
    # Baca bulan dari cache file
    local hijri_month=$(jq -r '.hijri_date.month // ""' "$HIJRI_CACHE_FILE" 2>/dev/null)
    local hijri_month_name=$(jq -r '.hijri_date.monthName // ""' "$HIJRI_CACHE_FILE" 2>/dev/null)
    local hijri_year=$(jq -r '.hijri_date.year // ""' "$HIJRI_CACHE_FILE" 2>/dev/null)
    
    # Validasi data
    if [ -z "$hijri_month" ] || [ "$hijri_month" = "null" ]; then
        log "ERROR" "❌ Data bulan Hijriyah tidak tersedia dalam cache"
        return 1
    fi
    
    # Cek apakah bulan ke-9 (Ramadhan)
    if [ "$hijri_month" -eq 9 ] 2>/dev/null; then
        [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "🌙 Deteksi: Bulan Ramadhan ($hijri_month_name $hijri_year)"
        return 0
    else
        [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "📅 Bukan Ramadhan (Bulan: $hijri_month_name $hijri_year)"
        return 1
    fi
}

# Fungsi atur teks sahur
SAHUR_REMINDER_FILE="/usr/share/jsholat/sahur-reminder.txt"
SAHUR_REMINDER_DEFAULT="Assalamu'alaikum. Bangunlah untuk sahur di bulan Ramadhan yang penuh berkah. Waktu sekarang menunjukkan {time} {timezone}. Untuk wilayah {location} dan sekitarnya. Segera bangun dan persiapkan sahur. Jangan lewatkan keberkahan sahur. Marhaban ya Ramadhan."

get_sahur_reminder_text() {
    if [ -f "$SAHUR_REMINDER_FILE" ] && [ -s "$SAHUR_REMINDER_FILE" ]; then
        cat "$SAHUR_REMINDER_FILE" 2>/dev/null | head -c 500
    else
        echo "$SAHUR_REMINDER_DEFAULT"
    fi
}

format_sahur_reminder() {
    local template="$1"
    local time="$2"
    local timezone="$3"
    local location="$4"
    
    local formatted_text="$template"
    formatted_text="${formatted_text//\{time\}/$time}"
    formatted_text="${formatted_text//\{timezone\}/$timezone}"
    formatted_text="${formatted_text//\{location\}/$location}"
    
    echo "$formatted_text"
}


# Fungsi untuk mengubah format waktu HH:MM menjadi teks yang dibaca
format_time_for_tts() {
    local time_str="$1"
    
    # Validasi format
    if ! echo "$time_str" | grep -qE '^[0-9]{1,2}:[0-9]{2}$'; then
        echo "$time_str"
        return
    fi
    
    local hours=${time_str%:*}
    local minutes=${time_str#*:}
    
    # Hilangkan leading zero
    hours=${hours#0}
    minutes=${minutes#0}
    
    # Jika menit 0, baca "jam X tepat"
    if [ "$minutes" -eq 0 ]; then
        echo "jam $hours tepat"
    else
        echo "$hours lewat $minutes menit"
    fi
}

# Fungsi untuk mengubah zona waktu menjadi teks yang dibaca
format_timezone_for_tts() {
    local timezone="$1"
    
    case "$timezone" in
        "WIB") echo "Waktu Indonesia Barat" ;;
        "WITA") echo "Waktu Indonesia Tengah" ;;
        "WIT") echo "Waktu Indonesia Timur" ;;
        *)
            # Untuk zona waktu lain (GMT+7, dll)
            echo "$timezone"
            ;;
    esac
}

# Fungsi untuk memvalidasi format file jadwal - dipanggil di awal run_service()
validate_schedule_file() {
    local file="$1"
    
    if [ ! -f "$file" ]; then
        log "ERROR" "❌ File jadwal tidak ditemukan: $file"
        return 1
    fi
    
    # Cek format JSON
    if jq -e . "$file" >/dev/null 2>&1; then
        local sample=$(jq -r '.[0] // empty' "$file" 2>/dev/null)
        if [ -n "$sample" ] && [ "$sample" != "null" ]; then
            local imsyak=$(echo "$sample" | jq -r '.imsyak // empty')
            if [[ "$imsyak" =~ ^[0-9]{1,2}:[0-9]{2}$ ]]; then
                log "INFO" "✅ File jadwal terdeteksi: JSON (valid)"
                return 0
            fi
        fi
        log "ERROR" "❌ File JSON tidak memiliki struktur yang benar"
        return 1
    fi
    
    # Cek format TEXT
    local first_line=$(head -1 "$file" 2>/dev/null)
    if echo "$first_line" | grep -qE '^[0-9]{2}-[0-9]{2}-[0-9]{4} [0-9]{2}:[0-9]{2}'; then
        local fields=$(echo "$first_line" | awk '{print NF}')
        if [ "$fields" -ge 7 ]; then
            log "INFO" "✅ File jadwal terdeteksi: TEXT legacy (valid)"
            return 0
        fi
    fi
    
    log "ERROR" "❌ Format file jadwal tidak dikenal atau corrupted"
    return 1
}

# File untuk menyimpan status reminder
REMINDER_STATUS_FILE="/var/lib/jsholat/reminder_status"

# Fungsi untuk menyimpan status reminder ke file
save_reminder_status() {
    local status_dir=$(dirname "$REMINDER_STATUS_FILE")
    [ -d "$status_dir" ] || mkdir -p "$status_dir"
    
    echo "REMINDER_IMSYAK=$REMINDER_IMSYAK" > "$REMINDER_STATUS_FILE"
    echo "REMINDER_SUBUH=$REMINDER_SUBUH" >> "$REMINDER_STATUS_FILE"
    echo "REMINDER_DZUHUR=$REMINDER_DZUHUR" >> "$REMINDER_STATUS_FILE"
    echo "REMINDER_ASHAR=$REMINDER_ASHAR" >> "$REMINDER_STATUS_FILE"
    echo "REMINDER_MAGHRIB=$REMINDER_MAGHRIB" >> "$REMINDER_STATUS_FILE"
    echo "REMINDER_ISYA=$REMINDER_ISYA" >> "$REMINDER_STATUS_FILE"
    
    [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "💾 Status reminder disimpan"
}

# Fungsi untuk membaca status reminder dari file
load_reminder_status() {
    local REMINDER_BEFORE=$(uci -q get jsholat.sound.reminder_before || echo "5")
    
    # ✅ JIKA REMINDER DINONAKTIFKAN, SKIP LOAD
    if [ "$REMINDER_BEFORE" = "0" ]; then
        [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "🔕 Skip load reminder status (fitur dinonaktifkan)"
        return
    fi
    
    if [ -f "$REMINDER_STATUS_FILE" ]; then
        # Source file untuk load variabel
        . "$REMINDER_STATUS_FILE"
        [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "📖 Status reminder dimuat dari file"
    else
        [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "📖 File status reminder tidak ditemukan, menggunakan default"
    fi
}

# Fungsi untuk reset reminder setiap hari baru
reset_reminder_status() {
    local TODAY=$(date +"%d-%m-%Y")
    local LAST_RESET_DATE=""
    local REMINDER_BEFORE=$(uci -q get jsholat.sound.reminder_before || echo "5")
    
    # ✅ JIKA REMINDER DINONAKTIFKAN, SKIP RESET
    if [ "$REMINDER_BEFORE" = "0" ]; then
        [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "🔕 Skip reset reminder (fitur dinonaktifkan)"
        return
    fi
    
    # Cek file last reset date jika ada
    if [ -f "/var/lib/jsholat/last_reset_date" ]; then
        LAST_RESET_DATE=$(cat "/var/lib/jsholat/last_reset_date")
    fi
    
    # Reset hanya jika hari berbeda
    if [ "$LAST_RESET_DATE" != "$TODAY" ]; then
        REMINDER_IMSYAK=0
        REMINDER_SUBUH=0
        REMINDER_DZUHUR=0
        REMINDER_ASHAR=0
        REMINDER_MAGHRIB=0
        REMINDER_ISYA=0
        
        # Simpan tanggal reset terakhir
        echo "$TODAY" > "/var/lib/jsholat/last_reset_date"
        save_reminder_status
        
        log "INFO" "🔄 Status reminder direset untuk hari baru: $TODAY"
    fi
}

# Fungsi alternatif dengan presisi lebih tinggi
get_system_memory_info() {
    if [ -f "/proc/meminfo" ]; then
        local total_kb=$(grep -E '^MemTotal:' /proc/meminfo 2>/dev/null | awk '{print $2}')
        local available_kb=$(grep -E '^MemAvailable:' /proc/meminfo 2>/dev/null | awk '{print $2}')
        
        if [ -n "$total_kb" ] && [ -n "$available_kb" ]; then
            local used_kb=$((total_kb - available_kb))
            local used_percent=0
            [ "$total_kb" -gt 0 ] && used_percent=$(( (used_kb * 100) / total_kb ))
            
            # Format used dalam MB (selalu)
            local used_mb_int=$((used_kb / 1024))
            local used_kb_remainder=$((used_kb % 1024))
            # Hitung fraksi MB (2 digit desimal)
            local used_mb_frac=$(( (used_kb_remainder * 100) / 1024 ))
            # Pastikan selalu 2 digit
            [ ${#used_mb_frac} -eq 1 ] && used_mb_frac="0${used_mb_frac}"
            
            # Format total: GB jika >= 1GB, MB jika < 1GB
            if [ $total_kb -ge 1048576 ]; then # >= 1GB
                local total_gb_int=$((total_kb / 1048576))
                local total_remainder_kb=$((total_kb % 1048576))
                local total_mb_remainder=$((total_remainder_kb / 1024))
                # Hitung fraksi GB (2 digit desimal)
                local total_gb_frac=$(( (total_mb_remainder * 100) / 1024 ))
                [ ${#total_gb_frac} -eq 1 ] && total_gb_frac="0${total_gb_frac}"
                
                echo "${used_mb_int}.${used_mb_frac} MB / ${total_gb_int}.${total_gb_frac} GB (${used_percent}%)"
            else
                local total_mb_int=$((total_kb / 1024))
                local total_kb_remainder=$((total_kb % 1024))
                local total_mb_frac=$(( (total_kb_remainder * 100) / 1024 ))
                [ ${#total_mb_frac} -eq 1 ] && total_mb_frac="0${total_mb_frac}"
                
                echo "${used_mb_int}.${used_mb_frac} MB / ${total_mb_int}.${total_mb_frac} MB (${used_percent}%)"
            fi
        else
            echo "Information not available"
        fi
    else
        echo "Information not available"
    fi
}

# Fungsi untuk menampilkan status waktu sholat
show_prayer_status() {
    local name="$1"
    local time="$2"
    local current_time="$3"
    local timezone="$4"
    
    # Skip jika waktu kosong atau tidak valid
    [ -z "$time" ] || [ "$time" = "-" ] || [ "$time" = "null" ] && return
    
    # Validasi format waktu
    if ! echo "$time" | grep -qE '^[0-9]{1,2}:[0-9]{2}$'; then
        [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "show_prayer_status: skip $name, format invalid: '$time'"
        return
    fi
    
    # Konversi waktu ke menit
    local prayer_hours=${time%:*}
    local prayer_minutes=${time#*:}
    prayer_hours=${prayer_hours#0}
    prayer_minutes=${prayer_minutes#0}
    [ -z "$prayer_hours" ] && prayer_hours=0
    [ -z "$prayer_minutes" ] && prayer_minutes=0
    local prayer_total_minutes=$((prayer_hours * 60 + prayer_minutes))
    
    local current_hours=${current_time%:*}
    local current_minutes=${current_time#*:}
    current_hours=${current_hours#0}
    current_minutes=${current_minutes#0}
    [ -z "$current_hours" ] && current_hours=0
    [ -z "$current_minutes" ] && current_minutes=0
    local current_total_minutes=$((current_hours * 60 + current_minutes))
    
    local diff=$((prayer_total_minutes - current_total_minutes))
    
    # Tampilkan status dengan emoji yang sesuai
    if [ $diff -eq 0 ]; then
        echo "   🕌 $name ($time): SAAT INI!"
    elif [ $diff -gt 0 ]; then
        if [ $diff -le 5 ]; then
            echo "   🔔 $name ($time): Dalam $diff menit"
        elif [ $diff -le 30 ]; then
            echo "   ⏳ $name ($time): ${diff} menit lagi"
        else
            local hours_remaining=$((diff / 60))
            local minutes_remaining=$((diff % 60))
            if [ $hours_remaining -gt 0 ]; then
                echo "   ○ $name ($time): ${hours_remaining} jam ${minutes_remaining} menit lagi"
            else
                echo "   ○ $name ($time): ${minutes_remaining} menit lagi"
            fi
        fi
    else
        echo "   ✓ $name ($time): Sudah lewat"
    fi
}

# FUNGSI BARU: TAMPILKAN STATUS SERVICE DENGAN UPTIME
show_status() {
    echo "============================================="
    echo "          STATUS SERVICE JSHOLAT"
    echo "============================================="
    
    # Cek apakah service berjalan
    local pid=$(pgrep -f "/usr/bin/jsholat run")
    if [ -n "$pid" ]; then
        echo "✅ Service: BERJALAN (PID: $pid)"
        
        # Cek apakah proses benar-benar berjalan
        if kill -0 "$pid" 2>/dev/null; then
            echo "   Proses: /usr/bin/jsholat run"
            
            # HITUNG UPTIME PROSES
            if [ -d "/proc/$pid" ]; then
                local start_time=$(stat -c %Y "/proc/$pid" 2>/dev/null)
                if [ -n "$start_time" ]; then
                    local now=$(date +%s)
                    local uptime_seconds=$((now - start_time))
                    
                    local days=$((uptime_seconds / 86400))
                    local hours=$(( (uptime_seconds % 86400) / 3600 ))
                    local minutes=$(( (uptime_seconds % 3600) / 60 ))
                    local seconds=$((uptime_seconds % 60))
                    
                    if [ $days -gt 0 ]; then
                        echo "   Uptime: ${days} hari ${hours} jam ${minutes} menit"
                    elif [ $hours -gt 0 ]; then
                        echo "   Uptime: ${hours} jam ${minutes} menit"
                    elif [ $minutes -gt 0 ]; then
                        echo "   Uptime: ${minutes} menit ${seconds} detik"
                    else
                        echo "   Uptime: ${seconds} detik"
                    fi
                    
                    local start_date=$(date -d "@$start_time" "+%Y-%m-%d %H:%M:%S" 2>/dev/null || \
                                     date "+%Y-%m-%d %H:%M:%S" -d "@$start_time" 2>/dev/null || \
                                     echo "Tidak diketahui")
                    echo "   Mulai:  $start_date"
                fi
            else
                local ps_output=$(ps -o etime= -p "$pid" 2>/dev/null || \
                                ps -o etime= "$pid" 2>/dev/null || \
                                echo "00:00")
                echo "   Uptime: $ps_output"
            fi
            
            if [ -f "/proc/$pid/status" ]; then
                local memory_kb=$(grep VmRSS "/proc/$pid/status" 2>/dev/null | awk '{print $2}')
                if [ -n "$memory_kb" ]; then
                    local memory_mb=$((memory_kb / 1024))
                    echo "   Memory: ${memory_mb} MB (${memory_kb} KB)"
                fi
            fi
        else
            echo "   ⚠️  Proses PID $pid ditemukan tetapi tidak merespon"
        fi
    else
        echo "❌ Service: TIDAK BERJALAN"
        
        if [ -f "/var/log/jsholat/service.log" ]; then
            local last_start=$(grep "SERVICE JSHOLAT DIMULAI" "/var/log/jsholat/service.log" 2>/dev/null | tail -1)
            if [ -n "$last_start" ]; then
                echo "   Terakhir berjalan: $(echo "$last_start" | cut -d' ' -f1-3)"
            fi
        fi
    fi
    
    local service_enabled=$(uci -q get jsholat.service.service || echo "1")
    echo "⚙️  Status Konfigurasi: $([ "$service_enabled" = "1" ] && echo "AKTIF" || echo "NONAKTIF")"
    
    if [ -f "/var/lib/jsholat/last_reset_date" ]; then
        echo "📅 Reset Terakhir: $(cat /var/lib/jsholat/last_reset_date)"
    fi
    
    if [ -f "/var/log/jsholat/service.log" ]; then
        local log_size=$(du -h "/var/log/jsholat/service.log" 2>/dev/null | awk '{print $1}')
        local log_lines=$(wc -l < "/var/log/jsholat/service.log" 2>/dev/null || echo "0")
        echo "📊 Log File: /var/log/jsholat/service.log"
        echo "   Ukuran: ${log_size:-Tidak diketahui}, Baris: $log_lines"
        echo "   --- 5 Baris Terakhir Log ---"
        tail -5 "/var/log/jsholat/service.log" 2>/dev/null | while read -r line; do
            echo "   $line"
        done
    else
        echo "📊 Log File: Tidak ditemukan"
    fi
    
    echo ""
    echo "============================================="
    echo "🔧 KONFIGURASI FITUR:"
    
    local telegram_enabled=$(uci -q get jsholat.service.telegram_enabled || echo "1")
    local sound_enabled=$(uci -q get jsholat.sound.sound_enabled || echo "1")
    local ayat_enabled=$(uci -q get jsholat.service.ayat_enabled || echo "1")
    local reminder_before=$(uci -q get jsholat.sound.reminder_before || echo "5")
    local debug_mode=$(uci -q get jsholat.service.debug_mode || echo "0")
    local volume_level=$(uci -q get jsholat.sound.volume_level || echo "80")
    local tts_method=$(uci -q get jsholat.sound.tts_method || echo "google")
    local reminder_sound_enabled=$(uci -q get jsholat.sound.reminder_sound_enabled || echo "0")
    
    echo "   • Telegram Notifikasi: $([ "$telegram_enabled" = "1" ] && echo "AKTIF" || echo "NONAKTIF")"
    echo "   • Pemutar Suara: $([ "$sound_enabled" = "1" ] && echo "AKTIF" || echo "NONAKTIF")"
    echo "   • Volume: ${volume_level}%"
    echo "   • Ayat Acak: $([ "$ayat_enabled" = "1" ] && echo "AKTIF" || echo "NONAKTIF")"
    echo "   • Reminder Sholat: $([ "$reminder_before" = "0" ] && echo "NONAKTIF" || echo "AKTIF (${reminder_before} menit)")"
    echo "   • Suara Reminder: $([ "$reminder_sound_enabled" = "1" ] && echo "AKTIF" || echo "NONAKTIF")"
    echo "   • Metode TTS: $tts_method"
    echo "   • Debug Mode: $([ "$debug_mode" = "1" ] && echo "AKTIF" || echo "NONAKTIF")"
    
    echo ""
    echo "============================================="
	echo "🗣️ Informasi TTS:"
        # Informasi Gemini
    local gemini_api_key=$(uci -q get jsholat.sound.gemini_api_key || echo "")
    local gemini_model=$(uci -q get jsholat.sound.gemini_model || echo "gemini-2.5-flash-preview-tts")
    local gemini_voice=$(uci -q get jsholat.sound.gemini_voice || echo "Leda")
    
    if [ -n "$gemini_api_key" ]; then
        local masked_key="${gemini_api_key:0:4}...${gemini_api_key: -4}"
        echo "   • Gemini API: ✅ $masked_key"
        echo "   • Gemini Model: $gemini_model"
        echo "   • Gemini Voice: $gemini_voice"
    else
        echo "   • Gemini API: ❌ Belum dikonfigurasi"
    fi
    
    # Informasi Edge-TTS
    local edge_voice=$(uci -q get jsholat.sound.edge_voice || echo "id-ID-ArdiNeural")
    local edge_voice_name=$(format_edge_voice "$edge_voice")
    if command -v edge-tts >/dev/null 2>&1; then
        echo "   • Edge-TTS: ✅ TERINSTAL (Voice: $edge_voice_name)"
    else
        echo "   • Edge-TTS: ❌ TIDAK TERINSTAL (pip install edge-tts)"
    fi
    
    local TODAY=$(date +"%d-%m-%Y")
    local JADWAL=$(uci get jsholat.schedule.file_jadwal 2>/dev/null)
    local LOKASI=$(uci get jsholat.schedule.city_label 2>/dev/null || echo "Tidak Diketahui")
    local TIMEZONE=$(uci -q get jsholat.schedule.timezone_value || echo "")
    local PROVINCE=$(uci get jsholat.schedule.province 2>/dev/null || echo "Tidak Diketahui")
    local SCHEDULE_SOURCE=$(uci -q get jsholat.schedule.source || echo "unknown")
    
    echo ""
    echo "============================================="
    echo "🕌 JADWAL SHOLAT HARI INI ($TODAY):"
    echo "   Lokasi: $LOKASI, $PROVINCE"
    echo "   Sumber: $(get_source_alias "$SCHEDULE_SOURCE")"
    
    local IMSYAK="" SHUBUH="" DZUHUR="" ASHAR="" MAGHRIB="" ISYA=""
    local FORMAT_DETECTED=""
    
    if [ -f "$JADWAL" ] && [ -r "$JADWAL" ]; then
        # DETEKSI FORMAT FILE
        if jq -e . "$JADWAL" >/dev/null 2>&1; then
            FORMAT_DETECTED="JSON"
            local JSON_DATA=$(jq -r --arg t "$TODAY" \
                '.[] | select(.gregorian_date==$t)' \
                "$JADWAL" 2>/dev/null)
            
            if [ -n "$JSON_DATA" ] && [ "$JSON_DATA" != "null" ]; then
                IMSYAK=$(echo "$JSON_DATA" | jq -r '.imsyak // empty')
                SHUBUH=$(echo "$JSON_DATA" | jq -r '.subuh // empty')
                DZUHUR=$(echo "$JSON_DATA" | jq -r '.dzuhur // empty')
                ASHAR=$(echo "$JSON_DATA" | jq -r '.ashar // empty')
                MAGHRIB=$(echo "$JSON_DATA" | jq -r '.maghrib // empty')
                ISYA=$(echo "$JSON_DATA" | jq -r '.isya // empty')
            fi
        else
            # CEK FORMAT TEXT
            local first_line=$(head -1 "$JADWAL" 2>/dev/null)
            if echo "$first_line" | grep -qE '^[0-9]{2}-[0-9]{2}-[0-9]{4} [0-9]{2}:[0-9]{2}'; then
                FORMAT_DETECTED="TEXT (legacy)"
                local JADWAL_LINE=$(grep "^$TODAY" "$JADWAL" 2>/dev/null | tr -d '\r')
                if [ -n "$JADWAL_LINE" ]; then
                    IMSYAK=$(echo "$JADWAL_LINE" | awk '{print $2}' | tr -d '\r')
                    SHUBUH=$(echo "$JADWAL_LINE" | awk '{print $3}' | tr -d '\r')
                    DZUHUR=$(echo "$JADWAL_LINE" | awk '{print $4}' | tr -d '\r')
                    ASHAR=$(echo "$JADWAL_LINE" | awk '{print $5}' | tr -d '\r')
                    MAGHRIB=$(echo "$JADWAL_LINE" | awk '{print $6}' | tr -d '\r')
                    ISYA=$(echo "$JADWAL_LINE" | awk '{print $7}' | tr -d '\r')
                fi
            else
                FORMAT_DETECTED="TIDAK DIKENAL"
            fi
        fi
        
        echo "   Format File: $FORMAT_DETECTED"
        
        if [ -n "$IMSYAK" ] && [ "$IMSYAK" != "-" ] && [ "$IMSYAK" != "null" ]; then
            echo "   • Imsyak:   $IMSYAK $TIMEZONE"
            echo "   • Subuh:    $SHUBUH $TIMEZONE"
            echo "   • Dzuhur:   $DZUHUR $TIMEZONE"
            echo "   • Ashar:    $ASHAR $TIMEZONE"
            echo "   • Maghrib:  $MAGHRIB $TIMEZONE"
            echo "   • Isya:     $ISYA $TIMEZONE"
            
            local NOW=$(date +"%H:%M")
            echo ""
            echo "============================================="
            echo "⏰ WAKTU SEKARANG: $NOW $TIMEZONE"
            echo ""
            echo "   STATUS WAKTU SHOLAT:"
            echo "   ─────────────────────────"
            
            # PASTIKAN FUNGSI INI DIPANGGIL DENGAN BENAR
            show_prayer_status "Imsyak" "$IMSYAK" "$NOW"
            show_prayer_status "Subuh" "$SHUBUH" "$NOW"
            show_prayer_status "Dzuhur" "$DZUHUR" "$NOW"
            show_prayer_status "Ashar" "$ASHAR" "$NOW"
            show_prayer_status "Maghrib" "$MAGHRIB" "$NOW"
            show_prayer_status "Isya" "$ISYA" "$NOW"
            
            echo ""
            local next_prayer=$(get_next_prayer_time "$IMSYAK" "$SHUBUH" "$DZUHUR" "$ASHAR" "$MAGHRIB" "$ISYA" "$NOW")
            if [ -n "$next_prayer" ]; then
                echo "   🕐 Sholat berikutnya: $next_prayer"
            fi
        else
            echo "   ❌ Jadwal untuk hari ini tidak ditemukan atau data tidak lengkap"
            echo ""
            echo "   ℹ️  Format jadwal yang diharapkan:"
            echo "      - JSON: {\"gregorian_date\":\"$TODAY\", \"imsyak\":\"04:30\", ...}"
            echo "      - Text: $TODAY 04:30 04:45 12:00 15:30 18:00 19:00"
        fi
    else
        echo "   ❌ File jadwal tidak ditemukan atau tidak dapat dibaca"
        echo "   Path: $JADWAL"
    fi
	
    echo ""
    echo "============================================="
    echo "💻 INFORMASI SISTEM:"
    echo "   Waktu Sistem: $(date '+%Y-%m-%d %H:%M:%S')"
    
    if [ -f "/proc/uptime" ]; then
        local uptime_seconds=$(awk '{print int($1)}' /proc/uptime 2>/dev/null)
        if [ -n "$uptime_seconds" ] && [ "$uptime_seconds" -gt 0 ]; then
            local days=$((uptime_seconds / 86400))
            local hours=$(( (uptime_seconds % 86400) / 3600 ))
            local minutes=$(( (uptime_seconds % 3600) / 60 ))
            
            local uptime_str=""
            if [ $days -gt 0 ]; then
                uptime_str="${days} hari"
                [ $hours -gt 0 ] && uptime_str="${uptime_str} ${hours} jam"
                [ $minutes -gt 0 ] && uptime_str="${uptime_str} ${minutes} menit"
            elif [ $hours -gt 0 ]; then
                uptime_str="${hours} jam"
                [ $minutes -gt 0 ] && uptime_str="${uptime_str} ${minutes} menit"
            elif [ $minutes -gt 0 ]; then
                uptime_str="${minutes} menit"
            else
                uptime_str="Kurang dari 1 menit"
            fi
            
            echo "   Uptime Sistem: $uptime_str"
        fi
    else
        local uptime_output=$(uptime 2>/dev/null | sed 's/.*up //' | sed 's/,.*load.*//')
        [ -n "$uptime_output" ] && echo "   Uptime Sistem: $uptime_output"
    fi
    
    local load_avg=$(uptime 2>/dev/null | grep -o 'load average: .*' || echo "load average: Tidak tersedia")
    echo "   Load Average: $load_avg"
    
    if [ -f "/proc/meminfo" ]; then
        local total_mem=$(grep MemTotal /proc/meminfo | awk '{print $2}')
        local available_mem=$(grep MemAvailable /proc/meminfo | awk '{print $2}')
        
        if [ -n "$total_mem" ] && [ -n "$available_mem" ]; then
            local total_mb=$((total_mem / 1024))
            local available_mb=$((available_mem / 1024))
            local used_mb=$((total_mb - available_mb))
            local usage_percent=$((used_mb * 100 / total_mb))
            
            echo "   Memory: ${used_mb}MB/${total_mb}MB digunakan (${usage_percent}%)"
        fi
    fi
    
    if [ -f "$JADWAL" ]; then
        echo ""
        echo "📁 INFORMASI FILE JADWAL:"
        echo "   Path: $JADWAL"
        echo "   Ukuran: $(du -h "$JADWAL" 2>/dev/null | awk '{print $1}')"
        echo "   Format: $FORMAT_DETECTED"
        
        local last_updated_file="/usr/share/jsholat/last_updated.txt"
        if [ -f "$last_updated_file" ]; then
            local last_updated=$(jq -r '.last_updated // empty' "$last_updated_file" 2>/dev/null)
            [ -n "$last_updated" ] && echo "   Update Terakhir: $last_updated"
        fi
    fi
    
    echo "============================================="
    
    if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
        return 0
    else
        return 1
    fi
}

# Fungsi helper untuk mendapatkan alias sumber jadwal
get_source_alias() {
    local source="$1"
    case "$source" in
        "jadwalsholat") echo "JadwalSholat.org" ;;
        "aladhan") echo "AlAdhan API" ;;
        "myquran") echo "MyQuran API" ;;
        "apiajimedia") echo "AjiMedia API" ;;
        *) echo "$source" ;;
    esac
}

# Fungsi helper untuk mendapatkan waktu sholat berikutnya
get_next_prayer_time() {
    local imsyak="$1" subuh="$2" dzuhur="$3" ashar="$4" maghrib="$5" isya="$6" current="$7"
    
    [ -z "$current" ] && return 1
    
    local current_seconds=$(time_to_seconds "$current")
    [ "$current_seconds" -eq 0 ] && return 1
    
    local next_prayer=""
    local next_name=""
    local next_time=""
    local min_diff=86400
    
    # Gunakan array dengan FORMAT YANG BENAR - simpan sebagai "nama|waktu"
    local prayers=(
        "Imsyak|$imsyak"
        "Subuh|$subuh"
        "Dzuhur|$dzuhur"
        "Ashar|$ashar"
        "Maghrib|$maghrib"
        "Isya|$isya"
    )
    
    for prayer in "${prayers[@]}"; do
        # Pisahkan dengan delimiter '|' bukan ':'
        local name="${prayer%%|*}"
        local time_val="${prayer##*|}"
        
        # Skip jika waktu kosong atau tidak valid
        [ -z "$time_val" ] || [ "$time_val" = "-" ] || [ "$time_val" = "null" ] && continue
        ! echo "$time_val" | grep -qE '^[0-9]{1,2}:[0-9]{2}$' && continue
        
        local prayer_seconds=$(time_to_seconds "$time_val")
        [ "$prayer_seconds" -eq 0 ] && continue
        
        local diff=$((prayer_seconds - current_seconds))
        
        if [ $diff -gt 0 ] && [ $diff -lt $min_diff ]; then
            min_diff=$diff
            next_name="$name"
            next_time="$time_val"
        fi
    done
    
    if [ -n "$next_name" ]; then
        local minutes_left=$((min_diff / 60))
        next_prayer="$next_name ($next_time) - $(format_minutes $minutes_left) lagi"
    elif [ -n "$imsyak" ] && [ "$imsyak" != "-" ] && [ "$imsyak" != "null" ]; then
        if echo "$imsyak" | grep -qE '^[0-9]{1,2}:[0-9]{2}$'; then
            local seconds_to_midnight=$(( (24 * 3600) - current_seconds ))
            local imsak_seconds=$(time_to_seconds "$imsyak")
            local total_seconds=$((seconds_to_midnight + imsak_seconds))
            local minutes_left=$((total_seconds / 60))
            next_prayer="Imsyak (besok) ($imsyak) - $(format_minutes $minutes_left) lagi"
        fi
    fi
    
    echo "$next_prayer"
}


# Fungsi helper untuk format menit
format_minutes() {
    local minutes=$1
    if [ $minutes -ge 60 ]; then
        local hours=$((minutes / 60))
        local mins=$((minutes % 60))
        echo "${hours} jam ${mins} menit"
    else
        echo "${minutes} menit"
    fi
}

# Fungsi untuk format voice Edge-TTS
format_edge_voice() {
    local voice="$1"
    
    case "$voice" in
        "id-ID-ArdiNeural") echo "Ardi (Indonesia-Pria)" ;;
        "id-ID-GadisNeural") echo "Gadis (Indonesia-Wanita)" ;;
        "jv-ID-DimasNeural") echo "Dimas (Jawa-Pria)" ;;
        "jv-ID-SitiNeural") echo "Siti (Jawa-Wanita)" ;;
        *) echo "$voice" ;;
    esac
}

# Fungsi untuk mendapatkan status jsholat-bot berdasarkan file PID
get_jsholat_bot_status() {
    local pid_file="/var/run/jsholat-bot.pid"
    
    # Cek file PID terlebih dahulu
    local bot_pid=""
    if [ -f "$pid_file" ] && [ -r "$pid_file" ]; then
        bot_pid=$(cat "$pid_file" 2>/dev/null)
        
        # Validasi PID dari file
        if [ -n "$bot_pid" ] && kill -0 "$bot_pid" 2>/dev/null; then
            echo "running:$bot_pid"
            return 0
        else
            # File PID ada tapi proses sudah mati, hapus file
            rm -f "$pid_file" 2>/dev/null
        fi
    fi
    
    # Fallback: Cari PID dari proses
    bot_pid=$(pgrep -f "/usr/bin/jsholat-bot" | head -1)
    
    if [ -n "$bot_pid" ] && kill -0 "$bot_pid" 2>/dev/null; then
        # Simpan PID ke file untuk penggunaan berikutnya
        echo "$bot_pid" > "$pid_file" 2>/dev/null
        echo "running:$bot_pid"
    else
        echo "stopped"
    fi
    
    return 0
}

# FUNGSI INFO SERVICE (UNTUK OUTPUT JSON)
info_service() {
    # Dapatkan status service terlebih dahulu
    local pid
    pid=$(pgrep -f "/usr/bin/jsholat run")
    local service_enabled
    service_enabled=$(uci -q get jsholat.service.service || echo "1")
    local service_running="0"
    
    if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
        service_running="1"
    fi
    
    # Hitung uptime jika service berjalan
    local uptime_seconds="0"
    local start_time_str=""
    if [ "$service_running" = "1" ] && [ -d "/proc/$pid" ]; then
        local start_time
        start_time=$(stat -c %Y "/proc/$pid" 2>/dev/null)
        if [ -n "$start_time" ]; then
            local now
            now=$(date +%s)
            uptime_seconds=$((now - start_time))
            start_time_str=$(date -d "@$start_time" "+%Y-%m-%d %H:%M:%S" 2>/dev/null || echo "Unknown")
        fi
    fi
    
    # Dapatkan konfigurasi dari UCI
    local telegram_enabled
    telegram_enabled=$(uci -q get jsholat.service.telegram_enabled || echo "1")
    local sound_enabled
    sound_enabled=$(uci -q get jsholat.sound.sound_enabled || echo "1")
    local ayat_enabled
    ayat_enabled=$(uci -q get jsholat.service.ayat_enabled || echo "1")
    local reminder_before
    reminder_before=$(uci -q get jsholat.sound.reminder_before || echo "5")
    local reminder_sound_enabled
    reminder_sound_enabled=$(uci -q get jsholat.sound.reminder_sound_enabled || echo "0")
    # ===== REMINDER =====
    local reminder_enabled="0"
    # Logika: enabled = 1 jika minutes_before > 0
    if [ "$reminder_before" != "0" ] && [ -n "$reminder_before" ]; then
        reminder_enabled="1"
    fi
    
    # Tampilkan di log untuk debugging
    [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "📊 Reminder status: minutes_before=$reminder_before, enabled=$reminder_enabled, sound_enabled=$reminder_sound_enabled"
    local volume_level
    volume_level=$(uci -q get jsholat.sound.volume_level || echo "80")
    local debug_mode
    debug_mode=$(uci -q get jsholat.service.debug_mode || echo "0")
    local tts_method
    tts_method=$(uci -q get jsholat.sound.tts_method || echo "google")
    local murf_api_key
    murf_api_key=$(uci -q get jsholat.sound.murf_api_key || echo "")
    local reminder_repeat_count
    reminder_repeat_count=$(uci -q get jsholat.sound.reminder_repeat_count || echo "3")
    local reminder_repeat_interval
    reminder_repeat_interval=$(uci -q get jsholat.sound.reminder_repeat_interval || echo "5")
    local volume_control
    volume_control=$(uci -q get jsholat.sound.volume_control || echo "hardware")
    local mixer_device
    mixer_device=$(uci -q get jsholat.sound.mixer_device || echo "PCM")
    
    # ===== KONFIGURASI GEMINI =====
    local gemini_api_key
    gemini_api_key=$(uci -q get jsholat.sound.gemini_api_key || echo "")
    local gemini_model
    gemini_model=$(uci -q get jsholat.sound.gemini_model || echo "gemini-2.5-flash-preview-tts")
    local gemini_voice
    gemini_voice=$(uci -q get jsholat.sound.gemini_voice || echo "Leda")
    
    # ===== KONFIGURASI EDGE-TTS =====
    local edge_voice
    edge_voice=$(uci -q get jsholat.sound.edge_voice || echo "id-ID-ArdiNeural")
    
    # ===== KONFIGURASI TARHIM/IMSYAK  =====
    local tarhim_enabled
    tarhim_enabled=$(uci -q get jsholat.sound.tarhim_enabled || echo "0")
    local tarhim_mode
    tarhim_mode=$(uci -q get jsholat.sound.tarhim_mode || echo "ramadhan_only")
    local tarhim_file
    tarhim_file=$(uci -q get jsholat.sound.sound_adzan_imsy || echo "")
    
    # Cek status Ramadhan untuk informasi TTS reminder
    local is_ramadhan_now=0
    if is_ramadhan; then
        is_ramadhan_now=1
    fi
    
    # Tentukan perilaku TTS reminder berdasarkan mode dan status Ramadhan
    local tts_imsyak_behavior=""
    if [ "$tarhim_enabled" = "1" ]; then
        if [ "$tarhim_mode" = "always" ]; then
            tts_imsyak_behavior="always"
        elif [ "$tarhim_mode" = "ramadhan_only" ]; then
            if [ "$is_ramadhan_now" = "1" ]; then
                tts_imsyak_behavior="active_ramadhan"
            else
                tts_imsyak_behavior="inactive_non_ramadhan"
            fi
        fi
    else
        tts_imsyak_behavior="tarhim_disabled"
    fi
    
    # Dapatkan informasi sumber jadwal
    local schedule_source
    schedule_source=$(uci -q get jsholat.schedule.source || echo "unknown")
    local schedule_file
    schedule_file=$(uci -q get jsholat.schedule.file_jadwal || echo "")
    local city
    city=$(uci get jsholat.schedule.city_label 2>/dev/null || echo "Unknown")
    local province
    province=$(uci get jsholat.schedule.province 2>/dev/null || echo "Unknown")
    local timezone
    timezone=$(uci -q get jsholat.schedule.timezone_value || echo "")
    local latitude
    latitude=$(uci -q get jsholat.schedule.latitude || echo "")
    local longitude
    longitude=$(uci -q get jsholat.schedule.longitude || echo "")
    local hijri_adj
    hijri_adj=$(uci -q get jsholat.schedule.hijri_adjust || echo "-1")
    
    # Konversi sumber ke alias
    local source_alias=""
    case "$schedule_source" in
        "jadwalsholat") source_alias="JadwalSholat.org" ;;
        "aladhan") source_alias="AlAdhan API" ;;
        "myquran") source_alias="MyQuran API" ;;
        "apiajimedia") source_alias="AjiMedia API" ;;
        *) source_alias="$schedule_source" ;;
    esac
    
    # Dapatkan info last update jadwal
    local last_updated="Tidak diketahui"
    local last_updated_file="/usr/share/jsholat/last_updated.txt"
    
    if [ -f "$last_updated_file" ] && [ -r "$last_updated_file" ]; then
        if command -v jq >/dev/null 2>&1; then
            local extracted_date=$(jq -r '.last_updated // ""' "$last_updated_file" 2>/dev/null)
            if [ -n "$extracted_date" ] && [ "$extracted_date" != "null" ] && [ "$extracted_date" != "" ]; then
                last_updated="$extracted_date"
            fi
        else
            local extracted_date=$(grep -o '"last_updated"[[:space:]]*:[[:space:]]*"[^"]*"' "$last_updated_file" 2>/dev/null | head -1)
            if [ -n "$extracted_date" ]; then
                last_updated=$(echo "$extracted_date" | sed 's/.*"last_updated"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/')
            else
                local first_line=$(head -1 "$last_updated_file" 2>/dev/null)
                if echo "$first_line" | grep -qE '[0-9]{4}-[0-9]{2}-[0-9]{2}'; then
                    last_updated="$first_line"
                fi
            fi
        fi
    fi
    
    # Format tanggal dan waktu untuk jadwal
    local TODAY
    TODAY=$(date +"%d-%m-%Y")
    
    # Dapatkan tanggal Hijriyah
    local HIJRI_DATE=""
    HIJRI_DATE=$(get_hijri_date 2>/dev/null || echo "")
    
    # Dapatkan nama hari dalam bahasa Indonesia
    local day_number=$(date +%u)
    local DAY_NAME=""
    case $day_number in
        1) DAY_NAME="Senin" ;;
        2) DAY_NAME="Selasa" ;;
        3) DAY_NAME="Rabu" ;;
        4) DAY_NAME="Kamis" ;;
        5) DAY_NAME="Jumat" ;;
        6) DAY_NAME="Sabtu" ;;
        7) DAY_NAME="Ahad" ;;
        *) DAY_NAME="Tidak Diketahui" ;;
    esac
    
    # Dapatkan nama bulan dalam bahasa Indonesia
    local month_number=$(date +%m)
    local month_name=""
    case $month_number in
        01) month_name="Januari" ;;
        02) month_name="Februari" ;;
        03) month_name="Maret" ;;
        04) month_name="April" ;;
        05) month_name="Mei" ;;
        06) month_name="Juni" ;;
        07) month_name="Juli" ;;
        08) month_name="Agustus" ;;
        09) month_name="September" ;;
        10) month_name="Oktober" ;;
        11) month_name="November" ;;
        12) month_name="Desember" ;;
        *) month_name="Tidak Diketahui" ;;
    esac
    
    # Format tanggal lengkap Gregorian
    local day_number_date=$(date +%d)
    local year_gregorian=$(date +%Y)
    local FULL_GREGORIAN_DATE="${day_number_date} ${month_name} ${year_gregorian}"
    
    # Inisialisasi variabel jadwal
    local IMSYAK="" SHUBUH="" DZUHUR="" ASHAR="" MAGHRIB="" ISYA=""
    local SCHEDULE_FORMAT="unknown"
    local SCHEDULE_VALID="false"

    # Cek jadwal hari ini dengan deteksi format otomatis
    if [ -f "$schedule_file" ] && [ -r "$schedule_file" ]; then
        # Deteksi format file
        if jq -e . "$schedule_file" >/dev/null 2>&1; then
            SCHEDULE_FORMAT="json"
            # Format JSON: Ambil data dengan jq
            local JSON_DATA=$(jq -r --arg t "$TODAY" \
                '.[] | select(.gregorian_date==$t)' \
                "$schedule_file" 2>/dev/null)
            
            if [ -n "$JSON_DATA" ] && [ "$JSON_DATA" != "null" ]; then
                IMSYAK=$(echo "$JSON_DATA" | jq -r '.imsyak // empty')
                SHUBUH=$(echo "$JSON_DATA" | jq -r '.subuh // empty')
                DZUHUR=$(echo "$JSON_DATA" | jq -r '.dzuhur // empty')
                ASHAR=$(echo "$JSON_DATA" | jq -r '.ashar // empty')
                MAGHRIB=$(echo "$JSON_DATA" | jq -r '.maghrib // empty')
                ISYA=$(echo "$JSON_DATA" | jq -r '.isya // empty')
                
                # Validasi data
                if [ -n "$IMSYAK" ] && [ -n "$SHUBUH" ] && [ -n "$DZUHUR" ] && \
                   [ -n "$ASHAR" ] && [ -n "$MAGHRIB" ] && [ -n "$ISYA" ] && \
                   [ "$IMSYAK" != "null" ] && [ "$SHUBUH" != "null" ] && \
                   [ "$DZUHUR" != "null" ] && [ "$ASHAR" != "null" ] && \
                   [ "$MAGHRIB" != "null" ] && [ "$ISYA" != "null" ]; then
                    SCHEDULE_VALID="true"
                fi
            fi
        else
            # Cek apakah format text (space-separated)
            local first_line=$(head -1 "$schedule_file" 2>/dev/null)
            if echo "$first_line" | grep -qE '^[0-9]{2}-[0-9]{2}-[0-9]{4} [0-9]{2}:[0-9]{2}'; then
                SCHEDULE_FORMAT="text_legacy"
                # Format lama: Space-separated text
                local JADWAL_LINE=$(grep "^$TODAY" "$schedule_file" 2>/dev/null | tr -d '\r')
                if [ -n "$JADWAL_LINE" ]; then
                    IMSYAK=$(echo "$JADWAL_LINE" | awk '{print $2}' | tr -d '\r')
                    SHUBUH=$(echo "$JADWAL_LINE" | awk '{print $3}' | tr -d '\r')
                    DZUHUR=$(echo "$JADWAL_LINE" | awk '{print $4}' | tr -d '\r')
                    ASHAR=$(echo "$JADWAL_LINE" | awk '{print $5}' | tr -d '\r')
                    MAGHRIB=$(echo "$JADWAL_LINE" | awk '{print $6}' | tr -d '\r')
                    ISYA=$(echo "$JADWAL_LINE" | awk '{print $7}' | tr -d '\r')
                    
                    # Validasi data
                    if [ -n "$IMSYAK" ] && [ -n "$SHUBUH" ] && [ -n "$DZUHUR" ] && \
                       [ -n "$ASHAR" ] && [ -n "$MAGHRIB" ] && [ -n "$ISYA" ] && \
                       [ "$IMSYAK" != "-" ] && [ "$SHUBUH" != "-" ] && \
                       [ "$DZUHUR" != "-" ] && [ "$ASHAR" != "-" ] && \
                       [ "$MAGHRIB" != "-" ] && [ "$ISYA" != "-" ]; then
                        SCHEDULE_VALID="true"
                    fi
                fi
            else
                SCHEDULE_FORMAT="unknown/corrupted"
                log "ERROR" "❌ Format file jadwal tidak dikenal: $schedule_file"
            fi
        fi
    fi
    
    # Tentukan waktu sholat berikutnya
    local next_prayer=""
    local next_prayer_time=""
    local minutes_to_next="0"
    local next_prayer_timestamp=""
    
    # Hanya cek jika ada jadwal yang valid
    if [ "$SCHEDULE_VALID" = "true" ] && [ -n "$IMSYAK" ] && [ "$IMSYAK" != "-" ] && [ "$IMSYAK" != "null" ]; then
        local current_time
        current_time=$(date +"%H:%M")
        local current_seconds
        current_seconds=$(time_to_seconds "$current_time")
        
        # Cari waktu sholat berikutnya
        local prayer_found="0"
        
        # Cek Imsyak
        if [ -n "$IMSYAK" ] && [ "$prayer_found" = "0" ]; then
            local prayer_seconds
            prayer_seconds=$(time_to_seconds "$IMSYAK")
            if [ "$prayer_seconds" -gt "$current_seconds" ]; then
                next_prayer="Imsyak"
                next_prayer_time="$IMSYAK"
                minutes_to_next=$(( (prayer_seconds - current_seconds) / 60 ))
                next_prayer_timestamp=$(date -d "$IMSYAK" "+%Y-%m-%d %H:%M:%S" 2>/dev/null || echo "")
                prayer_found="1"
            fi
        fi
        
        # Cek Subuh
        if [ -n "$SHUBUH" ] && [ "$prayer_found" = "0" ]; then
            local prayer_seconds
            prayer_seconds=$(time_to_seconds "$SHUBUH")
            if [ "$prayer_seconds" -gt "$current_seconds" ]; then
                next_prayer="Subuh"
                next_prayer_time="$SHUBUH"
                minutes_to_next=$(( (prayer_seconds - current_seconds) / 60 ))
                next_prayer_timestamp=$(date -d "$SHUBUH" "+%Y-%m-%d %H:%M:%S" 2>/dev/null || echo "")
                prayer_found="1"
            fi
        fi
        
        # Cek Dzuhur
        if [ -n "$DZUHUR" ] && [ "$prayer_found" = "0" ]; then
            local prayer_seconds
            prayer_seconds=$(time_to_seconds "$DZUHUR")
            if [ "$prayer_seconds" -gt "$current_seconds" ]; then
                next_prayer="Dzuhur"
                next_prayer_time="$DZUHUR"
                minutes_to_next=$(( (prayer_seconds - current_seconds) / 60 ))
                next_prayer_timestamp=$(date -d "$DZUHUR" "+%Y-%m-%d %H:%M:%S" 2>/dev/null || echo "")
                prayer_found="1"
            fi
        fi
        
        # Cek Ashar
        if [ -n "$ASHAR" ] && [ "$prayer_found" = "0" ]; then
            local prayer_seconds
            prayer_seconds=$(time_to_seconds "$ASHAR")
            if [ "$prayer_seconds" -gt "$current_seconds" ]; then
                next_prayer="Ashar"
                next_prayer_time="$ASHAR"
                minutes_to_next=$(( (prayer_seconds - current_seconds) / 60 ))
                next_prayer_timestamp=$(date -d "$ASHAR" "+%Y-%m-%d %H:%M:%S" 2>/dev/null || echo "")
                prayer_found="1"
            fi
        fi
        
        # Cek Maghrib
        if [ -n "$MAGHRIB" ] && [ "$prayer_found" = "0" ]; then
            local prayer_seconds
            prayer_seconds=$(time_to_seconds "$MAGHRIB")
            if [ "$prayer_seconds" -gt "$current_seconds" ]; then
                next_prayer="Maghrib"
                next_prayer_time="$MAGHRIB"
                minutes_to_next=$(( (prayer_seconds - current_seconds) / 60 ))
                next_prayer_timestamp=$(date -d "$MAGHRIB" "+%Y-%m-%d %H:%M:%S" 2>/dev/null || echo "")
                prayer_found="1"
            fi
        fi
        
        # Cek Isya
        if [ -n "$ISYA" ] && [ "$prayer_found" = "0" ]; then
            local prayer_seconds
            prayer_seconds=$(time_to_seconds "$ISYA")
            if [ "$prayer_seconds" -gt "$current_seconds" ]; then
                next_prayer="Isya"
                next_prayer_time="$ISYA"
                minutes_to_next=$(( (prayer_seconds - current_seconds) / 60 ))
                next_prayer_timestamp=$(date -d "$ISYA" "+%Y-%m-%d %H:%M:%S" 2>/dev/null || echo "")
                prayer_found="1"
            fi
        fi
        
        # Jika tidak ada waktu sholat yang lebih besar dari sekarang, ambil Imsyak besok dari file jadwal
        if [ "$prayer_found" = "0" ]; then
            # Hitung tanggal besok
            local besok=$(date -d "$TODAY +1 day" +"%d-%m-%Y" 2>/dev/null)
            if [ -z "$besok" ]; then
                # Fallback manual parsing tanggal
                local day=${TODAY%-*}
                local month=${TODAY#*-}
                month=${month%-*}
                local year=${TODAY##*-}
                day=$((10#$day + 1))
                besok=$(printf "%02d-%02d-%04d" $day $month $year)
            fi
            
            # Baca jadwal besok dari file
            local besok_data=$(jq -r --arg t "$besok" '.[] | select(.gregorian_date==$t)' "$schedule_file" 2>/dev/null)
            
            if [ -n "$besok_data" ] && [ "$besok_data" != "null" ]; then
                local imsyak_besok=$(echo "$besok_data" | jq -r '.imsyak // empty')
                
                if [ -n "$imsyak_besok" ] && [ "$imsyak_besok" != "null" ]; then
                    next_prayer="Imsyak (besok)"
                    next_prayer_time="$imsyak_besok"
                    
                    # Hitung selisih sampai Imsyak besok
                    local midnight_seconds=$((24 * 3600))
                    local seconds_to_midnight=$((midnight_seconds - current_seconds))
                    local imsak_seconds=$(time_to_seconds "$imsyak_besok")
                    minutes_to_next=$(( (seconds_to_midnight + imsak_seconds) / 60 ))
                    next_prayer_timestamp=$(date -d "$besok $imsyak_besok" "+%Y-%m-%d %H:%M:%S" 2>/dev/null || echo "")
                    prayer_found="1"
                fi
            fi
            
            # Fallback jika data besok tidak ditemukan
            if [ "$prayer_found" = "0" ]; then
                next_prayer="Imsyak (besok - estimasi)"
                next_prayer_time="$IMSYAK"
                # Hitung selisih sampai Imsyak besok dengan estimasi
                local midnight_seconds=$((24 * 3600))
                local seconds_to_midnight=$((midnight_seconds - current_seconds))
                local imsak_seconds=$(time_to_seconds "$IMSYAK")
                minutes_to_next=$(( (seconds_to_midnight + imsak_seconds) / 60 ))
                next_prayer_timestamp=$(date -d "tomorrow $IMSYAK" "+%Y-%m-%d %H:%M:%S" 2>/dev/null || echo "")
            fi
        fi
    fi
    
    # Dapatkan info jsholat-bot
    local bot_info_raw
    bot_info_raw=$(get_jsholat_bot_status)
    local bot_status="stopped"
    local bot_pid=""
    local bot_running="0"
    
    case "$bot_info_raw" in
        running:*)
            bot_status="running"
            bot_pid="${bot_info_raw#running:}"
            bot_running="1"
            ;;
        *)
            bot_status="$bot_info_raw"
            ;;
    esac
    
    # Dapatkan konfigurasi telegram
    local bot_enabled=$(uci -q get jsholat.service.telegram_enabled || echo "1")
    local bot_token=$(uci -q get jsholat.service.telegram_bot_token || echo "")
    local bot_chat_id=$(uci -q get jsholat.service.telegram_chat_id || echo "")
    
    # Dapatkan info bot lainnya
    local bot_uptime="0"
    local bot_start_time="Unknown"
    local bot_memory="0"
    local bot_log_file="/var/log/jsholat/bot.log"
    
    if [ "$bot_running" = "1" ] && [ -n "$bot_pid" ]; then
        # Hitung uptime dari /proc
        if [ -d "/proc/$bot_pid" ]; then
            local start_time
            start_time=$(stat -c %Y "/proc/$bot_pid" 2>/dev/null)
            if [ -n "$start_time" ]; then
                local now
                now=$(date +%s)
                bot_uptime=$((now - start_time))
                bot_start_time=$(date -d "@$start_time" "+%Y-%m-%d %H:%M:%S" 2>/dev/null || echo "Unknown")
            fi
            
            # Dapatkan penggunaan memory
            if [ -f "/proc/$bot_pid/status" ]; then
                local memory_kb
                memory_kb=$(grep VmRSS "/proc/$bot_pid/status" 2>/dev/null | awk '{print $2}')
                if [ -n "$memory_kb" ]; then
                    bot_memory=$((memory_kb / 1024))
                fi
            fi
        fi
    fi
    
    # Cek apakah bot configured (punya token dan chat ID)
    local bot_configured="0"
    if [ -n "$bot_token" ] && [ -n "$bot_chat_id" ]; then
        bot_configured="1"
    fi
    
    # Cek log file bot
    local bot_log_size="0"
    local bot_log_lines="0"
    if [ -f "$bot_log_file" ]; then
        bot_log_size=$(du -h "$bot_log_file" 2>/dev/null | awk '{print $1}' || echo "0")
        bot_log_lines=$(wc -l < "$bot_log_file" 2>/dev/null || echo "0")
    fi
    
    # Dapatkan variabel lain yang dibutuhkan
    local NOW=$(date +"%H:%M")
    local system_uptime="0"
    if [ -f "/proc/uptime" ]; then
        system_uptime=$(awk '{print int($1)}' /proc/uptime 2>/dev/null || echo "0")
    fi
    
    # Dapatkan log info jsholat
    local log_size="0"
    local log_lines="0"
    if [ -f "/var/log/jsholat/service.log" ]; then
        log_size=$(du -h "/var/log/jsholat/service.log" 2>/dev/null | awk '{print $1}' || echo "0")
        log_lines=$(wc -l < "/var/log/jsholat/service.log" 2>/dev/null || echo "0")
    fi
    
    # Dapatkan informasi file audio
    local adzan_file=$(uci -q get jsholat.sound.sound_adzan || echo "")
    local adzan_subuh_file=$(uci -q get jsholat.sound.sound_adzan_shubuh || echo "")
    local imsyak_file=$(uci -q get jsholat.sound.sound_adzan_imsy || echo "")
    local in_reminder_file="/usr/share/jsholat/sounds/in_reminder.mp3"
    local out_reminder_file="/usr/share/jsholat/sounds/out_reminder.mp3"
    
    # Cek keberadaan file audio
    local adzan_exists="false"
    local adzan_subuh_exists="false"
    local imsyak_exists="false"
    local in_reminder_exists="false"
    local out_reminder_exists="false"
    
    [ -f "$adzan_file" ] && adzan_exists="true"
    [ -f "$adzan_subuh_file" ] && adzan_subuh_exists="true"
    [ -f "$imsyak_file" ] && imsyak_exists="true"
    [ -f "$in_reminder_file" ] && in_reminder_exists="true"
    [ -f "$out_reminder_file" ] && out_reminder_exists="true"
    
    # Dapatkan informasi memori sistem
    local memory_human=$(get_system_memory_info 2>/dev/null)
    memory_human=$(echo "$memory_human" | sed 's/"/\\"/g; s/\\/\\\\/g')
    
    local memory_total_kb=0
    local memory_used_kb=0
    local memory_available_kb=0
    local memory_used_percent=0
    local memory_total_mb=0
    local memory_used_mb=0
    local memory_available_mb=0
    
    if [ -f "/proc/meminfo" ]; then
        memory_total_kb=$(grep -E '^MemTotal:' /proc/meminfo 2>/dev/null | awk '{print $2}')
        memory_available_kb=$(grep -E '^MemAvailable:' /proc/meminfo 2>/dev/null | awk '{print $2}')
        
        if [ -n "$memory_total_kb" ] && [ -n "$memory_available_kb" ]; then
            memory_used_kb=$((memory_total_kb - memory_available_kb))
            memory_total_mb=$((memory_total_kb / 1024))
            memory_used_mb=$((memory_used_kb / 1024))
            memory_available_mb=$((memory_available_kb / 1024))
            
            if [ "$memory_total_kb" -gt 0 ]; then
                memory_used_percent=$(( (memory_used_kb * 100) / memory_total_kb ))
            fi
        fi
    fi
    
    # Escape karakter khusus dalam string untuk JSON
    escaped_city=$(echo "$city" | sed 's/"/\\"/g; s/\\/\\\\/g')
    escaped_province=$(echo "$province" | sed 's/"/\\"/g; s/\\/\\\\/g')
    escaped_next_prayer=$(echo "$next_prayer" | sed 's/"/\\"/g; s/\\/\\\\/g')
    escaped_hijri_date=$(echo "$HIJRI_DATE" | sed 's/"/\\"/g; s/\\/\\\\/g')
    escaped_day_name=$(echo "$DAY_NAME" | sed 's/"/\\"/g; s/\\/\\\\/g')
    escaped_full_gregorian=$(echo "$FULL_GREGORIAN_DATE" | sed 's/"/\\"/g; s/\\/\\\\/g')
    escaped_timezone=$(echo "$timezone" | sed 's/"/\\"/g; s/\\/\\\\/g')
    escaped_schedule_file=$(echo "$schedule_file" | sed 's/"/\\"/g; s/\\/\\\\/g')
    
    # Escape untuk string tarhim
    escaped_tarhim_file=$(echo "$tarhim_file" | sed 's/"/\\"/g; s/\\/\\\\/g')
    
    # Buat output JSON secara manual dengan tambahan informasi tarhim, gemini, edge
    cat <<EOF
{
    "service": {
        "name": "jsholat",
        "version": "1.7.9",
        "description": "Jadwal Sholat dan Pemutar Adzan Otomatis",
        "enabled": $service_enabled,
        "running": $service_running,
        "pid": ${pid:-0},
        "uptime": $uptime_seconds,
        "uptime_human": "$(format_seconds $uptime_seconds)",
        "start_time": "$start_time_str",
        "log_file": "/var/log/jsholat/service.log",
        "log_size": "$log_size",
        "log_lines": $log_lines
    },
    "bot": {
        "name": "jsholat-bot",
        "version": "2.7",
        "enabled": $bot_enabled,
        "running": $bot_running,
        "configured": $bot_configured,
        "pid": ${bot_pid:-0},
        "uptime": $bot_uptime,
        "uptime_human": "$(format_seconds $bot_uptime)",
        "start_time": "$bot_start_time",
        "memory_mb": $bot_memory,
        "log_file": "$bot_log_file",
        "log_size": "$bot_log_size",
        "log_lines": $bot_log_lines
    },
    "config": {
        "telegram": {
            "enabled": $telegram_enabled,
            "configured": $bot_configured,
            "has_token": $([ -n "$bot_token" ] && echo "true" || echo "false"),
            "has_chat_id": $([ -n "$bot_chat_id" ] && echo "true" || echo "false")
        },
        "sound": {
            "enabled": $sound_enabled,
            "volume_control": "$volume_control",
            "volume_level": $volume_level,
            "mixer_device": "$mixer_device",
            "adzan_file": "$adzan_file",
            "adzan_subuh_file": "$adzan_subuh_file",
            "imsyak_file": "$imsyak_file",
            "adzan_exists": $adzan_exists,
            "adzan_subuh_exists": $adzan_subuh_exists,
            "imsyak_exists": $imsyak_exists
        },
        "reminder": {
            "enabled": $reminder_enabled,
            "minutes_before": $reminder_before,
            "sound_enabled": $reminder_sound_enabled,
            "tts_method": "$tts_method",
            "repeat_count": $reminder_repeat_count,
            "repeat_interval": $reminder_repeat_interval,
            "murf_configured": $([ -n "$murf_api_key" ] && echo "true" || echo "false"),
            "gemini_configured": $([ -n "$gemini_api_key" ] && echo "true" || echo "false"),
            "gemini_model": "$gemini_model",
            "gemini_voice": "$gemini_voice",
            "edge_configured": $(command -v edge-tts >/dev/null 2>&1 && echo "true" || echo "false"),
            "edge_voice": "$edge_voice",
            "in_reminder_exists": $in_reminder_exists,
            "out_reminder_exists": $out_reminder_exists
        },
        "tarhim": {
            "enabled": $tarhim_enabled,
            "mode": "$tarhim_mode",
            "file": "$escaped_tarhim_file",
            "file_exists": $([ -f "$tarhim_file" ] && echo "true" || echo "false"),
            "tts_imsyak_behavior": "$tts_imsyak_behavior",
            "is_ramadhan_now": $is_ramadhan_now,
            "description": $(if [ "$tarhim_enabled" = "1" ]; then
                if [ "$tarhim_mode" = "always" ]; then
                    echo "\"Tarhim selalu diputar setiap hari (termasuk TTS reminder)\""
                else
                    if [ "$is_ramadhan_now" = "1" ]; then
                        echo "\"Tarhim diputar, TTS reminder AKTIF (sedang Ramadhan)\""
                    else
                        echo "\"Tarhim diputar, TTS reminder NONAKTIF (bukan Ramadhan)\""
                    fi
                fi
            else
                echo "\"Tarhim nonaktif, notifikasi Telegram tetap berjalan\""
            fi)
        },
        "ayat": {
            "enabled": $ayat_enabled
        },
        "debug": {
            "enabled": $debug_mode
        }
    },
    "location": {
        "city": "$escaped_city",
        "province": "$escaped_province",
        "latitude": "$latitude",
        "longitude": "$longitude",
        "timezone": "$escaped_timezone",
        "hijri_adjustment": $hijri_adj
    },
    "schedule": {
        "date": {
            "gregorian": "$TODAY",
            "gregorian_full": "$escaped_full_gregorian",
            "hijri": "$escaped_hijri_date",
            "day_name": "$escaped_day_name"
        },
        "source": {
            "id": "$schedule_source",
            "name": "$source_alias"
        },
        "file": {
            "path": "$escaped_schedule_file",
            "format": "$SCHEDULE_FORMAT",
            "valid": $SCHEDULE_VALID,
            "last_updated": "$last_updated"
        },
        "times": {
            "imsyak": "${IMSYAK:-}",
            "subuh": "${SHUBUH:-}",
            "dzuhur": "${DZUHUR:-}",
            "ashar": "${ASHAR:-}",
            "maghrib": "${MAGHRIB:-}",
            "isya": "${ISYA:-}"
        }
    },
    "next_prayer": {
        "name": "$escaped_next_prayer",
        "time": "${next_prayer_time:-}",
        "minutes_left": $minutes_to_next,
        "minutes_left_human": "$(format_minutes $minutes_to_next)",
        "timestamp": "${next_prayer_timestamp:-}"
    },
    "system": {
        "current_time": "$NOW",
        "current_datetime": "$(date '+%Y-%m-%d %H:%M:%S')",
        "uptime": $system_uptime,
        "uptime_human": "$(format_seconds $system_uptime)",
        "hostname": "$(cat /proc/sys/kernel/hostname 2>/dev/null || echo 'unknown')",
        "kernel": "$(uname -r 2>/dev/null || echo 'unknown')",
        "architecture": "$(uname -m 2>/dev/null || echo 'unknown')",
        "memory": {
            "total_kb": $memory_total_kb,
            "total_mb": $memory_total_mb,
            "used_kb": $memory_used_kb,
            "used_mb": $memory_used_mb,
            "available_kb": $memory_available_kb,
            "available_mb": $memory_available_mb,
            "used_percent": $memory_used_percent,
            "human_readable": "$memory_human"
        },
        "load_average": {
            "1min": "$(awk '{print $1}' /proc/loadavg 2>/dev/null || echo '0.00')",
            "5min": "$(awk '{print $2}' /proc/loadavg 2>/dev/null || echo '0.00')",
            "15min": "$(awk '{print $3}' /proc/loadavg 2>/dev/null || echo '0.00')"
        }
    },
    "status": {
        "timestamp": "$(date '+%Y-%m-%d %H:%M:%S')",
        "healthy": $service_running
    }
}
EOF
}

# Fungsi helper untuk format detik ke human readable
format_seconds() {
    local seconds=$1
    local days=$((seconds / 86400))
    local hours=$(( (seconds % 86400) / 3600 ))
    local minutes=$(( (seconds % 3600) / 60 ))
    local secs=$((seconds % 60))
    
    local result=""
    [ $days -gt 0 ] && result="${days} hari"
    [ $hours -gt 0 ] && result="${result} ${hours} jam"
    [ $minutes -gt 0 ] && result="${result} ${minutes} menit"
    [ $secs -gt 0 ] && [ $days -eq 0 ] && [ $hours -eq 0 ] && result="${result} ${secs} detik"
    
    [ -z "$result" ] && result="0 detik"
    echo "$result" | sed 's/^[[:space:]]*//'
}

# Fungsi helper untuk format menit ke human readable (sudah ada sebelumnya)
format_minutes() {
    local minutes=$1
    if [ $minutes -ge 60 ]; then
        local hours=$((minutes / 60))
        local mins=$((minutes % 60))
        echo "${hours} jam ${mins} menit"
    else
        echo "${minutes} menit"
    fi
}

# Fungsi konversi waktu ke detik yang lebih aman
time_to_seconds() {
    local time_str="$1"
    
    # Handle empty input
    if [ -z "$time_str" ]; then
        [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "⚠️ time_to_seconds: input kosong"
        echo "0"
        return 1
    fi
    
    # BUANG karakter JSON yang mungkin nyangkut
    time_str=$(echo "$time_str" | sed 's/[{}",]//g' | tr -d '\n\r' | xargs)
    
    # CASE 1: Format HH:MM (04:30)
    if echo "$time_str" | grep -qE '^[0-9]{1,2}:[0-9]{2}$'; then
        local hours=${time_str%:*}
        local minutes=${time_str#*:}
        hours=${hours#0}
        minutes=${minutes#0}
        [ -z "$hours" ] && hours=0
        [ -z "$minutes" ] && minutes=0
        
        if [ "$hours" -ge 0 ] && [ "$hours" -le 23 ] && [ "$minutes" -ge 0 ] && [ "$minutes" -le 59 ]; then
            echo $((hours * 3600 + minutes * 60))
            return 0
        fi
    fi
    
    # CASE 2: Format HH:MM:SS (04:30:00)
    if echo "$time_str" | grep -qE '^[0-9]{1,2}:[0-9]{2}:[0-9]{2}$'; then
        local hours=$(echo "$time_str" | cut -d: -f1)
        local minutes=$(echo "$time_str" | cut -d: -f2)
        local seconds=$(echo "$time_str" | cut -d: -f3)
        hours=${hours#0}
        minutes=${minutes#0}
        seconds=${seconds#0}
        [ -z "$hours" ] && hours=0
        [ -z "$minutes" ] && minutes=0
        [ -z "$seconds" ] && seconds=0
        echo $((hours * 3600 + minutes * 60 + seconds))
        return 0
    fi
    
    # CASE 3: Format HHMM (0430) - tanpa titik dua
    if echo "$time_str" | grep -qE '^[0-9]{3,4}$'; then
        if [ ${#time_str} -eq 3 ]; then
            time_str="0${time_str}"
        fi
        local hours=${time_str:0:2}
        local minutes=${time_str:2:2}
        hours=${hours#0}
        minutes=${minutes#0}
        [ -z "$hours" ] && hours=0
        [ -z "$minutes" ] && minutes=0
        log "DEBUG" "⏱️ Auto-format waktu: '$1' -> '${hours}:${minutes}'"
        echo $((hours * 3600 + minutes * 60))
        return 0
    fi
    
    # CASE 4: String JSON atau format invalid
    if [[ "$time_str" == *"gregorian_date"* ]] || [[ "$time_str" == *"imsyak"* ]] || [[ "$time_str" == *":"* ]]; then
        # Coba ekstrak pola waktu HH:MM dari string
        local extracted=$(echo "$time_str" | grep -oE '[0-9]{1,2}:[0-9]{2}' | head -1)
        if [ -n "$extracted" ]; then
            log "WARNING" "⚠️ Ekstrak waktu dari string JSON: '$time_str' -> '$extracted'"
            time_to_seconds "$extracted"
            return $?
        fi
    fi
    
    # Jika semua format gagal
    log "ERROR" "❌ Format waktu tidak dapat diproses: '$time_str' (dari input: '$1')"
    echo "0"
    return 1
}

# Fungsi fleksibel nama sholat jum'at
get_salat_name() {
    local name="$1"
    local day=$(date +%u)
    
    # Ganti "Dzuhur" menjadi "Jumat" saat hari Jumat
    if [ "$name" = "Dzuhur" ] && [ "$day" -eq 5 ]; then
        echo "Jumat"
    else
        echo "$name"
    fi
}

# Fungsi bot telegram
send_telegram() {
    local telegram_enabled=$(uci -q get jsholat.service.telegram_enabled || echo "1")
    if [ "$telegram_enabled" = "0" ]; then
        log "INFO" "🔕 Notifikasi Telegram dinonaktifkan"
		[ "$DEBUG_MODE" = "1" ] && log "DEBUG" "🔕 Notifikasi Telegram dinonaktifkan"
        return
    fi

    local message="$1"
    local telegram_token=$(uci get jsholat.service.telegram_bot_token 2>/dev/null)
    local chat_id=$(uci get jsholat.service.telegram_chat_id 2>/dev/null)
    
    if [ -z "$telegram_token" ] || [ -z "$chat_id" ]; then
        log "ERROR" "❌ Telegram token/chat ID belum diatur!"
        return
    fi

    curl -s --connect-timeout 10 --max-time 15 -X POST \
        "https://api.telegram.org/bot${telegram_token}/sendMessage" \
        -d chat_id="${chat_id}" \
        -d text="${message}" \
        -d parse_mode="Markdown" \
        > /dev/null 2>&1
        
    if [ $? -ne 0 ]; then
        log "ERROR" "❌ Gagal mengirim notifikasi Telegram"
    else
        log "INFO" "📢 Notifikasi Telegram terkirim"
    fi
}

# Fungsi untuk mendapatkan ayat acak dari API myquran
get_random_ayat() {
    local api_url="https://api.myquran.com/v2/quran/ayat/acak"
    local response=$(curl -s "$api_url")

    [ -z "$response" ] && { log "ERROR" "Gagal mengambil ayat acak"; echo ""; return 1; }

    local surah_name=$(echo "$response" | jq -r '.data.info.surat.nama.id')
    local ayat_number=$(echo "$response" | jq -r '.data.ayat.ayah')
    local ayat_text=$(echo "$response" | jq -r '.data.ayat.text')
    local ayat_arab=$(echo "$response" | jq -r '.data.ayat.arab')
    local ayat_latin=$(echo "$response" | jq -r '.data.ayat.latin')
    local ayat_notes=$(echo "$response" | jq -r '.data.ayat.notes')

    # Format pesan dengan Markdown
    local formatted_ayat="
*📖 QS ${surah_name}:${ayat_number}*

\`${ayat_arab}\`

*${ayat_latin}*

*Artinya:* \"${ayat_text}\""

    # Tambahkan catatan jika ada
    if [ -n "$ayat_notes" ] && [ "$ayat_notes" != "null" ]; then
        formatted_ayat+="

📝 _${ayat_notes}_"
    fi

    # Return teks 
    echo "${formatted_ayat}"
    return 0
}

# Fungsi untuk memutar audio ayat
play_audio_ayat() {
    local audio_url="$1"
    local ayat_enabled=$(uci -q get jsholat.service.ayat_enabled || echo "1")
    local sound_enabled=$(uci -q get jsholat.service.sound_enabled || echo "1")
    
    # Cek status fitur
    if [ "$ayat_enabled" = "0" ] || [ "$sound_enabled" = "0" ]; then
        log "INFO" "🔇 Audio ayat dinonaktifkan"
        [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "🔇 Audio ayat dinonaktifkan (ayat_enabled=$ayat_enabled, sound_enabled=$sound_enabled)"
        return
    fi

    [ -z "$audio_url" ] && { log "ERROR" "URL audio ayat kosong"; return 1; }

    # Gunakan pengaturan volume adzan
    local volume_control=$(uci -q get jsholat.sound.volume_control || echo "hardware")
    local volume_level=$(uci -q get jsholat.sound.volume_level || echo "80")
    local mixer_device=$(uci -q get jsholat.sound.mixer_device || echo "Speaker")

    # Set volume sesuai setting adzan
    if [ "$volume_control" = "hardware" ]; then
        amixer -q set "$mixer_device" ${volume_level}% >/dev/null 2>&1 || 
        log "ERROR" "❌ Gagal set volume hardware"
    fi

    log "INFO" "🔊 Memutar audio ayat (Mengikuti volume adzan: $volume_level%)"

    # Pemutaran audio dengan manajemen resource
    local temp_audio=$(mktemp "/tmp/ayat_audio_$(date +%s).mp3")
    if wget -q -O "$temp_audio" "$audio_url"; then
        (
            timeout 30 madplay "$temp_audio" >/dev/null 2>&1  # Batasi 30 detik
            rm -f "$temp_audio"
            [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "✅ Audio ayat selesai"
        ) & # Jalankan di background
    else
        log "ERROR" "❌ Gagal download audio ayat"
        rm -f "$temp_audio"
    fi
}

# Fungsi Pemutar Adzan dengan Fallback
play_adzan() {
    if [ $# -lt 3 ]; then
        log "ERROR" "Parameter kurang untuk play_adzan: file_path=$1, salat_name=$2, prayer_time=$3"
        return 1
    fi

    local file_path="$1"
    local salat_name="$2"
    local prayer_time="$3"
    local timezone=$(uci -q get jsholat.schedule.timezone_value || echo "") 
    local timezone_display=""
    [ -n "$timezone" ] && timezone_display=" $timezone"
    local LOKASI=$(uci get jsholat.schedule.city_label 2>/dev/null || echo "Wilayah Tidak Diketahui")
    
    # ========== KONTROL TARHIM IMSYAK ==========
    # 🔧 Baca tarhim_enabled dan tarhim_mode
    local tarhim_enabled=$(uci -q get jsholat.sound.tarhim_enabled || echo "0")
    local tarhim_mode=$(uci -q get jsholat.sound.tarhim_mode || echo "ramadhan_only")
    local sound_enabled=$(uci -q get jsholat.sound.sound_enabled || echo "1")
    local telegram_enabled=$(uci -q get jsholat.service.telegram_enabled || echo "1")
    
    # ===== KHUSUS IMSYAK =====
    if [ "$salat_name" = "Imsyak" ]; then
        # 📋 LOG IMSYAK - INFORMASI LENGKAP
        log "INFO" "═══════════════════════════════════════════"
        log "INFO" "🕌 IMSYAK - PROSES DIMULAI"
        log "INFO" "   • Waktu Imsyak : $prayer_time$timezone_display"
        log "INFO" "   • Lokasi       : $LOKASI"
        log "INFO" "   • File Audio   : $file_path"
        log "INFO" "═══════════════════════════════════════════"
        
        # 🔍 DEBUG LOG - KONFIGURASI TARHIM
        [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "🔧 KONFIGURASI IMSYAK:"
        [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "   • tarhim_enabled : $tarhim_enabled"
        [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "   • tarhim_mode    : $tarhim_mode"
        [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "   • sound_enabled  : $sound_enabled"
        [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "   • telegram_enabled: $telegram_enabled"
        
        # 🌙 CEK STATUS RAMADHAN
        if is_ramadhan; then
            local hijri_date=$(get_hijri_date)
            log "INFO" "🌙 STATUS RAMADHAN: SAAT INI BULAN RAMADHAN"
            [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "   • Tanggal Hijriyah: $hijri_date"
        else
            log "INFO" "📅 STATUS RAMADHAN: BUKAN BULAN RAMADHAN"
        fi
        
        # 🔧 CEK APAKAH TARHIM ENABLED
        if [ "$tarhim_enabled" = "0" ]; then
            log "INFO" "🔇 Tarhim Imsyak dinonaktifkan (tarhim_enabled=0)"
            
            # 🔔 TETAP KIRIM NOTIFIKASI TELEGRAM IMSYAK MESKIPUN TARHIM MATI
            if [ "$telegram_enabled" = "1" ]; then
                log "INFO" "📤 Mengirim notifikasi Imsyak (tarhim disabled)"
                (
                    if is_ramadhan; then
                        send_telegram "🌙 *SAATNYA WAKTU IMSYAK*

Di bulan Ramadhan yang mulia ini, marilah kita persiapkan diri.

⏰ *Imsyak*: $prayer_time$timezone_display
📍 Untuk Wilayah: *$LOKASI* dan sekitarnya.

*Semoga Allah menerima amal ibadah kita* 🤲"
                        [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "📤 Notifikasi Imsyak Ramadhan dikirim (tarhim off)"
                    else
                        send_telegram "🕌 *WAKTU IMSYAK*

⏰ *Imsyak*: $prayer_time$timezone_display
📍 Untuk Wilayah: *$LOKASI* dan sekitarnya.

*Siapkan diri untuk sholat Subuh*
*Jangan lupa wudhu* 💧"
                        [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "📤 Notifikasi Imsyak biasa dikirim (tarhim off)"
                    fi
                ) &
            fi
            return 0
        fi
        
        # 🔧 PROSES TARHIM BERDASARKAN MODE
        case "$tarhim_mode" in
            "always")
                # 🔧 MODE A: Selalu putar tarhim setiap hari
                log "INFO" "🔊 MODE TARHIM: SELALU DIPUTAR (setiap hari)"
                
                # Kirim notifikasi telegram DI BACKGROUND
                if [ "$telegram_enabled" = "1" ]; then
                    log "INFO" "📤 Mengirim notifikasi Imsyak - Mode Harian"
                    (
                        if is_ramadhan; then
                            send_telegram "🌙 *SAATNYA WAKTU IMSYAK*

⏰ *Imsyak*: $prayer_time$timezone_display
📍 Untuk Wilayah: *$LOKASI* dan sekitarnya.

*Semoga Allah menerima amal ibadah kita* 🤲"
                            [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "📤 Notifikasi Imsyak Ramadhan - Mode Harian"
                        else
                            send_telegram "🕌 *WAKTU IMSYAK*

⏰ *Imsyak*: $prayer_time$timezone_display
📍 Untuk Wilayah: *$LOKASI* dan sekitarnya.

*Siapkan diri untuk sholat Subuh*
*Jangan lupa wudhu* 💧"
                            [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "📤 Notifikasi Imsyak biasa - Mode Harian"
                        fi
                    ) &
                fi
                
                # Putar audio setelah notifikasi dikirim di background
                if [ "$sound_enabled" = "1" ]; then
                    log "INFO" "🔊 Memutar Tarhim Imsyak (mode: HARIAN)"
                    play_audio_file "$file_path" "Tarhim Imsyak Harian"
                else
                    log "INFO" "🔇 Suara Tarhim Imsyak dinonaktifkan (sound_enabled=0)"
                fi
                ;;
                
            "ramadhan_only")
                # 🔧 MODE B: Tarhim selalu diputar, TTS reminder hanya Ramadhan
                log "INFO" "🔊 MODE TARHIM: RAMADHAN_ONLY (tarhim selalu diputar)"
                
                # Kirim notifikasi dengan pesan sesuai kondisi
                if [ "$telegram_enabled" = "1" ]; then
                    (
                        if is_ramadhan; then
                            send_telegram "🌙 *SAATNYA WAKTU IMSYAK*

Di bulan Ramadhan ${hijri_year} yang mulia ini, marilah kita persiapkan diri.

⏰ *Imsyak*: $prayer_time$timezone_display
📍 Untuk Wilayah: *$LOKASI* dan sekitarnya.

*Semoga Allah menerima amal ibadah kita* 🤲"
                            [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "📤 Notifikasi Imsyak Ramadhan - Mode Ramadhan Only"
                        else
                            send_telegram "🕌 *WAKTU IMSYAK*

⏰ *Imsyak*: $prayer_time$timezone_display
📍 Untuk Wilayah: *$LOKASI* dan sekitarnya.

*Siapkan diri untuk sholat Subuh*
*Jangan lupa wudhu* 💧"
                            [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "📤 Notifikasi Imsyak biasa - Mode Ramadhan Only"
                        fi
                    ) &
                fi
                
                # ✅ TARHIM TETAP DIPUTAR BAIK RAMADHAN MAUPUN TIDAK
                if [ "$sound_enabled" = "1" ]; then
                    if is_ramadhan; then
                        log "INFO" "🔊 Memutar Tarhim Imsyak Ramadhan"
                        play_audio_file "$file_path" "Tarhim Imsyak Ramadhan"
                    else
                        log "INFO" "🔊 Memutar Tarhim Imsyak (non-Ramadhan)"
                        play_audio_file "$file_path" "Tarhim Imsyak Non-Ramadhan"
                    fi
                else
                    log "INFO" "🔇 Suara Tarhim Imsyak dinonaktifkan (sound_enabled=0)"
                fi
                ;;
                
            *)
                # Fallback ke ramadhan_only dengan perilaku baru
                log "WARNING" "⚠️ Mode tarhim tidak dikenal: '$tarhim_mode', menggunakan default ramadhan_only dengan tarhim selalu diputar"
                
                # Kirim notifikasi
                if [ "$telegram_enabled" = "1" ]; then
                    (
                        if is_ramadhan; then
                            send_telegram "🌙 *SAATNYA WAKTU IMSYAK*

⏰ *Imsyak*: $prayer_time$timezone_display
📍 Untuk Wilayah: *$LOKASI* dan sekitarnya.

*Semoga Allah menerima amal ibadah kita* 🤲"
                        else
                            send_telegram "🕌 *WAKTU IMSYAK*

⏰ *Imsyak*: $prayer_time$timezone_display
📍 Untuk Wilayah: *$LOKASI* dan sekitarnya.

*Siapkan diri untuk sholat Subuh*
*Jangan lupa wudhu* 💧"
                        fi
                    ) &
                fi
                
                # ✅ TARHIM TETAP DIPUTAR (fallback)
                if [ "$sound_enabled" = "1" ]; then
                    if is_ramadhan; then
                        play_audio_file "$file_path" "Tarhim Imsyak Ramadhan (fallback)"
                    else
                        play_audio_file "$file_path" "Tarhim Imsyak Non-Ramadhan (fallback)"
                    fi
                fi
                ;;
        esac
        
        # 📋 LOG IMSYAK - SELESAI
        log "INFO" "✅ IMSYAK - PROSES SELESAI"
        
    else
        # ===== SHOLAT WAJIB (Subuh, Dzuhur, Ashar, Maghrib, Isya) =====
        # (kode untuk sholat wajib tetap sama seperti aslinya)
        # Cek apakah pemutar suara secara umum aktif
        if [ "$sound_enabled" = "0" ]; then
            log "INFO" "🔇 Pemutaran suara dinonaktifkan untuk $salat_name"
            
            # Tetap kirim notifikasi telegram jika diaktifkan, meskipun suara mati
            if [ "$telegram_enabled" = "1" ]; then
                log "INFO" "📤 Mengirim notifikasi $salat_name (sound disabled)"
                (
                    send_telegram "🕌 *SAATNYA WAKTU SHOLAT ${salat_name}*

⏰ *$salat_name*: $prayer_time$timezone_display
📍 Untuk Wilayah: *$LOKASI* dan sekitarnya.

Selamat menunaikan sholat *$salat_name*.
*Semoga Allah menerima ibadah kita* 🤲"
                ) &
                [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "📤 Notifikasi Telegram ${salat_name} dikirim (sound disabled)"
            fi
            return 0
        fi
        
        log "INFO" "🔊 Memutar adzan $salat_name pada pukul $prayer_time$timezone_display"
        
        # ✅ KIRIM NOTIFIKASI TELEGRAM DI BACKGROUND
        if [ "$telegram_enabled" = "1" ]; then
            log "INFO" "📤 Mengirim notifikasi $salat_name"
            (
                send_telegram "🕌 *SAATNYA WAKTU SHOLAT ${salat_name}*

⏰ *$salat_name*: $prayer_time$timezone_display
📍 Untuk Wilayah: *$LOKASI* dan sekitarnya.

Selamat menunaikan sholat *$salat_name*.
*Semoga Allah menerima ibadah kita* 🤲"
            ) &
            [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "📤 Notifikasi Telegram ${salat_name} dikirim di background"
        fi
        
        # ✅ PUTAR AUDIO
        play_audio_file "$file_path" "Adzan $salat_name"
    fi

    log "INFO" "✅ Selesai memainkan adzan untuk $salat_name"
}

# Fungsi untuk mengecek koneksi internet
check_internet_connection() {
    local timeout=5
    local max_attempts=2
    
    # Coba beberapa metode cek
    for attempt in $(seq 1 $max_attempts); do
        # Coba ping ke DNS Google
        if ping -c 1 -W $timeout 8.8.8.8 >/dev/null 2>&1; then
            log "DEBUG" "✅ Koneksi internet tersedia (ping 8.8.8.8)"
            return 0
        fi
        
        # Coba ping ke Cloudflare
        if ping -c 1 -W $timeout 1.1.1.1 >/dev/null 2>&1; then
            log "DEBUG" "✅ Koneksi internet tersedia (ping 1.1.1.1)"
            return 0
        fi
        
        # Coba curl ke website sederhana
        if curl -s --connect-timeout $timeout http://captive.apple.com >/dev/null 2>&1; then
            log "DEBUG" "✅ Koneksi internet tersedia (curl)"
            return 0
        fi
        
        [ $attempt -lt $max_attempts ] && sleep 1
    done
    
    log "WARNING" "⚠️ Tidak ada koneksi internet terdeteksi"
    return 1
}

# ----------------------------------------------------------------------
# GLOBAL VARIABLES UNTUK FALLBACK UNTUK TTS
# ----------------------------------------------------------------------

declare -a GLOBAL_FAILED_METHODS=()
GLOBAL_FAILED_METHODS_CACHE="/tmp/jsholat_cache/jsholat_failed_methods.cache"

# FUNGSI TTS FALLBACK BIDIRECTIONAL 
# Skor kualitas suara untuk prioritas fallback
# Skor prioritas (semakin tinggi, semakin diprioritaskan)
declare -A TTS_PRIORITY=(
    ["gemini"]=100  # Premium AI voice (butuh API key)
    ["edge"]=90     # Natural neural voice (gratis, kualitas bagus)
    ["murf"]=80     # Premium AI voice (butuh API key berbayar)
    ["google"]=60   # Standard TTS (gratis, selalu tersedia)
    ["espeak"]=30   # Robotik voice (offline, last resort)
)

# ----------------------------------------------------------------------
# FUNGSI MANAJEMEN GLOBAL FAILED METHODS TTS
# ----------------------------------------------------------------------

# Fungsi untuk load failed methods dari cache
load_global_failed_methods() {
    if [ -f "$GLOBAL_FAILED_METHODS_CACHE" ]; then
        local cache_date=$(head -1 "$GLOBAL_FAILED_METHODS_CACHE" 2>/dev/null)
        local today=$(date +"%Y-%m-%d")
        
        if [ "$cache_date" = "$today" ]; then
            # Load failed methods dari baris 2 dst
            mapfile -t GLOBAL_FAILED_METHODS < <(tail -n +2 "$GLOBAL_FAILED_METHODS_CACHE" 2>/dev/null)
            [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "📂 Load failed methods: ${GLOBAL_FAILED_METHODS[*]}"
        else
            # Cache expired, reset
            GLOBAL_FAILED_METHODS=()
            echo "$today" > "$GLOBAL_FAILED_METHODS_CACHE"
            [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "🆕 Reset failed methods cache untuk hari baru"
        fi
    else
        # Buat cache baru
        mkdir -p "$(dirname "$GLOBAL_FAILED_METHODS_CACHE")"
        echo "$(date +"%Y-%m-%d")" > "$GLOBAL_FAILED_METHODS_CACHE"
        [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "🆕 Inisialisasi failed methods cache"
    fi
}

# Fungsi untuk save failed methods
save_global_failed_methods() {
    local today=$(date +"%Y-%m-%d")
    {
        echo "$today"
        printf "%s\n" "${GLOBAL_FAILED_METHODS[@]}"
    } > "$GLOBAL_FAILED_METHODS_CACHE"
}

# Fungsi untuk menambah failed method
add_global_failed_method() {
    local method="$1"
    # Cek apakah sudah ada
    for m in "${GLOBAL_FAILED_METHODS[@]}"; do
        if [ "$m" = "$method" ]; then
            return
        fi
    done
    GLOBAL_FAILED_METHODS+=("$method")
    save_global_failed_methods
    [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "➕ Tambah $method ke global failed methods"
}

# Fungsi untuk reset global failed methods (dipanggil setiap hari baru)
reset_global_failed_methods() {
    GLOBAL_FAILED_METHODS=()
    echo "$(date +"%Y-%m-%d")" > "$GLOBAL_FAILED_METHODS_CACHE"
    [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "🔄 Reset global failed methods untuk hari baru"
}

# =============================================
# FUNGSI MENDAPATKAN METODE TTS YANG TERSEDIA
# =============================================

# Fungsi untuk mendapatkan daftar metode TTS yang tersedia (dengan filter internet)
get_available_tts_methods() {
    local -a available_methods=()
    local -a available_scores=()
    
    # Cek koneksi internet SEKALI
    local has_internet=0
    if check_internet_connection; then
        has_internet=1
        [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "🌐 Koneksi internet tersedia"
    else
        [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "📵 Tidak ada koneksi internet"
    fi
    
    # GEMINI (online, butuh API key)
    if [ $has_internet -eq 1 ] && [ -n "$(uci -q get jsholat.sound.gemini_api_key)" ]; then
        available_methods+=("gemini")
        available_scores+=("${TTS_PRIORITY[gemini]}")
        [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "➕ Gemini tersedia (online, API key OK)"
    fi
    
    # EDGE (online, butuh instalasi)
    if [ $has_internet -eq 1 ] && command -v edge-tts >/dev/null 2>&1; then
        available_methods+=("edge")
        available_scores+=("${TTS_PRIORITY[edge]}")
        [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "➕ Edge-TTS tersedia (online, terinstal)"
    fi
    
    # MURF (online, butuh API key)
    if [ $has_internet -eq 1 ] && [ -n "$(uci -q get jsholat.sound.murf_api_key)" ]; then
        available_methods+=("murf")
        available_scores+=("${TTS_PRIORITY[murf]}")
        [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "➕ Murf tersedia (online, API key OK)"
    fi
    
    # GOOGLE (online, selalu tersedia jika ada internet)
    if [ $has_internet -eq 1 ]; then
        available_methods+=("google")
        available_scores+=("${TTS_PRIORITY[google]}")
        [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "➕ Google TTS tersedia (online)"
    fi
    
    # E-SPEAK (offline, selalu tersedia jika terinstal)
    if command -v espeak >/dev/null 2>&1 && command -v aplay >/dev/null 2>&1; then
        available_methods+=("espeak")
        available_scores+=("${TTS_PRIORITY[espeak]}")
        [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "➕ eSpeak tersedia (offline)"
    fi
    
    # Bubble sort untuk mengurutkan berdasarkan prioritas (descending)
    local n=${#available_methods[@]}
    for ((i = 0; i < n-1; i++)); do
        for ((j = 0; j < n-i-1; j++)); do
            if [ "${available_scores[$j]}" -lt "${available_scores[$((j+1))]}" ]; then
                # Swap methods
                local temp_method="${available_methods[$j]}"
                available_methods[$j]="${available_methods[$((j+1))]}"
                available_methods[$((j+1))]="$temp_method"
                
                # Swap scores
                local temp_score="${available_scores[$j]}"
                available_scores[$j]="${available_scores[$((j+1))]}"
                available_scores[$((j+1))]="$temp_score"
            fi
        done
    done
    
    [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "📋 Metode TTS setelah sorting: ${available_methods[*]}"
    echo "${available_methods[@]}"
}

# Fungsi untuk mendapatkan urutan fallback (dengan filter blacklist)
get_fallback_order() {
    local original_method="$1"
    local current_failed="${2:-}"
    local all_available=($(get_available_tts_methods))
    local -a fallback=()
    
    # Log semua metode yang tersedia
    [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "📋 Semua metode tersedia: ${all_available[*]}"
    
    # Filter kandidat:
    # 1. Bukan metode asal
    # 2. Tidak ada di global failed methods
    # 3. Tidak ada di current failed
    for method in "${all_available[@]}"; do
        # Skip metode asal
        [ "$method" = "$original_method" ] && continue
        
        # Skip jika sudah ada di global failed
        local found=0
        for failed in "${GLOBAL_FAILED_METHODS[@]}"; do
            if [ "$failed" = "$method" ]; then
                found=1
                break
            fi
        done
        [ $found -eq 1 ] && continue
        
        # Skip jika sudah ada di current failed
        if [[ "$current_failed" == *"$method"* ]]; then
            continue
        fi
        
        fallback+=("$method")
    done
    
    # Jika tidak ada fallback, setidaknya eSpeak
    if [ ${#fallback[@]} -eq 0 ]; then
        if command -v espeak >/dev/null 2>&1 && command -v aplay >/dev/null 2>&1; then
            fallback=("espeak")
            [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "⚠️ Tidak ada fallback, menggunakan eSpeak"
        fi
    fi
    
    # Log urutan fallback final
    [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "🔄 Urutan fallback FINAL dari $original_method: ${fallback[*]}"
    
    echo "${fallback[@]}"
}

# Fungsi try_tts_fallback dengan global tracking
try_tts_fallback() {
    local original_method="$1"
    local text="$2"
    local salat_name="$3"
    local prayer_time="$4"
    local lokasi="$5"
    local timezone="$6"
    local current_failed="${7:-}"
    
    log "INFO" "🔄 Mencoba fallback TTS untuk $salat_name (dari $original_method)"
    
    # Dapatkan urutan fallback berdasarkan ketersediaan dan blacklist
    local fallback_order=($(get_fallback_order "$original_method" "$current_failed"))
    
    if [ ${#fallback_order[@]} -eq 0 ]; then
        log "ERROR" "❌ Tidak ada kandidat fallback tersedia untuk $salat_name"
        return 1
    fi
    
    log "INFO" "📋 Urutan fallback: ${fallback_order[*]}"
    
    # Coba setiap metode fallback
    for method in "${fallback_order[@]}"; do
        log "INFO" "🔧 Mencoba fallback ke metode: $method"
        
        local success=1
        case "$method" in
            "gemini")
                play_gemini_tts_with_repeat "$text" "$salat_name" "$prayer_time" "$lokasi" "$timezone"
                success=$?
                ;;
            "edge")
                play_edge_tts_with_repeat "$text" "$salat_name" "$prayer_time" "$lokasi" "$timezone"
                success=$?
                ;;
            "google")
                play_google_tts_with_repeat "$text" "$salat_name" "$prayer_time" "$lokasi" "$timezone"
                success=$?
                ;;
            "espeak")
                play_espeak_tts_with_repeat "$text" "$salat_name" "$prayer_time" "$lokasi" "$timezone"
                success=$?
                ;;
            "murf")
                play_murf_tts_with_repeat "$text" "$salat_name" "$prayer_time" "$lokasi" "$timezone"
                success=$?
                ;;
        esac
        
        if [ $success -eq 0 ]; then
            log "INFO" "✅ Fallback ke $method berhasil untuk $salat_name"
            return 0
        else
            log "WARNING" "❌ Fallback ke $method gagal untuk $salat_name"
            # Tambahkan metode yang gagal ke global failed methods
            add_global_failed_method "$method"
            # Update current_failed untuk menghindari pengulangan
            current_failed="$current_failed,$method"
        fi
    done
    
    log "ERROR" "❌ Semua metode fallback gagal untuk $salat_name"
    return 1
}

# Fungsi debug priority values
debug_priority_values() {
    if [ "$DEBUG_MODE" = "1" ]; then
        log "DEBUG" "📊 TTS PRIORITY VALUES:"
        log "DEBUG" "  - gemini: ${TTS_PRIORITY[gemini]}"
        log "DEBUG" "  - edge: ${TTS_PRIORITY[edge]}"
        log "DEBUG" "  - murf: ${TTS_PRIORITY[murf]}"
        log "DEBUG" "  - google: ${TTS_PRIORITY[google]}"
        log "DEBUG" "  - espeak: ${TTS_PRIORITY[espeak]}"
    fi
}

# Fungsi untuk memutar suara reminder dari berbagai sumber TTS dengan pengulangan
play_tts_reminder() {
    local salat_name="$1"
    local prayer_time="$2"
    local reminder_mins="$3"
    local timezone="$4"
    local lokasi="$5"
    local provinsi="$6"         
    local custom_text="${7:-}"  
    
    # Cek apakah fitur suara reminder aktif
    local tts_enabled=$(uci -q get jsholat.sound.reminder_sound_enabled || echo "0")
    if [ "$tts_enabled" = "0" ]; then
        [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "🔇 Suara reminder dinonaktifkan untuk $salat_name"
        return
    fi
    
    # Cek apakah pemutar suara secara umum aktif
    local sound_enabled=$(uci -q get jsholat.sound.sound_enabled || echo "1")
    if [ "$sound_enabled" = "0" ]; then
        [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "🔇 Pemutar suara dinonaktifkan"
        return
    fi
    
    # Format waktu dan zona waktu untuk TTS
    local formatted_time=$(format_time_for_tts "$prayer_time")
    local formatted_timezone=$(format_timezone_for_tts "$timezone")
    
    # Ambil metode TTS yang dipilih dari konfigurasi
    local tts_method=$(uci -q get jsholat.sound.tts_method || echo "google")
    
    # KELOMPOKKAN METODE TTS
    local online_methods="google edge murf gemini"
    local need_internet=0
    
    # CEK APAKAH METODE YANG DIPILIH BUTUH INTERNET
    for method in $online_methods; do
        if [ "$method" = "$tts_method" ]; then
            need_internet=1
            break
        fi
    done
    
    # Buat teks untuk TTS berdasarkan waktu sholat dengan format yang benar
    local tts_text=""
    
	if [ -n "$custom_text" ]; then
		tts_text="$custom_text"
	else
		# FORMAT LOKASI DENGAN PENANGANAN PROVINSI KOSONG
		local lokasi_text="$lokasi"
		# Bersihkan provinsi dari spasi dan null
		provinsi=$(echo "$provinsi" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
		if [ -n "$provinsi" ] && [ "$provinsi" != " " ] && [ "$provinsi" != "null" ] && [ "$provinsi" != "None" ]; then
			lokasi_text="$lokasi, $provinsi"
		fi
		
		if [ "$salat_name" = "Imsyak" ]; then
			# Nuansa berbeda untuk Imsyak
			if is_ramadhan; then
				tts_text="Pengumuman. Sebentar lagi pada $formatted_time $formatted_timezone akan memasuki waktu imsyak di bulan Ramadhan yang mulia. Untuk wilayah $lokasi_text dan sekitarnya. Segera akhiri sahur dan persiapkan diri untuk sholat Subuh. Perbanyak doa di sisa malam ini. Semoga Allah menerima amal ibadah puasa kita."
			else
				tts_text="Pengumuman. Sebentar lagi pada $formatted_time $formatted_timezone akan memasuki waktu imsyak untuk wilayah $lokasi_text dan sekitarnya. Segera persiapkan diri."
			fi
		else
			# Nuansa berbeda untuk sholat wajib saat Ramadhan
			if is_ramadhan; then
				if [ "$salat_name" = "Maghrib" ]; then
					tts_text="Pengumuman. Sebentar lagi pada $formatted_time $formatted_timezone akan memasuki waktu Maghrib di bulan Ramadhan. Untuk wilayah $lokasi_text dan sekitarnya. Segera persiapkan diri untuk berbuka puasa. Jangan lupa berdoa sebelum berbuka. Semoga Allah menerima amal ibadah puasa kita."
				elif [ "$salat_name" = "Subuh" ]; then
					tts_text="Pengumuman. Sebentar lagi pada $formatted_time $formatted_timezone akan memasuki waktu sholat Subuh di bulan Ramadhan. Untuk wilayah $lokasi_text dan sekitarnya. Marilah kita dirikan sholat Subuh berjamaah. Semoga Allah menerima amal ibadah kita di bulan yang suci ini."
				else
					tts_text="Pengumuman. Sebentar lagi pada $formatted_time $formatted_timezone akan memasuki waktu sholat $salat_name di bulan Ramadhan. Untuk wilayah $lokasi_text dan sekitarnya. Segera persiapkan diri untuk menunaikan sholat. Semoga ibadah kita diterima Allah Subhanahu Wata'ala."
				fi
			else
				tts_text="Pengumuman. Sebentar lagi pada $formatted_time $formatted_timezone akan memasuki waktu sholat $salat_name untuk wilayah $lokasi_text dan sekitarnya. Segera persiapkan diri untuk menunaikan sholat."
			fi
		fi
	fi	
    # Debug log untuk teks yang akan diucapkan
    [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "📝 TTS Text: $tts_text"
	
    log "INFO" "🔊 MEMBUAT SUARA REMINDER: Membuat suara reminder untuk $salat_name menggunakan $tts_method: $tts_text"
    
    # ✅ PERBAIKAN: SIMPAN METODE ASLI SEBELUM FALLBACK
    local original_tts_method="$tts_method"
    
    # JIKA METODE BUTUH INTERNET, CEK KONEKSI DULU
    if [ $need_internet -eq 1 ]; then
        if ! check_internet_connection; then
            log "WARNING" "📵 Tidak ada internet, fallback ke eSpeak (offline)"
            
            # Cek apakah eSpeak tersedia
            if command -v espeak >/dev/null 2>&1 && command -v aplay >/dev/null 2>&1; then
                tts_method="espeak"  # <-- SEKARANG BERUBAH UNTUK SELURUH FUNGSI
                log "INFO" "🔄 Switch ke eSpeak (offline TTS) dari $original_tts_method"
            else
                log "ERROR" "❌ Tidak ada internet DAN eSpeak tidak tersedia"
                return 1
            fi
        fi
    fi
    
    # ✅ PERBAIKAN: GUNAKAN VARIABLE $tts_method YANG SUDAH MUNGKIN BERUBAH
    log "INFO" "🔊 MEMUTAR REMINDER: Menggunakan metode TTS: $tts_method"
    
    # Pilih metode TTS berdasarkan konfigurasi (atau hasil fallback)
    local result=1
    case "$tts_method" in
        "murf")
            play_murf_tts_with_repeat "$tts_text" "$salat_name" "$prayer_time" "$lokasi" "$timezone"
            result=$?
            ;;
        "google")
            play_google_tts_with_repeat "$tts_text" "$salat_name" "$prayer_time" "$lokasi" "$timezone"
            result=$?
            ;;
        "edge")
            play_edge_tts_with_repeat "$tts_text" "$salat_name" "$prayer_time" "$lokasi" "$timezone"
            result=$?
            ;;
        "espeak")
            play_espeak_tts_with_repeat "$tts_text" "$salat_name" "$prayer_time" "$lokasi" "$timezone"
            result=$?
            ;;
        "gemini")
            play_gemini_tts_with_repeat "$tts_text" "$salat_name" "$prayer_time" "$lokasi" "$timezone"
            result=$?
            ;;
        *)
            log "ERROR" "❌ Metode TTS tidak dikenal: $tts_method"
            
            # Fallback terakhir: coba eSpeak jika tersedia
            if command -v espeak >/dev/null 2>&1 && command -v aplay >/dev/null 2>&1; then
                log "INFO" "🔄 Fallback ke eSpeak (karena metode tidak dikenal)"
                play_espeak_tts_with_repeat "$tts_text" "$salat_name" "$prayer_time" "$lokasi" "$timezone"
                result=$?
            else
                return 1
            fi
            ;;
    esac
    
    return $result
}

# Fungsi untuk alarm sahur (khusus Ramadhan)
play_sahur_alarm() {
    # Baca konfigurasi dari UCI
    local sahur_enabled=$(uci -q get jsholat.sound.sahur_enabled || echo "0")
    local alarm_time=$(uci -q get jsholat.sound.sahur_time || echo "02:30")
    local current_time=$(date +"%H:%M")
    local timezone=$(uci -q get jsholat.schedule.timezone_value || echo "")
    local LOKASI=$(uci get jsholat.schedule.city_label 2>/dev/null || echo "Wilayah Tidak Diketahui")
    local PROVINCE=$(uci get jsholat.schedule.province 2>/dev/null || echo "")
    
    # Cek apakah alarm diaktifkan
    if [ "$sahur_enabled" = "0" ]; then
        return 1
    fi
    
    # Cek apakah Ramadhan
    if ! is_ramadhan; then
        return 1
    fi
    
    # Cek apakah sudah waktunya sahur
    if [ "$current_time" != "$alarm_time" ]; then
        return 1
    fi
    
    # File status untuk mencegah pengulangan dalam 1 hari
    local SAHUR_STATUS_FILE="/var/lib/jsholat/sahur_today"
    local TODAY=$(date +"%d-%m-%Y")
    
    # Cek apakah alarm sahur sudah diputar hari ini
    if [ -f "$SAHUR_STATUS_FILE" ]; then
        local last_date=$(cat "$SAHUR_STATUS_FILE" 2>/dev/null)
        if [ "$last_date" = "$TODAY" ]; then
            log "INFO" "⏰ Alarm sahur sudah diputar hari ini, skip"
            return 0
        fi
    fi
    
    log "INFO" "🌙⏰ ALARM SAHUR RAMADHAN: Waktunya sahur pada $alarm_time $timezone"

    # Baca teks custom
    local template_text=$(get_sahur_reminder_text)    
    
    # Format waktu dan zona waktu menggunakan fungsi yang sudah ada
    local formatted_time=$(format_time_for_tts "$alarm_time")
    local formatted_timezone=$(format_timezone_for_tts "$timezone")
    
    # Format lokasi dengan provinsi
    local lokasi_text="$LOKASI"
    if [ -n "$PROVINCE" ] && [ "$PROVINCE" != " " ] && [ "$PROVINCE" != "null" ] && [ "$PROVINCE" != "None" ]; then
        lokasi_text="$LOKASI, $PROVINCE"
    fi
    
    # Buat teks TTS dengan format custom
    local tts_text=$(format_sahur_reminder \
        "$template_text" \
        "$formatted_time" \
        "$formatted_timezone" \
        "$lokasi_text")
    
    log "INFO" "🔊 Memutar alarm sahur dengan teks custom: $tts_text"
    
    # Gunakan TTS yang sudah ada
    local tts_method=$(uci -q get jsholat.sound.tts_method || echo "google")
    
    # Panggil fungsi TTS yang sesuai
    case "$tts_method" in
        "murf")
            play_murf_tts_with_repeat "$tts_text" "Sahur" "$alarm_time" "$LOKASI" "$timezone"
            ;;
        "google")
            play_google_tts_with_repeat "$tts_text" "Sahur" "$alarm_time" "$LOKASI" "$timezone"
            ;;
        "edge")
            play_edge_tts_with_repeat "$tts_text" "Sahur" "$alarm_time" "$LOKASI" "$timezone"
            ;;
        "espeak")
            play_espeak_tts_with_repeat "$tts_text" "Sahur" "$alarm_time" "$LOKASI" "$timezone"
            ;;
        "gemini")
            play_gemini_tts_with_repeat "$tts_text" "Sahur" "$alarm_time" "$LOKASI" "$timezone"
            ;;
    esac
    
    # Kirim notifikasi Telegram juga jika diaktifkan
    local telegram_enabled=$(uci -q get jsholat.service.telegram_enabled || echo "1")
    if [ "$telegram_enabled" = "1" ]; then
        local reminder_message="🌙 *ALARM SAHUR RAMADHAN* 🌙

⏰ *Waktu Sahur*: $alarm_time $timezone
📍 Wilayah: *$LOKASI${PROVINCE:+, $PROVINCE}* dan sekitarnya.

*Bangunlah untuk sahur, karena di dalam sahur terdapat keberkahan.*
(Rasulullah ﷺ)

*Marhaban ya Ramadhan* 🤲"
        
        send_telegram "$reminder_message" &
    fi
    
    # Tandai sudah diputar hari ini
    echo "$TODAY" > "$SAHUR_STATUS_FILE"
    
    log "INFO" "✅ Alarm sahur selesai diputar"
    sleep 61  # Hindari pengulangan di menit yang sama
    return 0
}

# Fungsi untuk memutar audio file dengan deteksi format otomatis
play_audio_file() {
    local audio_file="$1"
    local description="$2"
    
    # Validasi file
    if [ ! -f "$audio_file" ]; then
        log "ERROR" "❌ File audio tidak ditemukan: $audio_file"
        return 1
    fi
    
    if [ ! -s "$audio_file" ]; then
        log "ERROR" "❌ File audio kosong: $audio_file"
        return 1
    fi
    
    log "INFO" "🔊 MEMUTAR AUDIO: Memutar $description"
    
    # 🔧 AMBIL KONFIGURASI VOLUME SEBELUM MEMUTAR
    local volume_control=$(uci -q get jsholat.sound.volume_control || echo "hardware")
    local volume_level=$(uci -q get jsholat.sound.volume_level || echo "80")
    local mixer_device=$(uci -q get jsholat.sound.mixer_device || echo "PCM")
    
    # 🔧 SET VOLUME SEBELUM MEMUTAR (jika mode hardware)
    if [ "$volume_control" = "hardware" ]; then
        log "INFO" "🔊 AUDIO VOLUME: Mengatur volume ke $volume_level% (device: $mixer_device) untuk $description"
        if ! amixer -q set "$mixer_device" ${volume_level}% >/dev/null 2>&1; then
            log "ERROR" "❌ AUDIO VOLUME: Gagal mengatur volume hardware"
        else
            log "INFO" "✅ AUDIO VOLUME: Volume berhasil diatur ke $volume_level% untuk $description"
        fi
    else
        log "INFO" "🔊 AUDIO VOLUME: Menggunakan volume software (tidak perlu set hardware) untuk $description"
    fi
    
	# Deteksi format file langsung dari nama file
	local filename=$(basename "$audio_file")
	local file_ext=""

	# Deteksi berdasarkan pola nama file
	if [[ "$filename" == *.mp3 ]]; then
		file_ext="mp3"
	elif [[ "$filename" == *.wav ]]; then
		file_ext="wav"
	elif [[ "$filename" == *.ogg ]]; then
		file_ext="ogg"
	elif [[ "$filename" == *.flac ]]; then
		file_ext="flac"
	elif [[ "$filename" == *.m4a ]] || [[ "$filename" == *.aac ]]; then
		file_ext="aac"
	else
		# Fallback ke deteksi dengan file command
		if command -v file >/dev/null 2>&1; then
			local file_info=$(file -b "$audio_file" 2>/dev/null)
			if echo "$file_info" | grep -qi "MPEG.*layer 3"; then
				file_ext="mp3"
			elif echo "$file_info" | grep -qi "WAV"; then
				file_ext="wav"
			elif echo "$file_info" | grep -qi "Ogg"; then
				file_ext="ogg"
			elif echo "$file_info" | grep -qi "FLAC"; then
				file_ext="flac"
			else
				file_ext="unknown"
			fi
		else
			file_ext="unknown"
		fi
	fi

	[ "$DEBUG_MODE" = "1" ] && log "DEBUG" "📁 Deteksi format audio: '$file_ext' untuk $description (dari file: $filename)"    
    # Putar audio dengan metode yang sesuai berdasarkan format
    local play_success=0
    
    # Cek berdasarkan ekstensi
    case "$file_ext" in
        "wav"|"wave")
            # Format WAV - prioritaskan aplay, fallback ke play (sox)
            if command -v aplay >/dev/null 2>&1; then
                [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "▶ Menggunakan aplay untuk memutar WAV $description"
                if aplay -q "$audio_file" 2>/dev/null; then
                    play_success=1
                else
                    log "WARNING" "⚠️ aplay gagal, mencoba metode lain..."
                fi
            fi
            
            # Jika aplay gagal atau tidak tersedia, coba play (sox)
            if [ $play_success -eq 0 ] && command -v play >/dev/null 2>&1; then
                [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "▶ Menggunakan play (sox) untuk memutar WAV $description"
                if play -q "$audio_file" 2>/dev/null; then
                    play_success=1
                else
                    log "WARNING" "⚠️ play gagal, mencoba metode lain..."
                fi
            fi
            ;;
            
        "mp3"|"mpga"|"mpeg3"|"mpg")
            # Format MP3
            if command -v madplay >/dev/null 2>&1; then
                [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "▶ Menggunakan madplay untuk memutar MP3 $description"
                if madplay "$audio_file" >/dev/null 2>&1; then
                    play_success=1
                else
                    log "WARNING" "⚠️ madplay gagal, mencoba metode lain..."
                fi
            fi
            
            # Fallback ke mpg123 jika madplay tidak tersedia atau gagal
            if [ $play_success -eq 0 ] && command -v mpg123 >/dev/null 2>&1; then
                [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "▶ Menggunakan mpg123 untuk memutar MP3 $description"
                if mpg123 -q "$audio_file" >/dev/null 2>&1; then
                    play_success=1
                else
                    log "WARNING" "⚠️ mpg123 gagal, mencoba metode lain..."
                fi
            fi
            
            # Fallback ke ffplay jika tersedia
            if [ $play_success -eq 0 ] && command -v ffplay >/dev/null 2>&1; then
                [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "▶ Menggunakan ffplay untuk memutar MP3 $description"
                if ffplay -nodisp -autoexit -loglevel quiet "$audio_file" 2>/dev/null; then
                    play_success=1
                else
                    log "WARNING" "⚠️ ffplay gagal..."
                fi
            fi
            
            # Fallback ke play (sox) untuk MP3
            if [ $play_success -eq 0 ] && command -v play >/dev/null 2>&1; then
                [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "▶ Menggunakan play (sox) untuk memutar MP3 $description"
                if play -q "$audio_file" 2>/dev/null; then
                    play_success=1
                else
                    log "WARNING" "⚠️ play gagal..."
                fi
            fi
            ;;
            
        "ogg"|"oga"|"ogv")
            # Format OGG Vorbis
            if command -v ogg123 >/dev/null 2>&1; then
                [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "▶ Menggunakan ogg123 untuk memutar OGG $description"
                if ogg123 -q "$audio_file" 2>/dev/null; then
                    play_success=1
                else
                    log "WARNING" "⚠️ ogg123 gagal, mencoba metode lain..."
                fi
            fi
            
            # Fallback ke play (sox) untuk OGG
            if [ $play_success -eq 0 ] && command -v play >/dev/null 2>&1; then
                [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "▶ Menggunakan play (sox) untuk memutar OGG $description"
                if play -q "$audio_file" 2>/dev/null; then
                    play_success=1
                else
                    log "WARNING" "⚠️ play gagal..."
                fi
            fi
            ;;
            
        "flac"|"fla")
            # Format FLAC
            if command -v flac >/dev/null 2>&1 && command -v aplay >/dev/null 2>&1; then
                [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "▶ Menggunakan flac + aplay untuk memutar FLAC $description"
                if flac -c -d "$audio_file" 2>/dev/null | aplay -q 2>/dev/null; then
                    play_success=1
                else
                    log "WARNING" "⚠️ flac pipeline gagal, mencoba metode lain..."
                fi
            fi
            
            # Fallback ke play (sox) untuk FLAC
            if [ $play_success -eq 0 ] && command -v play >/dev/null 2>&1; then
                [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "▶ Menggunakan play (sox) untuk memutar FLAC $description"
                if play -q "$audio_file" 2>/dev/null; then
                    play_success=1
                else
                    log "WARNING" "⚠️ play gagal..."
                fi
            fi
            ;;
            
        "aac"|"m4a"|"mp4")
            # Format AAC/M4A
            if command -v ffplay >/dev/null 2>&1; then
                [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "▶ Menggunakan ffplay untuk memutar AAC $description"
                if ffplay -nodisp -autoexit -loglevel quiet "$audio_file" 2>/dev/null; then
                    play_success=1
                else
                    log "WARNING" "⚠️ ffplay gagal, mencoba metode lain..."
                fi
            fi
            
            # Fallback ke play (sox) untuk AAC (jika didukung)
            if [ $play_success -eq 0 ] && command -v play >/dev/null 2>&1; then
                [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "▶ Menggunakan play (sox) untuk memutar AAC $description"
                if play -q "$audio_file" 2>/dev/null; then
                    play_success=1
                else
                    log "WARNING" "⚠️ play gagal..."
                fi
            fi
            ;;
            
        *)
            # Format tidak dikenal, coba dengan metode umum
            log "WARNING" "⚠️ Format file tidak dikenal ($file_ext), mencoba berbagai metode pemutar..."
            
            # Cek dulu dengan file command untuk memastikan tipe file
            if command -v file >/dev/null 2>&1; then
                local file_info=$(file -b "$audio_file" 2>/dev/null)
                [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "📋 File info: $file_info"
                
                # Deteksi berdasarkan informasi file
                if echo "$file_info" | grep -qi "MPEG.*layer 3"; then
                    [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "🔍 Terdeteksi sebagai MP3 dari file command"
                    file_ext="mp3"
                elif echo "$file_info" | grep -qi "WAV"; then
                    [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "🔍 Terdeteksi sebagai WAV dari file command"
                    file_ext="wav"
                elif echo "$file_info" | grep -qi "Ogg"; then
                    [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "🔍 Terdeteksi sebagai OGG dari file command"
                    file_ext="ogg"
                fi
            fi
            
            # Coba madplay (umumnya bisa berbagai format)
            if [ $play_success -eq 0 ] && command -v madplay >/dev/null 2>&1; then
                [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "▶ Mencoba madplay untuk format $file_ext"
                if madplay "$audio_file" >/dev/null 2>&1; then
                    play_success=1
                fi
            fi
            
            # Coba mpg123
            if [ $play_success -eq 0 ] && command -v mpg123 >/dev/null 2>&1; then
                [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "▶ Mencoba mpg123 untuk format $file_ext"
                if mpg123 -q "$audio_file" >/dev/null 2>&1; then
                    play_success=1
                fi
            fi
            
            # Coba aplay (untuk WAV raw)
            if [ $play_success -eq 0 ] && command -v aplay >/dev/null 2>&1; then
                [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "▶ Mencoba aplay untuk format $file_ext (sebagai WAV raw)"
                if aplay -q "$audio_file" 2>/dev/null; then
                    play_success=1
                fi
            fi
            
            # Coba play (sox)
            if [ $play_success -eq 0 ] && command -v play >/dev/null 2>&1; then
                [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "▶ Mencoba play (sox) untuk format $file_ext"
                if play -q "$audio_file" 2>/dev/null; then
                    play_success=1
                fi
            fi
            
            # Coba ffplay sebagai fallback terakhir
            if [ $play_success -eq 0 ] && command -v ffplay >/dev/null 2>&1; then
                [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "▶ Mencoba ffplay untuk format $file_ext"
                if ffplay -nodisp -autoexit -loglevel quiet "$audio_file" 2>/dev/null; then
                    play_success=1
                fi
            fi
            ;;
    esac
    
    # Jika semua metode gagal, beri pesan error
    if [ $play_success -eq 0 ]; then
        log "ERROR" "❌ Tidak ada pemutar audio yang tersedia atau semua metode gagal untuk $description (format: $file_ext)"
        
        # Tampilkan daftar pemutar yang tersedia untuk debugging
        if [ "$DEBUG_MODE" = "1" ]; then
            log "DEBUG" "📋 Pemutar audio yang tersedia di sistem:"
            command -v aplay >/dev/null 2>&1 && [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "  - aplay: $(which aplay)"
            command -v play >/dev/null 2>&1 && [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "  - play: $(which play)"
            command -v madplay >/dev/null 2>&1 && [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "  - madplay: $(which madplay)"
            command -v mpg123 >/dev/null 2>&1 && [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "  - mpg123: $(which mpg123)"
            command -v ffplay >/dev/null 2>&1 && [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "  - ffplay: $(which ffplay)"
            command -v ogg123 >/dev/null 2>&1 && [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "  - ogg123: $(which ogg123)"
            command -v flac >/dev/null 2>&1 && [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "  - flac: $(which flac)"
        fi
    fi
    
    # Reset volume ke default setelah selesai (opsional)
    local default_volume=80
    if [ "$volume_control" = "hardware" ] && [ "$volume_level" != "$default_volume" ]; then
        [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "🔊 AUDIO VOLUME: Reset volume ke default $default_volume% setelah $description"
        amixer -q set "$mixer_device" ${default_volume}% >/dev/null 2>&1 || 
        log "WARNING" "⚠️ AUDIO VOLUME: Gagal reset volume setelah $description"
    fi
    
    if [ $play_success -eq 1 ]; then
        log "INFO" "✅ AUDIO SUKSES: $description berhasil diputar (format: $file_ext)"
        return 0
    else
        log "ERROR" "❌ AUDIO GAGAL: Gagal memutar $description (format: $file_ext)"
        return 1
    fi
}


# Fungsi untuk menentukan jumlah pengulangan berdasarkan sholat
get_reminder_repeat_count() {
    local salat_name="$1"
    
    # Khusus Imsyak: selalu 3x (bisa diubah)
    if [ "$salat_name" = "Imsyak" ]; then
        echo "3"
        return 0
    fi
    
    # Sholat lain: ambil dari konfigurasi UCI
    local repeat_count=$(uci -q get jsholat.sound.reminder_repeat_count || echo "3")
    echo "$repeat_count"
}

# Fungsi untuk memutar TTS menggunakan Google Translate dengan pengulangan
play_google_tts_with_repeat() {
    local text="$1"
    local salat_name="$2"
    local prayer_time="$3"
    local lokasi="$4"
    local timezone="$5"
    
    # Tentukan jumlah pengulangan berdasarkan sholat
    local repeat_count=$(get_reminder_repeat_count "$salat_name")
    
    # Log info pengulangan
    if [ "$salat_name" = "Imsyak" ]; then
        log "INFO" "🕌 REMINDER IMSYAK: Hanya 1 kali pemutaran (khusus Imsyak)"
    else
        log "INFO" "🔄 REMINDER $salat_name: Akan diputar $repeat_count kali untuk penegasan"
    fi
    
    # CEK KONEKSI INTERNET - EARLY EXIT
    if ! check_internet_connection; then
        log "WARNING" "📵 Tidak ada koneksi internet untuk Google TTS"
        add_global_failed_method "google"
        try_tts_fallback "google" "$text" "$salat_name" "$prayer_time" "$lokasi" "$timezone" "google"
        return $?
    fi
    
    # Tentukan maksimal percobaan download jika gagal
    local max_attempts=2
    
    # Encode text untuk URL
    local encoded_text=$(echo "$text" | sed 's/ /%20/g; s/:/%3A/g; s/"/%22/g; s/?/%3F/g; s/&/%26/g; s/=/%3D/g')
    
    local success=0
    local downloaded_file=""
    
    # ===== BAGIAN 1: DOWNLOAD AUDIO =====
    local download_attempt=1
    while [ $download_attempt -le $max_attempts ] && [ -z "$downloaded_file" ]; do
        local temp_audio_file="/tmp/reminder_${salat_name}_google_$(date +%s)_download${download_attempt}.mp3"
        
        log "INFO" "📥 REMINDER SUARA: Mencoba download ke-$download_attempt/$max_attempts untuk $salat_name"
        
        # Download audio dari Google Translate
        if wget -q -O "$temp_audio_file" \
            "https://translate.google.com/translate_tts?ie=UTF-8&tl=id&client=tw-ob&q=$encoded_text"; then
            
            if [ -s "$temp_audio_file" ]; then
                log "INFO" "✅ REMINDER SUARA: Google TTS berhasil diunduh"
                downloaded_file="$temp_audio_file"
                success=1
                break
            else
                log "ERROR" "❌ REMINDER SUARA: File audio Google TTS kosong (attempt $download_attempt)"
                rm -f "$temp_audio_file"
            fi
        else
            log "ERROR" "❌ REMINDER SUARA: Gagal mengunduh audio dari Google TTS (attempt $download_attempt)"
        fi
        
        # Jika ini attempt terakhir, fallback
        if [ $download_attempt -eq $max_attempts ] && [ -z "$downloaded_file" ]; then
            log "WARNING" "❌ Google TTS gagal setelah $max_attempts percobaan"
            add_global_failed_method "google"
            log "INFO" "🔄 Mencoba fallback ke metode TTS lain..."
            try_tts_fallback "google" "$text" "$salat_name" "$prayer_time" "$lokasi" "$timezone" "google"
            return $?
        fi
        
        # Tunggu sebelum retry
        if [ -z "$downloaded_file" ] && [ $download_attempt -lt $max_attempts ]; then
            local wait_time=$((download_attempt * 2))
            log "INFO" "⏳ REMINDER SUARA: Menunggu $wait_time detik sebelum download ulang..."
            sleep $wait_time
        fi
        
        download_attempt=$((download_attempt + 1))
    done
    
    # Jika download gagal (seharusnya sudah tertangani)
    if [ -z "$downloaded_file" ]; then
        return 1
    fi
    
    # ===== BAGIAN 2: PUTAR AUDIO DENGAN PENGULANGAN =====
    local repeat_success=0
    for ((current_repeat=1; current_repeat<=repeat_count; current_repeat++)); do
        log "INFO" "🔄 REMINDER SUARA: Pengulangan ke-$current_repeat/$repeat_count untuk $salat_name pukul $prayer_time"
        
        # Putar in_reminder.mp3 sebelum TTS (jika ada)
        local in_reminder_file="/usr/share/jsholat/sounds/in_reminder.mp3"
        if [ -f "$in_reminder_file" ]; then
            log "INFO" "🔊 REMINDER INTRO: Memutar intro sebelum reminder $salat_name"
            play_audio_file "$in_reminder_file" "intro reminder"
            sleep 1
        fi
        
        # Putar audio TTS
        log "INFO" "🔊 MEMUTAR REMINDER: Memutar suara reminder $salat_name (repeat $current_repeat)"
        if play_audio_file "$downloaded_file" "reminder $salat_name repeat $current_repeat"; then
            repeat_success=1
        else
            log "ERROR" "❌ REMINDER SUARA: Pengulangan ke-$current_repeat gagal"
            repeat_success=0
        fi
        
        # Putar out_reminder.mp3 setelah TTS (jika ada)
        local out_reminder_file="/usr/share/jsholat/sounds/out_reminder.mp3"
        if [ -f "$out_reminder_file" ]; then
            log "INFO" "🔊 REMINDER OUTRO: Memutar outro setelah reminder $salat_name"
            play_audio_file "$out_reminder_file" "outro reminder"
            sleep 1
        fi
        
        # Tunggu sebelum pengulangan berikutnya
        if [ $current_repeat -lt $repeat_count ] && [ "$salat_name" != "Imsyak" ]; then
            local repeat_wait=$(uci -q get jsholat.sound.reminder_repeat_interval || echo "5")
            log "INFO" "⏳ REMINDER SUARA: Menunggu $repeat_wait detik sebelum pengulangan berikutnya..."
            sleep $repeat_wait
        fi
    done
    
    # Bersihkan file
    rm -f "$downloaded_file" 2>/dev/null
    
    if [ $repeat_success -eq 1 ]; then
        log "INFO" "✅ REMINDER SUARA: $salat_name selesai dengan sukses"
        return 0
    fi
    
    return 1
}

# Fungsi untuk memutar TTS menggunakan Edge-TTS dengan pengulangan
play_edge_tts_with_repeat() {
    local text="$1"
    local salat_name="$2"
    local prayer_time="$3"
    local lokasi="$4"
    local timezone="$5"
    
    # Tentukan jumlah pengulangan berdasarkan sholat
    local repeat_count=$(get_reminder_repeat_count "$salat_name")
    
    # Log info pengulangan
    if [ "$salat_name" = "Imsyak" ]; then
        log "INFO" "🕌 REMINDER IMSYAK: Hanya 1 kali pemutaran (khusus Imsyak)"
    else
        log "INFO" "🔄 REMINDER $salat_name: Akan diputar $repeat_count kali untuk penegasan"
    fi
    
    # CEK KONEKSI INTERNET - EARLY EXIT
    if ! check_internet_connection; then
        log "WARNING" "📵 Tidak ada koneksi internet untuk Edge-TTS"
        add_global_failed_method "edge"
        try_tts_fallback "edge" "$text" "$salat_name" "$prayer_time" "$lokasi" "$timezone" "edge"
        return $?
    fi
    
    # Cek apakah edge-tts tersedia
    if ! command -v edge-tts >/dev/null 2>&1; then
        log "ERROR" "❌ edge-tts tidak ditemukan"
        add_global_failed_method "edge"
        try_tts_fallback "edge" "$text" "$salat_name" "$prayer_time" "$lokasi" "$timezone" "edge"
        return $?
    fi
    
    # Tentukan maksimal percobaan jika gagal
    local max_attempts=2
    
    # Ambil voice yang dipilih dari konfigurasi
    local edge_voice=$(uci -q get jsholat.sound.edge_voice || echo "id-ID-ArdiNeural")
    
    local success=0
    local downloaded_file=""
    
    # ===== BAGIAN 1: GENERATE AUDIO =====
    local generate_attempt=1
    while [ $generate_attempt -le $max_attempts ] && [ -z "$downloaded_file" ]; do
        local temp_audio_file="/tmp/reminder_${salat_name}_edge_$(date +%s)_generate${generate_attempt}.mp3"
        
        log "INFO" "🔧 REMINDER SUARA: Mencoba generate ke-$generate_attempt/$max_attempts untuk $salat_name menggunakan Edge-TTS"
        
        # Gunakan edge-tts untuk menghasilkan audio
        if edge-tts --text "$text" --voice "$edge_voice" --write-media "$temp_audio_file" >/dev/null 2>&1; then
            
            if [ -s "$temp_audio_file" ]; then
                log "INFO" "✅ REMINDER SUARA: Edge-TTS berhasil digenerate"
                downloaded_file="$temp_audio_file"
                success=1
                break
            else
                log "ERROR" "❌ REMINDER SUARA: File audio Edge-TTS kosong (attempt $generate_attempt)"
                rm -f "$temp_audio_file"
            fi
        else
            log "ERROR" "❌ REMINDER SUARA: Gagal membuat audio dengan Edge-TTS (attempt $generate_attempt)"
        fi
        
        # Jika ini attempt terakhir, fallback
        if [ $generate_attempt -eq $max_attempts ] && [ -z "$downloaded_file" ]; then
            log "WARNING" "❌ Edge-TTS gagal setelah $max_attempts percobaan"
            add_global_failed_method "edge"
            log "INFO" "🔄 Mencoba fallback ke metode TTS lain..."
            try_tts_fallback "edge" "$text" "$salat_name" "$prayer_time" "$lokasi" "$timezone" "edge"
            return $?
        fi
        
        # Tunggu sebelum retry
        if [ -z "$downloaded_file" ] && [ $generate_attempt -lt $max_attempts ]; then
            local wait_time=$((generate_attempt * 2))
            log "INFO" "⏳ REMINDER SUARA: Menunggu $wait_time detik sebelum generate ulang..."
            sleep $wait_time
        fi
        
        generate_attempt=$((generate_attempt + 1))
    done
    
    # Jika generate gagal (seharusnya sudah tertangani di loop)
    if [ -z "$downloaded_file" ]; then
        return 1
    fi
    
    # ===== BAGIAN 2: PUTAR AUDIO DENGAN PENGULANGAN =====
    local repeat_success=0
    for ((current_repeat=1; current_repeat<=repeat_count; current_repeat++)); do
        log "INFO" "🔄 REMINDER SUARA: Pengulangan ke-$current_repeat/$repeat_count untuk $salat_name pukul $prayer_time"
        
        # Putar in_reminder.mp3 sebelum TTS (jika ada)
        local in_reminder_file="/usr/share/jsholat/sounds/in_reminder.mp3"
        if [ -f "$in_reminder_file" ]; then
            log "INFO" "🔊 REMINDER INTRO: Memutar intro sebelum reminder $salat_name"
            play_audio_file "$in_reminder_file" "intro reminder"
            sleep 1
        fi
        
        # Putar audio TTS
        log "INFO" "🔊 MEMUTAR REMINDER: Memutar suara reminder $salat_name (repeat $current_repeat)"
        if play_audio_file "$downloaded_file" "reminder $salat_name repeat $current_repeat"; then
            repeat_success=1
        else
            log "ERROR" "❌ REMINDER SUARA: Pengulangan ke-$current_repeat gagal"
            repeat_success=0
        fi
        
        # Putar out_reminder.mp3 setelah TTS (jika ada)
        local out_reminder_file="/usr/share/jsholat/sounds/out_reminder.mp3"
        if [ -f "$out_reminder_file" ]; then
            log "INFO" "🔊 REMINDER OUTRO: Memutar outro setelah reminder $salat_name"
            play_audio_file "$out_reminder_file" "outro reminder"
            sleep 1
        fi
        
        # Tunggu sebelum pengulangan berikutnya
        if [ $current_repeat -lt $repeat_count ] && [ "$salat_name" != "Imsyak" ]; then
            local repeat_wait=$(uci -q get jsholat.sound.reminder_repeat_interval || echo "5")
            log "INFO" "⏳ REMINDER SUARA: Menunggu $repeat_wait detik sebelum pengulangan berikutnya..."
            sleep $repeat_wait
        fi
    done
    
    # Bersihkan file
    rm -f "$downloaded_file" 2>/dev/null
    
    if [ $repeat_success -eq 1 ]; then
        log "INFO" "✅ REMINDER SUARA: $salat_name selesai dengan sukses"
        return 0
    fi
    
    return 1
}

# Fungsi untuk memutar TTS menggunakan Murf.ai dengan pengulangan
play_murf_tts_with_repeat() {
    local text="$1"
    local salat_name="$2"
    local prayer_time="$3"
    local lokasi="$4"
    local timezone="$5"
    
    # Tentukan jumlah pengulangan berdasarkan sholat
    local repeat_count=$(get_reminder_repeat_count "$salat_name")
    
    # Log info pengulangan
    if [ "$salat_name" = "Imsyak" ]; then
        log "INFO" "🕌 REMINDER IMSYAK: Hanya 1 kali pemutaran (khusus Imsyak)"
    else
        log "INFO" "🔄 REMINDER $salat_name: Akan diputar $repeat_count kali untuk penegasan"
    fi
    
    # CEK KONEKSI INTERNET - EARLY EXIT
    if ! check_internet_connection; then
        log "WARNING" "📵 Tidak ada koneksi internet untuk Murf TTS"
        add_global_failed_method "murf"
        try_tts_fallback "murf" "$text" "$salat_name" "$prayer_time" "$lokasi" "$timezone" "murf"
        return $?
    fi
    
    # Tentukan maksimal percobaan jika gagal
    local max_attempts=2
    
    # Siapkan API key dari konfigurasi
    local murf_api_key=$(uci -q get jsholat.sound.murf_api_key || echo "")
    
    if [ -z "$murf_api_key" ]; then
        log "ERROR" "❌ API key Murf.ai belum dikonfigurasi"
        add_global_failed_method "murf"
        try_tts_fallback "murf" "$text" "$salat_name" "$prayer_time" "$lokasi" "$timezone" "murf"
        return $?
    fi
    
    # Buat payload JSON
    local json_payload=$(printf '{
        "text": "%s",
        "voiceId": "Ronnie",
        "model": "FALCON",
        "multiNativeLocale": "id-ID",
        "variation": 5,
        "format": "MP3",
        "rate": -10,
        "channelType": "STEREO",
        "pronunciationDictionary": {
            "WIB": { "pronunciation": "waktu indonesia barat", "type": "SAY_AS" },
            "WIT": { "pronunciation": "waktu indonesia timur", "type": "SAY_AS" },
            "WITA": { "pronunciation": "waktu indonesia tengah", "type": "SAY_AS" },
            "Dzuhur": { "pronunciation": "zuhur", "type": "SAY_AS" },
            "Ashar": { "pronunciation": "asar", "type": "SAY_AS" },
            "Maghrib": { "pronunciation": "magrib", "type": "SAY_AS" },
            "Isya": { "pronunciation": "isya", "type": "SAY_AS" },
            "Subuh": { "pronunciation": "subuh", "type": "SAY_AS" }
        }
    }' "$text")
    
    local success=0
    local downloaded_file=""
    
    # ===== BAGIAN 1: DOWNLOAD AUDIO =====
    local download_attempt=1
    while [ $download_attempt -le $max_attempts ] && [ -z "$downloaded_file" ]; do
        local temp_audio_file="/tmp/reminder_${salat_name}_murf_$(date +%s)_download${download_attempt}.mp3"
        
        log "INFO" "📥 REMINDER SUARA: Mencoba download ke-$download_attempt/$max_attempts untuk $salat_name"
        
        # Panggil API Murf.ai
        local curl_output=$(curl -s -X POST "https://api.murf.ai/v1/speech/stream" \
            -H "api-key: $murf_api_key" \
            -H "Content-Type: application/json" \
            -d "$json_payload" \
            --output "$temp_audio_file" \
            --write-out "%{http_code}" \
            --max-time 30)
        
        local http_code=${curl_output##*[^0-9]}
        
        if [ "$http_code" = "200" ] && [ -f "$temp_audio_file" ] && [ -s "$temp_audio_file" ]; then
            log "INFO" "✅ REMINDER SUARA: Murf.ai TTS berhasil diunduh"
            downloaded_file="$temp_audio_file"
            success=1
            break
        else
            log "ERROR" "❌ REMINDER SUARA: Gagal membuat suara dengan Murf.ai (attempt $download_attempt, HTTP: $http_code)"
            [ -f "$temp_audio_file" ] && rm -f "$temp_audio_file"
        fi
        
        # Jika ini attempt terakhir, fallback
        if [ $download_attempt -eq $max_attempts ] && [ -z "$downloaded_file" ]; then
            log "WARNING" "❌ Murf TTS gagal setelah $max_attempts percobaan"
            add_global_failed_method "murf"
            log "INFO" "🔄 Mencoba fallback ke metode TTS lain..."
            try_tts_fallback "murf" "$text" "$salat_name" "$prayer_time" "$lokasi" "$timezone" "murf"
            return $?
        fi
        
        # Tunggu sebelum retry
        if [ -z "$downloaded_file" ] && [ $download_attempt -lt $max_attempts ]; then
            local wait_time=$((download_attempt * 2))
            log "INFO" "⏳ REMINDER SUARA: Menunggu $wait_time detik sebelum download ulang..."
            sleep $wait_time
        fi
        
        download_attempt=$((download_attempt + 1))
    done
    
    # Jika download gagal (seharusnya sudah tertangani)
    if [ -z "$downloaded_file" ]; then
        return 1
    fi
    
    # ===== BAGIAN 2: PUTAR AUDIO DENGAN PENGULANGAN =====
    local repeat_success=0
    for ((current_repeat=1; current_repeat<=repeat_count; current_repeat++)); do
        log "INFO" "🔄 REMINDER SUARA: Pengulangan ke-$current_repeat/$repeat_count untuk $salat_name pukul $prayer_time"
        
        # Putar in_reminder.mp3 sebelum TTS (jika ada)
        local in_reminder_file="/usr/share/jsholat/sounds/in_reminder.mp3"
        if [ -f "$in_reminder_file" ]; then
            log "INFO" "🔊 REMINDER INTRO: Memutar intro sebelum reminder $salat_name"
            play_audio_file "$in_reminder_file" "intro reminder"
            sleep 1
        fi
        
        # Putar audio TTS
        log "INFO" "🔊 MEMUTAR REMINDER: Memutar suara reminder $salat_name (repeat $current_repeat)"
        if play_audio_file "$downloaded_file" "reminder $salat_name repeat $current_repeat"; then
            repeat_success=1
        else
            log "ERROR" "❌ REMINDER SUARA: Pengulangan ke-$current_repeat gagal"
            repeat_success=0
        fi
        
        # Putar out_reminder.mp3 setelah TTS (jika ada)
        local out_reminder_file="/usr/share/jsholat/sounds/out_reminder.mp3"
        if [ -f "$out_reminder_file" ]; then
            log "INFO" "🔊 REMINDER OUTRO: Memutar outro setelah reminder $salat_name"
            play_audio_file "$out_reminder_file" "outro reminder"
            sleep 1
        fi
        
        # Tunggu sebelum pengulangan berikutnya
        if [ $current_repeat -lt $repeat_count ] && [ "$salat_name" != "Imsyak" ]; then
            local repeat_wait=$(uci -q get jsholat.sound.reminder_repeat_interval || echo "5")
            log "INFO" "⏳ REMINDER SUARA: Menunggu $repeat_wait detik sebelum pengulangan berikutnya..."
            sleep $repeat_wait
        fi
    done
    
    # Bersihkan file
    rm -f "$downloaded_file" 2>/dev/null
    
    if [ $repeat_success -eq 1 ]; then
        log "INFO" "✅ REMINDER SUARA: $salat_name selesai dengan sukses"
        return 0
    fi
    
    return 1
}

# Fungsi untuk memutar TTS menggunakan Gemini dengan pengulangan
play_gemini_tts_with_repeat() {
    local text="$1"
    local salat_name="$2"
    local prayer_time="$3"
    local lokasi="$4"
    local timezone="$5"
    
    # Tentukan jumlah pengulangan berdasarkan sholat
    local repeat_count=$(get_reminder_repeat_count "$salat_name")
    
    # Log info pengulangan
    if [ "$salat_name" = "Imsyak" ]; then
        log "INFO" "🕌 REMINDER IMSYAK: Hanya 1 kali pemutaran (khusus Imsyak)"
    else
        log "INFO" "🔄 REMINDER $salat_name: Akan diputar $repeat_count kali untuk penegasan"
    fi
    
    # CEK KONEKSI INTERNET - EARLY EXIT
    if ! check_internet_connection; then
        log "WARNING" "📵 Tidak ada koneksi internet untuk Gemini TTS"
        add_global_failed_method "gemini"
        try_tts_fallback "gemini" "$text" "$salat_name" "$prayer_time" "$lokasi" "$timezone" "gemini"
        return $?
    fi
    
    # Tentukan maksimal percobaan jika gagal
    local max_attempts=2  # Kurangi jadi 2 percobaan untuk respons lebih cepat
    
    # Ambil konfigurasi Gemini dari UCI
    local gemini_api_key=$(uci -q get jsholat.sound.gemini_api_key || echo "")
    local gemini_model=$(uci -q get jsholat.sound.gemini_model || echo "gemini-2.5-flash-preview-tts")
    local gemini_voice=$(uci -q get jsholat.sound.gemini_voice || echo "Zephyr")
    
    # Validasi API key
    if [ -z "$gemini_api_key" ]; then
        log "ERROR" "❌ API key Gemini belum dikonfigurasi"
        add_global_failed_method "gemini"
        try_tts_fallback "gemini" "$text" "$salat_name" "$prayer_time" "$lokasi" "$timezone" "gemini"
        return $?
    fi
    
    # Persiapan file temporary dengan prefix unik untuk memudahkan cleanup
    local temp_prefix="/tmp/gemini_tts_${salat_name}_$(date +%s)_$$"
    local OUT_JSON="${temp_prefix}.json"
    local OUT_B64="${temp_prefix}.b64"
    local OUT_RAW="${temp_prefix}.raw"
    local OUT_WAV="${temp_prefix}.wav"
    
    local success=0
    local downloaded_file=""
    local http_code=""
    
    # ===== BAGIAN 1: GENERATE AUDIO dengan Gemini =====
    local generate_attempt=1
    while [ $generate_attempt -le $max_attempts ] && [ -z "$downloaded_file" ]; do
        log "INFO" "🔧 REMINDER SUARA: Mencoba generate ke-$generate_attempt/$max_attempts untuk $salat_name menggunakan Gemini (Voice: $gemini_voice)"
        
        # Buat payload JSON untuk request Gemini
        local json_payload=$(jq -n \
            --arg text "$text" \
            --arg voice "$gemini_voice" \
            '{
                contents: [{
                    parts: [{
                        text: $text
                    }]
                }],
                generationConfig: {
                    responseModalities: ["AUDIO"],
                    speechConfig: {
                        voiceConfig: {
                            prebuiltVoiceConfig: {
                                voiceName: $voice
                            }
                        }
                    }
                }
            }')
        
        # Panggil API Gemini
        http_code=$(curl -s -w "%{http_code}" -X POST \
            "https://generativelanguage.googleapis.com/v1beta/models/${gemini_model}:generateContent?key=${gemini_api_key}" \
            -H "Content-Type: application/json" \
            -d "$json_payload" \
            -o "$OUT_JSON" \
            --max-time 15 2>/dev/null)
        
        # Cek HTTP status code
        if [ "$http_code" = "200" ]; then
            # Proses response sukses
            if [ -f "$OUT_JSON" ] && [ -s "$OUT_JSON" ] && ! grep -q '"error"' "$OUT_JSON"; then
                # Ambil base64 audio dari response
                jq -r '.candidates[0].content.parts[0].inlineData.data' "$OUT_JSON" 2>/dev/null > "$OUT_B64"
                
                if [ -s "$OUT_B64" ]; then
                    # Decode base64 ke raw PCM
                    base64 -d "$OUT_B64" > "$OUT_RAW" 2>/dev/null
                    
                    if [ -s "$OUT_RAW" ]; then
                        # Convert raw PCM ke WAV
                        if command -v sox >/dev/null 2>&1; then
                            sox -t raw -r 24000 -e signed -b 16 -c 1 "$OUT_RAW" "$OUT_WAV" 2>/dev/null
                        elif command -v ffmpeg >/dev/null 2>&1; then
                            ffmpeg -f s16le -ar 24000 -ac 1 -i "$OUT_RAW" "$OUT_WAV" -y >/dev/null 2>&1
                        else
                            mv "$OUT_RAW" "$OUT_WAV"
                        fi
                        
                        if [ -f "$OUT_WAV" ] && [ -s "$OUT_WAV" ]; then
                            log "INFO" "✅ REMINDER SUARA: Gemini TTS berhasil digenerate"
                            downloaded_file="$OUT_WAV"
                            success=1
                            
                            # HAPUS FILE CACHE (JSON, B64, RAW) - HANYA SISAKAN WAV
                            rm -f "$OUT_JSON" "$OUT_B64" "$OUT_RAW" 2>/dev/null
                            [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "🧹 File cache dibersihkan: JSON, B64, RAW"
                            break
                        fi
                    fi
                fi
            fi
        else
            log "WARNING" "⚠️ Gemini API gagal (HTTP $http_code) pada attempt $generate_attempt"
            
            # HAPUS FILE CACHE YANG MUNGKIN TERBUAT
            rm -f "$OUT_JSON" "$OUT_B64" "$OUT_RAW" "$OUT_WAV" 2>/dev/null
        fi
        
        # PASTIKAN FILE CACHE DIBERSIHKAN DI SETIAP ITERASI (kecuali WAV yang sukses)
        if [ -z "$downloaded_file" ]; then
            rm -f "$OUT_JSON" "$OUT_B64" "$OUT_RAW" "$OUT_WAV" 2>/dev/null
        fi
        
        # Exponential backoff untuk retry
        if [ -z "$downloaded_file" ] && [ $generate_attempt -lt $max_attempts ]; then
            local wait_time=$((generate_attempt * 2))
            log "INFO" "⏳ Menunggu $wait_time detik sebelum retry Gemini..."
            sleep $wait_time
        fi
        
        generate_attempt=$((generate_attempt + 1))
    done
    
    # Jika semua percobaan gagal
    if [ -z "$downloaded_file" ]; then
        log "ERROR" "❌ Gagal generate audio dengan Gemini setelah $max_attempts percobaan"
        
        # PASTIKAN SEMUA FILE CACHE TERHAPUS
        rm -f "$OUT_JSON" "$OUT_B64" "$OUT_RAW" "$OUT_WAV" 2>/dev/null
        
        # TAMBAHKAN KE GLOBAL FAILED METHODS
        add_global_failed_method "gemini"
        
        # PANGGIL FALLBACK
        try_tts_fallback "gemini" "$text" "$salat_name" "$prayer_time" "$lokasi" "$timezone" "gemini"
        return $?
    fi
    
    # ===== BAGIAN 2: PUTAR AUDIO (jika Gemini berhasil) =====
    local repeat_success=0
    for ((current_repeat=1; current_repeat<=repeat_count; current_repeat++)); do
        log "INFO" "🔄 REMINDER SUARA: Pengulangan ke-$current_repeat/$repeat_count untuk $salat_name pukul $prayer_time"
        
        # Putar in_reminder.mp3 sebelum TTS (jika ada)
        local in_reminder_file="/usr/share/jsholat/sounds/in_reminder.mp3"
        if [ -f "$in_reminder_file" ]; then
            log "INFO" "🔊 REMINDER INTRO: Memutar intro sebelum reminder $salat_name"
            play_audio_file "$in_reminder_file" "intro reminder"
            sleep 1
        fi
        
        # Putar audio WAV yang sudah di-generate
        log "INFO" "🔊 MEMUTAR REMINDER: Memutar suara reminder $salat_name (repeat $current_repeat)"
        if play_audio_file "$downloaded_file" "reminder $salat_name repeat $current_repeat"; then
            repeat_success=1
        else
            log "ERROR" "❌ REMINDER SUARA: Pengulangan ke-$current_repeat gagal"
            repeat_success=0
        fi
        
        # Putar out_reminder.mp3 setelah TTS (jika ada)
        local out_reminder_file="/usr/share/jsholat/sounds/out_reminder.mp3"
        if [ -f "$out_reminder_file" ]; then
            log "INFO" "🔊 REMINDER OUTRO: Memutar outro setelah reminder $salat_name"
            play_audio_file "$out_reminder_file" "outro reminder"
            sleep 1
        fi
        
        # Tunggu sebelum pengulangan berikutnya
        if [ $current_repeat -lt $repeat_count ] && [ "$salat_name" != "Imsyak" ]; then
            local repeat_wait=$(uci -q get jsholat.sound.reminder_repeat_interval || echo "5")
            log "INFO" "⏳ REMINDER SUARA: Menunggu $repeat_wait detik sebelum pengulangan berikutnya..."
            sleep $repeat_wait
        fi
    done
    
    # HAPUS FILE WAV DAN SEMUA SISA FILE CACHE (cleanup final)
    log "INFO" "🧹 Membersihkan semua file temporary Gemini..."
    rm -f "$downloaded_file" "$OUT_JSON" "$OUT_B64" "$OUT_RAW" 2>/dev/null
    
    # PASTIKAN TIDAK ADA FILE DENGAN PREFIX YANG SAMA TERSISA
    rm -f "${temp_prefix}"* 2>/dev/null
    
    if [ $repeat_success -eq 1 ]; then
        log "INFO" "✅ REMINDER SUARA: $salat_name selesai dengan sukses"
        return 0
    fi
    
    return 1
}

# Fungsi untuk memutar TTS menggunakan eSpeak dengan pengulangan
play_espeak_tts_with_repeat() {
    local text="$1"
    local salat_name="$2"
    local prayer_time="$3"
    local lokasi="$4"
    local timezone="$5"
    
    # Tentukan jumlah pengulangan berdasarkan sholat
    local repeat_count=$(get_reminder_repeat_count "$salat_name")
    
    # Log info pengulangan
    if [ "$salat_name" = "Imsyak" ]; then
        log "INFO" "🕌 REMINDER IMSYAK: Hanya 1 kali pemutaran (khusus Imsyak)"
    else
        log "INFO" "🔄 REMINDER $salat_name: Akan diputar $repeat_count kali untuk penegasan"
    fi
    
    # Cek apakah espeak tersedia
    if ! command -v espeak >/dev/null 2>&1; then
        log "ERROR" "❌ eSpeak tidak ditemukan - TIDAK ADA FALLBACK LAGI"
        return 1
    fi
    
    # Cek apakah aplay tersedia
    if ! command -v aplay >/dev/null 2>&1; then
        log "ERROR" "❌ aplay tidak ditemukan - TIDAK ADA FALLBACK LAGI"
        return 1
    fi
    
    # Tentukan maksimal percobaan jika gagal
    local max_attempts=2
    
    local generated_file=""
    
    # ===== BAGIAN 1: GENERATE AUDIO WAV =====
    local generate_attempt=1
    while [ $generate_attempt -le $max_attempts ] && [ -z "$generated_file" ]; do
        local temp_audio_file="/tmp/reminder_${salat_name}_espeak_$(date +%s)_generate${generate_attempt}.wav"
        
        log "INFO" "🔧 REMINDER SUARA: Mencoba generate ke-$generate_attempt/$max_attempts untuk $salat_name menggunakan eSpeak"
        
        # Gunakan eSpeak untuk menghasilkan audio WAV
        if espeak -v id -s 140 -p 45 -w "$temp_audio_file" "$text" 2>/dev/null; then
            
            if [ -s "$temp_audio_file" ]; then
                log "INFO" "✅ REMINDER SUARA: eSpeak TTS berhasil digenerate"
                generated_file="$temp_audio_file"
                break
            else
                log "ERROR" "❌ REMINDER SUARA: File audio eSpeak kosong (attempt $generate_attempt)"
                rm -f "$temp_audio_file"
            fi
        else
            log "ERROR" "❌ REMINDER SUARA: Gagal membuat audio dengan eSpeak (attempt $generate_attempt)"
        fi
        
        # Jika ini attempt terakhir dan gagal
        if [ $generate_attempt -eq $max_attempts ] && [ -z "$generated_file" ]; then
            log "ERROR" "❌ REMINDER SUARA: Gagal generate audio dengan eSpeak setelah $max_attempts percobaan"
            return 1
        fi
        
        # Tunggu sebelum retry generate
        if [ -z "$generated_file" ] && [ $generate_attempt -lt $max_attempts ]; then
            local wait_time=$((generate_attempt * 2))
            log "INFO" "⏳ REMINDER SUARA: Menunggu $wait_time detik sebelum generate ulang..."
            sleep $wait_time
        fi
        
        generate_attempt=$((generate_attempt + 1))
    done
    
    # Jika generate gagal
    if [ -z "$generated_file" ]; then
        log "ERROR" "❌ REMINDER SUARA: Gagal generate audio dengan eSpeak"
        return 1
    fi
    
    # ===== BAGIAN 2: PUTAR AUDIO DENGAN PENGULANGAN =====
    local repeat_success=0
    for ((current_repeat=1; current_repeat<=repeat_count; current_repeat++)); do
        log "INFO" "🔄 REMINDER SUARA: Pengulangan ke-$current_repeat/$repeat_count untuk $salat_name pukul $prayer_time"
        
        # Putar in_reminder.mp3 sebelum TTS (jika ada)
        local in_reminder_file="/usr/share/jsholat/sounds/in_reminder.mp3"
        if [ -f "$in_reminder_file" ]; then
            log "INFO" "🔊 REMINDER INTRO: Memutar intro sebelum reminder $salat_name"
            play_audio_file "$in_reminder_file" "intro reminder"
            sleep 1
        fi
        
        # Set volume
        local volume_control=$(uci -q get jsholat.sound.volume_control || echo "hardware")
        local volume_level=$(uci -q get jsholat.sound.volume_level || echo "80")
        local mixer_device=$(uci -q get jsholat.sound.mixer_device || echo "PCM")
        
        if [ "$volume_control" = "hardware" ]; then
            amixer -q set "$mixer_device" ${volume_level}% >/dev/null 2>&1
        fi
        
        # Putar audio WAV
        if aplay -q "$generated_file" 2>/dev/null; then
            repeat_success=1
            log "INFO" "✅ REMINDER SUARA: Pengulangan ke-$current_repeat berhasil"
        else
            log "ERROR" "❌ REMINDER SUARA: Pengulangan ke-$current_repeat gagal"
            repeat_success=0
        fi
        
        # Reset volume
        local default_volume=80
        if [ "$volume_control" = "hardware" ] && [ "$volume_level" != "$default_volume" ]; then
            amixer -q set "$mixer_device" ${default_volume}% >/dev/null 2>&1
        fi
        
        # Putar out_reminder.mp3 setelah TTS (jika ada)
        local out_reminder_file="/usr/share/jsholat/sounds/out_reminder.mp3"
        if [ -f "$out_reminder_file" ]; then
            log "INFO" "🔊 REMINDER OUTRO: Memutar outro setelah reminder $salat_name"
            play_audio_file "$out_reminder_file" "outro reminder"
            sleep 1
        fi
        
        # Tunggu sebelum pengulangan berikutnya
        if [ $current_repeat -lt $repeat_count ] && [ "$salat_name" != "Imsyak" ]; then
            local repeat_wait=$(uci -q get jsholat.sound.reminder_repeat_interval || echo "5")
            log "INFO" "⏳ REMINDER SUARA: Menunggu $repeat_wait detik sebelum pengulangan berikutnya..."
            sleep $repeat_wait
        fi
    done
    
    # Bersihkan file
    rm -f "$generated_file" 2>/dev/null
    
    if [ $repeat_success -eq 1 ]; then
        log "INFO" "✅ REMINDER SUARA: $salat_name selesai dengan sukses"
        return 0
    fi
    
    return 1
}

# Fungsi untuk test TTS
test_tts() {
    local text="$1"
    
    # Load config
    local tts_enabled=$(uci -q get jsholat.sound.reminder_sound_enabled || echo "0")
    local tts_method=$(uci -q get jsholat.sound.tts_method || echo "google")
    
    if [ "$tts_enabled" = "0" ]; then
        log "ERROR" "❌ TTS dinonaktifkan"
        return 1
    fi
    
    local sound_enabled=$(uci -q get jsholat.sound.sound_enabled || echo "1")
    if [ "$sound_enabled" = "0" ]; then
        log "ERROR" "❌ Pemutar suara dinonaktifkan"
        return 1
    fi
    
    # Simpan metode asli dan teks asli
    local original_tts_method="$tts_method"
    local original_text="$text"
    
    # Cek metode online
    local online_methods="google edge murf gemini"
    local need_internet=0
    
    for method in $online_methods; do
        if [ "$method" = "$tts_method" ]; then
            need_internet=1
            break
        fi
    done
    
    # ⚠️ Jika butuh internet tapi tidak ada
    if [ $need_internet -eq 1 ]; then
        if ! check_internet_connection; then
            log "WARNING" "📵 Tidak ada internet, fallback ke eSpeak (offline)"
            
            if command -v espeak >/dev/null 2>&1 && command -v aplay >/dev/null 2>&1; then
                tts_method="espeak"
                log "INFO" "🔄 Switch ke eSpeak (offline TTS) dari $original_tts_method"
                
                # ⚠️⚠️⚠️ PERBAIKAN: GANTI TEKS DENGAN VERSI NATURAL UNTIK ESPEAK
                # Ganti teks dengan versi natural untuk espeak
                case "$original_tts_method" in
                    "google"|"edge"|"murf"|"espeak|gemini")
                        # Buat teks baru yang natural untuk espeak
                        text="Ini adalah uji coba suara Teks ke Suara menggunakan eSpeak. Suara ini akan digunakan untuk pengingat waktu sholat."
                        ;;
                esac
                
                log "DEBUG" "📝 Teks natural untuk espeak: $text"
            else
                log "ERROR" "❌ Tidak ada internet DAN eSpeak tidak tersedia"
                return 1
            fi
        fi
    fi
    
    log "INFO" "🔊 Memutar TTS test dengan metode: $tts_method"
    
    # Set volume
    local volume_control=$(uci -q get jsholat.sound.volume_control || echo "hardware")
    local volume_level=$(uci -q get jsholat.sound.volume_level || echo "80")
    local mixer_device=$(uci -q get jsholat.sound.mixer_device || echo "PCM")
    
    if [ "$volume_control" = "hardware" ]; then
        log "INFO" "🔊 Setting volume to $volume_level% for TTS test"
        amixer -q set "$mixer_device" ${volume_level}% >/dev/null 2>&1
    fi
    
    # Putar dengan metode yang sudah mungkin berubah
    local result=1
    case "$tts_method" in
        "google")
            play_google_tts_with_repeat "$text" "Test" "12:00" "Test Location" "WIB"
            result=$?
            ;;
        "edge")
            play_edge_tts_with_repeat "$text" "Test" "12:00" "Test Location" "WIB"
            result=$?
            ;;
        "espeak")
            play_espeak_tts_with_repeat "$text" "Test" "12:00" "Test Location" "WIB"
            result=$?
            ;;
        "murf")
            play_murf_tts_with_repeat "$text" "Test" "12:00" "Test Location" "WIB"
            result=$?
            ;;
        "gemini")
            play_gemini_tts_with_repeat "$text" "Test" "12:00" "Test Location" "WIB"
            result=$?
            ;;
        *)
            log "ERROR" "❌ Metode TTS tidak dikenal: $tts_method"
            return 1
            ;;
    esac
    
    # Reset volume
    local default_volume=80
    if [ "$volume_control" = "hardware" ] && [ "$volume_level" != "$default_volume" ]; then
        amixer -q set "$mixer_device" ${default_volume}% >/dev/null 2>&1
    fi
    
    if [ $result -eq 0 ]; then
        log "INFO" "✅ Test TTS selesai dengan metode: $tts_method"
    else
        log "ERROR" "❌ Test TTS gagal"
    fi
    
    return $result
}

# Tambahkan fungsi untuk mengecek dependensi eSpeak:
check_espeak_dependencies() {
    log "INFO" "🔍 Mengecek dependensi eSpeak..."
    
    if ! command -v espeak >/dev/null 2>&1; then
        log "WARNING" "⚠️  eSpeak tidak ditemukan. Instal dengan: opkg install espeak"
        return 1
    fi
    
    if ! command -v aplay >/dev/null 2>&1; then
        log "WARNING" "⚠️  aplay tidak ditemukan. Instal dengan: opkg install alsa-utils"
        return 1
    fi
    
    log "INFO" "✅ eSpeak dan aplay tersedia"
    return 0
}

# Fungsi untuk mengecek dan menginstall dependensi TTS
check_tts_dependencies() {
    local tts_method=$(uci -q get jsholat.sound.tts_method || echo "google")
    
    case "$tts_method" in
        "google")
            # Google TTS hanya butuh wget/curl dan pemutar audio
            log "INFO" "✓ Google TTS siap digunakan"
            ;;
        "edge")
            # Cek edge-tts
            if ! command -v edge-tts >/dev/null 2>&1; then
                log "WARNING" "⚠️  edge-tts tidak ditemukan. Silakan instal dengan: pip install edge-tts"
                return 1
            fi
            log "INFO" "✓ Edge-TTS siap digunakan"
            ;;
        "murf")
            # Cek API key
            local murf_api_key=$(uci -q get jsholat.sound.murf_api_key || echo "")
            if [ -z "$murf_api_key" ]; then
                log "WARNING" "⚠️  API key Murf.ai belum dikonfigurasi"
                return 1
            fi
            log "INFO" "✓ Murf.ai TTS siap digunakan"
            ;;
    esac
    
    return 0
}

# Fungsi untuk mengecek dependensi Gemini TTS
check_gemini_dependencies() {
    log "INFO" "🔍 Mengecek dependensi Gemini TTS..."
    
    # Cek API key
    local gemini_api_key=$(uci -q get jsholat.sound.gemini_api_key || echo "")
    if [ -z "$gemini_api_key" ]; then
        log "WARNING" "⚠️  API key Gemini belum dikonfigurasi"
        return 1
    fi
    
    # Cek koneksi internet
    if ! check_internet_connection; then
        log "WARNING" "⚠️  Tidak ada koneksi internet untuk Gemini TTS"
        return 1
    fi
    
    # Cek dependensi konversi audio
    local converter_available=0
    if command -v sox >/dev/null 2>&1; then
        log "INFO" "✓ sox tersedia untuk konversi audio"
        converter_available=1
    elif command -v ffmpeg >/dev/null 2>&1; then
        log "INFO" "✓ ffmpeg tersedia untuk konversi audio"
        converter_available=1
    else
        log "WARNING" "⚠️  Tidak ada sox/ffmpeg, audio akan diputar sebagai raw PCM (mungkin tidak kompatibel)"
    fi
    
    log "INFO" "✓ Gemini TTS siap digunakan"
    return 0
}

# =============================================
# FUNGSI REMINDER BEFORE PRAYER - FIXED VERSION
# =============================================

# Fungsi Peringatan Sebelum Waktu Sholat
reminder_before_prayer() {
    local salat_name="$1"
    local prayer_time="$2"
    local timezone=$(uci -q get jsholat.schedule.timezone_value || echo "")
    local reminder_mins=$(uci -q get jsholat.sound.reminder_before || echo "5")
    local LOKASI=$(uci get jsholat.schedule.city_label 2>/dev/null || echo "Wilayah Tidak Diketahui")
    local PROVINCE=$(uci get jsholat.schedule.province 2>/dev/null || echo "")
    local ayat_enabled=$(uci -q get jsholat.service.ayat_enabled || echo "1")
    local telegram_enabled=$(uci -q get jsholat.service.telegram_enabled || echo "1")
    local reminder_sound_enabled=$(uci -q get jsholat.sound.reminder_sound_enabled || echo "0")
    local tts_method=$(uci -q get jsholat.sound.tts_method || echo "google")
    
    # Validasi 1: Reminder dinonaktifkan
    if [ "$reminder_mins" = "0" ]; then
        [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "🔕 Fitur reminder dinonaktifkan (reminder_mins=0)"
        return 1
    fi
    
    # Validasi 2: Skip jika reminder sudah dikirim hari ini
    case "$salat_name" in
        "Imsyak") [ "$REMINDER_IMSYAK" -eq 1 ] && return 1 ;;
        "Subuh") [ "$REMINDER_SUBUH" -eq 1 ] && return 1 ;;
        "Dzuhur"|"Jumat") [ "$REMINDER_DZUHUR" -eq 1 ] && return 1 ;;
        "Ashar") [ "$REMINDER_ASHAR" -eq 1 ] && return 1 ;;
        "Maghrib") [ "$REMINDER_MAGHRIB" -eq 1 ] && return 1 ;;
        "Isya") [ "$REMINDER_ISYA" -eq 1 ] && return 1 ;;
    esac

    # Konversi waktu ke detik dengan validasi
    local prayer_sec=$(time_to_seconds "$prayer_time")
    if [ "$prayer_sec" -eq 0 ]; then
        log "ERROR" "❌ Gagal mengkonversi waktu sholat: $prayer_time"
        return 1
    fi
    
    local reminder_sec=$((prayer_sec - reminder_mins * 60))
    
    # Waktu sekarang dalam detik
    local current_time=$(date +"%H:%M")
    local current_sec=$(time_to_seconds "$current_time")
    if [ "$current_sec" -eq 0 ]; then
        log "ERROR" "❌ Gagal mengkonversi waktu sekarang: $current_time"
        return 1
    fi
    
    # Cek apakah masuk waktu reminder
    if [ "$current_sec" -ge "$reminder_sec" ] && [ "$current_sec" -lt "$prayer_sec" ]; then
        log "INFO" "🔔 REMINDER: Waktu $salat_name akan tiba dalam $reminder_mins menit ($prayer_time $timezone) untuk wilayah $LOKASI"

        # ========== BAGIAN 1: KIRIM NOTIFIKASI TELEGRAM ==========
        if [ "$telegram_enabled" = "1" ]; then
            local timezone_display=""
            [ -n "$timezone" ] && timezone_display=" $timezone"
            
            # Format pesan Telegram berdasarkan kondisi
            local reminder_message=""
            
            # KHUSUS IMSYAK
            if [ "$salat_name" = "Imsyak" ]; then
                if is_ramadhan; then
                    reminder_message="🌙 *PENGINGAT IMSYAK RAMADHAN* 🌙
                    
Waktu *Imsyak* akan tiba dalam *$reminder_mins menit*!  
🕒 Pukul: $prayer_time$timezone_display
📍 Wilayah: *$LOKASI${PROVINCE:+, $PROVINCE}* dan sekitarnya.

*Segera akhiri sahur*
*Persiapkan diri untuk sholat Subuh*
*Perbanyak doa di sisa malam ini*

🤲 *Ramadhan Mubarak, semoga Allah menerima amal ibadah kita*"
                else
                    reminder_message="🔔 *PENGINGAT IMSYAK*
                    
Waktu *Imsyak* akan tiba dalam *$reminder_mins menit*!  
🕒 Pukul: $prayer_time$timezone_display
📍 Wilayah: *$LOKASI${PROVINCE:+, $PROVINCE}* dan sekitarnya.

*Siapkan diri untuk sholat Subuh*
*Jangan lupa wudhu* 💧"
                fi
            
            # KHUSUS ISYA DI BULAN RAMADHAN (dengan notifikasi Tarawih)
            elif [ "$salat_name" = "Isya" ] && is_ramadhan; then
                reminder_message="🌙 *PENGINGAT SHOLAT ISYA & TARAWIH* 🌙
                    
Waktu *Sholat Isya* akan tiba dalam *$reminder_mins menit*!  
🕒 Pukul: $prayer_time$timezone_display
📍 Wilayah: *$LOKASI${PROVINCE:+, $PROVINCE}* dan sekitarnya.

*Marilah kita persiapkan diri untuk:*
✅ Sholat Isya berjamaah
✅ Sholat Tarawih
✅ Sholat Witir

*Keutamaan Sholat Tarawih:*
\"Barangsiapa melaksanakan sholat malam (Tarawih) di bulan Ramadhan karena iman dan mengharap pahala, maka diampuni dosa-dosanya yang telah lalu.\" 
(HR. Bukhari dan Muslim)

🤲 *Semoga Allah menerima amal ibadah kita di bulan Ramadhan*"
            
            # SHOLAT WAJIB LAINNYA (termasuk Isya di luar Ramadhan)
            else
                reminder_message="🔔 *PENGINGAT SHOLAT*
                    
Waktu *$salat_name* akan tiba dalam *$reminder_mins menit*!  
🕒 Pukul: $prayer_time$timezone_display
📍 Wilayah: *$LOKASI${PROVINCE:+, $PROVINCE}* dan sekitarnya.

*Siapkan diri untuk sholat*
*Jangan lupa wudhu* 💧"
            fi
            
            # Kirim notifikasi Telegram (background process)
            send_telegram "$reminder_message" &

            # Kirim ayat acak jika fitur aktif (kecuali Imsyak)
            if [ "$ayat_enabled" = "1" ] && [ "$salat_name" != "Imsyak" ]; then
                local random_ayat=$(get_random_ayat)
                if [ -n "$random_ayat" ]; then
                    send_telegram "$(printf "💫 *Ayat Pilihan Hari Ini*\n%s" "$random_ayat")" &
                fi
            fi
        fi

        # ========== BAGIAN 2: PUTAR SUARA REMINDER TTS ==========
        if [ "$reminder_sound_enabled" = "1" ]; then
            # Logika khusus Imsyak: hanya putar saat Ramadhan
            if [ "$salat_name" = "Imsyak" ]; then
                if is_ramadhan; then
                    log "INFO" "🔊 Memutar TTS reminder Imsyak (khusus Ramadhan)"
                    play_tts_reminder "$salat_name" "$prayer_time" "$reminder_mins" "$timezone" "$LOKASI" "$PROVINCE" &
                else
                    [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "📵 TTS reminder Imsyak tidak diputar (non-Ramadhan)"
                fi
            
            # SHOLAT WAJIB (termasuk Isya)
            else
                log "INFO" "🔊 Memutar TTS reminder $salat_name"
                play_tts_reminder "$salat_name" "$prayer_time" "$reminder_mins" "$timezone" "$LOKASI" "$PROVINCE" &
            fi
        else
            [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "🔇 Suara reminder dinonaktifkan untuk $salat_name"
        fi

        # ========== BAGIAN 3: NOTIFIKASI TAMBAHAN UNTUK ISYA RAMADHAN ==========
        if [ "$salat_name" = "Isya" ] && is_ramadhan; then
            log "INFO" "🌙 Memproses notifikasi tambahan untuk Sholat Tarawih"
            
            # Kirim notifikasi Tarawih tambahan via Telegram (jika diinginkan)
            if [ "$telegram_enabled" = "1" ] && [ "$(uci -q get jsholat.service.tarawih_notification || echo "1")" = "1" ]; then
                local tarawih_message="🌙 *SHOLAT TARAWIH* 🌙
                    
Setelah Sholat Isya berjamaah, 
jangan lupa untuk melaksanakan *Sholat Tarawih* 
dan *Sholat Witir* secara berjamaah.

*Niat Sholat Tarawih:*
اُصَلِّى سُنَّةَ التَّرَاوِيْحِ رَكْعَتَيْنِ مَأْمُوْمًا ِللهِ تَعَالَى
\"Aku niat sholat sunnah Tarawih dua rakaat sebagai makmum karena Allah Ta'ala.\"

*Niat Sholat Witir:*
اُصَلِّى سُنَّةَ الْوِتْرِ رَكْعَةً مَأْمُوْمًا ِللهِ تَعَالَى
\"Aku niat sholat sunnah Witir satu rakaat sebagai makmum karena Allah Ta'ala.\"

🤲 *Selamat menunaikan ibadah sholat Tarawih*"
                
                send_telegram "$tarawih_message" &
            fi
            
            # Putar TTS khusus untuk Tarawih jika fitur diaktifkan
            if [ "$(uci -q get jsholat.sound.tarawih_tts_enabled || echo "0")" = "1" ]; then
                local tarawih_text="🌙 Marhaban ya Ramadhan. Mari kita laksanakan sholat Isya berjamaah, dilanjutkan sholat Tarawih dan Witir. Semoga Allah menerima amal ibadah kita."
                
                # Gunakan metode TTS yang sama atau berbeda
                local tarawih_tts_method=$(uci -q get jsholat.sound.tarawih_tts_method || echo "$tts_method")
                
                log "INFO" "🔊 Memutar TTS khusus untuk Tarawih"
                
                # Panggil fungsi TTS dengan teks khusus (background)
                (
                    case "$tarawih_tts_method" in
                        "gemini") play_gemini_tts_with_repeat "$tarawih_text" "Tarawih" "$prayer_time" "$LOKASI" "$timezone" ;;
                        "edge") play_edge_tts_with_repeat "$tarawih_text" "Tarawih" "$prayer_time" "$LOKASI" "$timezone" ;;
                        "google") play_google_tts_with_repeat "$tarawih_text" "Tarawih" "$prayer_time" "$LOKASI" "$timezone" ;;
                        "espeak") play_espeak_tts_with_repeat "$tarawih_text" "Tarawih" "$prayer_time" "$LOKASI" "$timezone" ;;
                        "murf") play_murf_tts_with_repeat "$tarawih_text" "Tarawih" "$prayer_time" "$LOKASI" "$timezone" ;;
                    esac
                ) &
            fi
            
            # Putar audio Tarawih jika file tersedia
            local tarawih_audio_file=$(uci -q get jsholat.sound.tarawih_audio_file || echo "/usr/share/jsholat/sounds/tarawih.mp3")
            if [ -f "$tarawih_audio_file" ] && [ "$(uci -q get jsholat.sound.tarawih_audio_enabled || echo "0")" = "1" ]; then
                log "INFO" "🔊 Memutar audio Tarawih"
                play_audio_file "$tarawih_audio_file" "Audio Tarawih" &
            fi
        fi

        # ========== BAGIAN 4: TANDAI REMINDER SUDAH DIKIRIM ==========
        case "$salat_name" in
            "Imsyak") REMINDER_IMSYAK=1 ;;
            "Subuh") REMINDER_SUBUH=1 ;;
            "Jumat") REMINDER_DZUHUR=1 ;;
            "Dzuhur") REMINDER_DZUHUR=1 ;;
            "Ashar") REMINDER_ASHAR=1 ;;
            "Maghrib") REMINDER_MAGHRIB=1 ;;
            "Isya") REMINDER_ISYA=1 ;;
        esac
        save_reminder_status
        
        log "INFO" "✅ Reminder $salat_name berhasil diproses"
        return 0
    fi
    
    # Reset status reminder jika sudah lewat waktu sholat
    if [ "$current_sec" -ge "$prayer_sec" ]; then
        case "$salat_name" in
            "Imsyak") [ "$REMINDER_IMSYAK" -eq 1 ] && REMINDER_IMSYAK=0 ;;
            "Subuh") [ "$REMINDER_SUBUH" -eq 1 ] && REMINDER_SUBUH=0 ;;
            "Dzuhur") [ "$REMINDER_DZUHUR" -eq 1 ] && REMINDER_DZUHUR=0 ;;
            "Ashar") [ "$REMINDER_ASHAR" -eq 1 ] && REMINDER_ASHAR=0 ;;
            "Maghrib") [ "$REMINDER_MAGHRIB" -eq 1 ] && REMINDER_MAGHRIB=0 ;;
            "Isya") [ "$REMINDER_ISYA" -eq 1 ] && REMINDER_ISYA=0 ;;
        esac
        save_reminder_status
    fi
    
    return 1
}

# Fungsi Utama Service
run_service() {
    init_log_system
    load_reminder_status
	#Load global failed methods tts
	load_global_failed_methods
    reset_reminder_status
    
    log "INFO" "=========== SERVICE JSHOLAT DIMULAI ==========="
    
    # Panggil get_hijri_date sekali di awal untuk memastikan cache terisi
    local hijri_date_info=$(get_hijri_date)
    
    # === CEK STATUS RAMADHAN ===
    if is_ramadhan; then
        local hijri_year=$(jq -r '.hijri_date.year // ""' "$HIJRI_CACHE_FILE" 2>/dev/null)
        local hijri_month_name=$(jq -r '.hijri_date.monthName // ""' "$HIJRI_CACHE_FILE" 2>/dev/null)
        
        if [ -n "$hijri_year" ] && [ "$hijri_year" != "null" ]; then
            log "INFO" "🌙🌙🌙 SELAMAT MENUNAIKAN IBADAH PUASA RAMADHAN ${hijri_year} 🌙🌙🌙"
        else
            log "INFO" "🌙🌙🌙 SELAMAT MENUNAIKAN IBADAH PUASA RAMADHAN 🌙🌙🌙"
        fi
        log "INFO" "📢 Notifikasi Imsyak: Pesan nuansa Ramadhan"
    else
        if [ -n "$hijri_date_info" ]; then
            log "INFO" "📅 Tanggal Hijriyah saat ini: $hijri_date_info"
        fi
        log "INFO" "📢 Notifikasi Imsyak: Pesan biasa dengan tarhim tetap diputar"
    fi
    
    # === LOG KONFIGURASI TARHIM ===
    local tarhim_mode=$(uci -q get jsholat.sound.tarhim_mode || echo "ramadhan_only")
    case "$tarhim_mode" in
        "always")
            log "INFO" "🔊 Konfigurasi Tarhim: SELALU diputar setiap hari"
            ;;
        "ramadhan_only")
            log "INFO" "🔊 Konfigurasi Tarhim: TARHIM selalu diputar, TTS reminder Imsyak HANYA saat Ramadhan"
            ;;
        *)
            log "INFO" "🔊 Konfigurasi Tarhim: TARHIM selalu diputar, TTS reminder Imsyak HANYA saat Ramadhan"
            ;;
    esac
    
    # === LOAD KONFIGURASI UCI ===
    local JADWAL=$(uci get jsholat.schedule.file_jadwal 2>/dev/null)
    local FILE_ADZAN=$(uci get jsholat.sound.sound_adzan 2>/dev/null)
    local FILE_ADZAN_SHUBUH=$(uci get jsholat.sound.sound_adzan_shubuh 2>/dev/null)
    local FILE_IMSYAK=$(uci get jsholat.sound.sound_adzan_imsy 2>/dev/null)
    local LOKASI=$(uci get jsholat.schedule.city_label 2>/dev/null)
    local PROVINCE=$(uci get jsholat.schedule.province 2>/dev/null || echo "Tidak Diketahui")
    local TIMEZONE=$(uci -q get jsholat.schedule.timezone_value || echo "")
    local SUMBER=$(uci get jsholat.schedule.source 2>/dev/null)
    local REMINDER_BEFORE=$(uci -q get jsholat.sound.reminder_before || echo "5")
    local REMINDER_SOUND_ENABLED=$(uci -q get jsholat.sound.reminder_sound_enabled || echo "0")
    local TTS_METHOD=$(uci -q get jsholat.sound.tts_method || echo "google")
    local REMINDER_REPEAT_COUNT=$(uci -q get jsholat.sound.reminder_repeat_count || echo "3")
    local REMINDER_REPEAT_INTERVAL=$(uci -q get jsholat.sound.reminder_repeat_interval || echo "5")
    local MURF_API_KEY=$(uci -q get jsholat.sound.murf_api_key || echo "")
    local TELEGRAM_ENABLED=$(uci -q get jsholat.service.telegram_enabled || echo "1")
    local SOUND_ENABLED=$(uci -q get jsholat.sound.sound_enabled || echo "1")
    local SERVICE_ENABLED=$(uci -q get jsholat.service.service || echo "1")
    local AYAT_ENABLED=$(uci -q get jsholat.service.ayat_enabled || echo "1")
    local TARHIM_ENABLED=$(uci -q get jsholat.sound.tarhim_enabled || echo "0")
    local TARHIM_MODE=$(uci -q get jsholat.sound.tarhim_mode || echo "ramadhan_only")
	# === LOG GEMINI ===
    local gemini_api_key=$(uci -q get jsholat.sound.gemini_api_key || echo "")
    local gemini_model=$(uci -q get jsholat.sound.gemini_model || echo "gemini-2.0-flash-exp")
    local gemini_voice=$(uci -q get jsholat.sound.gemini_voice || echo "en-US-Journey-F")
    
    # Override DEBUG_MODE dari konfigurasi
    DEBUG_MODE=$(uci -q get jsholat.service.debug_mode || echo "0")
    
    # === LOG STATUS REMINDER ===
    log "INFO" "📊 Status Reminder: Imsyak=$REMINDER_IMSYAK, Subuh=$REMINDER_SUBUH, Dzuhur=$REMINDER_DZUHUR, Ashar=$REMINDER_ASHAR, Maghrib=$REMINDER_MAGHRIB, Isya=$REMINDER_ISYA"
    
    # === LOG KONFIGURASI ===
    log "INFO" "⚙️ Konfigurasi yang digunakan:"
	# === CEK FILE JADWAL ===
	if [ -f "$JADWAL" ]; then
		# Dapatkan ukuran file
		local jadwal_size=$(du -h "$JADWAL" 2>/dev/null | cut -f1)
		local jadwal_lines=$(wc -l < "$JADWAL" 2>/dev/null || echo "0")
		
		# Deteksi format file
		local format_info=""
		local jadwal_hari_ini=""
		local TODAY=$(date +"%d-%m-%Y")
		
		if jq -e . "$JADWAL" >/dev/null 2>&1; then
			# Format JSON
			local jadwal_days=$(jq '. | length' "$JADWAL" 2>/dev/null || echo "0")
			format_info="JSON ($jadwal_days hari)"
			
			# Cek jadwal hari ini di JSON
			jadwal_hari_ini=$(jq -r --arg t "$TODAY" '.[] | select(.gregorian_date==$t) | .gregorian_date' "$JADWAL" 2>/dev/null | head -1)
		else
			# Cek apakah format TEXT (space-separated)
			local first_line=$(head -1 "$JADWAL" 2>/dev/null)
			if echo "$first_line" | grep -qE '^[0-9]{2}-[0-9]{2}-[0-9]{4}'; then
				format_info="TEXT legacy ($jadwal_lines baris)"
				
				# Cek jadwal hari ini di TEXT
				jadwal_hari_ini=$(grep "^$TODAY" "$JADWAL" 2>/dev/null | head -1 | cut -d' ' -f1)
			else
				format_info="Format tidak dikenal"
			fi
		fi
		
		log "INFO" "📅 FILE JADWAL: $(basename "$JADWAL") tersedia: $jadwal_size ($format_info)"
		
		# Log info jadwal hari ini
		if [ -n "$jadwal_hari_ini" ]; then
			log "INFO" "✅ JADWAL HARI INI: $TODAY tersedia dalam file"
		else
			# Jangan kasih warning dulu, karena mungkin formatnya berbeda
			# Biarkan main loop yang akan mencoba membaca
			[ "$DEBUG_MODE" = "1" ] && log "DEBUG" "📅 JADWAL HARI INI: $TODAY akan dicoba dibaca di main loop"
		fi
	else
		log "INFO" "ℹ️ FILE JADWAL: $(basename "$JADWAL") tidak ditemukan di $JADWAL"
	fi	
    log "INFO" " - Sumber Jadwal: $SUMBER"
    log "INFO" " - Wilayah: $LOKASI, $PROVINCE"
    log "INFO" " - Zona Waktu: $TIMEZONE"

    # === LOG STATUS FITUR ===
    log "INFO" "⚙️ Status Fitur:"
    log "INFO" " - Service: $([ "$SERVICE_ENABLED" = "1" ] && echo "AKTIF" || echo "NONAKTIF")"
    log "INFO" " - Notifikasi Telegram: $([ "$TELEGRAM_ENABLED" = "1" ] && echo "AKTIF" || echo "NONAKTIF")"
    log "INFO" " - Pemutar Suara: $([ "$SOUND_ENABLED" = "1" ] && echo "AKTIF" || echo "NONAKTIF")"
    log "INFO" " - Reminder Sholat: $([ "$REMINDER_BEFORE" = "0" ] && echo "NONAKTIF" || echo "AKTIF (${REMINDER_BEFORE} menit)")"
    log "INFO" " - Suara Reminder: $([ "$REMINDER_SOUND_ENABLED" = "1" ] && echo "AKTIF" || echo "NONAKTIF")"
    log "INFO" " - Metode TTS: $TTS_METHOD"
    log "INFO" " - Ayat Acak: $([ "$AYAT_ENABLED" = "1" ] && echo "AKTIF" || echo "NONAKTIF")"
    log "INFO" " - Debug Mode: $([ "$DEBUG_MODE" = "1" ] && echo "AKTIF" || echo "NONAKTIF")"
    
    # === LOG API MURF ===
    if [ -n "$MURF_API_KEY" ]; then
        log "INFO" " - API Murf.ai: TERKONFIGURASI"
    else
        log "INFO" " - API Murf.ai: BELUM DIKONFIGURASI"
    fi
	
    # === LOG GEMINI ===
    local gemini_api_key=$(uci -q get jsholat.sound.gemini_api_key || echo "")
    local gemini_model=$(uci -q get jsholat.sound.gemini_model || echo "gemini-2.5-flash-preview-tts")
    local gemini_voice=$(uci -q get jsholat.sound.gemini_voice || echo "Leda")
    
    if [ -n "$gemini_api_key" ]; then
        log "INFO" " - API Gemini: TERKONFIGURASI (Model: $gemini_model, Voice: $gemini_voice)"
    else
        log "INFO" " - API Gemini: BELUM DIKONFIGURASI"
    fi
    
    # === LOG EDGE-TTS ===
    local edge_voice=$(uci -q get jsholat.sound.edge_voice || echo "id-ID-ArdiNeural")
    local edge_installed=$(command -v edge-tts >/dev/null 2>&1 && echo "TERINSTAL" || echo "TIDAK TERINSTAL")
    local edge_voice_name=$(format_edge_voice "$edge_voice")
    log "INFO" " - Edge-TTS: $edge_installed (Voice: $edge_voice_name)"

    # === LOG REMINDER STATUS ===
    local reminder_before=$(uci -q get jsholat.sound.reminder_before || echo "5")
    local reminder_sound=$(uci -q get jsholat.sound.reminder_sound_enabled || echo "0")
    local reminder_enabled_calc="0"
    [ "$reminder_before" != "0" ] && reminder_enabled_calc="1"
    
    log "INFO" "🔔 REMINDER CONFIG: minutes_before=$reminder_before, sound_enabled=$reminder_sound, calculated_enabled=$reminder_enabled_calc"
    
    if [ "$reminder_before" = "0" ]; then
        log "INFO" "🔕 Fitur reminder dinonaktifkan (minutes_before=0)"
    else
        log "INFO" "🔔 Fitur reminder aktif dengan $reminder_before menit sebelum sholat"
    fi

	# Cek ketersediaan file audio adzan
	if [ "$SOUND_ENABLED" = "1" ]; then
		# Cek file adzan umum
		if [ -f "$FILE_ADZAN" ]; then
			log "INFO" "🔊 FILE ADZAN: $(basename "$FILE_ADZAN") tersedia: $(du -h "$FILE_ADZAN" 2>/dev/null | cut -f1)"
		else
			log "INFO" "ℹ️ FILE ADZAN: $(basename "$FILE_ADZAN") tidak ditemukan di $FILE_ADZAN"
		fi
		
		# Cek file adzan subuh
		if [ -f "$FILE_ADZAN_SHUBUH" ]; then
			log "INFO" "🔊 FILE ADZAN SUBUH: $(basename "$FILE_ADZAN_SHUBUH") tersedia: $(du -h "$FILE_ADZAN_SHUBUH" 2>/dev/null | cut -f1)"
		else
			log "INFO" "ℹ️ FILE ADZAN SUBUH: $(basename "$FILE_ADZAN_SHUBUH") tidak ditemukan di $FILE_ADZAN_SHUBUH"
		fi
		
		# Cek file imsyak/tarhim
		if [ -f "$FILE_IMSYAK" ]; then
			if [ "$TARHIM_ENABLED" = "1" ]; then
				log "INFO" "🔊 FILE IMSYAK/TARHIM: $(basename "$FILE_IMSYAK") tersedia: $(du -h "$FILE_IMSYAK" 2>/dev/null | cut -f1)"
			else
				log "INFO" "🔊 FILE IMSYAK/TARHIM: $(basename "$FILE_IMSYAK") tersedia (tarhim nonaktif): $(du -h "$FILE_IMSYAK" 2>/dev/null | cut -f1)"
			fi
		else
			if [ "$TARHIM_ENABLED" = "1" ]; then
				log "INFO" "ℹ️ FILE IMSYAK/TARHIM: $(basename "$FILE_IMSYAK") tidak ditemukan di $FILE_IMSYAK"
			else
				log "INFO" "ℹ️ FILE IMSYAK/TARHIM: $(basename "$FILE_IMSYAK") tidak ditemukan (tarhim nonaktif)"
			fi
		fi
	fi
    
	# === CEK FILE AUDIO INTRO/OUTRO REMINDER ===
    local IN_REMINDER_FILE="/usr/share/jsholat/sounds/in_reminder.mp3"
    local OUT_REMINDER_FILE="/usr/share/jsholat/sounds/out_reminder.mp3"
    
    if [ "$REMINDER_SOUND_ENABLED" = "1" ]; then
        if [ -f "$IN_REMINDER_FILE" ]; then
            log "INFO" "🔊 FILE INTRO: in_reminder.mp3 tersedia: $(du -h "$IN_REMINDER_FILE" 2>/dev/null | cut -f1)"
        else
            log "INFO" "ℹ️ FILE INTRO: in_reminder.mp3 tidak ditemukan di $IN_REMINDER_FILE"
        fi
        
        if [ -f "$OUT_REMINDER_FILE" ]; then
            log "INFO" "🔊 FILE OUTRO: out_reminder.mp3 tersedia: $(du -h "$OUT_REMINDER_FILE" 2>/dev/null | cut -f1)"
        else
            log "INFO" "ℹ️ FILE OUTRO: out_reminder.mp3 tidak ditemukan di $OUT_REMINDER_FILE"
        fi
    fi
    
    # === VALIDASI FILE JADWAL ===
    if [ ! -f "$JADWAL" ]; then
        log "ERROR" "❌ File jadwal tidak ditemukan: $JADWAL"
        exit 1
    fi
    
    if [ ! -r "$JADWAL" ]; then
        log "ERROR" "❌ File jadwal tidak dapat dibaca: $JADWAL"
        exit 1
    fi
    
    # === DETEKSI FORMAT FILE JADWAL ===
    local FILE_FORMAT="unknown"
    if jq -e . "$JADWAL" >/dev/null 2>&1; then
        FILE_FORMAT="json"
        log "INFO" "✅ File jadwal terdeteksi: JSON format"
    else
        local first_line=$(head -1 "$JADWAL" 2>/dev/null)
        if echo "$first_line" | grep -qE '^[0-9]{2}-[0-9]{2}-[0-9]{4} [0-9]{2}:[0-9]{2}'; then
            FILE_FORMAT="text"
            log "INFO" "✅ File jadwal terdeteksi: TEXT legacy format"
        else
            log "ERROR" "❌ Format file jadwal tidak dikenal!"
            exit 1
        fi
    fi
    
    # === VALIDASI FILE AUDIO (jika sound enabled) ===
    if [ "$SOUND_ENABLED" = "1" ]; then
        local audio_error=0
        
        if [ ! -f "$FILE_ADZAN" ]; then
            log "ERROR" "❌ File adzan tidak ditemukan: $FILE_ADZAN"
            audio_error=1
        fi
        
        if [ ! -f "$FILE_ADZAN_SHUBUH" ]; then
            log "ERROR" "❌ File adzan subuh tidak ditemukan: $FILE_ADZAN_SHUBUH"
            audio_error=1
        fi
        
        if [ ! -f "$FILE_IMSYAK" ]; then
            if [ "$TARHIM_ENABLED" = "1" ]; then
                log "ERROR" "❌ File imsyak/tarhim tidak ditemukan: $FILE_IMSYAK"
                audio_error=1
            else
                log "WARNING" "⚠️ File imsyak/tarhim tidak ditemukan, tapi tarhim dinonaktifkan"
            fi
        fi
        
        if [ $audio_error -eq 1 ]; then
            log "ERROR" "❌ Service tidak dapat dimulai karena file audio tidak lengkap"
            exit 1
        fi
    fi
    
    # === INISIALISASI VARIABEL ===
    local CURRENT_DATE=""
    local IMSYAK="" SHUBUH="" DZUHUR="" ASHAR="" MAGHRIB="" ISYA=""
    local LAST_DATE=""
    
    # === MAIN SERVICE LOOP ===
    while true; do
        # Cek apakah service masih enabled
        local service_enabled=$(uci -q get jsholat.service.service || echo "1")
        if [ "$service_enabled" = "0" ]; then
            log "INFO" "⏸️ Service dinonaktifkan, menunggu 60 detik..."
            sleep 60
            continue
        fi
        
        # Dapatkan tanggal dan waktu sekarang
        local TODAY=$(date +"%d-%m-%Y")
        local CURRENT_TIME=$(date +"%H:%M")
        
        # Reset reminder status jika hari berganti
        if [ "$LAST_DATE" != "$TODAY" ]; then
            reset_reminder_status			
			#Load global failed methods tts
			load_global_failed_methods
            LAST_DATE="$TODAY"
            log "INFO" "📅 Hari berganti ke: $TODAY"
        fi
        
        # Update jadwal jika hari berganti atau jadwal belum terisi
        if [ "$CURRENT_DATE" != "$TODAY" ] || [ -z "$IMSYAK" ]; then
            log "INFO" "📅 Mengupdate jadwal untuk tanggal $TODAY"
            
            # Ambil jadwal berdasarkan format file
            local jadwal_success=0
            
            if [ "$FILE_FORMAT" = "json" ]; then
                # FORMAT JSON
                local JSON_DATA=$(jq -r --arg t "$TODAY" \
                    '.[] | select(.gregorian_date==$t)' \
                    "$JADWAL" 2>/dev/null)
                
                if [ -n "$JSON_DATA" ] && [ "$JSON_DATA" != "null" ]; then
                    IMSYAK=$(echo "$JSON_DATA" | jq -r '.imsyak // empty')
                    SHUBUH=$(echo "$JSON_DATA" | jq -r '.subuh // empty')
                    DZUHUR=$(echo "$JSON_DATA" | jq -r '.dzuhur // empty')
                    ASHAR=$(echo "$JSON_DATA" | jq -r '.ashar // empty')
                    MAGHRIB=$(echo "$JSON_DATA" | jq -r '.maghrib // empty')
                    ISYA=$(echo "$JSON_DATA" | jq -r '.isya // empty')
                    jadwal_success=1
                fi
            else
                # FORMAT TEXT (space-separated)
                local JADWAL_LINE=$(grep "^$TODAY" "$JADWAL" 2>/dev/null | head -1 | tr -d '\r')
                if [ -n "$JADWAL_LINE" ]; then
                    IMSYAK=$(echo "$JADWAL_LINE" | awk '{print $2}' | tr -d '\r')
                    SHUBUH=$(echo "$JADWAL_LINE" | awk '{print $3}' | tr -d '\r')
                    DZUHUR=$(echo "$JADWAL_LINE" | awk '{print $4}' | tr -d '\r')
                    ASHAR=$(echo "$JADWAL_LINE" | awk '{print $5}' | tr -d '\r')
                    MAGHRIB=$(echo "$JADWAL_LINE" | awk '{print $6}' | tr -d '\r')
                    ISYA=$(echo "$JADWAL_LINE" | awk '{print $7}' | tr -d '\r')
                    jadwal_success=1
                fi
            fi
            
            # Validasi jadwal
            if [ $jadwal_success -eq 1 ]; then
                # Bersihkan nilai null
                [ "$IMSYAK" = "null" ] && IMSYAK=""
                [ "$SHUBUH" = "null" ] && SHUBUH=""
                [ "$DZUHUR" = "null" ] && DZUHUR=""
                [ "$ASHAR" = "null" ] && ASHAR=""
                [ "$MAGHRIB" = "null" ] && MAGHRIB=""
                [ "$ISYA" = "null" ] && ISYA=""
                
                # Validasi format waktu
                local waktu_valid=1
                for waktu in "$IMSYAK" "$SHUBUH" "$DZUHUR" "$ASHAR" "$MAGHRIB" "$ISYA"; do
                    if [ -n "$waktu" ]; then
                        if ! echo "$waktu" | grep -qE '^[0-9]{1,2}:[0-9]{2}$'; then
                            log "ERROR" "❌ Format waktu tidak valid: '$waktu' (harus HH:MM)"
                            waktu_valid=0
                            break
                        fi
                    else
                        log "ERROR" "❌ Data waktu sholat kosong"
                        waktu_valid=0
                        break
                    fi
                done
                
                if [ $waktu_valid -eq 1 ]; then
                    CURRENT_DATE="$TODAY"
                    log "INFO" "🕌 Jadwal Sholat $TODAY untuk daerah $LOKASI:"
                    log "INFO" " - Imsyak:   $IMSYAK $TIMEZONE"
                    log "INFO" " - Subuh:    $SHUBUH $TIMEZONE"
                    log "INFO" " - Dzuhur:   $DZUHUR $TIMEZONE"
                    log "INFO" " - Ashar:    $ASHAR $TIMEZONE"
                    log "INFO" " - Maghrib:  $MAGHRIB $TIMEZONE"
                    log "INFO" " - Isya:     $ISYA $TIMEZONE"
                else
                    log "ERROR" "❌ Jadwal untuk tanggal $TODAY tidak valid, akan coba lagi dalam 300 detik"
                    sleep 300
                    continue
                fi
            else
                log "ERROR" "❌ Jadwal tidak ditemukan untuk tanggal $TODAY"
                log "INFO" "📋 Contoh format yang diharapkan:"
                log "INFO" "   JSON: {\"gregorian_date\":\"$TODAY\", \"imsyak\":\"04:30\", ...}"
                log "INFO" "   TEXT: $TODAY 04:30 04:45 12:00 15:30 18:00 19:00"
                sleep 300
                continue
            fi
        fi
        
        # === CEK WAKTU SHOLAT ===
        if [ "$CURRENT_TIME" = "$IMSYAK" ]; then
            log "INFO" "⏰ Waktu menunjukkan $CURRENT_TIME - Imsyak"
            play_adzan "$FILE_IMSYAK" "Imsyak" "$IMSYAK"
            sleep 61
            continue
        elif [ "$CURRENT_TIME" = "$SHUBUH" ]; then
            log "INFO" "⏰ Waktu menunjukkan $CURRENT_TIME - Subuh"
            play_adzan "$FILE_ADZAN_SHUBUH" "Subuh" "$SHUBUH"
            sleep 61
            continue
        elif [ "$CURRENT_TIME" = "$DZUHUR" ]; then
            local nama_sholat=$(get_salat_name "Dzuhur")
            log "INFO" "⏰ Waktu menunjukkan $CURRENT_TIME - $nama_sholat"
            play_adzan "$FILE_ADZAN" "$nama_sholat" "$DZUHUR"
            sleep 61
            continue
        elif [ "$CURRENT_TIME" = "$ASHAR" ]; then
            log "INFO" "⏰ Waktu menunjukkan $CURRENT_TIME - Ashar"
            play_adzan "$FILE_ADZAN" "Ashar" "$ASHAR"
            sleep 61
            continue
        elif [ "$CURRENT_TIME" = "$MAGHRIB" ]; then
            log "INFO" "⏰ Waktu menunjukkan $CURRENT_TIME - Maghrib"
            play_adzan "$FILE_ADZAN" "Maghrib" "$MAGHRIB"
            sleep 61
            continue
        elif [ "$CURRENT_TIME" = "$ISYA" ]; then
            log "INFO" "⏰ Waktu menunjukkan $CURRENT_TIME - Isya"
            play_adzan "$FILE_ADZAN" "Isya" "$ISYA"
            sleep 61
            continue
        fi
        
        # === CEK REMINDER SHOLAT (jika enabled) ===
        if [ "$REMINDER_BEFORE" != "0" ]; then
            reminder_before_prayer "Imsyak" "$IMSYAK"
            reminder_before_prayer "Subuh" "$SHUBUH"
            reminder_before_prayer "$(get_salat_name "Dzuhur")" "$DZUHUR"
            reminder_before_prayer "Ashar" "$ASHAR"
            reminder_before_prayer "Maghrib" "$MAGHRIB"
            reminder_before_prayer "Isya" "$ISYA"
        else
            [ "$DEBUG_MODE" = "1" ] && log "DEBUG" "🔕 Skip pengecekan reminder (fitur dinonaktifkan)"
        fi
		
		# === CEK ALARM SAHUR (khusus Ramadhan) ===
		play_sahur_alarm
        
        # Tunggu 5 detik sebelum iterasi berikutnya
        sleep 5
    done
}

# =============================================
# MAIN ENTRY POINT
# =============================================

case "$1" in
    "install")
        uci -q set jsholat.service.telegram_enabled=1
        uci -q set jsholat.sound.sound_enabled=1
        uci -q set jsholat.service.service=1
        uci commit jsholat
        
        mkdir -p "/var/log/jsholat"
        touch "/var/log/jsholat/service.log"
        chmod 644 "/var/log/jsholat/service.log"
        
        cp -f "$0" /usr/bin/jsholat
        chmod 755 /usr/bin/jsholat
        
cat > /etc/init.d/jsholat <<'EOF'
#!/bin/sh /etc/rc.common

USE_PROCD=1
START=20
STOP=90

start_service() {
    procd_open_instance
    procd_set_param command /usr/bin/jsholat run
    procd_set_param respawn 300 5
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_set_param file /var/log/jsholat/service.log
    procd_close_instance
}

stop_service() {
    pid=$(pgrep -f "/usr/bin/jsholat run")
    [ -n "$pid" ] && kill $pid
}
EOF

        chmod 755 /etc/init.d/jsholat
        /etc/init.d/jsholat enable
        /etc/init.d/jsholat start
        echo "Instalasi berhasil! Service jsholat telah diaktifkan."
        ;;
    "uninstall")
        opkg remove luci-app-jsholat
        rm -rf /var/lib/jsholat  
        echo "jsholat berhasil dihapus"
        ;;
    "run")
        run_service
        ;;
    "status") 
        show_status
        ;;
    "info")  
        info_service
        ;;    
    "tts-test")
        if [ -z "$2" ]; then
            echo "Usage: $0 tts-test \"text to speak\""
            exit 1
        fi
        test_tts "$2"
        ;;
	"reminder-config")
		echo "============================================="
		echo "   KONFIGURASI REMINDER & TARHIM IMSYAK"
		echo "============================================="
		echo ""
		echo "📋 STATUS SAAT INI:"
		echo ""
		
		# 🔧 TAMBAHKAN INFORMASI TARHIM_ENABLED
		tarhim_enabled=$(uci -q get jsholat.sound.tarhim_enabled || echo "0")
		echo "🕌 STATUS TARHIM IMSYAK:"
		if [ "$tarhim_enabled" = "1" ]; then
			echo "   ✅ TARHIM: AKTIF"
		else
			echo "   ❌ TARHIM: NONAKTIF"
		fi
		
		# Status Suara Reminder
		reminder_sound=$(uci -q get jsholat.sound.reminder_sound_enabled || echo "0")
		if [ "$reminder_sound" = "1" ]; then
			echo "  • Suara Reminder TTS: AKTIF"
		else
			echo "  • Suara Reminder TTS: NONAKTIF"
		fi
		
		# Status Metode TTS
		tts_method=$(uci -q get jsholat.sound.tts_method || echo "google")
		echo "  • Metode TTS: $tts_method"
		
		# Status Reminder Before
		reminder_before=$(uci -q get jsholat.sound.reminder_before || echo "5")
		if [ "$reminder_before" = "0" ]; then
			echo "  • Waktu Reminder: NONAKTIF"
		else
			echo "  • Waktu Reminder: ${reminder_before} menit sebelum"
		fi
		
		echo ""
		echo "🕌 KONFIGURASI TARHIM IMSYAK:"
		echo ""
		
		# Status Tarhim Mode
		tarhim_mode=$(uci -q get jsholat.sound.tarhim_mode || echo "ramadhan_only")
		echo -n "  Mode Tarhim Saat Ini: "
		case "$tarhim_mode" in
			"always")
				echo "✅ SELALU DIPUTAR (setiap hari)" ;;
			"ramadhan_only")
				echo "🌙 TARHIM selalu diputar, TTS reminder HANYA Ramadhan" ;;
			*)
				echo "⚠️  $tarhim_mode (tidak dikenal)" ;;
		esac
		
		# Status File Tarhim
		tarhim_file=$(uci -q get jsholat.sound.sound_adzan_imsy || echo "")
		if [ -n "$tarhim_file" ] && [ -f "$tarhim_file" ]; then
			echo "  • File Tarhim: ✅ $(basename "$tarhim_file")"
		else
			echo "  • File Tarhim: ❌ Belum dikonfigurasi"
		fi
		
		echo ""
		echo "🔧 PILIHAN KONFIGURASI:"
		echo ""
		echo "  ────────────────────────────────────────────"
		echo "  1. Mode Tarhim:"
		echo "     ──────────────────────────────────────"
		echo "     ✓ TARHIM selalu diputar, TTS reminder HANYA Ramadhan"
		echo "       uci set jsholat.sound.tarhim_mode=ramadhan_only"
		echo "       uci commit jsholat"
		echo ""
		echo "     ✓ SELALU DIPUTAR (setiap hari, termasuk TTS reminder)"
		echo "       uci set jsholat.sound.tarhim_mode=always"
		echo "       uci commit jsholat"
		echo "  ────────────────────────────────────────────"
		echo ""
		echo "  2. File Suara Tarhim:"
		echo "     ──────────────────────────────────────"
		echo "     uci set jsholat.sound.sound_adzan_imsy=/path/file.mp3"
		echo "     uci commit jsholat"
		echo "  ────────────────────────────────────────────"
		echo ""
		echo "  3. Format Pesan Notifikasi:"
		echo "     ──────────────────────────────────────"
		echo "     ✓ Ramadhan    : Nuansa Ramadhan, ajakan akhiri sahur"
		echo "     ✓ Non-Ramadhan: Pesan biasa, ajakan wudhu"
		echo "     ⚡ Otomatis menyesuaikan tanpa konfigurasi"
		echo "  ────────────────────────────────────────────"
		echo ""
		echo "  4. Restart Service Setelah Konfigurasi:"
		echo "     /etc/init.d/jsholat restart"
		echo ""
		echo "============================================="
		
		# Tampilkan juga informasi reminder TTS
		echo ""
		echo "📢 KONFIGURASI REMINDER TTS:"
		echo ""
		echo "  Status saat ini:"
		echo "    - Suara Reminder: $(uci -q get jsholat.sound.reminder_sound_enabled || echo "0")"
		echo "    - Metode TTS: $(uci -q get jsholat.sound.tts_method || echo "google")"
		echo "    - Jumlah Pengulangan: $(uci -q get jsholat.sound.reminder_repeat_count || echo "3")"
		echo "    - Interval Pengulangan: $(uci -q get jsholat.sound.reminder_repeat_interval || echo "5") detik"
		echo "    - Imsyak khusus: SELALU 1 kali pemutaran (hanya saat Ramadhan)"
		echo ""
		echo "  File Audio:"
		in_file="/usr/share/jsholat/sounds/in_reminder.mp3"
		out_file="/usr/share/jsholat/sounds/out_reminder.mp3"
		echo "    - File Intro: $([ -f "$in_file" ] && echo "ADA" || echo "TIDAK ADA")"
		echo "    - File Outro: $([ -f "$out_file" ] && echo "ADA" || echo "TIDAK ADA")"
		echo ""
		echo "  Pilihan metode TTS:"
		echo "    1. Google Translate (gratis, tidak butuh API key)"
		echo "    2. Edge-TTS (gratis, butuh pip install edge-tts)"
		echo "    3. eSpeak (gratis, butuh opkg install espeak dan aplay)"
		echo "    4. Murf.ai (berbayar, butuh API key)"
		echo "    5. Gemini TTS (gratis/berbayar, butuh API key Google AI Studio)"
		echo ""
		echo "  Contoh perintah konfigurasi TTS:"
		echo "    uci set jholat.sound.reminder_sound_enabled=1"
		echo "    uci set jsholat.sound.tts_method=google"
		echo "    uci set jsholat.sound.reminder_repeat_count=3"
		echo "    uci set jsholat.sound.reminder_repeat_interval=5"
		echo "    uci commit jsholat"
		echo "    /etc/init.d/jsholat restart"
		echo ""
		echo "============================================="
    ;;
	# Fungsi tarhim-config
	"tarhim-config")
		echo "============================================="
		echo "   KONFIGURASI TARHIM IMSYAK - JSHOLAT"
		echo "============================================="
		echo ""
		
		# 🔧 INFORMASI TARHIM_ENABLED
		tarhim_enabled=$(uci -q get jsholat.sound.tarhim_enabled || echo "0")
		echo "🔊 STATUS TARHIM:"
		if [ "$tarhim_enabled" = "1" ]; then
			echo "   ✅ AKTIF"
		else
			echo "   ❌ NONAKTIF"
		fi
		echo ""
		
		# 🔧 MODE TARHIM
		mode=$(uci -q get jsholat.sound.tarhim_mode || echo "ramadhan_only")
		
		echo "📌 MODE TARHIM:"
		echo "   ──────────────────────────────────────"
		if [ "$mode" = "always" ]; then
			echo "   ✅ SELALU DIPUTAR (setiap hari, termasuk TTS reminder)"
		elif [ "$mode" = "ramadhan_only" ]; then
			echo "   🌙 TARHIM selalu diputar, TTS reminder HANYA Ramadhan"
		else
			echo "   ⚠️  Tidak dikenal: $mode"
		fi
		echo "   ──────────────────────────────────────"
		echo ""
		
		# 🔧 FILE SUARA
		file=$(uci -q get jsholat.sound.sound_adzan_imsy || echo "")
		echo "📁 FILE SUARA TARHIM:"
		if [ -n "$file" ]; then
			echo "   $file"
			if [ -f "$file" ]; then
				size=$(du -h "$file" 2>/dev/null | cut -f1)
				echo "   ✅ File ditemukan - $size"
			else
				echo "   ❌ File TIDAK ditemukan"
			fi
		else
			echo "   (belum dikonfigurasi)"
			echo "   ❌ File TIDAK ditemukan"
		fi
		echo ""
		
		# 🔧 REMINDER IMSYAK
		reminder=$(uci -q get jsholat.sound.reminder_before || echo "5")
		echo "⏰ REMINDER IMSYAK:"
		if [ "$reminder" = "0" ]; then
			echo "   ❌ NONAKTIF"
		else
			echo "   ✅ $reminder menit sebelum imsyak"
		fi
		echo ""
		
		# 🔧 SUARA REMINDER TTS
		tts_enabled=$(uci -q get jsholat.sound.reminder_sound_enabled || echo "0")
		tts_method=$(uci -q get jsholat.sound.tts_method || echo "google")
		
		echo "🔊 SUARA REMINDER TTS:"
		if [ "$tts_enabled" = "1" ]; then
			echo "   Status: AKTIF"
		else
			echo "   Status: NONAKTIF"
		fi
		echo "   Metode: $tts_method"
		echo "   Imsyak: Hanya diputar saat Ramadhan"
		echo ""
		
		# 🔧 STATUS RAMADHAN
		echo "🌙 STATUS BULAN SAAT INI:"
		if is_ramadhan; then
			hijri_date=$(get_hijri_date)
			echo "   ✅ SAAT INI BULAN RAMADHAN"
			echo "   📅 $hijri_date"
			echo "   🔊 TTS reminder Imsyak: AKTIF"
		else
			echo "   📅 BUKAN BULAN RAMADHAN"
			echo "   📵 TTS reminder Imsyak: NONAKTIF"
		fi
		echo ""
		
		echo "============================================="
		echo ""
		echo "🔧 CONTOH PERUBAHAN KONFIGURASI:"
		echo "  # Tarhim selalu diputar (dengan TTS reminder)"
		echo "  uci set jsholat.sound.tarhim_mode=always"
		echo "  uci commit jsholat"
		echo "  /etc/init.d/jsholat restart"
		echo ""
		echo "  # Tarhim selalu diputar, TTS reminder hanya Ramadhan"
		echo "  uci set jsholat.sound.tarhim_mode=ramadhan_only"
		echo "  uci commit jsholat"
		echo "  /etc/init.d/jsholat restart"
		echo "============================================="
		;;
    "gemini-config")
        echo "============================================="
        echo "   KONFIGURASI GEMINI TTS - JSHOLAT"
        echo "============================================="
        echo ""
        
        # Tampilkan konfigurasi saat ini
        echo "📋 KONFIGURASI SAAT INI:"
        echo ""
        
        api_key=$(uci -q get jsholat.sound.gemini_api_key || echo "")
        if [ -n "$api_key" ]; then
            masked_key="${api_key:0:4}...${api_key: -4}"
            echo "  • API Key: ✅ $masked_key"
        else
            echo "  • API Key: ❌ Belum dikonfigurasi"
        fi
        
        model=$(uci -q get jsholat.sound.gemini_model || echo "gemini-2.0-flash-exp")
        echo "  • Model: $model"
        
        voice=$(uci -q get jsholat.sound.gemini_voice || echo "Zephyr")
        echo "  • Voice: $voice"
        
        echo ""
        echo "============================================="
        echo ""
        echo "🔧 CARA KONFIGURASI:"
        echo ""
        echo "  1. Dapatkan API key dari Google AI Studio:"
        echo "     https://aistudio.google.com/app/apikey"
        echo ""
        echo "  2. Set konfigurasi Gemini:"
        echo "     uci set jsholat.sound.gemini_api_key=\"API_KEY_ANDA\""
        echo "     uci set jsholat.sound.gemini_model=\"gemini-2.0-flash-exp\""
        echo "     uci set jsholat.sound.gemini_voice=\"Zephyr\""
        echo "     uci commit jsholat"
        echo ""
        echo "  3. Aktifkan suara reminder dan pilih metode Gemini:"
        echo "     uci set jsholat.sound.reminder_sound_enabled=1"
        echo "     uci set jsholat.sound.tts_method=gemini"
        echo "     uci commit jsholat"
        echo ""
        echo "  4. Restart service:"
        echo "     /etc/init.d/jsholat restart"
        echo ""
        echo "============================================="
        echo ""
        echo "🎤 PREMIUM VOICE OPTIONS:"
        echo "  ──────────────────────────────────────────"
        echo "  Zephyr        -- Bright          Puck          -- Upbeat"
        echo "  Charon        -- Informative     Kore          -- Firm"
        echo "  Fenrir        -- Excitable       Leda          -- Youthful"
        echo "  Orus          -- Firm            Aoede         -- Breezy"
        echo "  Callirrhoe    -- Easy-going      Autonoe       -- Bright"
        echo "  Enceladus     -- Breathy         Iapetus       -- Clear"
        echo "  Umbriel       -- Easy-going      Algieba       -- Smooth"
        echo "  Despina       -- Smooth          Erinome       -- Clear"
        echo "  Algenib       -- Gravelly        Rasalgethi    -- Informative"
        echo "  Laomedeia     -- Upbeat          Achernar      -- Soft"
        echo "  Alnilam       -- Firm            Schedar       -- Even"
        echo "  Gacrux        -- Mature          Pulcherrima   -- Forward"
        echo "  Achird        -- Friendly        Zubenelgenubi -- Casual"
        echo "  Vindemiatrix  -- Gentle          Sadachbia     -- Lively"
        echo "  Sadaltager    -- Knowledgeable   Sulafat       -- Warm"
        echo "  ──────────────────────────────────────────"
        echo ""
        echo "📝 Contoh penggunaan voice:"
        echo "  uci set jsholat.sound.gemini_voice=\"Sulafat\"  # Warm voice"
        echo "  uci set jsholat.sound.gemini_voice=\"Fenrir\"   # Excitable voice"
        echo "  uci set jsholat.sound.gemini_voice=\"Zephyr\"   # Bright voice (default)"
        echo "  uci commit jsholat"
        echo ""
        echo "============================================="
        ;;
    "edge-config")
        echo "============================================="
        echo "   KONFIGURASI EDGE-TTS - JSHOLAT"
        echo "============================================="
        echo ""
        
        # Tampilkan konfigurasi saat ini
        echo "📋 KONFIGURASI SAAT INI:"
        echo ""
        
        if command -v edge-tts >/dev/null 2>&1; then
            echo "  • Edge-TTS: ✅ TERINSTAL"
        else
            echo "  • Edge-TTS: ❌ TIDAK TERINSTAL"
            echo "    Install dengan: pip install edge-tts"
        fi
        
        edge_voice=$(uci -q get jsholat.sound.edge_voice || echo "id-ID-ArdiNeural")
        voice_name=$(format_edge_voice "$edge_voice")
        echo "  • Voice: $voice_name ($edge_voice)"
        
        echo ""
        echo "============================================="
        echo ""
        echo "🔧 CARA KONFIGURASI:"
        echo ""
        echo "  1. Install Edge-TTS (jika belum):"
        echo "     pip install edge-tts"
        echo ""
        echo "  2. Pilih voice yang diinginkan:"
        echo "     uci set jsholat.sound.edge_voice=id-ID-ArdiNeural  # Ardi (Pria)"
        echo "     uci set jsholat.sound.edge_voice=id-ID-GadisNeural # Gadis (Wanita)"
        echo "     uci set jsholat.sound.edge_voice=jv-ID-DimasNeural # Dimas (Jawa-Pria)"
        echo "     uci set jsholat.sound.edge_voice=jv-ID-SitiNeural  # Siti (Jawa-Wanita)"
        echo "     uci commit jsholat"
        echo ""
        echo "  3. Aktifkan suara reminder dan pilih metode Edge:"
        echo "     uci set jsholat.sound.reminder_sound_enabled=1"
        echo "     uci set jsholat.sound.tts_method=edge"
        echo "     uci commit jsholat"
        echo ""
        echo "  4. Restart service:"
        echo "     /etc/init.d/jsholat restart"
        echo ""
        echo "============================================="
        ;;		
    *)
        echo "Usage: $0 {install|uninstall|run|info|status|tts-test|reminder-config|tarhim-config|gemini-config|edge-config}"
        echo ""
        echo "Commands:"
        echo "  install        - Install service jsholat"
        echo "  uninstall      - Hapus service jsholat"
        echo "  run            - Jalankan service secara langsung"
        echo "  status         - Tampilkan status service"
        echo "  info           - Tampilkan info service dalam format JSON"
        echo "  tts-test       - Untuk tes suara TTS (Suara pengingat sebelum waktu sholat)"
        echo "  reminder-config - Konfigurasi reminder/pengingat sebelum waktu sholat"
        echo "  tarhim-config  - Konfigurasi tarhim imsyak"
        echo "  gemini-config  - Konfigurasi Gemini TTS"
        echo "  edge-config    - Konfigurasi Edge-TTS"
        exit 1
        ;;
esac

exit 0